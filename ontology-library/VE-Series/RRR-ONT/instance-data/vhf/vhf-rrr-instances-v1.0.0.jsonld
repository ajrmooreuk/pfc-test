{
  "@context": {
    "pf": "https://oaa-ontology.org/v6/rrr/",
    "raci": "https://oaa-ontology.org/v6/raci/",
    "org": "https://oaa-ontology.org/v6/organisation/",
    "schema": "https://schema.org/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "oaa": "https://oaa-ontology.org/v7/"
  },
  "@id": "pf:vhf-rrr-instance",
  "@type": "oaa:OntologyInstance",
  "oaa:schemaVersion": "7.0.0",
  "oaa:instanceVersion": "1.0.0",
  "oaa:brand": "vhf",
  "oaa:brandFullName": "VHF Nutrition App",
  "oaa:organizationContextRef": "org:ctx-vhf",
  "oaa:created": "2026-02-26",
  "oaa:lastModified": "2026-02-26",
  "oaa:imports": [
    { "ontology": "RRR-ONT", "version": ">=4.0.0", "purpose": "Role, RACI, and RBAC schema" },
    { "ontology": "ORG-ONT", "version": ">=2.1.0", "purpose": "Organization context" }
  ],

  "entities": [

    {"_section": "=== FUNCTIONAL ROLES ==="},

    {
      "@id": "pf:func-vhf-coach",
      "@type": "pf:FunctionalRole",
      "roleTitle": "Nutrition Coach",
      "function": "Coaching & Client Management",
      "seniorityLevel": 3,
      "coreResponsibilities": [
        "Onboard new clients with medical profile, dietary restrictions, and goal assessment",
        "Review and approve AI-generated meal plans before client delivery",
        "Monitor client progress via weekly weigh-ins and feedback",
        "Adjust macro targets and coaching protocols based on client response",
        "Manage client relationships, motivation, and retention",
        "Escalate clinical edge cases that exceed AI constraint model"
      ],
      "keyDecisions": [
        "Client acceptance based on medical complexity assessment",
        "Macro target adjustments based on progress data",
        "Plan approval or override after AI generation",
        "Coaching protocol selection (aggressive cut, maintenance, reverse diet, re-feed)",
        "Client escalation to GP when medical indicators warrant it"
      ],
      "raciAccountable": [
        "Client health outcomes and safety",
        "Plan quality and clinical appropriateness",
        "Client retention and satisfaction"
      ],
      "raciResponsible": [
        "Client onboarding and goal setting",
        "Weekly progress review and macro adjustment",
        "Plan review, approval, and delivery",
        "Client communication and coaching sessions"
      ],
      "typicalOrgSize": "micro (1-10)",
      "notes": "Coach James Kerby -- founder and lead coach. Methodology encoded as coaching protocols in AI pipeline."
    },

    {
      "@id": "pf:func-vhf-ai-agent",
      "@type": "pf:FunctionalRole",
      "roleTitle": "AI Meal Plan Agent",
      "function": "Automated Plan Generation",
      "seniorityLevel": 6,
      "coreResponsibilities": [
        "Generate personalised 30-day meal plans based on client profile and constraints",
        "Resolve multi-constraint combinations (30 diet types x 14 allergens)",
        "Calculate per-meal macro targets with portion scaling to <5% variance",
        "Enforce variety rules (no repeat within 10 days, cuisine diversity)",
        "Apply coaching protocols (progressive macro adjustment, cheat day placement)",
        "Flag impossible constraint combinations to coach at onboarding",
        "Maintain and expand recipe knowledge base"
      ],
      "keyDecisions": [
        "Recipe selection within constraint envelope",
        "Portion scaling to meet macro targets",
        "Variety algorithm weighting (cuisine, ingredient, preparation method)",
        "Constraint conflict detection and resolution strategy",
        "Theme curation assignment per week"
      ],
      "raciAccountable": [
        "Constraint compliance (100% allergen safety, zero violations)",
        "Macro accuracy (<5% variance from target)",
        "Variety score (>60% across all plans)",
        "Plan generation throughput (<10 minutes per 30-day plan)"
      ],
      "raciResponsible": [
        "Meal plan generation on coach request",
        "Constraint validation per meal per plan",
        "Macro calculation and portion adjustment",
        "Variety scoring and enforcement",
        "Recipe knowledge base maintenance"
      ],
      "typicalOrgSize": "micro (1-10)",
      "notes": "AI agent operates under coach supervision -- no plan is delivered to client without coach approval. Agent acts as a force multiplier, not a replacement."
    },

    {
      "@id": "pf:func-vhf-client",
      "@type": "pf:FunctionalRole",
      "roleTitle": "Client",
      "function": "Plan Consumer & Feedback Provider",
      "seniorityLevel": 7,
      "coreResponsibilities": [
        "Complete onboarding profile (medical conditions, allergens, dietary preferences, goals)",
        "Follow assigned meal plans and log adherence",
        "Provide weekly weigh-in data and progress feedback",
        "Report any adverse reactions or constraint violations",
        "Communicate dietary preference changes to coach"
      ],
      "keyDecisions": [
        "Subscription tier selection (self-serve AI / coach-assisted / full coaching)",
        "Goal selection (weight loss, maintenance, muscle gain, medical management)",
        "Meal plan adherence level (strict, flexible, intuitive)",
        "Feedback frequency and detail level"
      ],
      "raciAccountable": [
        "Own health data accuracy and completeness",
        "Meal plan adherence and honest progress reporting"
      ],
      "raciResponsible": [
        "Complete and accurate onboarding profile",
        "Weekly weigh-in submission",
        "Adverse reaction reporting within 24 hours",
        "Dietary preference updates when circumstances change"
      ],
      "typicalOrgSize": "micro (1-10)",
      "notes": "B2C end user. Target segment: UK adults with medical conditions or multiple dietary restrictions seeking personalised nutrition coaching."
    },

    {"_section": "=== RISKS (from VP Problems via JP-VP-RRR-001) ==="},

    {
      "@id": "pf:risk-vhf-weight-medical-safety",
      "@type": "pf:Risk",
      "riskId": "risk:vhf-weight-medical-safety",
      "riskName": "Medical Condition Safety Risk",
      "riskDescription": "Clients with medical conditions (diabetes, PCOS, thyroid, IBS) receive meal plans that do not account for their clinical constraints, leading to unsafe food choices, adverse health events, and liability exposure for the coaching business.",
      "riskCategory": "Clinical Safety",
      "riskSeverity": "Critical",
      "riskLikelihood": "High",
      "riskOwner": "pf:func-vhf-coach",
      "mitigatedBy": "pf:req-vhf-macro-targeting",
      "vpAlignment": {
        "vpEntity": "vp:vhf-prob-weight-mgmt",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:risk-vhf-allergen-violation",
      "@type": "pf:Risk",
      "riskId": "risk:vhf-allergen-violation",
      "riskName": "Allergen Violation Risk",
      "riskDescription": "Meal plans contain ingredients that violate client allergen profiles, causing allergic reactions ranging from discomfort to anaphylaxis. Manual checking by coaches has an estimated 2-5% miss rate that is unacceptable at scale.",
      "riskCategory": "Clinical Safety",
      "riskSeverity": "Critical",
      "riskLikelihood": "Medium",
      "riskOwner": "pf:func-vhf-ai-agent",
      "mitigatedBy": "pf:req-vhf-constraint-resolution",
      "vpAlignment": {
        "vpEntity": "vp:vhf-prob-dietary-compliance",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:risk-vhf-coaching-bottleneck",
      "@type": "pf:Risk",
      "riskId": "risk:vhf-coaching-bottleneck",
      "riskName": "Coaching Capacity Bottleneck Risk",
      "riskDescription": "Manual meal plan creation (4-6 hours per plan) limits Coach James to approximately 20 active clients, creating a hard ceiling on revenue growth and making the coaching business model unsustainable. Every new client requires proportional coach time with no economies of scale.",
      "riskCategory": "Business Viability",
      "riskSeverity": "Major",
      "riskLikelihood": "Certain",
      "riskOwner": "pf:func-vhf-coach",
      "mitigatedBy": "pf:req-vhf-automated-generation",
      "vpAlignment": {
        "vpEntity": "vp:vhf-prob-coach-efficiency",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:risk-vhf-recipe-pool-inadequacy",
      "@type": "pf:Risk",
      "riskId": "risk:vhf-recipe-pool-inadequacy",
      "riskName": "Recipe Pool Inadequacy Risk",
      "riskDescription": "Limited recipe pool (30-50 manually curated recipes) causes monotonous plans with low variety, leading to 60-70% client dropout within 8 weeks. Manual macro calculations produce 15-25% variance, undermining nutritional accuracy and client trust.",
      "riskCategory": "Product Quality",
      "riskSeverity": "Major",
      "riskLikelihood": "High",
      "riskOwner": "pf:func-vhf-ai-agent",
      "mitigatedBy": "pf:req-vhf-variety-enforcement",
      "vpAlignment": {
        "vpEntity": "vp:vhf-prob-nutritional-quality",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },

    {"_section": "=== REQUIREMENTS (from VP Solutions via JP-VP-RRR-001) ==="},

    {
      "@id": "pf:req-vhf-macro-targeting",
      "@type": "pf:Requirement",
      "requirementId": "req:vhf-macro-targeting",
      "requirementName": "Macro-First Personalised Plan Generation",
      "requirementDescription": "AI meal plan generator must take client medical profile, dietary restrictions, and weight goals as inputs and generate 30-day personalised plans with per-meal macro targets (protein, carbs, fat, fibre, calories) adjusted for medical conditions. Coach review and approval required before delivery.",
      "requirementType": "Functional",
      "priority": "Must-Have",
      "acceptanceCriteria": [
        "Plans generated for all supported medical conditions (diabetes, PCOS, thyroid, IBS, kidney)",
        "Per-meal macro targets within 5% of prescribed values",
        "Coach approval workflow with override capability",
        "Clinical safety audit log for all medical-condition plans"
      ],
      "implementedBy": "pf:func-vhf-ai-agent",
      "approvedBy": "pf:func-vhf-coach",
      "vpAlignment": {
        "vpEntity": "vp:vhf-sol-weight-mgmt",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:req-vhf-constraint-resolution",
      "@type": "pf:Requirement",
      "requirementId": "req:vhf-constraint-resolution",
      "requirementName": "Multi-Constraint Resolution Engine",
      "requirementDescription": "Constraint-resolution engine must model 30 diet types and 14 allergen categories as graph constraints. Every generated meal must be validated against all active constraints before inclusion. Impossible combinations must be detected at onboarding and flagged to coach.",
      "requirementType": "Functional",
      "priority": "Must-Have",
      "acceptanceCriteria": [
        "All 30 diet types modelled and enforceable",
        "All 14 major allergen categories modelled and enforceable",
        "100% constraint validation pass rate (zero violations in production)",
        "Impossible combination detection at onboarding with coach notification",
        "Constraint resolution completes in under 5 seconds per plan"
      ],
      "implementedBy": "pf:func-vhf-ai-agent",
      "approvedBy": "pf:func-vhf-coach",
      "vpAlignment": {
        "vpEntity": "vp:vhf-sol-dietary-compliance",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:req-vhf-automated-generation",
      "@type": "pf:Requirement",
      "requirementId": "req:vhf-automated-generation",
      "requirementName": "Automated 30-Day Plan Generation with Coaching Protocols",
      "requirementDescription": "AI pipeline must generate complete 30-day meal plans (90 meals + snacks) in under 10 minutes, incorporating all client constraints, macro targets, variety rules, and coaching protocols. Coach James Kerby's methodology must be encoded as configurable rules (progressive macro adjustment, cheat day placement, re-feed strategies).",
      "requirementType": "Functional",
      "priority": "Must-Have",
      "acceptanceCriteria": [
        "Full 30-day plan generated in under 10 minutes",
        "All coaching protocols configurable and versioned",
        "Coach review dashboard with approve/adjust/reject workflow",
        "Generation supports batch mode (multiple clients in queue)"
      ],
      "implementedBy": "pf:func-vhf-ai-agent",
      "approvedBy": "pf:func-vhf-coach",
      "vpAlignment": {
        "vpEntity": "vp:vhf-sol-coach-efficiency",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:req-vhf-variety-enforcement",
      "@type": "pf:Requirement",
      "requirementId": "req:vhf-variety-enforcement",
      "requirementName": "Variety Rules and Portion Scaling Enforcement",
      "requirementDescription": "Three-layer quality enforcement: (1) Variety rules prevent recipe repetition within configurable windows, enforce cuisine diversity, and track variety scores. (2) Portion scaling adjusts recipes to hit per-meal macro targets with <5% variance. (3) Theme curation assigns weekly cuisine themes for engagement.",
      "requirementType": "Functional",
      "priority": "Should-Have",
      "acceptanceCriteria": [
        "No recipe repeat within 10-day window (configurable)",
        "Variety score >60% across all generated plans",
        "Macro variance <5% after portion scaling",
        "Weekly theme assignment from curated theme library",
        "Variety scoring visible on coach dashboard"
      ],
      "implementedBy": "pf:func-vhf-ai-agent",
      "approvedBy": "pf:func-vhf-coach",
      "vpAlignment": {
        "vpEntity": "vp:vhf-sol-nutritional-quality",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },

    {"_section": "=== RESULTS (from VP Benefits via JP-VP-RRR-001) ==="},

    {
      "@id": "pf:result-vhf-weight-progress-safety",
      "@type": "pf:Result",
      "resultId": "result:vhf-weight-progress-safety",
      "resultName": "Measurable Weight Progress with Clinical Safety",
      "resultDescription": "Clients achieve target weight trajectory (within 2% of plan) while zero clinical safety violations are recorded across all medical-condition plans.",
      "resultType": "Outcome",
      "targetValue": "Weight trajectory within 2% of plan; zero clinical safety violations",
      "measurementMethod": "Weekly weigh-in variance vs plan trajectory; clinical safety audit log",
      "measurementFrequency": "Weekly (weight); continuous (safety)",
      "vpAlignment": {
        "vpEntity": "vp:vhf-ben-weight-mgmt",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:result-vhf-allergen-compliance",
      "@type": "pf:Result",
      "resultId": "result:vhf-allergen-compliance",
      "resultName": "100% Allergen Compliance",
      "resultDescription": "Every meal in every plan passes all active dietary and allergen constraints with zero violations. No manual checking required by coach or client.",
      "resultType": "Outcome",
      "targetValue": "100% compliance rate; zero violations",
      "measurementMethod": "Automated constraint validation pass/fail per plan; violation incident count",
      "measurementFrequency": "Per plan generation",
      "vpAlignment": {
        "vpEntity": "vp:vhf-ben-dietary-compliance",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:result-vhf-coach-throughput",
      "@type": "pf:Result",
      "resultId": "result:vhf-coach-throughput",
      "resultName": "10x Coach Throughput",
      "resultDescription": "Coach James scales from 20 to 200+ active clients without additional coaching hires. Plan generation time drops from 4-6 hours to under 10 minutes per plan.",
      "resultType": "Outcome",
      "targetValue": "200+ active clients per coach; <10 minutes per plan generation",
      "measurementMethod": "Active subscription count per coach; average plan generation time",
      "measurementFrequency": "Monthly",
      "vpAlignment": {
        "vpEntity": "vp:vhf-ben-coach-efficiency",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },
    {
      "@id": "pf:result-vhf-variety-macro-accuracy",
      "@type": "pf:Result",
      "resultId": "result:vhf-variety-macro-accuracy",
      "resultName": "High Variety and Macro Accuracy",
      "resultDescription": "Greater than 60% variety score and less than 5% macro variance across all generated plans, reducing client dropout from monotony and improving nutritional outcomes.",
      "resultType": "Outcome",
      "targetValue": ">60% variety score; <5% macro variance",
      "measurementMethod": "Variety score (unique recipes / total meals); macro variance (actual vs target per meal)",
      "measurementFrequency": "Per plan generation",
      "vpAlignment": {
        "vpEntity": "vp:vhf-ben-nutritional-quality",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },

