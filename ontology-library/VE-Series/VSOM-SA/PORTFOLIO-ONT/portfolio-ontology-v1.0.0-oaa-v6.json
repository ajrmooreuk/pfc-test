    {
      "@id": "pfl:GrowthShareMatrix",
      "@type": "rdfs:Class",
      "name": "GrowthShareMatrix",
      "rdfs:subClassOf": "schema:Report",
      "description": "BCG Growth-Share Matrix — portfolio analysis across Relative Market Share x Market Growth Rate. Classifies products/brands/BUs into Stars, Cash Cows, Question Marks, Dogs. Directly informs VSOM resource allocation strategy and PPM investment decisions. References existing orgctx:Product and orgctx:Brand entities.",
      "oaa:properties": [
        {
          "name": "matrixId",
          "type": "xsd:string",
          "required": true,
          "schemaOrgMapping": "schema:identifier"
        },
        {
          "name": "name",
          "type": "xsd:string",
          "required": true,
          "schemaOrgMapping": "schema:name"
        },
        {
          "name": "contextRef",
          "type": "xsd:string",
          "required": true,
          "description": "Reference to orgctx:OrganizationContext @id"
        },
        {
          "name": "analysisDate",
          "type": "xsd:date",
          "required": true
        },
        {
          "name": "portfolioScope",
          "type": "xsd:string",
          "required": true,
          "enum": [
            "Products",
            "Brands",
            "BusinessUnits",
            "Services",
            "Markets"
          ],
          "description": "What type of portfolio elements are being classified"
        },
        {
          "name": "portfolioHealth",
          "type": "xsd:string",
          "required": false,
          "enum": [
            "Balanced",
            "GrowthHeavy",
            "HarvestHeavy",
            "AtRisk"
          ],
          "description": "Overall portfolio balance assessment"
        },
        {
          "name": "cashFlowBalance",
          "type": "xsd:string",
          "required": false,
          "description": "Whether cash cows fund stars and question marks adequately"
        },
        {
          "name": "totalRevenue",
          "type": "xsd:decimal",
          "required": false
        },
        {
          "name": "vsomStrategyRef",
          "type": "xsd:string",
          "required": false,
          "description": "Reference to vsom:StrategyComponent @id governing resource allocation"
        }
      ]
    },
    {
