{
  "@context": {
    "@vocab": "https://schema.org/",
    "ds": "https://platformcore.io/ontology/ds/",
    "pfc-ds": "https://platformcore.io/ds/rules/"
  },
  "@id": "pfc-ds:design-rules-v1.0.0",
  "@type": "ds:DesignRuleSet",
  "name": "PFC Design Rules v1.0.0",
  "description": "Platform Core (PFC) normative design rules codified as DS-ONT v1.4.0 DesignRule instances. These 45 DR-* rules govern graph rendering, colour, edges, series, brand integration, DS tokens, typography, status badges, canvas background, container surfaces, PFI brand resolution, context switch UI, context node visibility, node labels, and semantic coherence across all PF-Instance brands. Plus 4 ComponentDesignRule instances for per-component constraints.",
  "ds:version": "1.3.0",
  "ds:ontologyVersion": "1.4.0",
  "dateCreated": "2026-02-12",
  "@graph": [
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-canvas-001",
      "ds:ruleId": "DR-CANVAS-001",
      "ds:ruleName": "Canvas Background Immutability",
      "ds:ruleCategory": "Canvas",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF --viz-surface-default value is set by brand",
      "ds:requirement": "THEN luminance MUST be < 0.05 (dark-safe) OR >= 0.2 (light-safe); values in 0.05-0.19 dead zone are rejected",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Canvas background is the WCAG contrast foundation. Mid-range luminance (0.05-0.19) breaks all contrast ratios. Enforced by _relativeLuminance() guard in generateCSSVars()."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-graph-001",
      "ds:ruleId": "DR-GRAPH-001",
      "ds:ruleName": "Node Colours on Dark Canvas",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF on dark backgrounds (luminance < 0.2)",
      "ds:requirement": "THEN node fill colours MUST have contrast ratio >= 3:1 against the canvas; bright, saturated mid-tones (Material 500 range) work best",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Ensures node visibility on dark canvas. Material 500-range colours (e.g. #4CAF50, #2196F3, #FF9800) provide sufficient contrast."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-graph-002",
      "ds:ruleId": "DR-GRAPH-002",
      "ds:ruleName": "Node Colours on Light Canvas",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF on light backgrounds (luminance >= 0.2)",
      "ds:requirement": "THEN node fill colours MUST be darkened to the 700-900 Material range or use outline-only style with coloured borders",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Light canvas requires darker node fills or outline-only rendering to maintain WCAG AA contrast."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-graph-003",
      "ds:ruleId": "DR-GRAPH-003",
      "ds:ruleName": "Node Font Colour",
      "ds:ruleCategory": "Font",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering graph node labels",
      "ds:requirement": "THEN node font colour MUST be --viz-text-primary (#e0e0e0 dark / #212121 light), never the node fill colour",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Node labels must always use the text-primary CSS variable regardless of node fill, ensuring readability."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-001",
      "ds:ruleId": "DR-EDGE-001",
      "ds:ruleName": "Edge Colours on Dark Theme",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edges on dark theme (luminance < 0.2)",
      "ds:requirement": "THEN edge colours MUST have luminance > 0.15; minimum 1px stroke width",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Dark grey edges become invisible on dark canvas. Minimum luminance 0.15 ensures visibility."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-002",
      "ds:ruleId": "DR-EDGE-002",
      "ds:ruleName": "Edge Colours on Light Theme",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edges on light theme (luminance >= 0.2)",
      "ds:requirement": "THEN edge colours MUST have luminance < 0.5; prefer 700-900 Material range",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Bright pastel edges wash out on light canvas. Darker edge colours ensure visibility."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-003",
      "ds:ruleId": "DR-EDGE-003",
      "ds:ruleName": "Highlight Colour Theme Swap",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering highlight edges",
      "ds:requirement": "THEN --viz-accent MUST swap: bright cyan #9dfff5 on dark, deep teal #017c75 on light",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Highlight accent colour must theme-swap to maintain contrast. Brands may override the specific accent hue."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-004",
      "ds:ruleId": "DR-EDGE-004",
      "ds:ruleName": "Cross-Ontology Bridge Edge Distinction",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering cross-ontology bridge edges",
      "ds:requirement": "THEN cross-ontology bridge edges MUST remain visually distinct from intra-ontology edges; use 2px width + dashed pattern",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Bridge edges need visual distinction to show cross-ontology relationships clearly."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-005",
      "ds:ruleId": "DR-EDGE-005",
      "ds:ruleName": "Edge Width Hierarchy",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering any edges",
      "ds:requirement": "THEN edge width MUST encode semantic importance via priority 0-5 scale: P1 (1-1.5px) taxonomy; P2 (1.5px) intra-ontology; P3 (2-2.5px) bindings/value-chains; P4 (2-2.5px) cross-ontology; P5 (3.5-4px) lineage chains",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Edge width communicates relationship importance. Consistent width hierarchy prevents visual confusion."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-006",
      "ds:ruleId": "DR-EDGE-006",
      "ds:ruleName": "Dash Pattern Semantics",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edge stroke patterns",
      "ds:requirement": "THEN dash patterns MUST use EDGE_STYLES constants exclusively: Solid=intra-ontology, [5,5]=taxonomy, [6,3]=partial-series, [8,4]=cross-boundary",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Dash patterns encode boundary semantics. Custom patterns break the visual grammar."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-007",
      "ds:ruleId": "DR-EDGE-007",
      "ds:ruleName": "Arrow Semantics",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edge arrows",
      "ds:requirement": "THEN all edges MUST use directional 'to' arrows; connection map edges use scaleFactor 0.5 to avoid visual dominance",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Directional arrows show relationship flow. Scaled arrows on dense connection maps prevent clutter."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-edge-008",
      "ds:ruleId": "DR-EDGE-008",
      "ds:ruleName": "Edge Label Readability",
      "ds:ruleCategory": "Font",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edge labels",
      "ds:requirement": "THEN edge label font colour MUST be --viz-text-secondary (#888) for standard edges or edge's own colour for lineage/cross-ontology; 2px stroke in #0f1117; font sizes: 9px lineage, 10px standard, 11px tier-0",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Edge labels need consistent styling for readability. Stroke prevents label/edge blending."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-series-001",
      "ds:ruleId": "DR-SERIES-001",
      "ds:ruleName": "Series Colours Light Theme",
      "ds:ruleCategory": "Series",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering in light theme (luminance >= 0.2)",
      "ds:requirement": "THEN series colours MUST use the 700-900 Material alternative column",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Light theme requires darker series colours for adequate contrast."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-series-002",
      "ds:ruleId": "DR-SERIES-002",
      "ds:ruleName": "Convergence Colour Distinction",
      "ds:ruleCategory": "Series",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering convergence (VE+PE overlap) nodes",
      "ds:requirement": "THEN convergence colour MUST remain distinct from both VE gold and PE copper; use orange-red in both modes",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Convergence points need a unique colour to distinguish from individual VE/PE series."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-series-003",
      "ds:ruleId": "DR-SERIES-003",
      "ds:ruleName": "Series Border Persistence",
      "ds:ruleCategory": "Series",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF drilling from Tier 1 to Tier 2 entity nodes",
      "ds:requirement": "THEN entity node borders MUST use the parent series colour for visual continuity; silo and component-coloured nodes take priority",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Series border colour persists during drill-through to maintain visual context."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-series-004",
      "ds:ruleId": "DR-SERIES-004",
      "ds:ruleName": "Series Provenance Legend",
      "ds:ruleCategory": "Series",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF Tier 2 graph is reached via series drill-through",
      "ds:requirement": "THEN Tier 2 graph legend MUST include a series provenance indicator",
      "ds:severity": "info",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Provenance legend helps users understand which series they drilled into."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-brand-001",
      "ds:ruleId": "DR-BRAND-001",
      "ds:ruleName": "Brand Key Node Outline",
      "ds:ruleCategory": "Brand",
      "ds:scope": "BrandVariant",
      "ds:condition": "IF a DS brand is active (state.brandContext is set)",
      "ds:requirement": "THEN all Tier 2 graph nodes MUST show a shadow glow in the brand's accent colour; three-layer hierarchy: glow (brand) → border (series) → fill (entity type)",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Brand glow provides persistent visual brand identity in the graph without overriding structural colours."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ds-001",
      "ds:ruleId": "DR-DS-001",
      "ds:ruleName": "Token Cascade Node Colour Scheme",
      "ds:ruleCategory": "DS",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering token cascade graph nodes",
      "ds:requirement": "THEN token cascade nodes MUST use the same colour scheme as entity types (Primitive=Core green #4CAF50, Semantic=Framework blue #2196F3, Component=Supporting orange #FF9800)",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Token cascade colours align with entity type palette for visual consistency across views."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ds-002",
      "ds:ruleId": "DR-DS-002",
      "ds:ruleName": "Token Cascade Edge Arrows",
      "ds:ruleCategory": "DS",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering token cascade edges (Primitive → Semantic → Component)",
      "ds:requirement": "THEN token cascade edges MUST use directional arrows with 50% opacity of the target tier colour",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "50% opacity cascade edges avoid visual dominance while showing directional token flow."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ds-003",
      "ds:ruleId": "DR-DS-003",
      "ds:ruleName": "DesignComponent Node Rendering",
      "ds:ruleCategory": "DS",
      "ds:scope": "ComponentDefinition",
      "ds:condition": "IF rendering DesignComponent nodes in token cascade graph",
      "ds:requirement": "THEN DesignComponent nodes MUST render as box shapes with [N] badge suffix showing ComponentToken binding count; zero bindings show no badge",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Box shapes distinguish components from token dots. Badge count gives instant binding visibility."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ds-004",
      "ds:ruleId": "DR-DS-004",
      "ds:ruleName": "consumesToken Edge Styling",
      "ds:ruleCategory": "DS",
      "ds:scope": "ComponentDefinition",
      "ds:condition": "IF rendering consumesToken edges (DesignComponent → ComponentToken)",
      "ds:requirement": "THEN consumesToken edges MUST use dashed stroke [4,2], 50% opacity of #FF9800, and width 1.5px; visually subordinate to primary cascade edges",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "consumesToken edges are visually lighter than cascade reference edges to show hierarchy."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-status-001",
      "ds:ruleId": "DR-STATUS-001",
      "ds:ruleName": "Status Badge Text Colour",
      "ds:ruleCategory": "Status",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering status badges (Pass, Fail, Warning, Info)",
      "ds:requirement": "THEN status badge text colour MUST be dark (700-900 range) regardless of theme mode; background shifts to pastel on light, vivid on dark",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Dark text on status badges ensures readability in both light and dark themes."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-font-001",
      "ds:ruleId": "DR-FONT-001",
      "ds:ruleName": "Graph Node Label Font",
      "ds:ruleCategory": "Font",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering graph node labels",
      "ds:requirement": "THEN graph node labels MUST be --viz-text-primary, never the node fill colour, to guarantee readability",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Node label font must use the theme-aware text-primary colour, not the node fill."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-font-002",
      "ds:ruleId": "DR-FONT-002",
      "ds:ruleName": "Edge Label Font and Background",
      "ds:ruleCategory": "Font",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edge labels",
      "ds:requirement": "THEN edge labels MUST be --viz-text-secondary with semi-transparent background matching --viz-surface-default at 80% opacity",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Edge label styling ensures readability without obscuring the edge itself."
    },

    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-container-001",
      "ds:ruleId": "DR-CONTAINER-001",
      "ds:ruleName": "Container Surface Immutability",
      "ds:ruleCategory": "Container",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF container.surface.default token exists in a DS instance",
      "ds:requirement": "THEN its mutabilityTier MUST be PF-Core. Brands MUST NOT override container surface tokens via BrandVariant.tokenOverrides.",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Container surface colour is a structural decision by the Design Director. It defines the bounded visual region behind graph node groups and must remain consistent across all brands to preserve graph readability and series-colour contrast. This is the first PF-Core semantic colour token — establishing the precedent that the Design Director can classify semantic colours as structural."
    },

    {
      "@type": "ds:ComponentDesignRule",
      "@id": "pfc-ds:rule-comp-button-contrast",
      "ds:ruleId": "DR-COMP-BUTTON-001",
      "ds:ruleName": "Button Background Contrast",
      "ds:ruleCategory": "Component",
      "ds:scope": "ComponentDefinition",
      "ds:condition": "IF Button component has background token binding",
      "ds:requirement": "THEN background MUST maintain >= 4.5:1 contrast ratio against text token",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Button background must meet WCAG AA text contrast. Brands may change the specific colour but must maintain ratio.",
      "ds:targetCategory": "Atom",
      "ds:constraintType": "ContrastRatio",
      "ds:constraintTarget": "background",
      "ds:constraintValue": "4.5"
    },
    {
      "@type": "ds:ComponentDesignRule",
      "@id": "pfc-ds:rule-comp-card-radius",
      "ds:ruleId": "DR-COMP-CARD-001",
      "ds:ruleName": "Card Border Radius Allowed Values",
      "ds:ruleCategory": "Component",
      "ds:scope": "ComponentDefinition",
      "ds:condition": "IF Card component has border-radius token binding",
      "ds:requirement": "THEN border-radius MUST be one of the approved PF-Core values",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Card border-radius is PF-Core (structurally immutable). Brands cannot override the approved radius set.",
      "ds:targetCategory": "Molecule",
      "ds:constraintType": "AllowedValues",
      "ds:constraintTarget": "border-radius",
      "ds:constraintValue": "4px,8px,12px,16px"
    },
    {
      "@type": "ds:ComponentDesignRule",
      "@id": "pfc-ds:rule-comp-input-focus",
      "ds:ruleId": "DR-COMP-INPUT-001",
      "ds:ruleName": "Input Focus Ring Must Reference Semantic",
      "ds:ruleCategory": "Component",
      "ds:scope": "ComponentDefinition",
      "ds:condition": "IF Input component has focusRing token binding",
      "ds:requirement": "THEN focusRing MUST reference a semantic token (not a primitive or hardcoded value)",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Input focus ring must cascade through semantic tokens to support theme-switching and brand override.",
      "ds:targetCategory": "Atom",
      "ds:constraintType": "MustReference",
      "ds:constraintTarget": "focusRing",
      "ds:constraintValue": "ds:SemanticToken"
    },
    {
      "@type": "ds:ComponentDesignRule",
      "@id": "pfc-ds:rule-comp-nav-contrast",
      "ds:ruleId": "DR-COMP-NAV-001",
      "ds:ruleName": "Navigation Bar Minimum Contrast",
      "ds:ruleCategory": "Component",
      "ds:scope": "ComponentDefinition",
      "ds:condition": "IF Navigation component has background and text token bindings",
      "ds:requirement": "THEN background-to-text contrast ratio MUST be >= 4.5:1 for WCAG AA",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Navigation bar is a primary UI landmark — text must be readable against background in all brand variants.",
      "ds:targetCategory": "Organism",
      "ds:constraintType": "ContrastRatio",
      "ds:constraintTarget": "background",
      "ds:constraintValue": "4.5"
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-pfi-001",
      "ds:ruleId": "DR-PFI-001",
      "ds:ruleName": "PFI Instance Brand Resolution",
      "ds:ruleCategory": "Brand",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF a PFI instance is selected via the instance selector",
      "ds:requirement": "THEN the DS brand MUST be auto-resolved using the three-tier cascade: (1) designSystemConfig.brand, (2) designSystemConfig.fallback, (3) brands[0].toLowerCase(). Manual brand selection via the DS dropdown MUST remain functional as an override.",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "PFI→DS brand resolution bridges EMC InstanceConfiguration (designSystemConfig) to DS-ONT brand instances via resolveDSBrandForPFI(). Null brand with fallback supports placeholder instances using PF-Core defaults. Implements the ds:configuredByInstance relationship at the application layer."
    },

    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-container-002",
      "ds:ruleId": "DR-CONTAINER-002",
      "ds:ruleName": "Container Fill Opacity",
      "ds:ruleCategory": "Container",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering container bounding rectangles on canvas",
      "ds:requirement": "THEN container fill opacity MUST be 0.18 (18%)",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Visible tint on dark #0f1117 canvas while keeping nodes readable."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-container-003",
      "ds:ruleId": "DR-CONTAINER-003",
      "ds:ruleName": "Container Stroke Opacity",
      "ds:ruleCategory": "Container",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering container bounding rectangles on canvas",
      "ds:requirement": "THEN container stroke opacity MUST be 0.40 (40%)",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Clear boundary without competing with node borders."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-container-004",
      "ds:ruleId": "DR-CONTAINER-004",
      "ds:ruleName": "Container Stroke Width",
      "ds:ruleCategory": "Container",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering container bounding rectangles on canvas",
      "ds:requirement": "THEN container stroke width MUST be 2px",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Matches primary node border width for visual consistency."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-container-005",
      "ds:ruleId": "DR-CONTAINER-005",
      "ds:ruleName": "Container Corner Radius",
      "ds:ruleCategory": "Container",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering container bounding rectangles on canvas",
      "ds:requirement": "THEN container corner radius MUST be 12 canvas units",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Proportionate to canvas-scale geometry."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-container-006",
      "ds:ruleId": "DR-CONTAINER-006",
      "ds:ruleName": "Container Padding",
      "ds:ruleCategory": "Container",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering container bounding rectangles on canvas",
      "ds:requirement": "THEN container padding MUST be 30 + 40 (node allowance) canvas units clearance beyond node centres",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Clearance covers disc + label area for all contained nodes."
    },

    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ctx-switch-001",
      "ds:ruleId": "DR-CTX-SWITCH-001",
      "ds:ruleName": "Context Identity Bar",
      "ds:ruleCategory": "Brand",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF PFI instances are loaded",
      "ds:requirement": "THEN a persistent context identity bar MUST appear between the toolbar and graph container showing active PFI instance ID (or 'PF-Core'), resolved DS brand, and 4px left accent strip matching brandContext.accentColor; clicking MUST open the quick-switch drawer",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Context identity bar provides persistent visual feedback about the active PFI/PF-Core context."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ctx-switch-002",
      "ds:ruleId": "DR-CTX-SWITCH-002",
      "ds:ruleName": "Graph Border Glow",
      "ds:ruleCategory": "Brand",
      "ds:scope": "BrandVariant",
      "ds:condition": "IF a DS brand context is active",
      "ds:requirement": "THEN #graph-container MUST display an inset box-shadow glow (inset 0 0 12px 2px) coloured by brandContext.accentColor; glow MUST be removed when context is reset to PF-Core; transition MUST be 0.4s ease",
      "ds:severity": "info",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Border glow provides ambient brand presence in the graph canvas area."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ctx-switch-003",
      "ds:ruleId": "DR-CTX-SWITCH-003",
      "ds:ruleName": "Dynamic Title and Favicon",
      "ds:ruleCategory": "Brand",
      "ds:scope": "BrandVariant",
      "ds:condition": "IF a PFI instance is selected",
      "ds:requirement": "THEN document.title MUST reflect the active PFI instance ('PFI-BAIV — OAA Visualiser'); a 16x16 canvas favicon MUST be generated with the brand accent colour as a centred dot on dark background",
      "ds:severity": "info",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Browser tab reflects the active PFI context for multi-tab workflows."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-ctx-switch-004",
      "ds:ruleId": "DR-CTX-SWITCH-004",
      "ds:ruleName": "Switch Confirmation Modal",
      "ds:ruleCategory": "Brand",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF switching FROM one PFI instance TO another (not initial selection, not clearing to PF-Core)",
      "ds:requirement": "THEN a confirmation modal MUST be shown stating source and target instance; Escape MUST dismiss the modal (cancel action)",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Context switch confirmation prevents accidental PFI changes that reset graph state."
    },

    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-context-001",
      "ds:ruleId": "DR-CONTEXT-001",
      "ds:ruleName": "Context Node Opacity",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering context/ghost nodes (faded series super-nodes, sub-series parents, diff removed nodes)",
      "ds:requirement": "THEN context/ghost node opacity MUST be 0.55",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "55% opacity provides clear visual subordination while remaining legible on the dark canvas."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-context-002",
      "ds:ruleId": "DR-CONTEXT-002",
      "ds:ruleName": "Context Node Size",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering context/ghost nodes",
      "ds:requirement": "THEN context node size MUST be 60-70% of primary node size; series context nodes use size 25 (vs primary 30-35)",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Smaller context nodes establish visual hierarchy without disappearing."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-context-003",
      "ds:ruleId": "DR-CONTEXT-003",
      "ds:ruleName": "Context Node Border",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering context/ghost nodes",
      "ds:requirement": "THEN context node border MUST be 1px with colour #333 or #555; composition ghost nodes use dashed borders [6,3]",
      "ds:severity": "info",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Thin borders distinguish context from primary nodes which use 2-3px borders."
    },

    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-node-label-001",
      "ds:ruleId": "DR-NODE-LABEL-001",
      "ds:ruleName": "Abbreviated Code on Node Labels",
      "ds:ruleCategory": "Font",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering Tier 0 series nodes, Tier 1 ontology nodes, or Tier 1 sub-series grouping nodes",
      "ds:requirement": "THEN nodes MUST display an abbreviated code on the first line of a multi-line label for rapid identification",
      "ds:severity": "info",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Abbreviated codes (e.g. VE, bsc:, SA) provide rapid identification without reading full labels."
    },

    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-semantic-001",
      "ds:ruleId": "DR-SEMANTIC-001",
      "ds:ruleName": "Archetype Colour via CSS Vars",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering graph node fill colours",
      "ds:requirement": "THEN node fill colours MUST be read from --viz-archetype-{type} CSS custom properties, falling back to TYPE_COLORS when no CSS var is set; refreshArchetypeCache() MUST be called at the start of each render cycle",
      "ds:severity": "error",
      "ds:priority": 2,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "CSS variable bridge enables brand override of archetype colours while maintaining WCAG-validated defaults. Cache avoids per-node getComputedStyle() overhead."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-semantic-002",
      "ds:ruleId": "DR-SEMANTIC-002",
      "ds:ruleName": "Edge Label Semantic Categories",
      "ds:ruleCategory": "Edge",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering edge visual style and a relationship label is present",
      "ds:requirement": "THEN edge styling MUST resolve from the label via EDGE_LABEL_CATEGORIES (5 categories: structural, taxonomy, dependency, informational, operational) before falling back to EDGE_STYLES[edgeType]",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Label-based semantic categories encode relationship intent via colour/width/dash. Unmapped labels fall through to type-based resolution for backward compatibility."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-semantic-003",
      "ds:ruleId": "DR-SEMANTIC-003",
      "ds:ruleName": "Archetype Shape Encoding",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF rendering graph nodes for entity archetypes",
      "ds:requirement": "THEN each entity archetype MUST map to a distinct vis-network shape via ARCHETYPE_SHAPES: core=hexagon, class=dot, framework=box, supporting=triangle, agent=star, external=diamond, layer=square, concept=ellipse; auto-sizing shapes use widthConstraint {min:60, max:120}",
      "ds:severity": "warning",
      "ds:priority": 2,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Distinct shapes provide instant archetype identification without relying on colour alone — important for colour-blind accessibility."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-semantic-004",
      "ds:ruleId": "DR-SEMANTIC-004",
      "ds:ruleName": "Interactive Semantic Legend",
      "ds:ruleCategory": "Graph",
      "ds:scope": "GlobalSystem",
      "ds:condition": "IF graph legend is rendered",
      "ds:requirement": "THEN the legend MUST be interactive with: (1) hover dims non-matching nodes to 15% opacity (100ms debounce), (2) click toggles persistent filter, (3) Reset button clears all; legend MUST include node section (shape indicators + counts) and edge section (line samples + counts)",
      "ds:severity": "warning",
      "ds:priority": 3,
      "ds:mutabilityTier": "PF-Core",
      "ds:description": "Interactive legend enables exploratory filtering of complex graphs without modifying the underlying data."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-semantic-005",
      "ds:ruleId": "DR-SEMANTIC-005",
      "ds:ruleName": "Brand Archetype Override Validation",
      "ds:ruleCategory": "Brand",
      "ds:scope": "BrandVariant",
      "ds:condition": "IF DS-ONT brand tokens include archetype.{type}.surface values",
      "ds:requirement": "THEN generateCSSVars() MUST map them to --viz-archetype-{type} CSS variables; applyCSSVars() MUST validate each at 3:1 minimum contrast against canvas (--viz-surface-default); failing colours MUST be reverted with console.warn",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Brand archetype overrides are allowed but must meet WCAG graphical object contrast (3:1). Failing overrides silently revert to maintain accessibility."
    },
    {
      "@type": "ds:DesignRule",
      "@id": "pfc-ds:rule-semantic-006",
      "ds:ruleId": "DR-SEMANTIC-006",
      "ds:ruleName": "Brand Edge Category Override Validation",
      "ds:ruleCategory": "Edge",
      "ds:scope": "BrandVariant",
      "ds:condition": "IF DS-ONT brand tokens include edge.{category}.color values",
      "ds:requirement": "THEN generateCSSVars() MUST map them to --viz-edge-{category} CSS variables; same 3:1 contrast validation as DR-SEMANTIC-005 applies; edge category colours read from CSS vars via getEdgeSemanticColor(category)",
      "ds:severity": "error",
      "ds:priority": 1,
      "ds:wcagLevel": "AA",
      "ds:mutabilityTier": "PF-Instance",
      "ds:description": "Brand edge category overrides follow the same WCAG validation pattern as archetype colours."
    }
  ]
}
