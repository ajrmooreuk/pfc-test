      "problemStatement": "Compliance Directors struggle with audit preparation overhead when coordinating evidence collection across MCSB, GDPR, and PII requirements, resulting in 3-6 month preparation cycles per framework, $200K-$500K in annual audit prep costs, and 30% of compliance team capacity consumed by evidence gathering rather than remediation.",
      "problemType": "Economic",
      "severity": "Major",
      "frequency": "Frequent",
      "isGrowing": false,
      "scopeLevel": "Tactical",
      "ownerRole": "pf:func-compliance-director"
    },
