  "versionHistory": [
    {
      "version": "1.0.0",
      "date": "2026-02-17",
      "changes": "Initial release: 6 entities, 19 relationships (11 internal + 8 cross-ontology), 15 business rules, 11 enumerations, 8 join patterns. ISO 31000:2018 aligned. 23 risk categories inc. 9 AI-specific. Satisfies grc-fw:governsRisk and grc-fw:assuranceAssessesRisk forward references. Epic 30 F30.2."
    }
  ],
  "notes": "ERM-ONT is the GRC Tier 1 domain-agnostic risk management ontology. Positioned between GRC-FW-ONT v3.0.0 (Tier 0 hub) and RMF-IS27005-ONT v1.0.0 (Tier 2 ISO 27005 specialisation). Single authoritative source for enterprise controls across GRC — SEC-FW and COMP-FW will reference erm:Control rather than creating domain-specific control entities. Satisfies forward references grc-fw:governsRisk (GRCContext→RiskRegister) and grc-fw:assuranceAssessesRisk (GovernanceAssurance→Risk).",
  "oaa:joinPatterns": [
    { "patternId": "JP-ERM-001", "name": "GRC Governance to Risk Register Bridge", "joinPath": "grc-fw:GRCContext → grc-fw:governsRisk → erm:RiskRegister → erm:containsRisk → erm:Risk" },
    { "patternId": "JP-ERM-002", "name": "Risk Assessment to Treatment Lifecycle", "joinPath": "erm:RiskAssessment → erm:assessesRegister → erm:RiskRegister → erm:containsRisk → erm:Risk → erm:mitigatedByControl → erm:Control" },
    { "patternId": "JP-ERM-003", "name": "Risk Appetite Governance Bridge", "joinPath": "erm:RiskRegister → erm:hasAppetite → erm:RiskAppetite" },
    { "patternId": "JP-ERM-004", "name": "ERM to RMF Tier 1-to-Tier 2 Specialisation", "joinPath": "erm:Risk → erm:specialisedByInfoSecRisk → rmf:Risk → rmf:affectsAsset → rmf:Asset" },
    { "patternId": "JP-ERM-005", "name": "ERM Control to MCSB Benchmark Alignment", "joinPath": "erm:Control → erm:controlAlignsToBenchmark → mcsb:SecurityControl" },
    { "patternId": "JP-ERM-006", "name": "Risk Threatens Strategic Objective (VSEM Bridge)", "joinPath": "erm:Risk → erm:riskThreatsObjective → vsom:StrategicObjective" },
    { "patternId": "JP-ERM-007", "name": "Resilience Capability to Risk Coverage", "joinPath": "erm:ResilienceCapability → erm:protectsAgainstRisk → erm:Risk" },
    { "patternId": "JP-ERM-008", "name": "Assurance to Risk Assessment Bridge", "joinPath": "grc-fw:GovernanceAssurance → grc-fw:assuranceAssessesRisk → erm:Risk" }
  ]
}
