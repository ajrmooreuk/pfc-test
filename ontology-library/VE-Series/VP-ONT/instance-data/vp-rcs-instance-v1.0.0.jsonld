    },
    {
      "@id": "vp:rcs-diff-ontology-crossref",
      "@type": "vp:Differentiator",
      "name": "Ontology-Driven Cross-Referencing",
      "differentiatorId": "diff:rcs-ontology-crossref",
      "differentiatorDescription": "RCSG-Series ontologies encode semantic relationships between compliance requirements across frameworks, enabling automated cross-referencing with 95%+ accuracy — replacing error-prone manual mapping",
      "differentiatorType": "Technology",
      "competitiveAdvantage": "Semantic mapping means the system understands requirement meaning, not just keyword matching. 95% accuracy vs. 80-85% for manual mapping. Cross-references updated automatically when frameworks change.",
