// Safe DOM helpers — prevent "Cannot read properties of null" when elements are absent
function _show(id, display = 'block') { const el = document.getElementById(id); if (el) el.style.display = display; }
function _hide(id) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }

// ========================================
// FILE INPUT & DRAG-DROP
// ========================================

document.getElementById('file-input').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (file) loadFile(file);
});

const dropArea = document.getElementById('drop-area');
const dropZone = document.getElementById('drop-zone');

['dragenter', 'dragover'].forEach(evt => {
  dropArea.addEventListener(evt, e => { e.preventDefault(); dropArea.classList.add('dragover'); });
});
['dragleave', 'drop'].forEach(evt => {
  dropArea.addEventListener(evt, e => { e.preventDefault(); dropArea.classList.remove('dragover'); });
});
dropArea.addEventListener('drop', e => {
  const file = e.dataTransfer.files[0];
  if (file) loadFile(file);
});

function loadFile(file) {
  document.getElementById('file-name').textContent = file.name;

  // Route Mermaid files to Mermaid viewer (Epic 9F)
  const ext = file.name.split('.').pop().toLowerCase();
  if (ext === 'mmd' || ext === 'mermaid') {
    const reader = new FileReader();
    reader.onload = async function(e) {
      _closeAllOverlays();
      state.mermaidOrigin = 'file';
      const result = await loadAndRenderMermaid(e.target.result, file.name);
      if (result.error) {
        const errorEl = document.getElementById('mermaid-editor-error');
        if (errorEl) { errorEl.textContent = result.error; errorEl.style.display = 'block'; }
      }
      _setToolbarButtonsForView('mermaid');
      _updateViewTabs('mermaid');
      dropZone.classList.add('hidden');
      addRecentFile({ name: file.name, source: 'file', path: file.name, format: 'mermaid' });
    };
    reader.readAsText(file);
    return;
  }

  // Default: JSON ontology loading
  state.viewMode = 'single';
  resetNavigation();
  if (state.activeView !== 'graph') setViewMode('graph');
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const data = JSON.parse(e.target.result);
      state.currentData = data;
      const parsed = parseOntology(data, file.name);
      if (parsed.nodes.length === 0) {
        alert('No nodes parsed from this file. Keys found: ' + Object.keys(data).join(', '));
        return;
      }
      renderGraph(parsed);
      dropZone.classList.add('hidden');
      addRecentFile({ name: parsed.name || file.name, source: 'file', path: file.name, format: parsed.diagnostics?.format });
      updateBookmarkStar();
    } catch (err) {
      alert('Failed to parse JSON: ' + err.message);
    }
  };
  reader.readAsText(file);
}

// ========================================
// GITHUB BROWSER (Epic 5 — Stories 5.1.1, 5.1.2)
// ========================================

let _ghSelectedPath = null;

function loadFromGitHub() {
  showGitHubModal();
}

function showGitHubModal() {
  const modal = document.getElementById('github-modal');
  if (!modal) return;
  // Restore previous repo if set
  const gb = state.githubBrowser;
  if (gb.owner && gb.repo) {
    const input = document.getElementById('gh-repo-input');
    if (input) input.value = `${gb.owner}/${gb.repo}`;
  }
  // Update status dot
  const pat = sessionStorage.getItem('gh_pat') || localStorage.getItem('gh_pat');
  const dot = document.getElementById('gh-status-dot');
  if (dot) {
    dot.style.background = pat ? '#4CAF50' : '#666';
    dot.title = pat ? 'GitHub: token configured' : 'GitHub: no token (set via gear icon)';
  }
  modal.style.display = 'flex';
}

function closeGitHubModal() { _hide('github-modal'); }

function ghDisconnect() {
  _hide('gh-step-browse');
  _show('gh-step-repo');
  state.githubBrowser = { owner: null, repo: null, ref: null, currentPath: '' };
  _ghSelectedPath = null;
}

async function ghConnect() {
  const input = document.getElementById('gh-repo-input');
  const errorEl = document.getElementById('gh-repo-error');
  const val = input?.value?.trim();
  if (!val) return;
  if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

  const parts = val.split('/');
  if (parts.length !== 2 || !parts[0] || !parts[1]) {
    if (errorEl) { errorEl.textContent = 'Format: owner/repo'; errorEl.style.display = 'block'; }
    return;
  }
  const [owner, repo] = parts;

  try {
    const { listBranches, listTags } = await import('./github-loader.js');
    const [branches, tags] = await Promise.all([
      listBranches(owner, repo),
      listTags(owner, repo).catch(() => [])
    ]);

    state.githubBrowser = { owner, repo, ref: branches[0] || 'main', currentPath: '' };

    // Populate ref selector
    const select = document.getElementById('gh-ref-select');
    if (select) {
      let html = '<optgroup label="Branches">';
      branches.forEach(b => { html += `<option value="${b}"${b === state.githubBrowser.ref ? ' selected' : ''}>${b}</option>`; });
      html += '</optgroup>';
      if (tags.length > 0) {
        html += '<optgroup label="Tags">';
        tags.forEach(t => { html += `<option value="${t}">${t}</option>`; });
        html += '</optgroup>';
      }
      select.innerHTML = html;
    }

    _hide('gh-step-repo');
    _show('gh-step-browse');
    await ghNavigate('');
  } catch (err) {
    if (errorEl) {
      const msg = err.message.includes('No GitHub token')
        ? 'No GitHub token configured. Enter a PAT in sessionStorage or use the settings gear.'
        : err.message;
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
    }
  }
}

async function ghNavigate(path) {
  const gb = state.githubBrowser;
  if (!gb.owner) return;

  // Update ref from selector
  const select = document.getElementById('gh-ref-select');
  if (select) gb.ref = select.value;
  gb.currentPath = path;
  _ghSelectedPath = null;
  _hide('gh-preview');

  // Update breadcrumb
  const bcEl = document.getElementById('gh-breadcrumb');
  if (bcEl) {
    let bc = `<span style="cursor:pointer; color:#9dfff5;" onclick="ghNavigate('')">${gb.owner}/${gb.repo}</span>`;
    if (path) {
      const segments = path.split('/');
      let accumulated = '';
      segments.forEach((seg, i) => {
        accumulated += (i > 0 ? '/' : '') + seg;
        const p = accumulated;
        if (i < segments.length - 1) {
          bc += ` / <span style="cursor:pointer; color:#9dfff5;" onclick="ghNavigate('${p}')">${seg}</span>`;
        } else {
          bc += ` / ${seg}`;
        }
      });
    }
    bcEl.innerHTML = bc;
  }

  const treeEl = document.getElementById('gh-file-tree');
  const loadingEl = document.getElementById('gh-loading');
  if (loadingEl) loadingEl.style.display = 'flex';

  try {
    const { getRepoTree } = await import('./github-loader.js');
    const items = await getRepoTree(gb.owner, gb.repo, gb.ref, path);
    ghRenderTree(items, path);
  } catch (err) {
    if (treeEl) treeEl.innerHTML = `<div style="color:#fca5a5; padding:12px; font-size:13px;">${escapeHtml(err.message)}</div>`;
  } finally {
    if (loadingEl) loadingEl.style.display = 'none';
  }
}

function ghRenderTree(items, parentPath) {
  const treeEl = document.getElementById('gh-file-tree');
  if (!treeEl) return;

  // Sort: folders first, then files alphabetically
  const sorted = [...items].sort((a, b) => {
    if (a.type === 'dir' && b.type !== 'dir') return -1;
    if (a.type !== 'dir' && b.type === 'dir') return 1;
    return a.name.localeCompare(b.name);
  });

  // Back button if not at root
  let html = '';
  if (parentPath) {
    const parent = parentPath.includes('/') ? parentPath.substring(0, parentPath.lastIndexOf('/')) : '';
    html += `<div class="gh-item gh-folder" onclick="ghNavigate('${parent}')"><span class="gh-icon">\u2190</span> ..</div>`;
  }

  sorted.forEach(item => {
    if (item.type === 'dir') {
      html += `<div class="gh-item gh-folder" onclick="ghNavigate('${item.path}')"><span class="gh-icon">\u{1F4C1}</span> ${escapeHtml(item.name)}</div>`;
    } else {
      const isJson = item.name.endsWith('.json') || item.name.endsWith('.jsonld');
      const cls = isJson ? 'gh-file gh-file-json' : 'gh-file';
      const onclick = isJson ? `ghSelectFile('${item.path}')` : '';
      const sizeStr = item.size > 1024 ? `${(item.size / 1024).toFixed(1)}KB` : `${item.size}B`;
      html += `<div class="gh-item ${cls}"${onclick ? ` onclick="${onclick}"` : ''}>` +
        `<span class="gh-icon">${isJson ? '\u{1F4C4}' : '\u{1F4DD}'}</span> ${escapeHtml(item.name)} ` +
        `<span style="color:#666; font-size:11px; margin-left:auto;">${sizeStr}</span></div>`;
    }
  });

  if (sorted.length === 0) {
    html = '<div style="color:#666; padding:12px; font-size:13px;">Empty directory</div>';
  }

  treeEl.innerHTML = html;
}

function ghSelectFile(path) {
  _ghSelectedPath = path;
  const previewEl = document.getElementById('gh-preview');
  const nameEl = document.getElementById('gh-preview-name');
  if (nameEl) nameEl.textContent = path.split('/').pop();
  if (previewEl) previewEl.style.display = 'block';
  // Highlight selected
  document.querySelectorAll('.gh-item').forEach(el => el.classList.remove('gh-selected'));
  // Find the matching item by text
  document.querySelectorAll('.gh-file-json').forEach(el => {
    if (el.getAttribute('onclick')?.includes(path)) el.classList.add('gh-selected');
  });
}

async function ghLoadSelected() {
  if (!_ghSelectedPath) return;
  const gb = state.githubBrowser;

  try {
    const { fetchFileContent } = await import('./github-loader.js');
    const data = await fetchFileContent(gb.owner, gb.repo, gb.ref, _ghSelectedPath);
    state.currentData = data;
    state.viewMode = 'single';
    resetNavigation();
    const filename = _ghSelectedPath.split('/').pop();
    document.getElementById('file-name').textContent = filename;
    const parsed = parseOntology(data, filename);
    if (parsed.nodes.length === 0) {
      alert('No nodes parsed. Keys: ' + Object.keys(data).join(', '));
      return;
    }
    renderGraph(parsed);
    dropZone.classList.add('hidden');
    const fullPath = `${gb.owner}/${gb.repo}/${_ghSelectedPath}`;
    addRecentFile({ name: parsed.name || filename, source: 'github', path: fullPath, format: parsed.diagnostics?.format });
    updateBookmarkStar();
    closeGitHubModal();
  } catch (err) {
    alert('Failed to load file: ' + err.message);
  }
}

// ========================================
// GITHUB PAT SETTINGS (Epic 5 — Story 5.1.3)
// ========================================

function showGitHubSettings() {
  const modal = document.getElementById('github-settings-modal');
  if (!modal) return;
  updateGitHubTokenStatus();
  modal.style.display = 'flex';
}

function closeGitHubSettings() { _hide('github-settings-modal'); }

async function saveGitHubPAT() {
  const input = document.getElementById('gh-pat-input');
  const pat = input?.value?.trim();
  if (!pat) return;

  const persist = document.getElementById('gh-persist-pat')?.checked || false;
  const statusEl = document.getElementById('gh-token-status');
  if (statusEl) statusEl.innerHTML = '<span style="color:#888;">Validating...</span>';

  try {
    const { validatePAT, setGitHubPAT } = await import('./github-loader.js');
    const result = await validatePAT(pat);
    if (result.valid) {
      setGitHubPAT(pat, persist);
      if (input) input.value = '';
      updateGitHubTokenStatus();
    } else {
      if (statusEl) statusEl.innerHTML = `<span style="color:#fca5a5;">Invalid token: ${result.error}</span>`;
    }
  } catch (err) {
    if (statusEl) statusEl.innerHTML = `<span style="color:#fca5a5;">Error: ${err.message}</span>`;
  }
}

async function doClearGitHubPAT() {
  const { clearGitHubPAT } = await import('./github-loader.js');
  clearGitHubPAT();
  const input = document.getElementById('gh-pat-input');
  if (input) input.value = '';
  updateGitHubTokenStatus();
}

async function updateGitHubTokenStatus() {
  const statusEl = document.getElementById('gh-token-status');
  const { getGitHubPAT, validatePAT } = await import('./github-loader.js');
  const pat = getGitHubPAT();
  if (!pat) {
    if (statusEl) statusEl.innerHTML = '<span style="color:#666;">No token configured</span>';
    return;
  }
  if (statusEl) statusEl.innerHTML = '<span style="color:#888;">Checking token...</span>';
  const result = await validatePAT(pat);
  if (result.valid) {
    const scopes = result.scopes ? ` (scopes: ${result.scopes})` : '';
    if (statusEl) statusEl.innerHTML = `<span style="color:#4CAF50;">\u2713 Connected as <strong>${escapeHtml(result.login)}</strong>${scopes}</span>`;
  } else {
    if (statusEl) statusEl.innerHTML = `<span style="color:#fca5a5;">Token invalid: ${result.error}</span>`;
  }
}

// Auto-validate GitHub token on page load (non-blocking)
(async function autoValidateGitHubPAT() {
  try {
    const { getGitHubPAT } = await import('./github-loader.js');
    const pat = getGitHubPAT();
    if (pat) {
      const dot = document.getElementById('gh-status-dot');
      if (dot) { dot.style.background = '#4CAF50'; dot.title = 'GitHub: token found'; }
    }
  } catch { /* ignore */ }
})();

// ========================================
// URL LOADING (Epic 5 — Stories 5.2.1, 5.2.2)
// ========================================

function showURLModal() {
  const modal = document.getElementById('url-modal');
  const input = document.getElementById('url-input');
  const errEl = document.getElementById('url-error');
  const loadingEl = document.getElementById('url-loading');
  if (errEl) errEl.style.display = 'none';
  if (loadingEl) loadingEl.style.display = 'none';
  if (input) input.value = '';
  if (modal) modal.style.display = 'flex';
  if (input) input.focus();
}

function closeURLModal() {
  _hide('url-modal');
}

function showURLError(msg) {
  const el = document.getElementById('url-error');
  if (el) { el.textContent = msg; el.style.display = 'block'; }
}

function showURLLoading(show) {
  const el = document.getElementById('url-loading');
  if (el) el.style.display = show ? 'flex' : 'none';
}

async function loadFromURL() {
  const urlInput = document.getElementById('url-input');
  const url = urlInput?.value?.trim();
  if (!url) return;

  // Validate URL
  try { new URL(url); } catch { showURLError('Invalid URL'); return; }

  const isRegistry = document.getElementById('url-registry-mode')?.checked;
  const errEl = document.getElementById('url-error');
  if (errEl) errEl.style.display = 'none';
  showURLLoading(true);

  try {
    const response = await fetch(url, { headers: { 'Accept': 'application/json' } });
    if (!response.ok) throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    const data = await response.json();

    if (isRegistry && data.entries) {
      // CDN registry mode (5.2.2): treat as registry index, load all entries
      await loadRemoteRegistry(data, url);
    } else {
      // Single ontology mode (5.2.1)
      state.currentData = data;
      state.viewMode = 'single';
      resetNavigation();
      const filename = url.split('/').pop()?.split('?')[0] || 'remote-ontology.json';
      document.getElementById('file-name').textContent = filename;
      const parsed = parseOntology(data, filename);
      if (parsed.nodes.length === 0) throw new Error('No nodes parsed from URL. Keys: ' + Object.keys(data).join(', '));
      renderGraph(parsed);
      dropZone.classList.add('hidden');
      addRecentFile({ name: parsed.name || filename, source: 'url', url, format: parsed.diagnostics?.format });
      state.lastParsed.sourceURL = url;
      updateBookmarkStar();
    }
    closeURLModal();
  } catch (err) {
    showURLError(
      err.message.includes('Failed to fetch')
        ? 'CORS blocked or network error. The server must allow cross-origin requests.'
        : err.message
    );
  } finally {
    showURLLoading(false);
  }
}

async function loadRemoteRegistry(registryData, registryURL) {
  const baseURL = registryURL.substring(0, registryURL.lastIndexOf('/') + 1);
  state.registryIndex = registryData;
  const registryMeta = validateRegistryMetadata(registryData);
  state.registryMeta = registryMeta;
  state.viewMode = 'multi';

  const entries = registryData.entries || [];
  const fileNameEl = document.getElementById('file-name');
  const statsEl = document.getElementById('stats');

  fileNameEl.textContent = `Loading remote registry (${entries.length} entries)...`;
  statsEl.textContent = 'Loading...';

  const results = await Promise.allSettled(
    entries.map(async (entry) => {
      const entryPath = entry.path?.replace('./', '') || '';
      const entryURL = baseURL + entryPath;
      const namespace = entry.namespace || '';

      try {
        const res = await fetch(entryURL);
        if (!res.ok) return { entry, namespace, isPlaceholder: true };
        const fullEntry = await res.json();

        const artifactPath = fullEntry.artifacts?.ontology;
        if (!artifactPath) return { entry, namespace, fullEntry, isPlaceholder: true };

        const entryDir = entryURL.substring(0, entryURL.lastIndexOf('/') + 1);
        const artifactURL = entryDir + artifactPath.replace('./', '');
        const artRes = await fetch(artifactURL);
        if (!artRes.ok) return { entry, namespace, fullEntry, isPlaceholder: true };

        const rawData = await artRes.json();
        const parsed = parseOntology(rawData, entry.name || namespace);
        return { entry, namespace, fullEntry, rawData, parsed, isPlaceholder: false };
      } catch {
        return { entry, namespace, isPlaceholder: true };
      }
    })
  );

  // Build loadedOntologies map
  const loadedOntologies = new Map();
  const seriesRegistry = registryData.seriesRegistry || {};
  let loaded = 0;
  let placeholders = 0;

  for (const result of results) {
    const record = result.status === 'fulfilled' ? result.value : { entry: {}, namespace: '', isPlaceholder: true };
    const ns = record.namespace;
    if (!ns) continue;

    const series = resolveSeriesForOntology(record.entry?.name || ns, seriesRegistry);
    loadedOntologies.set(ns, {
      name: record.entry?.name || ns,
      series,
      isPlaceholder: record.isPlaceholder,
      registryEntry: record.fullEntry || null,
      parsed: record.parsed || { nodes: [], edges: [], name: ns, diagnostics: {} },
      rawData: record.rawData || {},
      status: record.isPlaceholder ? 'placeholder' : 'active'
    });

    if (record.isPlaceholder) placeholders++;
    else loaded++;
  }

  state.loadedOntologies = loadedOntologies;
  state.seriesData = buildSeriesData(loadedOntologies, seriesRegistry);
  state.subSeriesData = buildSubSeriesData(seriesRegistry, loadedOntologies);

  const mergedGraph = buildMergedGraph(loadedOntologies);
  state.mergedGraph = mergedGraph;

  const crossEdges = detectCrossReferences(loadedOntologies, mergedGraph);
  state.crossEdges = crossEdges;
  state.crossSeriesEdges = buildCrossSeriesEdges(crossEdges, loadedOntologies);
  state.bridgeNodes = detectBridgeNodes(crossEdges, loadedOntologies, 3);

  dropZone.classList.add('hidden');
  const regVer = registryMeta?.version && registryMeta.version !== 'unknown' ? ` v${registryMeta.version}` : '';
  fileNameEl.textContent = `Remote Registry${regVer} (${loaded} loaded, ${placeholders} placeholders)`;
  statsEl.textContent = '';

  const detailEl = document.getElementById('registry-version-detail');
  if (detailEl && registryMeta) {
    detailEl.textContent = `(updated ${registryMeta.lastUpdated})`;
    detailEl.title = `Registry v${registryMeta.version} | OAA ${registryMeta.oaaVersion} | ${registryMeta.totalEntries} entries`;
    detailEl.style.display = '';
  }

  state.multiOntologyScores = computeMultiOntologyScores(loadedOntologies);
  navigateToTier0();
  renderComparisonTable(state.multiOntologyScores);

  // Auto-detect DS-ONT and populate brand dropdown (non-blocking)
  populateDSBrandDropdown().catch(err =>
    console.warn('[DS] Auto-detect failed:', err.message)
  );

  // Load app skeleton instance data (non-blocking)
  loadAppSkeleton().catch(err =>
    console.warn('[Skeleton] Auto-load failed:', err.message)
  );
}

// Build seriesData map from loadedOntologies
function buildSeriesData(loadedOntologies, seriesRegistry) {
  const seriesData = {};
  for (const [ns, record] of loadedOntologies) {
    const series = record.series || 'Other';
    if (!seriesData[series]) {
      const info = seriesRegistry?.[series] || {};
      seriesData[series] = {
        name: info.name || series,
        color: SERIES_COLORS[series] || SERIES_COLORS.placeholder,
        count: 0,
        ontologies: [],
        placeholders: 0
      };
    }
    seriesData[series].count++;
    seriesData[series].ontologies.push(ns);
    if (record.isPlaceholder) seriesData[series].placeholders++;
  }
  return seriesData;
}

// ========================================
// RECENT FILES UI (Epic 5 — Story 5.3.2)
// ========================================

function timeAgo(isoString) {
  const diff = Date.now() - new Date(isoString).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d ago`;
  return `${Math.floor(days / 30)}mo ago`;
}

function renderRecentFiles() {
  const container = document.getElementById('library-content');
  if (!container) return;
  const bookmarks = getBookmarks();
  const recent = getRecentFiles();

  if (bookmarks.length === 0 && recent.length === 0) {
    container.innerHTML = '<p class="library-empty">No recent files.<br>Load an ontology to see it here.</p>';
    return;
  }

  let html = '';

  // Favorites section
  if (bookmarks.length > 0) {
    html += '<h4 style="color:#fcd34d; font-size:12px; margin:0 0 8px;">\u2605 Favorites</h4>';
    html += '<div class="recent-list">';
    bookmarks.forEach((item, i) => {
      const subtitle = item.url || item.path || item.source || '';
      html += `<div class="recent-item" onclick="reloadBookmark(${i})" title="${escapeHtml(subtitle)}">
        <span class="recent-icon" style="color:#fcd34d;">\u2605</span>
        <div class="recent-info">
          <div class="recent-name">${escapeHtml(item.name || 'Untitled')}</div>
          <div class="recent-meta">${escapeHtml(item.source || '')}</div>
        </div>
        <button class="bookmark-remove" onclick="event.stopPropagation(); removeBookmarkByIndex(${i})" title="Remove">&times;</button>
      </div>`;
    });
    html += '</div>';
    html += '<hr style="border-color:#2a2d37; margin:12px 0;">';
  }

  // Recent files section
  if (recent.length > 0) {
    html += '<h4 style="color:#888; font-size:12px; margin:0 0 8px;">Recent</h4>';
    const sourceIcons = { file: '\u{1F4C4}', github: '\u{1F419}', url: '\u{1F310}', registry: '\u{1F4DA}' };
    html += '<div class="recent-list">';
    recent.forEach((item, i) => {
      const icon = sourceIcons[item.source] || '\u{1F4C4}';
      const age = timeAgo(item.timestamp);
      const subtitle = item.url || item.path || item.source;
      html += `<div class="recent-item" onclick="reloadRecent(${i})" title="${escapeHtml(subtitle)}">
        <span class="recent-icon">${icon}</span>
        <div class="recent-info">
          <div class="recent-name">${escapeHtml(item.name || 'Untitled')}</div>
          <div class="recent-meta">${escapeHtml(item.source || '')} \u00B7 ${age}</div>
        </div>
      </div>`;
    });
    html += '</div>';
    html += '<button class="oaa-btn oaa-btn-secondary" style="margin-top:12px; font-size:11px; padding:6px 10px;" onclick="doClearRecentFiles()">Clear History</button>';
  }

  container.innerHTML = html;
}

function reloadRecent(index) {
  const recent = getRecentFiles();
  const item = recent[index];
  if (!item) return;

  if (item.source === 'url' && item.url) {
    const input = document.getElementById('url-input');
    if (input) input.value = item.url;
    showURLModal();
    if (input) input.value = item.url;
    loadFromURL();
  } else if (item.source === 'registry' && item.path) {
    loadOntologyFromPanel(item.path);
  } else if (item.source === 'github' && item.path) {
    alert('To reload from GitHub, use "Load from GitHub" and enter:\n' + item.path);
  } else {
    alert('To reload this file, use the file picker or drag-and-drop.');
  }
}

function doClearRecentFiles() {
  clearRecentFiles();
  renderRecentFiles();
}

// ========================================
// BOOKMARKS / FAVORITES (Epic 5 — Story 5.3.3)
// ========================================

function getCurrentBookmarkKey() {
  // Build a key from the currently loaded ontology metadata
  if (state.lastParsed?.sourceURL) return state.lastParsed.sourceURL;
  const name = document.getElementById('file-name')?.textContent;
  return name || null;
}

function toggleBookmark() {
  const key = getCurrentBookmarkKey();
  if (!key) return;
  if (isBookmarked(key)) {
    removeBookmark(key);
  } else {
    const parsed = state.lastParsed;
    addBookmark({
      name: parsed?.name || key,
      source: state.lastParsed?.sourceURL ? 'url' : (state.currentRegistryEntry ? 'registry' : 'file'),
      url: state.lastParsed?.sourceURL || undefined,
      path: state.currentRegistryEntry?.namespace || document.getElementById('file-name')?.textContent,
      format: parsed?.diagnostics?.format
    });
  }
  updateBookmarkStar();
  // Refresh recent tab if visible
  if (state.libraryView === 'recent') renderRecentFiles();
}

function updateBookmarkStar() {
  const el = document.getElementById('bookmark-toggle');
  if (!el) return;
  const key = getCurrentBookmarkKey();
  if (!key) { el.style.display = 'none'; return; }
  el.style.display = 'inline';
  const bookmarked = isBookmarked(key);
  el.textContent = bookmarked ? '\u2605' : '\u2606';
  el.style.color = bookmarked ? '#fcd34d' : '#666';
  el.title = bookmarked ? 'Remove bookmark' : 'Bookmark this ontology';
}

function reloadBookmark(index) {
  const bookmarks = getBookmarks();
  const item = bookmarks[index];
  if (!item) return;
  if (item.source === 'url' && item.url) {
    const input = document.getElementById('url-input');
    if (input) input.value = item.url;
    showURLModal();
    if (input) input.value = item.url;
    loadFromURL();
  } else if (item.source === 'registry' && item.path) {
    loadOntologyFromPanel(item.path);
  } else {
    alert('To reload this file, use the file picker or drag-and-drop.');
  }
}

function removeBookmarkByIndex(index) {
  const bookmarks = getBookmarks();
  const item = bookmarks[index];
  if (!item) return;
  const key = item.url || item.path || item.name;
  removeBookmark(key);
  updateBookmarkStar();
  renderRecentFiles();
}

// ========================================
// LIBRARY ORCHESTRATION (needs renderGraph + library CRUD)
// ========================================

function toggleLibrary() {
  const panel = document.getElementById('library-panel');
  const isOpen = panel.classList.toggle('open');
  if (isOpen) {
    switchLibraryView(state.libraryView || 'registry');
  }
}

function switchLibraryView(view) {
  state.libraryView = view;
  document.querySelectorAll('.library-view-tab').forEach(tab => {
    tab.classList.toggle('active', tab.dataset.view === view);
  });

  const content = document.getElementById('library-content');
  const depGraph = document.getElementById('library-dep-graph');
  const savedActions = document.getElementById('library-saved-actions');
  const search = document.getElementById('library-search');
  const filterChips = document.getElementById('library-filter-chips');

  if (view === 'registry') {
    content.style.display = 'block';
    depGraph.style.display = 'none';
    savedActions.style.display = 'none';
    search.style.display = 'block';
    if (filterChips) filterChips.style.display = '';  // let updateFilterChips control visibility
    renderRegistryLibrary();
  } else if (view === 'deps') {
    content.style.display = 'none';
    savedActions.style.display = 'none';
    search.style.display = 'none';
    if (filterChips) filterChips.style.display = 'none';
    renderLibraryDepGraph();
  } else if (view === 'recent') {
    content.style.display = 'block';
    depGraph.style.display = 'none';
    savedActions.style.display = 'none';
    search.style.display = 'none';
    if (filterChips) filterChips.style.display = 'none';
    renderRecentFiles();
  } else {
    content.style.display = 'block';
    depGraph.style.display = 'none';
    savedActions.style.display = 'flex';
    search.style.display = 'none';
    if (filterChips) filterChips.style.display = 'none';
    refreshLibraryPanel();
  }
}

async function renderRegistryLibrary() {
  const content = document.getElementById('library-content');

  if (!state.registryIndex) {
    const { loadRegistryIndex } = await import('./github-loader.js');
    content.innerHTML = '<div class="registry-loading"><div class="spinner"></div>Loading registry...</div>';
    await loadRegistryIndex();
  }

  if (!state.registryIndex?.entries) {
    content.innerHTML = '<p class="library-empty">Registry not available. Try "Load Registry" first.</p>';
    return;
  }

  const seriesRegistry = state.registryIndex.seriesRegistry || {};
  const seriesOrder = ['VE-Series', 'PE-Series', 'Foundation', 'Competitive', 'RCSG-Series', 'Orchestration'];

  // Group entries by series
  const groups = {};
  for (const series of seriesOrder) groups[series] = [];

  for (const entry of state.registryIndex.entries) {
    const series = resolveSeriesForOntology(entry.name, seriesRegistry);
    if (!groups[series]) groups[series] = [];
    groups[series].push(entry);
  }

  // F40.16: Discover processes and applications from loaded entries
  if (state.loadedOntologies?.size > 0) {
    state.discoveredProcesses = discoverProcesses(state.loadedOntologies);
    state.discoveredApplications = discoverApplications(
      state.loadedOntologies, state.appSkeleton, state.zoneRegistry, state.navLayerRegistry
    );
  }
  const processParentNs = new Set(state.discoveredProcesses.map(p => p.parentNs));
  const appParentNs = new Set(state.discoveredApplications.map(a => a.parentNs));
  updateFilterChips();

  const activeFilter = state.libraryFilter || 'all';

  let html = '';

  // Registry metadata summary card
  const meta = state.registryMeta;
  if (meta) {
    html += '<div class="registry-meta-card" style="margin-bottom:12px; padding:10px 12px; background:rgba(40,40,60,0.5); border:1px solid #444; border-radius:6px; font-size:12px;">';
    html += `<div style="display:flex; justify-content:space-between; margin-bottom:4px;"><span style="color:#aaa;">Registry Version</span><span style="color:#e0e0e0;"><strong>v${escapeHtml(meta.version)}</strong></span></div>`;
    html += `<div style="display:flex; justify-content:space-between; margin-bottom:4px;"><span style="color:#aaa;">OAA Version</span><span style="color:#e0e0e0;">${escapeHtml(meta.oaaVersion)}</span></div>`;
    html += `<div style="display:flex; justify-content:space-between; margin-bottom:4px;"><span style="color:#aaa;">Last Updated</span><span style="color:#e0e0e0;">${escapeHtml(meta.lastUpdated)}</span></div>`;
    html += `<div style="display:flex; justify-content:space-between;"><span style="color:#aaa;">Total Entries</span><span style="color:#e0e0e0;">${meta.totalEntries}</span></div>`;
    if (meta.warnings.length > 0) {
      html += '<div style="margin-top:8px; padding:6px 8px; background:rgba(85,48,22,0.3); border:1px solid #834a22; border-radius:4px; font-size:11px; color:#ffb48e;">';
      html += '<strong>Warnings:</strong><br>';
      meta.warnings.forEach(w => { html += escapeHtml(w) + '<br>'; });
      html += '</div>';
    }
    html += '</div>';
  }

  for (const series of seriesOrder) {
    const entries = groups[series];
    if (!entries || entries.length === 0) continue;

    // F40.16: Filter series based on active filter
    if (activeFilter === 'processes') {
      const hasProcess = entries.some(e => processParentNs.has(e.namespace || ''));
      if (!hasProcess) continue;
    }
    if (activeFilter === 'applications') {
      const hasApp = entries.some(e => appParentNs.has(e.namespace || ''));
      if (!hasApp) continue;
    }

    const color = SERIES_COLORS[series] || SERIES_COLORS.placeholder;
    const seriesInfo = seriesRegistry[series];
    const seriesLabel = seriesInfo?.name || series;

    // S9C.1.3: Compute series-level summary metrics
    const compliantCount = entries.filter(e => e.status === 'compliant' || e.status === 'proposal').length;
    const deprecatedCount = entries.filter(e => e.status === 'deprecated' || e.status === 'superseded').length;
    const placeholderCount = entries.filter(e => e.status === 'placeholder').length;
    let totalEntities = 0;
    let loadedCount = 0;
    let avgCompleteness = null;
    let completenessSum = 0;
    let completenessN = 0;

    for (const entry of entries) {
      const ns = entry.namespace || '';
      const record = state.loadedOntologies?.get(ns);
      if (record) {
        loadedCount++;
        if (record.parsed?.nodes) totalEntities += record.parsed.nodes.length;
        if (record.completenessScore != null) {
          completenessSum += record.completenessScore;
          completenessN++;
        }
      }
    }
    if (completenessN > 0) avgCompleteness = Math.round(completenessSum / completenessN);

    // Series summary card
    const compliantPct = entries.length > 0 ? Math.round((compliantCount / entries.length) * 100) : 0;
    const compColor = compliantPct === 100 ? '#86efac' : compliantPct >= 50 ? '#FFB48E' : '#fca5a5';

    html += `<div class="library-series" data-series="${series}">`;

    html += `<div class="library-series-card" onclick="drillToSeries('${series}')" title="Click to view ${seriesLabel} in graph">`;
    html += `<div class="library-series-card-top">`;
    html += `<span class="library-series-dot" style="background:${color}"></span>`;
    html += `<span class="library-series-card-name">${seriesLabel}</span>`;
    html += `</div>`;

    html += `<div class="library-series-card-metrics">`;
    html += `<div class="library-series-metric"><span class="library-series-metric-value">${compliantCount}</span><span class="library-series-metric-label">Compliant</span></div>`;
    html += `<div class="library-series-metric"><span class="library-series-metric-value">${deprecatedCount || placeholderCount}</span><span class="library-series-metric-label">${deprecatedCount ? 'Deprecated' : 'Placeholder'}</span></div>`;
    html += `<div class="library-series-metric"><span class="library-series-metric-value">${totalEntities || '\u2014'}</span><span class="library-series-metric-label">Entities</span></div>`;
    html += `<div class="library-series-metric"><span class="library-series-metric-value" style="color:${avgCompleteness != null ? compColor : 'var(--viz-text-muted)'}">${avgCompleteness != null ? avgCompleteness + '%' : '\u2014'}</span><span class="library-series-metric-label">Completeness</span></div>`;
    html += `</div>`;

    // Compliance bar
    html += `<div class="library-series-card-bar">`;
    html += `<div class="library-series-card-bar-fill" style="width:${compliantPct}%; background:${color};"></div>`;
    html += `</div>`;

    if (seriesInfo?.description) {
      const desc = seriesInfo.description.length > 90 ? seriesInfo.description.slice(0, 90) + '...' : seriesInfo.description;
      html += `<div class="library-series-desc">${escapeHtml(desc)}</div>`;
    }
    html += `</div>`;

    // Collapsible ontology list header — auto-expand when filtered
    const isFiltered = activeFilter !== 'all';
    html += `<div class="library-series-header" onclick="toggleSeriesExpand(this)">`;
    html += `<span style="font-size:10px; transition:transform 0.15s;${isFiltered ? ' transform:rotate(90deg);' : ''}" class="library-series-chevron">\u25B6</span>`;
    html += `<span>Ontologies</span>`;
    html += `<span class="library-series-count">${entries.length}</span>`;
    html += `</div>`;

    html += `<div class="library-series-items" style="display:${isFiltered ? 'block' : 'none'};">`;
    for (const entry of entries) {
      const ns = entry.namespace || '';
      const hasProcesses = processParentNs.has(ns);
      const hasApps = appParentNs.has(ns);

      // F40.16: Skip items that don't match active filter
      if (activeFilter === 'processes' && !hasProcesses) continue;
      if (activeFilter === 'applications' && !hasApps) continue;

      const isLoaded = state.loadedOntologies?.has(ns);
      const entryStatus = entry.status || 'compliant';
      const isPlaceholder = entryStatus === 'placeholder';
      const isDeprecated = entryStatus === 'deprecated';
      const isSuperseded = entryStatus === 'superseded';
      const isProposal = entryStatus === 'proposal';
      const shortName = entry.name.replace(/\s+Ontology.*$/i, '').replace(/\s*\(.*\)$/, '').replace(/\s*\[.*\]$/, '');

      let itemClass = 'library-item library-item--draggable';
      if (isPlaceholder) itemClass += ' library-item--placeholder';
      if (isDeprecated || isSuperseded) itemClass += ' library-item--deprecated';
      if (isLoaded) itemClass += ' library-item--loaded';

      const badgeClass = isDeprecated ? 'deprecated' : isSuperseded ? 'superseded' : isPlaceholder ? 'placeholder' : isProposal ? 'proposal' : 'compliant';
      const badgeLabel = isDeprecated ? 'deprecated' : isSuperseded ? 'superseded' : isPlaceholder ? 'placeholder' : isProposal ? 'proposal' : 'compliant';

      html += `<div class="${itemClass}" draggable="true" data-namespace="${ns}" data-name="${escapeHtml(entry.name)}" data-has-processes="${hasProcesses}" data-has-applications="${hasApps}"
        ondragstart="onLibraryDragStart(event, '${ns}')" onclick="loadOntologyFromPanel('${ns}')">`;
      html += `<div class="library-item-header">`;
      html += `<span class="library-item-name">${escapeHtml(shortName)}</span>`;
      html += `<span class="library-item-badge ${badgeClass}">${badgeLabel}</span>`;
      html += `</div>`;
      html += `<div class="library-item-meta"><span>${ns}</span></div>`;
      if ((isDeprecated || isSuperseded) && entry.deprecationReason) {
        html += `<div class="library-item-deprecation">${escapeHtml(entry.deprecationReason)}</div>`;
      }
      if (entry.description) {
        const desc = entry.description.length > 80 ? entry.description.slice(0, 80) + '...' : entry.description;
        html += `<div class="library-item-desc">${escapeHtml(desc)}</div>`;
      }
      html += `</div>`;

      // F40.16: Inject process cards after matching ontology item
      if ((activeFilter === 'all' || activeFilter === 'processes') && hasProcesses) {
        for (const proc of state.discoveredProcesses) {
          if (proc.parentNs !== ns) continue;
          const autoClass = proc.instances.length >= 3 ? 'automation-high' : 'automation-low';
          const autoLabel = proc.instances.length >= 3 ? `${proc.instanceCount} instances` : `${proc.instanceCount} instance`;
          html += `<div class="library-process-card">`;
          html += `<div class="library-process-header">`;
          html += `<span class="library-process-id">${escapeHtml(proc.processId)}</span>`;
          html += `<span class="library-process-badge ${autoClass}">${escapeHtml(autoLabel)}</span>`;
          html += `</div>`;
          html += `<div class="library-process-name">${escapeHtml(proc.name)}</div>`;
          html += `<div class="library-process-meta">${escapeHtml(proc.parentName)}</div>`;
          html += `</div>`;
        }
      }

      // F40.16: Inject application cards after matching ontology item
      if ((activeFilter === 'all' || activeFilter === 'applications') && hasApps) {
        for (const app of state.discoveredApplications) {
          if (app.parentNs !== ns) continue;
          const tierClass = app.cascadeTier === 'PFC' ? 'tier-pfc' : 'tier-pfi';
          let metaParts = [`v${app.version}`, app.status];
          if (app.zones != null) metaParts.push(`${app.zones} zones`);
          if (app.navLayers != null) metaParts.push(`${app.navLayers} nav layers`);
          if (app.components != null) metaParts.push(`${app.components} components`);
          html += `<div class="library-app-card">`;
          html += `<div class="library-app-header">`;
          html += `<span class="library-app-name">${escapeHtml(app.appName)}</span>`;
          html += `<span class="library-app-badge ${tierClass}">${escapeHtml(app.cascadeTier)}</span>`;
          html += `</div>`;
          html += `<div class="library-app-meta">${escapeHtml(metaParts.join(' \u00b7 '))}</div>`;
          html += `</div>`;
        }
      }
    }
    html += `</div>`;

    html += `</div>`;
  }

  content.innerHTML = html;
}

function toggleSeriesExpand(headerEl) {
  const items = headerEl.nextElementSibling;
  const chevron = headerEl.querySelector('.library-series-chevron');
  if (!items) return;
  const isOpen = items.style.display !== 'none';
  items.style.display = isOpen ? 'none' : 'block';
  if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(90deg)';
}

function filterLibraryEntries(query) {
  const q = query.toLowerCase().trim();
  const seriesGroups = document.querySelectorAll('#library-content .library-series');

  for (const group of seriesGroups) {
    const seriesKey = group.dataset.series?.toLowerCase() || '';
    const items = group.querySelectorAll('.library-item');
    let anyVisible = false;

    for (const item of items) {
      const name = item.dataset.name?.toLowerCase() || '';
      const ns = item.dataset.namespace?.toLowerCase() || '';
      const matches = !q || name.includes(q) || ns.includes(q) || seriesKey.includes(q);
      item.style.display = matches ? '' : 'none';
      if (matches) anyVisible = true;
    }

    group.style.display = anyVisible ? '' : 'none';
  }
}

// F40.16: Filter chip management
function setLibraryFilter(filter) {
  state.libraryFilter = filter;
  document.querySelectorAll('.library-filter-chip').forEach(chip => {
    chip.classList.toggle('active', chip.dataset.filter === filter);
  });
  renderRegistryLibrary();
}

function updateFilterChips() {
  const chipsEl = document.getElementById('library-filter-chips');
  if (!chipsEl) return;

  const procCount = state.discoveredProcesses?.length || 0;
  const appCount = state.discoveredApplications?.length || 0;

  // Show chips if anything was discovered
  chipsEl.style.display = (procCount > 0 || appCount > 0) ? 'flex' : 'none';

  const procCountEl = document.getElementById('process-count');
  const appCountEl = document.getElementById('app-count');
  if (procCountEl) procCountEl.textContent = procCount;
  if (appCountEl) appCountEl.textContent = appCount;
}

async function loadOntologyFromPanel(namespace) {
  if (!namespace) return;

  try {
    const record = await loadSingleOntologyFromRegistry(namespace);
    if (record.isPlaceholder) {
      showPlaceholderDetails(namespace);
      return;
    }

    state.viewMode = 'single';
    resetNavigation();
    state.currentData = record.rawData;
    document.getElementById('file-name').textContent = record.name;
    renderGraph(record.parsed);
    document.getElementById('drop-zone').classList.add('hidden');
    refreshLibraryLoadedState();
    addRecentFile({ name: record.name, source: 'registry', path: namespace, format: record.parsed?.diagnostics?.format });
  } catch (err) {
    alert('Failed to load ontology: ' + err.message);
  }
}

function refreshLibraryLoadedState() {
  document.querySelectorAll('.library-item--draggable').forEach(el => {
    const ns = el.dataset.namespace;
    if (ns && state.loadedOntologies?.has(ns)) {
      el.classList.add('library-item--loaded');
    } else {
      el.classList.remove('library-item--loaded');
    }
  });
}

// Drag-to-add from Library (Epic 2 — Story #71)

function onLibraryDragStart(event, namespace) {
  event.dataTransfer.setData('application/x-ontology-namespace', namespace);
  event.dataTransfer.effectAllowed = 'copy';
}

function setupLibraryDragDrop() {
  const networkEl = document.getElementById('network');

  networkEl.addEventListener('dragover', (e) => {
    if (e.dataTransfer.types.includes('application/x-ontology-namespace')) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'copy';
      networkEl.classList.add('drop-target-active');
    }
  });

  networkEl.addEventListener('dragleave', () => {
    networkEl.classList.remove('drop-target-active');
  });

  networkEl.addEventListener('drop', async (e) => {
    e.preventDefault();
    networkEl.classList.remove('drop-target-active');

    const namespace = e.dataTransfer.getData('application/x-ontology-namespace');
    if (!namespace) return;

    await loadOntologyFromPanel(namespace);
  });

  // Mindmap canvas drag-drop (F9F.8)
  const mmNetworkEl = document.getElementById('mindmap-network');
  if (mmNetworkEl) {
    mmNetworkEl.addEventListener('dragover', (e) => {
      if (e.dataTransfer.types.includes('application/x-ontology-namespace')) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'copy';
        mmNetworkEl.classList.add('drop-target-active');
      }
    });

    mmNetworkEl.addEventListener('dragleave', () => {
      mmNetworkEl.classList.remove('drop-target-active');
    });

    mmNetworkEl.addEventListener('drop', async (e) => {
      e.preventDefault();
      mmNetworkEl.classList.remove('drop-target-active');

      const namespace = e.dataTransfer.getData('application/x-ontology-namespace');
      if (!namespace || !state.mindmapMode) return;

      // Convert drop position to canvas coordinates
      const rect = mmNetworkEl.getBoundingClientRect();
      const domX = e.clientX - rect.left;
      const domY = e.clientY - rect.top;
      let canvasPos = { x: domX, y: domY };
      if (state.mindmapNetwork) {
        canvasPos = state.mindmapNetwork.DOMtoCanvas({ x: domX, y: domY });
      }

      // Build a minimal entity from the namespace
      const entity = {
        label: namespace.split('/').pop() || namespace,
        '@id': namespace,
        entityType: 'default'
      };
      addOntologyRefNode(canvasPos.x, canvasPos.y, entity, namespace);
    });
  }
}

// Dependency Graph (Epic 2 — Story #72)

async function renderLibraryDepGraph() {
  const container = document.getElementById('library-dep-graph');
  container.style.display = 'block';

  if (!state.registryIndex) {
    const { loadRegistryIndex } = await import('./github-loader.js');
    container.innerHTML = '<p class="library-empty" style="padding:180px 16px;">Loading registry...</p>';
    await loadRegistryIndex();
  }

  if (!state.registryIndex?.entries) {
    container.innerHTML = '<p class="library-empty" style="padding:180px 16px;">Registry not available.</p>';
    return;
  }

  container.innerHTML = '';
  const seriesRegistry = state.registryIndex.seriesRegistry || {};

  // Build nodes
  const visNodes = [];
  for (const entry of state.registryIndex.entries) {
    const ns = entry.namespace || entry['@id'];
    const series = resolveSeriesForOntology(entry.name, seriesRegistry);
    const color = SERIES_COLORS[series] || SERIES_COLORS.placeholder;
    const shortName = entry.name.replace(/\s+Ontology.*$/i, '').replace(/\s*\(.*\)$/, '');
    const isPlaceholder = entry.status === 'placeholder';

    visNodes.push({
      id: ns,
      label: shortName,
      color: {
        background: isPlaceholder ? SERIES_COLORS.placeholder : color,
        border: isPlaceholder ? '#888' : color,
        highlight: { background: '#9dfff5', border: '#017c75' }
      },
      font: { color: '#e0e0e0', size: 11 },
      shape: isPlaceholder ? 'diamond' : 'dot',
      size: 16,
      shapeProperties: { borderDashes: isPlaceholder ? [4, 2] : false },
      title: `${entry.name}\n${series}\n${entry.status}`
    });
  }

  // Build edges — use cross-edges if available, otherwise fall back to registry dependencies
  const visEdges = [];
  const edgeKeys = new Set();

  if (state.crossEdges?.length > 0) {
    // Aggregate entity-level cross-edges to ontology-level
    const ontEdges = new Map();
    for (const edge of state.crossEdges) {
      const fromNs = edge.sourceNamespace;
      const targetNs = edge.targetNamespace || inferNamespace(edge.to);
      if (!targetNs || fromNs === targetNs) continue;
      const key = [fromNs, targetNs].sort().join('<>');
      ontEdges.set(key, (ontEdges.get(key) || 0) + 1);
    }

    for (const [key, count] of ontEdges) {
      const [from, to] = key.split('<>');
      visEdges.push({
        from, to,
        label: String(count),
        color: { color: '#eab839', highlight: '#FFF176' },
        font: { color: '#eab839', size: 9, strokeWidth: 1, strokeColor: '#0f1117' },
        width: Math.min(1 + count * 0.3, 4),
        smooth: { type: 'continuous', roundness: 0.3 }
      });
    }
  }

  // Also add declared dependencies from registry entries
  if (state.loadedOntologies?.size > 0) {
    const entryIdToNs = new Map();
    for (const [ns, record] of state.loadedOntologies) {
      if (record.registryEntry?.['@id']) entryIdToNs.set(record.registryEntry['@id'], ns);
    }

    for (const [ns, record] of state.loadedOntologies) {
      const deps = record.registryEntry?.dependencies;
      if (!Array.isArray(deps)) continue;
      for (const depId of deps) {
        const targetNs = entryIdToNs.get(depId);
        if (!targetNs || targetNs === ns) continue;
        const key = `dep:${ns}->${targetNs}`;
        if (!edgeKeys.has(key)) {
          edgeKeys.add(key);
          visEdges.push({
            from: ns, to: targetNs,
            color: { color: '#888', highlight: '#ccc' },
            dashes: [4, 4],
            arrows: 'to',
            width: 1.5,
            smooth: { type: 'continuous', roundness: 0.3 },
            title: 'declared dependency'
          });
        }
      }
    }
  }

  const data = {
    nodes: new vis.DataSet(visNodes),
    edges: new vis.DataSet(visEdges)
  };

  const options = {
    physics: {
      enabled: true,
      stabilization: { iterations: 100 },
      barnesHut: { gravitationalConstant: -2000, springLength: 120, springConstant: 0.03 }
    },
    interaction: { hover: true, tooltipDelay: 200, dragNodes: true, zoomView: true },
    nodes: { borderWidth: 2 },
    edges: { smooth: { type: 'continuous', roundness: 0.3 } }
  };

  if (state.libraryDepNetwork) {
    state.libraryDepNetwork.destroy();
    state.libraryDepNetwork = null;
  }

  // Render after a frame to ensure container is visible
  requestAnimationFrame(() => {
    state.libraryDepNetwork = new vis.Network(container, data, options);

    state.libraryDepNetwork.once('stabilizationIterationsDone', () => {
      state.libraryDepNetwork.fit({ animation: true });
    });

    state.libraryDepNetwork.on('doubleClick', (params) => {
      if (params.nodes.length > 0) {
        const ns = params.nodes[0];
        loadOntologyFromPanel(ns);
        toggleLibrary();
      }
    });
  });
}

function inferNamespace(nodeId) {
  if (!nodeId) return null;
  const prefix = nodeId.split('::')[0];
  if (!prefix) return null;
  return prefix + ':';
}

async function refreshLibraryPanel() {
  const content = document.getElementById('library-content');

  try {
    const grouped = await getAllOntologies();
    let html = '';
    let hasAny = false;

    for (const [category, ontologies] of Object.entries(grouped)) {
      if (ontologies.length === 0) continue;
      hasAny = true;

      const displayCategory = category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
      html += `<div class="library-category">
        <h4>${displayCategory} (${ontologies.length})</h4>`;

      ontologies.forEach(ont => {
        const date = new Date(ont.updated).toLocaleDateString();
        const complianceClass = ont.compliance === 'pass' ? 'ok' : (ont.compliance === 'warn' ? 'warn' : 'fail');
        html += `
          <div class="library-item" onclick="loadFromLibrary(${ont.id})">
            <div class="library-item-header">
              <span class="library-item-name">${escapeHtml(ont.name)}</span>
              <span class="library-item-version">v${ont.version}</span>
            </div>
            <div class="library-item-meta">
              <span class="audit-badge ${complianceClass}">${ont.compliance}</span>
              <span>${date}</span>
            </div>
            <div class="library-item-actions" onclick="event.stopPropagation()">
              <button class="oaa-btn oaa-btn-secondary" onclick="showVersionHistory(${ont.id}, '${escapeHtml(ont.name)}')">History</button>
              <button class="oaa-btn oaa-btn-secondary" onclick="downloadOntology(${ont.id})">Download</button>
              <button class="oaa-btn oaa-btn-secondary" onclick="deleteOntology(${ont.id})" style="color:#fca5a5;">Delete</button>
            </div>
          </div>`;
      });

      html += '</div>';
    }

    if (!hasAny) {
      html = '<p class="library-empty">No ontologies saved yet.<br>Load an ontology and click "Save to Library" when it passes OAA v7.0.0 compliance.</p>';
    }

    content.innerHTML = html;
  } catch (err) {
    content.innerHTML = `<p class="library-empty" style="color:#fca5a5;">Error loading library: ${err.message}</p>`;
  }
}

async function loadFromLibrary(id) {
  try {
    const ontology = await loadOntologyFromLibrary(id);
    if (!ontology) {
      alert('Ontology not found in library');
      return;
    }

    state.viewMode = 'single';
    resetNavigation();
    state.currentData = ontology.data;
    document.getElementById('file-name').textContent = `${ontology.name} (v${ontology.version})`;

    const parsed = parseOntology(ontology.data, ontology.name);
    if (parsed.nodes.length === 0) {
      alert('No nodes parsed from saved ontology');
      return;
    }

    renderGraph(parsed);
    document.getElementById('drop-zone').classList.add('hidden');
    updateBookmarkStar();
    toggleLibrary();

  } catch (err) {
    alert('Error loading from library: ' + err.message);
  }
}

async function doSaveToLibrary() {
  const name = document.getElementById('save-ont-name').value.trim();
  const category = document.getElementById('save-ont-category').value;
  const version = document.getElementById('save-ont-version').value.trim();
  const notes = document.getElementById('save-ont-notes').value.trim();
  const resultDiv = document.getElementById('save-result');

  if (!name) {
    resultDiv.innerHTML = '<p style="color:#fca5a5; font-size:12px;">Name is required</p>';
    return;
  }

  try {
    const result = await saveOntologyToLibrary(state.currentData, name, category, version, notes);

    resultDiv.innerHTML = `
      <div class="save-success">
        \u2713 Saved ${result.isUpdate ? 'updated' : 'new'} ontology: <strong>${name}</strong> v${result.version}
        ${result.isUpdate ? `<br><small>Previous version ${result.previousVersion} archived</small>` : ''}
      </div>
    `;

    document.getElementById('file-name').textContent = `${name} (v${result.version})`;

    if (document.getElementById('library-panel').classList.contains('open')) {
      refreshLibraryPanel();
    }

    setTimeout(() => {
      closeSaveLibraryModal();
    }, 1500);

  } catch (err) {
    resultDiv.innerHTML = `<p style="color:#fca5a5; font-size:12px;">Error saving: ${err.message}</p>`;
  }
}

async function restoreVersion(versionId) {
  try {
    const version = await getVersionById(versionId);
    if (version) {
      state.currentData = version.data;
      document.getElementById('file-name').textContent = `Restored v${version.version}`;

      const parsed = parseOntology(version.data, `Restored v${version.version}`);
      renderGraph(parsed);
      document.getElementById('drop-zone').classList.add('hidden');
      closeSaveLibraryModal();
      toggleLibrary();
    }
  } catch (err) {
    alert('Error restoring version: ' + err.message);
  }
}

async function downloadOntology(id) {
  try {
    const ontology = await loadOntologyFromLibrary(id);
    const blob = new Blob([JSON.stringify(ontology.data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${ontology.name}-v${ontology.version}.json`;
    a.click();
    URL.revokeObjectURL(url);
  } catch (err) {
    alert('Error downloading: ' + err.message);
  }
}

async function deleteOntology(id) {
  if (!confirm('Delete this ontology and its version history?')) return;

  try {
    await deleteFromLibrary(id);
    refreshLibraryPanel();
  } catch (err) {
    alert('Error deleting: ' + err.message);
  }
}

async function exportLibrary() {
  try {
    const exportData = await exportLibraryData();

    const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `ontology-library-${new Date().toISOString().split('T')[0]}.json`;
    a.click();
    URL.revokeObjectURL(url);

  } catch (err) {
    alert('Error exporting library: ' + err.message);
  }
}

function importLibrary() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';

  input.onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = async (evt) => {
      try {
        const importData = JSON.parse(evt.target.result);
        const imported = await importLibraryData(importData);
        alert(`Imported ${imported} ontologies`);
        refreshLibraryPanel();
      } catch (err) {
        alert('Error importing library: ' + err.message);
      }
    };
    reader.readAsText(file);
  };

  input.click();
}

// ========================================
// MULTI-ONTOLOGY REGISTRY LOADING (Phase 1 + Phase 2)
// ========================================

async function loadRegistry() {
  console.log('[EMC] loadRegistry() called');
  const fileNameEl = document.getElementById('file-name');
  const statsEl = document.getElementById('stats');

  fileNameEl.textContent = 'Loading unified registry...';
  statsEl.textContent = 'Loading...';

  try {
    const { loadedOntologies, seriesData, subSeriesData, namespaceRegistry, stats, registryMeta } =
      await loadFullRegistry((msg, current, total) => {
        statsEl.textContent = msg;
      });

    state.loadedOntologies = loadedOntologies;
    state.seriesData = seriesData;
    state.subSeriesData = subSeriesData || null;
    state.viewMode = 'multi';

    const mergedGraph = buildMergedGraph(loadedOntologies);
    state.mergedGraph = mergedGraph;

    const crossEdges = detectCrossReferences(loadedOntologies, mergedGraph);
    state.crossEdges = crossEdges;

    // Build series-level edges for Tier 0
    state.crossSeriesEdges = buildCrossSeriesEdges(crossEdges, loadedOntologies);

    // Detect bridge nodes (entities referenced by 3+ ontologies)
    state.bridgeNodes = detectBridgeNodes(crossEdges, loadedOntologies, 3);
    console.log(`Bridge nodes detected: ${state.bridgeNodes.size}`);

    // Hide drop zone before navigation so errors don't leave it blocking the graph
    dropZone.classList.add('hidden');

    const regVer = registryMeta?.version && registryMeta.version !== 'unknown' ? ` v${registryMeta.version}` : '';
    fileNameEl.textContent = `Unified Registry${regVer} (${stats.total} ontologies, ${stats.placeholders} placeholders)`;

    const detailEl = document.getElementById('registry-version-detail');
    if (detailEl && registryMeta) {
      detailEl.textContent = `(updated ${registryMeta.lastUpdated})`;
      detailEl.title = `Registry v${registryMeta.version} | OAA ${registryMeta.oaaVersion} | ${registryMeta.totalEntries} entries`;
      detailEl.style.display = '';
    }

    // Compute multi-ontology comparison scores
    state.multiOntologyScores = computeMultiOntologyScores(loadedOntologies);
    console.log('Multi-ontology scores computed:', state.multiOntologyScores.length, 'ontologies');

    // Start at Tier 0 (series rollup) instead of flat entity view
    navigateToTier0();

    // Render comparison table in audit panel (available when audit is opened)
    renderComparisonTable(state.multiOntologyScores);

    console.log('Registry loaded:', stats);

    // Auto-detect DS-ONT and populate brand dropdown (non-blocking)
    populateDSBrandDropdown().catch(err =>
      console.warn('[DS] Auto-detect failed:', err.message)
    );

    // Load app skeleton instance data (non-blocking)
    loadAppSkeleton().catch(err =>
      console.warn('[Skeleton] Auto-load failed:', err.message)
    );

    // Load PFI instance configs and populate PFI dropdown (F8.4)
    loadPFIInstanceConfigs(state.registryIndex);
    populatePFIDropdown();
    _showContextControlsIfPFI();

    // Enable EMC nav bar PFI level now that instances are available
    initEMCNavBar();

  } catch (err) {
    alert('Failed to load registry: ' + err.message);
    fileNameEl.textContent = '';
    statsEl.textContent = '';
    console.error('Registry load error:', err);
  }
}

// ========================================
// TIER NAVIGATION (Phase 2)
// ========================================

function resetNavigation() {
  state.currentTier = -1;
  state.currentSeries = null;
  state.currentOntology = null;
  state.navigationStack = [];
  state.highlightedSeries.clear();
  state.crossEdgeFilterActive = false;
  _hide('breadcrumb');
  _hide('tier0-toggle');
  showSeriesControls(false);
}

function setActiveToggle(viewName) {
  const buttons = document.querySelectorAll('#tier0-toggle .tier-toggle');
  buttons.forEach(btn => {
    btn.classList.toggle('active', btn.dataset.view === viewName);
  });
}

function navigateToTier0() {
  state.currentTier = 0;
  state.currentSeries = null;
  state.currentSubSeries = null;
  state.currentOntology = null;
  state.viewMode = 'multi';
  state.bridgeFilterActive = false;
  state.navigationStack = [{ tier: 0, label: 'Library' }];

  renderTier0(state.seriesData, state.crossSeriesEdges);
  updateBreadcrumb();

  _show('tier0-toggle', 'inline-flex');
  setActiveToggle('series');
  _hide('bridge-filter');
  _hide('btn-run-oaa');
  _hide('btn-save-library');
  _hide('btn-export-audit');
  showSeriesControls(true);
  updateSeriesToggleUI();
  updateCrossEdgeFilterUI();
}

function drillToSeries(seriesKey) {
  state.currentTier = 1;
  state.currentSeries = seriesKey;
  state.currentSubSeries = null;
  state.currentOntology = null;
  state.viewMode = 'multi';
  state.navigationStack = [
    { tier: 0, label: 'Library' },
    { tier: 1, series: seriesKey, label: seriesKey }
  ];

  renderTier1(seriesKey, state.loadedOntologies, state.seriesData);
  updateBreadcrumb();

  _hide('tier0-toggle');
  showSeriesControls(true);
  updateSeriesToggleUI();
  updateCrossEdgeFilterUI();
}

function drillToOntology(namespace) {
  const record = state.loadedOntologies.get(namespace);
  if (!record || !record.parsed || record.isPlaceholder) return;

  state.currentTier = 2;
  state.currentOntology = namespace;
  const stack = [
    { tier: 0, label: 'Library' },
    { tier: 1, series: state.currentSeries, label: state.currentSeries }
  ];
  if (state.currentSubSeries) {
    stack.push({ tier: 1, series: state.currentSeries, subSeries: state.currentSubSeries, label: state.currentSubSeries });
  }
  stack.push({ tier: 2, ontology: namespace, label: record.name });
  state.navigationStack = stack;

  // Use single-ontology renderer for the entity graph
  // DR-SERIES-003: pass series context for border colour persistence through drill-through
  const series = record.series;
  const seriesColor = SERIES_COLORS[series] || SERIES_COLORS.placeholder;
  state.currentData = record.rawData;
  state.viewMode = 'single';
  renderGraph(record.parsed, { seriesKey: series, seriesColor });
  state.viewMode = 'multi';

  updateBreadcrumb();

  _hide('tier0-toggle');
  const fnEl = document.getElementById('file-name');
  if (fnEl) fnEl.textContent = record.name;
  showSeriesControls(false);
}

function drillToSubSeries(seriesKey, subSeriesKey) {
  state.currentTier = 1;
  state.currentSeries = seriesKey;
  state.currentSubSeries = subSeriesKey;
  state.currentOntology = null;
  state.viewMode = 'multi';
  state.navigationStack = [
    { tier: 0, label: 'Library' },
    { tier: 1, series: seriesKey, label: seriesKey },
    { tier: 1, series: seriesKey, subSeries: subSeriesKey, label: subSeriesKey }
  ];

  renderTier1SubSeries(seriesKey, subSeriesKey, state.loadedOntologies, state.seriesData);
  updateBreadcrumb();

  _hide('tier0-toggle');
  showSeriesControls(true);
  updateSeriesToggleUI();
  updateCrossEdgeFilterUI();
}

function navigateTo(stackIndex) {
  const item = state.navigationStack[stackIndex];
  if (!item) return;
  if (item.tier === 0) navigateToTier0();
  else if (item.tier === 1 && item.subSeries) drillToSubSeries(item.series, item.subSeries);
  else if (item.tier === 1) drillToSeries(item.series);
}

function navigateBack(targetTier) {
  const idx = state.navigationStack.findIndex(i => i.tier === targetTier);
  if (idx >= 0) navigateTo(idx);
}

// Navigate to an ontology by namespace (handles both loaded and placeholder)
function navigateToOntology(namespace) {
  if (!state.loadedOntologies) return;

  // Try direct namespace match
  let record = state.loadedOntologies.get(namespace);

  // If not found, try to find by entry ID
  if (!record) {
    for (const [ns, r] of state.loadedOntologies) {
      if (r.registryEntry && r.registryEntry['@id'] === namespace) {
        record = r;
        namespace = ns;
        break;
      }
    }
  }

  if (!record) {
    console.warn('Ontology not found:', namespace);
    return;
  }

  // Find the series for this ontology
  const targetSeries = record.series;

  if (record.isPlaceholder) {
    // Navigate to series then show placeholder details
    if (targetSeries && targetSeries !== state.currentSeries) {
      drillToSeries(targetSeries);
    }
    setTimeout(() => showPlaceholderDetails(namespace), 100);
  } else {
    // Navigate to series first if different
    if (targetSeries && targetSeries !== state.currentSeries) {
      state.currentSeries = targetSeries;
    }
    drillToOntology(namespace);
  }
}

// Show placeholder details in a modal
function showPlaceholderDetails(namespace) {
  const record = state.loadedOntologies?.get(namespace);
  if (!record) return;

  const entry = record.registryEntry || {};
  const modal = document.getElementById('oaa-modal');
  const body = document.getElementById('oaa-modal-body');

  let html = `<div class="placeholder-details">`;
  html += `<div class="placeholder-badge">PLACEHOLDER</div>`;
  html += `<h4>${entry.name || record.name}</h4>`;

  if (entry.description) {
    html += `<p class="placeholder-desc">${entry.description}</p>`;
  }

  if (entry.plannedComponents && Object.keys(entry.plannedComponents).length > 0) {
    html += `<div class="placeholder-section"><h5>Planned Components</h5><ul>`;
    for (const [key, value] of Object.entries(entry.plannedComponents)) {
      html += `<li><strong>${key}:</strong> ${value}</li>`;
    }
    html += `</ul></div>`;
  }

  if (entry.dependencies && entry.dependencies.length > 0) {
    html += `<div class="placeholder-section"><h5>Dependencies</h5><div class="dependency-links">`;
    entry.dependencies.forEach(depId => {
      const depNs = findNamespaceForEntryId(depId);
      const depRecord = depNs ? state.loadedOntologies.get(depNs) : null;
      const depName = depRecord?.name || depId.replace('Entry-ONT-', '').replace('-001', '');
      const isPlaceholder = depRecord?.isPlaceholder;
      html += `<span class="dep-link ${isPlaceholder ? 'placeholder' : ''}"
        onclick="closeOAAModal(); navigateToOntology('${depNs || depId}')">${depName}</span>`;
    });
    html += `</div></div>`;
  }

  if (entry.notes) {
    html += `<div class="placeholder-section"><h5>Notes</h5><p>${entry.notes}</p></div>`;
  }

  html += `<div class="placeholder-actions">
    <p style="color:#888; font-size:12px; margin-top:16px;">This ontology is a placeholder. The full ontology files have not yet been created.</p>
  </div>`;
  html += `</div>`;

  body.innerHTML = html;
  modal.style.display = 'flex';
}

// Helper to find namespace for entry ID
function findNamespaceForEntryId(entryId) {
  if (!state.loadedOntologies) return null;
  for (const [ns, record] of state.loadedOntologies) {
    if (record.registryEntry && record.registryEntry['@id'] === entryId) {
      return ns;
    }
  }
  return null;
}

function showAllOntologies() {
  state.currentTier = 0;
  state.currentSeries = null;
  state.viewMode = 'multi';
  state.bridgeFilterActive = false;
  state.navigationStack = [{ tier: 0, label: 'All Ontologies' }];

  renderMultiGraph(state.mergedGraph, state.crossEdges, state.seriesData);
  updateBreadcrumb();

  _show('tier0-toggle', 'inline-flex');
  setActiveToggle('ontologies');
  updateBridgeFilterUI();
  _show('bridge-filter', 'block');
  _hide('btn-run-oaa');
  _hide('btn-save-library');
  _hide('btn-export-audit');
  showSeriesControls(true);
  updateSeriesToggleUI();
  updateCrossEdgeFilterUI();
}

function showConnectionMap() {
  state.currentTier = 0;
  state.currentSeries = null;
  state.viewMode = 'multi';
  state.navigationStack = [{ tier: 0, label: 'Connection Map' }];

  renderConnectionMap(state.loadedOntologies, state.crossEdges, state.seriesData);
  updateBreadcrumb();

  _show('tier0-toggle', 'inline-flex');
  setActiveToggle('connections');
  _hide('bridge-filter');
  _hide('btn-run-oaa');
  _hide('btn-save-library');
  _hide('btn-export-audit');
  showSeriesControls(true);
  updateSeriesToggleUI();
  updateCrossEdgeFilterUI();
}

function toggleBridgeFilter() {
  state.bridgeFilterActive = !state.bridgeFilterActive;
  updateBridgeFilterUI();
  // Re-render the graph with the filter applied
  renderMultiGraph(state.mergedGraph, state.crossEdges, state.seriesData);
}

function updateBridgeFilterUI() {
  const btn = document.getElementById('btn-bridge-filter');
  const countEl = document.getElementById('bridge-count');
  const bridgeCount = state.bridgeNodes?.size || 0;

  if (countEl) countEl.textContent = bridgeCount;
  if (btn) btn.classList.toggle('active', state.bridgeFilterActive);
}

function updateBreadcrumb() {
  const bar = document.getElementById('breadcrumb');
  if (!bar) return;
  bar.style.display = state.navigationStack.length > 0 ? 'flex' : 'none';

  const tierIcons = ['\u25A6', '\u25C9', '\u25CF'];  // ▦ ◉ ●
  const subSeriesIcon = '\u25CE';  // ◎

  let html = '';
  state.navigationStack.forEach((item, i) => {
    const isLast = i === state.navigationStack.length - 1;
    const icon = item.subSeries ? subSeriesIcon : (tierIcons[item.tier] || '');
    let count = '';
    if (item.tier === 0 && state.seriesData) {
      count = ` (${Object.keys(state.seriesData).length} series)`;
    } else if (item.tier === 1 && item.subSeries && state.subSeriesData) {
      const ck = `${item.series}::${item.subSeries}`;
      const ss = state.subSeriesData[ck];
      count = ss ? ` (${ss.count} ontologies)` : '';
    } else if (item.tier === 1 && state.seriesData && item.series) {
      const sd = state.seriesData[item.series];
      count = sd ? ` (${sd.ontologies.length} ontologies)` : '';
    } else if (item.tier === 2 && item.ontology) {
      const rec = state.loadedOntologies.get(item.ontology);
      if (rec && rec.parsed) count = ` (${rec.parsed.nodes.length} entities)`;
    }
    if (isLast) {
      html += `<span class="breadcrumb-current"><span class="breadcrumb-icon">${icon}</span>${item.label}<span class="breadcrumb-count">${count}</span></span>`;
    } else {
      html += `<span class="breadcrumb-link" onclick="navigateTo(${i})"><span class="breadcrumb-icon">${icon}</span>${item.label}<span class="breadcrumb-count">${count}</span></span>`;
      html += `<span class="breadcrumb-sep">\u203A</span>`;
    }
  });
  const bp = document.getElementById('breadcrumb-path');
  if (bp) bp.innerHTML = html;

  updateTierGauge();
}

function updateTierGauge() {
  const gauge = document.getElementById('tier-depth-gauge');
  if (!gauge) return;

  if (state.currentTier < 0) {
    gauge.style.display = 'none';
    return;
  }
  gauge.style.display = 'inline-flex';

  gauge.querySelectorAll('.tier-level').forEach(el => {
    const tier = parseInt(el.dataset.tier, 10);
    el.classList.remove('active', 'completed', 'pending');
    if (tier === state.currentTier) {
      el.classList.add('active');
    } else if (tier < state.currentTier) {
      el.classList.add('completed');
    } else {
      el.classList.add('pending');
    }
  });
}

// ========================================
// SERIES HIGHLIGHT + CROSS-EDGE FILTER (Phase 2/4)
// ========================================

function toggleSeriesHighlight(seriesKey) {
  if (state.highlightedSeries.has(seriesKey)) {
    state.highlightedSeries.delete(seriesKey);
  } else {
    state.highlightedSeries.add(seriesKey);
  }
  updateSeriesToggleUI();
  rerenderCurrentView();
}

function toggleCrossEdgeFilter() {
  state.crossEdgeFilterActive = !state.crossEdgeFilterActive;
  updateCrossEdgeFilterUI();
  rerenderCurrentView();
}

// F40.22 S40.22.6: Toggle ghost (context) node visibility
function toggleGhostVisibility() {
  state.ghostNodesVisible = !state.ghostNodesVisible;
  try { localStorage.setItem('oaa-viz-ghost-visible', state.ghostNodesVisible ? '1' : '0'); } catch (_) { /* ignore */ }
  const btn = document.getElementById('ghost-toggle-btn');
  if (btn) btn.textContent = state.ghostNodesVisible ? 'Hide Ghosts' : 'Show Ghosts';
  rerenderCurrentView();
}

function rerenderCurrentView() {
  if (state.currentTier === 0) {
    // Check which Tier 0 view is active
    const activeToggle = document.querySelector('#tier0-toggle .tier-toggle.active');
    const view = activeToggle?.dataset.view;
    if (view === 'ontologies') showAllOntologies();
    else if (view === 'connections') showConnectionMap();
    else navigateToTier0();
  } else if (state.currentTier === 1 && state.currentSubSeries) {
    drillToSubSeries(state.currentSeries, state.currentSubSeries);
  } else if (state.currentTier === 1) {
    drillToSeries(state.currentSeries);
  }
  // Tier 2 (entity graph) doesn't have lineage highlighting
}

function updateSeriesToggleUI() {
  document.querySelectorAll('.series-toggle').forEach(btn => {
    const series = btn.dataset.series;
    btn.classList.toggle('active', state.highlightedSeries.has(series));
  });
}

function updateCrossEdgeFilterUI() {
  const btn = document.getElementById('btn-cross-edge-filter');
  if (btn) btn.classList.toggle('active', state.crossEdgeFilterActive);
}

function showSeriesControls(show) {
  const seriesToggle = document.getElementById('series-toggle');
  const crossEdgeFilter = document.getElementById('cross-edge-filter');
  if (seriesToggle) seriesToggle.style.display = show ? 'inline-flex' : 'none';
  if (crossEdgeFilter) crossEdgeFilter.style.display = show ? 'block' : 'none';
}

// ========================================
// MODAL EVENT LISTENERS
// ========================================

document.addEventListener('click', (e) => {
  const modal = document.getElementById('oaa-modal');
  if (e.target === modal) closeOAAModal();
  const urlModal = document.getElementById('url-modal');
  if (e.target === urlModal) closeURLModal();
  const ghModal = document.getElementById('github-modal');
  if (e.target === ghModal) closeGitHubModal();
  const ghSettings = document.getElementById('github-settings-modal');
  if (e.target === ghSettings) closeGitHubSettings();
  // Close any open dynamic nav dropdowns on outside click
  if (!e.target.closest('.nav-dropdown-wrapper')) {
    document.querySelectorAll('.nav-dropdown-menu').forEach(m => { m.style.display = 'none'; });
  }
});

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    closeOAAModal();
    closeSaveLibraryModal();
    closeURLModal();
    closeGitHubModal();
    closeGitHubSettings();
    _hide('diff-modal');
    // S8.8.3: dismiss context switch modal
    const csm = document.getElementById('context-switch-modal');
    if (csm && csm.style.display !== 'none') { cancelContextSwitch(); }
  }
});

// ========================================
// SERIES KEYBOARD NAVIGATION (Epic 9C — S9C.1.4)
// ========================================

document.addEventListener('keydown', (e) => {
  // Skip when typing in inputs/textareas or modals are open
  const tag = e.target.tagName;
  if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
  if (document.querySelector('.oaa-modal[style*="display: flex"]')) return;

  // Escape: navigate up one tier (if in multi-ontology mode)
  if (e.key === 'Escape' && state.viewMode === 'multi' && state.currentTier >= 0) {
    e.preventDefault();
    if (state.currentTier === 2 && state.currentSeries) {
      drillToSeries(state.currentSeries);
    } else if (state.currentTier === 1) {
      navigateToTier0();
    }
    return;
  }

  // Backspace: navigate up one tier (same as Escape but more discoverable)
  if (e.key === 'Backspace' && state.viewMode === 'multi' && state.currentTier >= 1) {
    e.preventDefault();
    if (state.currentTier === 2 && state.currentSeries) {
      drillToSeries(state.currentSeries);
    } else if (state.currentTier === 1) {
      navigateToTier0();
    }
    return;
  }

  // H: go Home (tier 0) when in multi-mode
  if (e.key === 'h' && !e.ctrlKey && !e.metaKey && state.viewMode === 'multi' && state.currentTier > 0) {
    navigateToTier0();
    return;
  }

  // L: toggle Library panel
  if (e.key === 'l' && !e.ctrlKey && !e.metaKey) {
    toggleLibrary();
    return;
  }

  // C: toggle Context drawer (S8.8.6)
  if (e.key === 'c' && !e.ctrlKey && !e.metaKey) {
    toggleContextDrawer();
    return;
  }

  // ?: show keyboard shortcut help overlay
  if (e.key === '?' && !e.ctrlKey && !e.metaKey) {
    showKeyboardHelp();
    return;
  }
});

function showKeyboardHelp() {
  const existing = document.getElementById('keyboard-help-overlay');
  if (existing) { existing.remove(); return; }

  const overlay = document.createElement('div');
  overlay.id = 'keyboard-help-overlay';
  overlay.style.cssText = 'position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:999; display:flex; align-items:center; justify-content:center; cursor:pointer;';
  overlay.onclick = () => overlay.remove();

  overlay.innerHTML = `<div style="background:var(--viz-surface-elevated, #1a1d27); border:1px solid var(--viz-border-default, #3a3d47); border-radius:12px; padding:24px 32px; max-width:420px; color:#e0e0e0;" onclick="event.stopPropagation()">
    <h3 style="color:#9dfff5; margin:0 0 16px;">Keyboard Shortcuts</h3>
    <table style="width:100%; font-size:13px; border-collapse:collapse;">
      <tr><td style="padding:4px 12px 4px 0; color:#888;">Esc</td><td>Navigate up one tier / close modal</td></tr>
      <tr><td style="padding:4px 12px 4px 0; color:#888;">Backspace</td><td>Navigate up one tier</td></tr>
      <tr><td style="padding:4px 12px 4px 0; color:#888;">H</td><td>Go Home (series overview)</td></tr>
      <tr><td style="padding:4px 12px 4px 0; color:#888;">L</td><td>Toggle Library panel</td></tr>
      <tr><td style="padding:4px 12px 4px 0; color:#888;">C</td><td>Toggle Context drawer</td></tr>
      <tr><td style="padding:4px 12px 4px 0; color:#888;">?</td><td>Show / hide this help</td></tr>
    </table>
    <p style="font-size:11px; color:#666; margin:12px 0 0;">Press any key or click outside to dismiss</p>
  </div>`;

  document.body.appendChild(overlay);
  const dismiss = (ev) => { if (ev.key !== '?') { overlay.remove(); document.removeEventListener('keydown', dismiss); } };
  document.addEventListener('keydown', dismiss);
}

// ========================================
// DESIGN SYSTEM PANEL (Epic 7 — Feature 7.6 / Epic 8)
// ========================================

function toggleDSPanel() {
  const panel = document.getElementById('ds-panel');
  if (!panel) return;
  panel.classList.toggle('open');
}

async function populateDSBrandDropdown() {
  // Find DS-ONT record in loadedOntologies (keyed by namespace 'ds:')
  if (!state.loadedOntologies || state.loadedOntologies.size === 0) {
    console.log('[DS] No loadedOntologies, skipping');
    return;
  }

  let dsRecord = state.loadedOntologies.get('ds:');
  if (!dsRecord) {
    // Fallback: search by name
    for (const [ns, record] of state.loadedOntologies) {
      if (record.name?.toLowerCase().includes('ds ontology') ||
          record.name?.toLowerCase().includes('design system')) {
        dsRecord = record;
        console.log(`[DS] Found DS-ONT via name fallback at key "${ns}"`);
        break;
      }
    }
  }
  if (!dsRecord) {
    console.log('[DS] DS-ONT not found in loadedOntologies. Keys:', [...state.loadedOntologies.keys()]);
    return;
  }
  if (!dsRecord.registryEntry) {
    console.log('[DS] DS-ONT found but registryEntry is null');
    return;
  }

  const fullEntry = dsRecord.registryEntry;
  const instances = fullEntry?.artifacts?.instanceData;
  if (!Array.isArray(instances) || instances.length === 0) {
    console.log('[DS] No instanceData in DS-ONT registryEntry. artifacts:', JSON.stringify(fullEntry?.artifacts));
    return;
  }

  console.log(`[DS] Found ${instances.length} instance(s), loading...`);

  try {
    // Load all DS instances
    const dsInstances = await loadDSInstanceData(fullEntry);
    state.dsInstances = dsInstances;

    // Populate dropdown
    const select = document.getElementById('ds-brand-select');
    if (!select) {
      console.warn('[DS] ds-brand-select element not found in DOM');
      return;
    }

    // Clear existing options except placeholder
    select.innerHTML = '<option value="">-- Brand --</option>';
    for (const [brand, parsed] of dsInstances) {
      const summary = getDSInstanceSummary(parsed);
      const label = `${brand} (${summary.totalTokens} tokens)`;
      const opt = document.createElement('option');
      opt.value = brand;
      opt.textContent = label;
      select.appendChild(opt);
    }
    select.style.display = 'inline-block';

    console.log(`[DS] ${dsInstances.size} brand(s) loaded:`, [...dsInstances.keys()]);

    // Restore persisted brand theme if one was saved
    const savedBrand = localStorage.getItem('oaa-viz-ds-brand');
    if (savedBrand && dsInstances.has(savedBrand)) {
      select.value = savedBrand;
      switchDSBrand(savedBrand);

      // Re-apply CSS vars from the loaded instance (not stale localStorage copy)
      const parsed = dsInstances.get(savedBrand);
      const cssVars = generateCSSVars(parsed);
      applyCSSVars(cssVars);
      refreshArchetypeCache(); // DR-SEMANTIC-005: pick up brand archetype overrides
      state.dsAppliedCSSVars = cssVars;
      // DR-BRAND-001: restore brand context for node shadow glow
      const accentColor = cssVars['--viz-accent'] || '#9dfff5';
      state.brandContext = { brand: savedBrand, tier: 'PF-Instance', accentColor };
      // Update stored vars with fresh values
      localStorage.setItem('oaa-viz-ds-vars', JSON.stringify(cssVars));
      console.log(`[DS] Restored saved brand "${savedBrand}" with ${Object.keys(cssVars).length} CSS vars`);
    }
  } catch (err) {
    console.warn('[DS] Failed to populate brand dropdown:', err.message);
  }
}

// ========================================
// APP SKELETON LOADING (F40.13 — DS-ONT v2.0.0)
// ========================================

async function loadAppSkeleton() {
  try {
    // Check for pending edits in localStorage first
    if (hasPendingSkeletonEdits()) {
      const restored = restoreSkeletonFromLocalStorage();
      if (restored && state.appSkeleton) {
        state.skeletonSource = 'localStorage';
        buildSkeletonRegistries(state.appSkeleton);
        renderDynamicNavBar();
        console.log(
          `[Skeleton] Restored edited skeleton from localStorage: ` +
          `${state.appSkeleton.zones.length} zones, ` +
          `${state.appSkeleton.navItems.length} nav items`
        );
        return;
      }
    }

    const result = await resolveAppSkeletonForPFI();
    if (!result) {
      console.log('[Skeleton] No app skeleton found, using static HTML fallback');
      return;
    }

    const { skeleton, source } = result;
    state.appSkeleton = skeleton;
    state.skeletonSource = source;

    // Build registries for zone and nav lookup
    buildSkeletonRegistries(skeleton);

    // Render dynamic nav bar (Z2-dyn) if container exists
    renderDynamicNavBar();

    console.log(
      `[Skeleton] Loaded: ${skeleton.zones.length} zones, ` +
      `${skeleton.navLayers.length} nav layers, ` +
      `${skeleton.navItems.length} nav items, ` +
      `${skeleton.zoneComponents.length} components (source: ${source})`
    );
  } catch (err) {
    console.warn('[Skeleton] Failed to load app skeleton:', err.message);
  }
}

/**
 * Boot-only skeleton loader — always fetches fresh JSONLD, skips localStorage.
 * Prevents stale skeleton edits from hiding newly added NavItems.
 */
async function loadAppSkeletonFresh() {
  try {
    const result = await resolveAppSkeletonForPFI();
    if (!result) {
      console.warn('[DynNav] No skeleton found — nav bar will be empty');
      return;
    }
    const { skeleton, source } = result;
    state.appSkeleton = skeleton;
    state.skeletonSource = source;
    buildSkeletonRegistries(skeleton);
    renderDynamicNavBar();
    console.log(
      `[DynNav] Boot: ${skeleton.navLayers.length} layers, ` +
      `${skeleton.navItems.length} items (source: ${source})`
    );
  } catch (err) {
    console.warn('[DynNav] Boot skeleton load failed:', err.message);
  }
}

// ========================================
// ACTION REGISTRY — Skeleton-Driven Dynamic Navigation (F40.17b + F40.20)
// ========================================

/**
 * Declarative map from ds:action strings (defined in the app skeleton JSONLD)
 * to JS functions. Used by wireAction() in app-skeleton-loader.js to attach
 * click/change handlers to dynamically rendered NavItem elements.
 *
 * Parameterised actions use colon syntax: "setViewMode:graph" splits into
 * action="setViewMode", param="graph".
 */
const ACTION_REGISTRY = {
  // L1 — Main Capabilities
  toggleOntologyMenu:      () => { toggleLibrary(); },
  toggleAuditPanel:        () => { toggleAudit(); },
  toggleLibraryPanel:      () => { toggleLibrary(); },
  toggleCategoryPanel:     () => { toggleCategoryPanel(); },
  toggleLayerPanel:        () => { toggleLayerPanel(); },
  // Export dropdown toggle handled by Dropdown renderer — no registry entry needed
  // Export sub-actions (children of Export dropdown)
  exportPNG:               () => { exportPNG(); },
  exportSVG:               () => { exportSVG(); },
  exportMermaid:            () => { exportMermaid(); },
  exportD3JSON:             () => { exportD3JSON(); },
  exportCypher:             () => { exportCypher(); },
  exportGateReport:         () => { exportGateReport(); },
  exportAuditFile:          () => { exportAuditFile(); },
  exportPDF:                () => { exportPDF(); },
  showDiffModal:            () => { showDiffModal(); },
  downloadDSBundle:         () => { downloadDSBundle(); },
  toggleGlossary:          () => { showGlossaryEditor(); },
  openFileDialog:          () => {
    const input = document.getElementById('file-input');
    if (input) input.click();
  },
  loadFromGitHub:          () => { loadFromGitHub(); },
  loadFromURL:             () => { showURLModal(); },
  loadFromRegistry:        () => { loadRegistry(); },
  createNewOntology:       () => { showCreateOntologyModal(); },
  forkOntology:            () => {
    if (!state.currentData) { alert('Load an ontology first'); return; }
    showForkModal();
  },
  saveToLibrary:           () => { showSaveToLibrary(); },

  // L2 — View Controls
  togglePhysics:           () => { togglePhysics(); _syncDynNav(); },
  fitGraphToView:          () => { fitGraph(); },
  resetGraphView:          () => { resetGraph(); },
  toggleDetailsPanel:      () => { toggleSidebar(); },
  changeLayout:            (param) => { changeLayout(param); },
  fitMermaidToView:        () => { fitMermaid(); },

  // L3-context — View Mode (dedicated wrappers with validation logic)
  switchToGraphTab:        () => { switchToGraphTab(); },
  switchToDSCascadeTab:    () => { switchToDSCascadeTab(); },
  switchToMermaidTab:      () => { switchToMermaidTab(); },
  switchToMindmapTab:      () => { switchToMindmapTab(); },
  toggleBacklogPanel:      () => { toggleBacklogPanel(); },
  toggleMermaidEditor:     () => {
    if (typeof window.toggleMermaidEditor === 'function') window.toggleMermaidEditor();
  },

  // L3-admin — Admin/Config
  toggleDSPanel:           () => { toggleDSPanel(); },
  toggleTokenMapPanel:     () => { toggleAdminPanel(); },
  togglePFCPFIMode:        () => {
    state.isPFIMode = !state.isPFIMode;
    _syncDynNav();
  },
  selectPFIInstance:       (param) => { selectPFIInstance(param); },
  selectBrandVariant:      (param) => { switchDSBrand(param); },
  togglePFILifecyclePanel: () => { togglePFILifecyclePanel(); },
  showSnapshotManager:     () => { showSnapshotManager(); },
  toggleSkeletonPanel:     () => { toggleSkeletonPanel(); },
  runOAAUpgrade:           () => { runOAAUpgrade(); },
  showGitHubSettings:      () => { showGitHubSettings(); },
  loadTestData:            () => { loadTestDataFile(); },

  // L5-authoring — Authoring Tools (visible when authoringMode === true)
  showEntityEditor:        () => { showEntityEditor(); },
  showRelationshipEditor:  () => { showRelationshipEditor(); },
  doUndo:                  () => { doUndo(renderGraph); },
  doRedo:                  () => { doRedo(renderGraph); },
  showVersionBumpModal:    () => { showVersionBumpModal(); },
  showRevisionHistory:     () => { showRevisionHistoryPanel(); },
  showGlossaryEditor:      () => { showGlossaryEditor(); },
  saveAuthoredOntology:    () => { showSaveWithValidation(); },
  showGenerationModal:     () => { showGenerationModal(); },
  toggleSelectionMode:     () => { toggleSelectionMode(); _syncDynNav(); },
  exitAuthoringMode:       () => { exitAuthoringMode(); _syncDynNav(); },

  // L6-selection — Selection Tools (visible when selectionMode === true)
  selectAllNodes:          () => { selectAllNodes(); },
  clearSelection:          () => { clearSelection(); _syncDynNav(); },
  exportSelectionJSON:     () => {
    if (!state.selectedNodeIds || state.selectedNodeIds.size === 0) { alert('No nodes selected'); return; }
    const json = exportSubgraph(state.currentData, state.selectedNodeIds, state.selectedEdgeIds);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'selection-export.json'; a.click();
    URL.revokeObjectURL(url);
  },
  showSaveSelectionModal:  () => { showSaveSelectionModal(); },

  // Separators / no-op
  noop:                    () => {},
};

/**
 * Render the dynamic navigation bar (Z2-dyn) from skeleton data.
 * Called once at boot after buildSkeletonRegistries().
 */
function renderDynamicNavBar() {
  const mainBar = document.getElementById('dynamic-nav-bar');
  if (!mainBar || !state.appSkeleton) return;

  // Build zone→container map for multi-zone rendering
  const zoneContainerMap = new Map();
  zoneContainerMap.set('default', mainBar);
  zoneContainerMap.set('Z2', mainBar);
  zoneContainerMap.set('Z2-dyn', mainBar);
  const authoringBar = document.getElementById('dynamic-authoring-bar');
  if (authoringBar) { zoneContainerMap.set('Z4', authoringBar); authoringBar.innerHTML = ''; }
  const selectionBar = document.getElementById('dynamic-selection-bar');
  if (selectionBar) { zoneContainerMap.set('Z4b', selectionBar); selectionBar.innerHTML = ''; }

  // Clear main bar
  mainBar.innerHTML = '';

  // Render nav items grouped by layer, routed to zone containers
  renderNavFromSkeleton(state.appSkeleton, zoneContainerMap, ACTION_REGISTRY);

  console.log('[DynNav] Rendered dynamic navigation bar (multi-zone)');
}

/**
 * Convenience wrapper — build a state snapshot and sync the dynamic nav bar.
 * Call after any state change that affects nav visibility, toggles, or active chips.
 */
function _syncDynNav() {
  syncDynamicNavState({
    currentView: state.activeView,
    isPFIMode: state.isPFIMode,
    physicsEnabled: state.physicsEnabled,
    authoringMode: state.authoringMode,
    selectionMode: state.selectionMode,
    authoringUndoLength: state.authoringUndoStack?.length || 0,
    authoringRedoLength: state.authoringRedoStack?.length || 0,
    authoringDirty: state.authoringDirty,
    selectedNodes: state.selectedNodeIds || [],
    selectedEdges: state.selectedEdgeIds || [],
    breadcrumbPath: state.breadcrumbPath || [],
    isDragOver: false,
    ontologyCount: state.ontologyCount || 0,
  });
}

// Export for skeleton editor _apply() re-renders
window._ACTION_REGISTRY = ACTION_REGISTRY;
window.renderDynamicNavBar = renderDynamicNavBar;
window._syncDynNav = _syncDynNav;

function switchDSBrand(brand) {
  if (!brand) {
    state.activeDSBrand = null;
    // Clear panel
    const summaryEl = document.getElementById('ds-summary');
    if (summaryEl) summaryEl.innerHTML = '<p style="color:#666; font-size:12px;">Select a brand to view DS tokens.</p>';
    _hide('ds-categories');
    _hide('ds-primitives');
    _hide('ds-semantics');
    _hide('ds-components');
    _hide('ds-actions');
    return;
  }

  state.activeDSBrand = brand;
  const parsed = state.dsInstances.get(brand);
  if (!parsed) return;

  renderDSPanel(parsed);
}

// ========================================
// PFI INSTANCE SELECTION (F8.4 — EMC→DS brand resolution)
// ========================================

/**
 * Populate the PFI instance dropdown from the registry.
 * Called after registry loads.
 */
function populatePFIDropdown() {
  const select = document.getElementById('pfi-instance-select');
  if (!select) return;

  const instances = listPFIInstances(state.registryIndex);
  if (instances.length === 0) return;

  // Clear existing options except placeholder
  select.innerHTML = '<option value="">PF-Core (no instance)</option>';
  for (const inst of instances) {
    const opt = document.createElement('option');
    opt.value = inst.id;
    opt.textContent = `${inst.id} — ${inst.brands?.[0] || inst.name}`;
    select.appendChild(opt);
  }
  select.style.display = 'inline-block';

  // Restore previously selected instance from localStorage
  const savedPFI = localStorage.getItem('oaa-viz-pfi-instance');
  if (savedPFI && instances.some(i => i.id === savedPFI)) {
    select.value = savedPFI;
    // Don't call selectPFIInstance here — DS brand restore happens in populateBrandDropdown
  }
  updateContextBar();
}

/**
 * Select a PFI instance and auto-resolve its DS brand.
 * Wired to window.selectPFIInstance for the HTML onchange handler.
 * S8.8.3: gates through confirmation modal when switching between PFI instances.
 */
let _pendingPFISwitch = null;

async function selectPFIInstance(instanceId) {
  // S8.8.3: if switching FROM one PFI TO another, show confirmation modal
  if (state.activePFI && instanceId && instanceId !== state.activePFI) {
    _pendingPFISwitch = instanceId;
    const msg = document.getElementById('context-switch-message');
    if (msg) {
      msg.textContent = `Switch from ${state.activePFI} to ${instanceId}? This will change the active design system brand.`;
    }
    const modal = document.getElementById('context-switch-modal');
    if (modal) modal.style.display = 'flex';
    return;
  }
  await _doSelectPFIInstance(instanceId);
}

async function confirmContextSwitch() {
  const modal = document.getElementById('context-switch-modal');
  if (modal) modal.style.display = 'none';
  if (_pendingPFISwitch !== null) {
    const target = _pendingPFISwitch;
    _pendingPFISwitch = null;
    await _doSelectPFIInstance(target);
  }
}

function cancelContextSwitch() {
  const modal = document.getElementById('context-switch-modal');
  if (modal) modal.style.display = 'none';
  const select = document.getElementById('pfi-instance-select');
  if (select) select.value = state.activePFI || '';
  _pendingPFISwitch = null;
}

async function _doSelectPFIInstance(instanceId) {
  if (!instanceId) {
    // Reset to PF-Core defaults
    state.activePFI = null;
    state.activeInstanceId = null;
    if (state.dsAppliedCSSVars) resetCSSVars(state.dsAppliedCSSVars);
    state.activeDSBrand = null;
    state.dsAppliedCSSVars = null;
    state.brandContext = null;
    localStorage.removeItem('oaa-viz-ds-vars');
    localStorage.removeItem('oaa-viz-ds-brand');
    localStorage.removeItem('oaa-viz-pfi-instance');

    // Reset DS brand dropdown
    const brandSelect = document.getElementById('ds-brand-select');
    if (brandSelect) brandSelect.value = '';
    switchDSBrand('');

    // Epic 9D: Clear composition filter and restore full graph
    clearCompositionFilter();
    _reRenderCurrentView();

    // F40.21: Reset skeleton to PFC base (no PFI overrides)
    const baseResult = await resolveAppSkeletonForPFI();
    if (baseResult) {
      state.appSkeleton = baseResult.skeleton;
      state.skeletonSource = baseResult.source;
      buildSkeletonRegistries(baseResult.skeleton);
      renderDynamicNavBar();
      console.log(`[Skeleton] Reset to PFC base: ${baseResult.skeleton.zones.length} zones`);
    }

    console.log('[PFI] Cleared — PF-Core defaults active');
    updateContextBar();
    updateGraphBorderGlow();
    updateContextTitle();
    return;
  }

  const config = state.pfiInstances.get(instanceId);
  if (!config) {
    console.warn('[PFI] Unknown instance:', instanceId);
    return;
  }

  state.activePFI = instanceId;
  state.activeInstanceId = instanceId;
  localStorage.setItem('oaa-viz-pfi-instance', instanceId);

  // Auto-resolve DS brand via EMC designSystemConfig
  const resolution = resolveDSBrandForPFI(config);
  if (resolution.brand) {
    // Sync the DS brand dropdown
    const brandSelect = document.getElementById('ds-brand-select');
    if (brandSelect) brandSelect.value = resolution.brand;

    switchDSBrand(resolution.brand);
    const parsed = state.dsInstances.get(resolution.brand);
    if (parsed) {
      const cssVars = generateCSSVars(parsed);
      applyCSSVars(cssVars);
      refreshArchetypeCache(); // DR-SEMANTIC-005: pick up brand archetype overrides
      state.dsAppliedCSSVars = cssVars;
      const accentColor = cssVars['--viz-accent'] || '#9dfff5';
      state.brandContext = { brand: resolution.brand, tier: 'PF-Instance', accentColor };
      localStorage.setItem('oaa-viz-ds-vars', JSON.stringify(cssVars));
      localStorage.setItem('oaa-viz-ds-brand', resolution.brand);
    }
  } else {
    // PF-Core defaults — reset any active brand
    if (state.dsAppliedCSSVars) resetCSSVars(state.dsAppliedCSSVars);
    state.activeDSBrand = null;
    state.dsAppliedCSSVars = null;
    state.brandContext = null;
    localStorage.removeItem('oaa-viz-ds-vars');
    localStorage.removeItem('oaa-viz-ds-brand');

    const brandSelect = document.getElementById('ds-brand-select');
    if (brandSelect) brandSelect.value = '';
    switchDSBrand('');
  }

  console.log(`[PFI] Selected ${instanceId} → DS brand: ${resolution.brand || 'PF-Core defaults'} (${resolution.source})`);

  // S8.8.1/S8.8.2/S8.8.5: update context UI
  updateContextBar();
  updateGraphBorderGlow();
  updateContextTitle();

  // Sync PFI dropdown
  const pfiSelect = document.getElementById('pfi-instance-select');
  if (pfiSelect) pfiSelect.value = instanceId;

  // Load PFI instance data if available
  if (config.instanceDataFiles?.length > 0) {
    await loadPFIInstanceData(instanceId, state.registryIndex);
  }

  // Epic 9D/9F.2: Apply multi-category composition filter based on PFI requirement scopes
  const scopes = config.requirementScopes || [];
  if (scopes.length > 0) {
    const result = composeMultiCategory(scopes, {
      contextLevel: 'PFI',
      productCode: config.products?.[0] || instanceId,
      maturityLevel: state.activeMaturityLevel ?? config.maturityLevel ?? 5,
      complianceScope: state.complianceScopeActive || false,
    });
    if (result.success) {
      let composition = result.composition;
      const instanceOnts = config.instanceOntologies || [];
      if (instanceOnts.length > 0) {
        composition = constrainToInstanceOntologies(composition, instanceOnts);
      }
      state.activeCategories = [...scopes];
      state.multiCategoryResult = result;
      applyCompositionFilter(composition);
      _reRenderCurrentView();
    }
  }

  // F40.21: Reload skeleton with PFI cascade overrides
  if (config.appSkeletonConfig) {
    const skeletonResult = await resolveAppSkeletonForPFI(config.appSkeletonConfig);
    if (skeletonResult) {
      state.appSkeleton = skeletonResult.skeleton;
      state.skeletonSource = skeletonResult.source;
      buildSkeletonRegistries(skeletonResult.skeleton);
      renderDynamicNavBar();
      console.log(
        `[Skeleton] PFI cascade loaded for ${instanceId}: ` +
        `${skeletonResult.skeleton.zones.length} zones, ` +
        `${skeletonResult.skeleton.navItems.length} nav items`
      );
    }
  }

  // 9E.5: Update scope chips and instance picker label
  renderScopeChips(instanceId);
  _updateInstancePickerLabel();
}

/**
 * Re-render the current view after composition filter changes.
 * Dispatches to the appropriate renderer based on viewMode and currentTier.
 */
function _reRenderCurrentView() {
  if (state.viewMode === 'multi' && state.currentTier === 0 && state.seriesData) {
    renderTier0(state.seriesData, state.crossSeriesEdges);
  } else if (state.mergedGraph) {
    renderMultiGraph(state.mergedGraph, state.crossEdges, state.seriesData);
  }
}

// ========================================
// EPIC 9E/9F: Context Toggle, Instance Picker, Category Panel, Scope Chips
// ========================================

/**
 * Set context level: 'PFC' (Core Templates) or 'PFI' (Instance View).
 * 9E.1 — PFC/PFI Context Toggle.
 */
function setContextLevel(level) {
  state.contextLevel = level;
  document.querySelectorAll('.context-toggle-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.ctx === level);
  });
  const picker = document.getElementById('instance-picker');
  const chips = document.getElementById('scope-chips');
  if (level === 'PFC') {
    // Clear composition filter and return to full graph
    if (picker) picker.style.display = 'none';
    if (chips) chips.style.display = 'none';
    state.activeInstanceId = null;
    state.activeCategories = [];
    state.multiCategoryResult = null;
    clearCompositionFilter();
    updateContextBar();
    updateGraphBorderGlow();
    updateContextTitle();
    _reRenderCurrentView();
  } else {
    // Show instance picker; restore last selection
    if (picker) picker.style.display = 'inline-block';
    const lastId = localStorage.getItem('oaa-viz-pfi-instance');
    if (lastId && state.pfiInstances.has(lastId)) {
      selectPFIInstance(lastId);
    }
  }
  try { localStorage.setItem('oaa-viz-context-level', level); } catch { /* quota */ }
}

/**
 * Toggle instance picker dropdown.
 * 9E.2 — Instance Picker Dropdown.
 */
function toggleInstancePicker() {
  const dd = document.getElementById('instance-picker-dropdown');
  if (!dd) return;
  const isOpen = dd.style.display !== 'none';
  dd.style.display = isOpen ? 'none' : 'block';
  if (!isOpen) renderInstancePickerItems();
}

function renderInstancePickerItems() {
  const list = document.getElementById('instance-picker-list');
  if (!list) return;
  const instances = listPFIInstances(state.registryIndex);
  if (instances.length === 0) {
    list.innerHTML = '<div style="padding:12px; color:var(--viz-text-muted); font-size:12px;">No PFI instances in registry.</div>';
    return;
  }
  let html = '';
  // PF-Core option
  const isCore = !state.activeInstanceId;
  html += `<div class="instance-picker-item${isCore ? ' active' : ''}" onclick="doPickInstance('')">
    <div class="instance-picker-name">PF-Core</div>
    <div class="instance-picker-meta">Default templates — all ontologies</div>
  </div>`;
  for (const inst of instances) {
    const isActive = state.activeInstanceId === inst.id;
    const scopePills = (inst.requirementScopes || []).map(s =>
      `<span class="instance-picker-scope-pill">${_escapeAttr(s)}</span>`
    ).join('');
    html += `<div class="instance-picker-item${isActive ? ' active' : ''}" onclick="doPickInstance('${_escapeAttr(inst.id)}')">
      <div class="instance-picker-name">${_escapeAttr(inst.name)}</div>
      <div class="instance-picker-meta">${_escapeAttr(inst.brands?.[0] || '')} &middot; maturity ${inst.maturityLevel || '?'}</div>
      <div class="instance-picker-scopes">${scopePills}</div>
    </div>`;
  }
  list.innerHTML = html;
}

/**
 * Handle picking an instance from the custom dropdown.
 */
function doPickInstance(instanceId) {
  document.getElementById('instance-picker-dropdown').style.display = 'none';
  if (!instanceId) {
    // Back to PF-Core
    setContextLevel('PFC');
  } else {
    selectPFIInstance(instanceId);
  }
  // Update the trigger label
  _updateInstancePickerLabel();
}

function _updateInstancePickerLabel() {
  const label = document.getElementById('instance-picker-label');
  if (!label) return;
  if (!state.activeInstanceId) {
    label.textContent = 'Select Instance...';
  } else {
    const config = state.pfiInstances.get(state.activeInstanceId);
    label.textContent = config?.name || config?.instanceName || state.activeInstanceId;
  }
}

/**
 * Show the context toggle and populate instance picker after registry load.
 * Called from loadRegistry() completion path.
 *
 * NOTE: We no longer auto-restore PFI context level here. Auto-restoring
 * applied a composition filter (via selectPFIInstance → composeMultiCategory)
 * that silently narrowed the tier0 view to only the PFI's requirement scopes,
 * hiding series like RCSG-Series and Orchestration. The user must explicitly
 * switch to PFI mode via the Core/Instance toggle.
 */
function _showContextControlsIfPFI() {
  const toggle = document.getElementById('context-toggle');
  if (!toggle) return;
  const instances = listPFIInstances(state.registryIndex);
  if (instances.length > 0) {
    toggle.style.display = 'inline-flex';
  }
}

// Close instance picker on outside click
document.addEventListener('click', (e) => {
  const picker = document.getElementById('instance-picker');
  const dd = document.getElementById('instance-picker-dropdown');
  if (picker && dd && !picker.contains(e.target)) {
    dd.style.display = 'none';
  }
  // Also close EMC nav dropdowns on outside click
  const navBar = document.getElementById('emc-nav-bar');
  if (navBar && !navBar.contains(e.target)) {
    _closeAllEMCDropdowns();
  }
});

// ========================================
// EMC CASCADE NAVIGATION BAR (F19.4+ — PFC → PFI → Product → App)
// ========================================

/**
 * Initialise the EMC navigation bar.
 * Called at DOMContentLoaded (bar visible immediately with PFC default)
 * and again after loadRegistry() to enable PFI level.
 */
function initEMCNavBar() {
  const bar = document.getElementById('emc-nav-bar');
  if (!bar) return;

  bar.style.display = 'flex';
  _setEMCNavLevelState(0, 'active');

  // Enable PFI level if registry loaded and instances exist
  const instances = listPFIInstances(state.registryIndex);
  if (instances.length > 0) {
    _setEMCNavLevelState(1, 'active');
    const btn = document.getElementById('emc-nav-pfi-btn');
    if (btn) btn.disabled = false;
  }

  _updateEMCNavSummary();
}

/**
 * Navigate to a cascade level (breadcrumb click).
 * Level 0 = PFC, 1 = PFI, 2 = Product.
 */
function setEMCLevel(level) {
  _closeAllEMCDropdowns();

  if (level === 0) {
    state.activeProductCode = null;
    state.emcNavLevel = 0;
    setContextLevel('PFC');
    _resetEMCLevelsAbove(0);
    _syncEMCNavHighlights();
    _updateEMCNavSummary();
    return;
  }

  if (level === 1 && state.activeInstanceId) {
    state.activeProductCode = null;
    state.emcNavLevel = 1;
    _resetEMCLevelsAbove(1);
    _applyEMCComposition(state.activeInstanceId, null);
    _syncEMCNavHighlights();
    _updateEMCNavSummary();
  }
}

/**
 * Toggle dropdown for a specific EMC nav level.
 * @param {number} level — 1 (PFI) or 2 (Product)
 */
function toggleEMCDropdown(level) {
  const dropdownIds = { 1: 'emc-nav-pfi-dropdown', 2: 'emc-nav-product-dropdown' };
  const dropdownId = dropdownIds[level];
  if (!dropdownId) return;

  const dropdown = document.getElementById(dropdownId);
  if (!dropdown) return;

  const wasOpen = dropdown.style.display !== 'none';
  _closeAllEMCDropdowns();

  if (!wasOpen) {
    dropdown.style.display = 'block';
    if (level === 1) _renderEMCPFIItems();
    if (level === 2) _renderEMCProductItems();
  }
}

/**
 * Select a PFI instance from the EMC nav dropdown.
 * Wraps existing setContextLevel('PFI') + selectPFIInstance().
 */
async function selectEMCInstance(instanceId) {
  _closeAllEMCDropdowns();

  if (!instanceId) {
    setEMCLevel(0);
    return;
  }

  // Delegate to existing PFI selection flow
  setContextLevel('PFI');
  await selectPFIInstance(instanceId);

  state.emcNavLevel = 1;
  _updateEMCNavPFILabel(instanceId);

  // Show separator
  const sep1 = document.getElementById('emc-nav-sep-1');
  if (sep1) sep1.style.display = 'inline';

  // Enable and populate product level
  const config = state.pfiInstances.get(instanceId);
  const products = config?.products || [];
  if (products.length > 0) {
    _setEMCNavLevelState(2, 'active');
    const btn = document.getElementById('emc-nav-product-btn');
    if (btn) btn.disabled = false;

    // Auto-select first product
    state.activeProductCode = products[0];
    state.emcNavLevel = 2;
    _updateEMCNavProductLabel(products[0]);

    const sep2 = document.getElementById('emc-nav-sep-2');
    if (sep2) sep2.style.display = 'inline';
    const sep3 = document.getElementById('emc-nav-sep-3');
    if (sep3) sep3.style.display = 'inline';
  } else {
    _setEMCNavLevelState(2, 'disabled');
  }

  _syncEMCNavHighlights();
  _updateEMCNavSummary();
}

/**
 * Select a product from the EMC nav product dropdown.
 * Re-applies composition with the specific product code.
 */
function selectEMCProduct(productCode) {
  _closeAllEMCDropdowns();

  state.activeProductCode = productCode;
  state.emcNavLevel = 2;

  _updateEMCNavProductLabel(productCode);

  const sep2 = document.getElementById('emc-nav-sep-2');
  if (sep2) sep2.style.display = 'inline';
  const sep3 = document.getElementById('emc-nav-sep-3');
  if (sep3) sep3.style.display = 'inline';

  // Re-apply composition with selected product
  _applyEMCComposition(state.activeInstanceId, productCode);

  _syncEMCNavHighlights();
  _updateEMCNavSummary();

  try { localStorage.setItem('oaa-viz-emc-product', productCode); } catch { /* quota */ }
}

/**
 * Re-apply PFI composition with an optional product code override.
 */
function _applyEMCComposition(instanceId, productCode) {
  const config = state.pfiInstances.get(instanceId);
  if (!config) return;

  const scopes = config.requirementScopes || [];
  if (scopes.length === 0) return;

  const result = composeMultiCategory(scopes, {
    contextLevel: 'PFI',
    productCode: productCode || config.products?.[0] || instanceId,
    maturityLevel: state.activeMaturityLevel ?? config.maturityLevel ?? 5,
    complianceScope: state.complianceScopeActive || false,
  });

  if (result.success) {
    let composition = result.composition;
    const instanceOnts = config.instanceOntologies || [];
    if (instanceOnts.length > 0) {
      composition = constrainToInstanceOntologies(composition, instanceOnts);
    }
    state.activeCategories = [...scopes];
    state.multiCategoryResult = result;
    applyCompositionFilter(composition);
    _reRenderCurrentView();
  }

  renderScopeChips(instanceId);
}

// --- EMC Nav Helpers ---

function _closeAllEMCDropdowns() {
  ['emc-nav-pfi-dropdown', 'emc-nav-product-dropdown'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });
}

function _setEMCNavLevelState(level, levelState) {
  const ids = ['emc-nav-pfc', 'emc-nav-pfi', 'emc-nav-product', 'emc-nav-app'];
  const el = document.getElementById(ids[level]);
  if (!el) return;
  el.className = 'emc-nav-level';
  if (levelState === 'active') el.classList.add('emc-nav-level--active');
  else if (levelState === 'disabled') el.classList.add('emc-nav-level--disabled');
  else if (levelState === 'placeholder') el.classList.add('emc-nav-level--placeholder');
}

function _resetEMCLevelsAbove(level) {
  const pfiLabel = document.getElementById('emc-nav-pfi-label');
  const productLabel = document.getElementById('emc-nav-product-label');

  if (level < 1) {
    // Keep PFI enabled if registry has instances, but reset label
    const instances = listPFIInstances(state.registryIndex);
    _setEMCNavLevelState(1, instances.length > 0 ? 'active' : 'disabled');
    const btn = document.getElementById('emc-nav-pfi-btn');
    if (btn) btn.disabled = instances.length === 0;
    if (pfiLabel) pfiLabel.textContent = 'Instance';
    const sep1 = document.getElementById('emc-nav-sep-1');
    if (sep1) sep1.style.display = 'none';
  }
  if (level < 2) {
    _setEMCNavLevelState(2, 'disabled');
    const btn = document.getElementById('emc-nav-product-btn');
    if (btn) btn.disabled = true;
    if (productLabel) productLabel.textContent = 'Product';
    const sep2 = document.getElementById('emc-nav-sep-2');
    if (sep2) sep2.style.display = 'none';
  }
  // App is always placeholder
  _setEMCNavLevelState(3, 'placeholder');
  const sep3 = document.getElementById('emc-nav-sep-3');
  if (sep3) sep3.style.display = 'none';
}

function _updateEMCNavPFILabel(instanceId) {
  const label = document.getElementById('emc-nav-pfi-label');
  if (!label) return;
  const config = state.pfiInstances.get(instanceId);
  label.textContent = config?.name || instanceId || 'Instance';
}

function _updateEMCNavProductLabel(productCode) {
  const label = document.getElementById('emc-nav-product-label');
  if (label) label.textContent = productCode || 'Product';
}

function _updateEMCNavSummary() {
  const brandEl = document.getElementById('emc-nav-brand');
  const tierEl = document.getElementById('emc-nav-tier');
  const accentEl = document.getElementById('emc-nav-accent');

  if (state.activePFI) {
    const config = state.pfiInstances.get(state.activePFI);
    if (brandEl) brandEl.textContent = state.brandContext?.brand ? `DS: ${state.brandContext.brand}` : '';
    if (tierEl) {
      let tierText = config?.verticalMarket ? `${config.verticalMarket} | PF-Instance` : 'PF-Instance';
      if (state.activeProductCode) tierText = `${state.activeProductCode} | ${tierText}`;
      tierEl.textContent = tierText;
    }
  } else {
    if (brandEl) brandEl.textContent = '';
    if (tierEl) tierEl.textContent = 'Core Templates';
  }

  if (accentEl) {
    accentEl.style.background = state.brandContext?.accentColor || 'var(--viz-accent)';
  }
}

function _syncEMCNavHighlights() {
  const levelBtnIds = ['emc-nav-pfc-btn', 'emc-nav-pfi-btn', 'emc-nav-product-btn'];
  levelBtnIds.forEach((id, idx) => {
    const btn = document.getElementById(id);
    if (btn) btn.classList.toggle('emc-nav-btn--active', idx === state.emcNavLevel);
  });
}

function _renderEMCPFIItems() {
  const list = document.getElementById('emc-nav-pfi-list');
  if (!list) return;

  const instances = listPFIInstances(state.registryIndex);
  let html = '';

  // PF-Core option
  const isCore = !state.activeInstanceId;
  html += `<div class="emc-nav-item${isCore ? ' active' : ''}" onclick="selectEMCInstance('')">
    <div class="emc-nav-item-name">PF-Core</div>
    <div class="emc-nav-item-meta">Default templates &mdash; all ontologies</div>
  </div>`;

  for (const inst of instances) {
    const isActive = state.activeInstanceId === inst.id;
    const scopePills = (inst.requirementScopes || []).map(s =>
      `<span class="instance-picker-scope-pill">${escapeHtml(s)}</span>`
    ).join('');
    const meta = [inst.brands?.[0], inst.verticalMarket, `maturity ${inst.maturityLevel ?? '?'}`]
      .filter(Boolean).join(' \u00B7 ');
    html += `<div class="emc-nav-item${isActive ? ' active' : ''}" onclick="selectEMCInstance('${escapeHtml(inst.id)}')">
      <div class="emc-nav-item-name">${escapeHtml(inst.name || inst.id)}</div>
      <div class="emc-nav-item-meta">${escapeHtml(meta)}</div>
      <div class="emc-nav-item-scopes">${scopePills}</div>
    </div>`;
  }

  list.innerHTML = html;
}

function _renderEMCProductItems() {
  const list = document.getElementById('emc-nav-product-list');
  if (!list) return;

  const config = state.pfiInstances.get(state.activeInstanceId);
  const products = config?.products || [];

  if (products.length === 0) {
    list.innerHTML = '<div class="emc-nav-item"><div class="emc-nav-item-meta">No products defined.</div></div>';
    return;
  }

  let html = '';
  for (const productCode of products) {
    const isActive = state.activeProductCode === productCode;
    html += `<div class="emc-nav-item${isActive ? ' active' : ''}" onclick="selectEMCProduct('${escapeHtml(productCode)}')">
      <div class="emc-nav-item-name">${escapeHtml(productCode)}</div>
      <div class="emc-nav-item-meta">${escapeHtml(config?.name || state.activeInstanceId || '')} product</div>
    </div>`;
  }

  list.innerHTML = html;
}

/**
 * Toggle the requirement category panel.
 * 9F.1 — Requirement Category Panel.
 */
function toggleCategoryPanel() {
  const panel = document.getElementById('category-panel');
  if (!panel) return;
  const isOpen = panel.classList.toggle('open');
  state.categoryPanelOpen = isOpen;
  if (isOpen) renderCategoryPanel();
}

function renderCategoryPanel() {
  const container = document.getElementById('category-panel-content');
  if (!container) return;
  const categories = listCategories();
  const activeSet = new Set(state.activeCategories);

  let html = '';
  for (const cat of categories) {
    const selected = activeSet.has(cat.code);
    const seriesBadges = (cat.activeSeries || []).map(s =>
      `<span class="category-series-badge">${_escapeAttr(s)}</span>`
    ).join('');
    html += `<div class="category-card${selected ? ' selected' : ''}" onclick="toggleCategory('${_escapeAttr(cat.code)}')">
      <div class="category-card-header">
        <span class="category-card-name">${_escapeAttr(cat.name)}</span>
        <span class="category-card-count">${cat.requiredCount} req</span>
      </div>
      <div class="category-series-badges">${seriesBadges}</div>
    </div>`;
  }
  container.innerHTML = html;
  _updateOverlapInfo();
}

/**
 * Toggle a category in/out of the active set.
 */
function toggleCategory(code) {
  const idx = state.activeCategories.indexOf(code);
  if (idx >= 0) {
    state.activeCategories.splice(idx, 1);
  } else {
    state.activeCategories.push(code);
  }
  applyCategorySelection();
}

/**
 * Central function: recompose from active categories and apply filter.
 * Called from toggleCategory, toggleScopeChip, setMaturityLevel, toggleComplianceScope.
 */
function applyCategorySelection() {
  if (state.activeCategories.length === 0) {
    clearCompositionFilter();
    state.multiCategoryResult = null;
    _reRenderCurrentView();
    _updateOverlapInfo();
    renderCategoryPanel();
    _syncScopeChips();
    return;
  }

  const opts = {
    contextLevel: state.contextLevel,
    maturityLevel: state.activeMaturityLevel ?? 5,
    complianceScope: state.complianceScopeActive || false,
  };
  if (state.contextLevel === 'PFI' && state.activeInstanceId) {
    const config = state.pfiInstances.get(state.activeInstanceId);
    opts.productCode = config?.products?.[0] || state.activeInstanceId;
  }

  const result = composeMultiCategory(state.activeCategories, opts);
  if (result.success) {
    let composition = result.composition;
    if (state.contextLevel === 'PFI' && state.activeInstanceId) {
      const pfiConfig = state.pfiInstances.get(state.activeInstanceId);
      const instanceOnts = pfiConfig?.instanceOntologies || [];
      if (instanceOnts.length > 0) {
        composition = constrainToInstanceOntologies(composition, instanceOnts);
      }
    }
    state.multiCategoryResult = result;
    applyCompositionFilter(composition);
    _reRenderCurrentView();
  }
  _updateOverlapInfo();
  renderCategoryPanel();
  _syncScopeChips();
}

function _updateOverlapInfo() {
  const el = document.getElementById('category-overlap-info');
  if (!el) return;
  const r = state.multiCategoryResult;
  if (!r || state.activeCategories.length < 2) {
    el.textContent = '';
    return;
  }
  el.textContent = `${r.composition.allOntologies.length} ontologies active, ${r.overlapCount} shared across categories`;
}

/**
 * Render scope chips for the selected PFI instance.
 * 9E.5 — Requirement Scope Chips.
 */
function renderScopeChips(instanceId) {
  const container = document.getElementById('scope-chips');
  if (!container) return;
  if (!instanceId) {
    container.style.display = 'none';
    container.innerHTML = '';
    return;
  }
  const config = state.pfiInstances.get(instanceId);
  const scopes = config?.requirementScopes || [];
  if (scopes.length === 0) {
    container.style.display = 'none';
    return;
  }
  container.style.display = 'inline-flex';
  const activeSet = new Set(state.activeCategories);
  container.innerHTML = scopes.map(code => {
    const active = activeSet.has(code);
    return `<span class="scope-chip${active ? ' active' : ''}" onclick="toggleScopeChip('${_escapeAttr(code)}')">${_escapeAttr(code)}</span>`;
  }).join('');
}

function toggleScopeChip(code) {
  const idx = state.activeCategories.indexOf(code);
  if (idx >= 0) {
    state.activeCategories.splice(idx, 1);
  } else {
    state.activeCategories.push(code);
  }
  applyCategorySelection();
}

function _syncScopeChips() {
  if (state.activeInstanceId) {
    renderScopeChips(state.activeInstanceId);
  }
}

/**
 * Render persona selector chips when a PFI composed graph is active.
 * Epic 19, F19.4 — S19.4.5.
 */
function renderPersonaSelector() {
  const container = document.getElementById('persona-chips');
  if (!container) return;

  if (!state.activeInstanceId || !state.composedPFIGraph) {
    container.style.display = 'none';
    container.innerHTML = '';
    return;
  }

  // Get ICP hierarchy from product context or ICP bindings
  const icpEntries = [];
  if (state.productContext?.icpHierarchy) {
    for (const icp of state.productContext.icpHierarchy) {
      icpEntries.push({ ref: icp.ref || icp['@id'], label: icp.label || icp.roleName, seniority: icp.seniorityLevel || '' });
    }
  } else if (state.icpBindings) {
    const seen = new Set();
    for (const [, bindings] of state.icpBindings) {
      for (const b of bindings) {
        if (!seen.has(b.icpRef)) {
          seen.add(b.icpRef);
          icpEntries.push({ ref: b.icpRef, label: b.icpLabel || b.icpRef, seniority: b.seniorityLevel || '' });
        }
      }
    }
  }

  if (icpEntries.length === 0) {
    container.style.display = 'none';
    return;
  }

  container.style.display = 'inline-flex';
  const isAll = !state.activePersonaScope;
  let html = `<span class="scope-chip${isAll ? ' active' : ''}" onclick="selectPersona(null)">All</span>`;
  for (const icp of icpEntries) {
    const active = state.activePersonaScope === icp.ref;
    const seniorityBadge = icp.seniority ? ` [${icp.seniority}]` : '';
    html += `<span class="scope-chip${active ? ' active' : ''}" onclick="selectPersona('${_escapeAttr(icp.ref)}')">${escapeHtml(icp.label)}${seniorityBadge}</span>`;
  }
  container.innerHTML = html;
}

function selectPersona(icpRef) {
  if (!state.activeInstanceId) return;
  generatePersonaWorkflow(state.activeInstanceId, icpRef);
  renderPersonaSelector();
  if (typeof window.renderCurrentView === 'function') window.renderCurrentView();
}
window.selectPersona = selectPersona;

// ========================================
// PFI LIFECYCLE WORKBENCH (F40.17)
// ========================================

function togglePFILifecyclePanel() {
  const panel = document.getElementById('pfi-lifecycle-panel');
  if (!panel) return;
  const isVisible = panel.style.display !== 'none';
  panel.style.display = isVisible ? 'none' : 'block';
  if (!isVisible) renderPFILifecyclePanel(state.activeInstanceId);
}

function showSnapshotManager() {
  const modal = document.getElementById('snapshot-modal');
  if (modal) modal.style.display = 'flex';
  renderSnapshotManager(state.activeInstanceId);
}

function closeSnapshotModal() {
  const modal = document.getElementById('snapshot-modal');
  if (modal) modal.style.display = 'none';
}

function composeBAIVGraph() {
  if (!state.activeInstanceId) return;
  doLifecycleCompose();
  renderPersonaSelector();
  if (typeof window.renderCurrentView === 'function') window.renderCurrentView();
}

function freezeBAIVSnapshot() {
  showSnapshotManager();
}

function showBindingsTab() {
  switchTab('bindings');
  renderBindingInspector(state.activeInstanceId);
}

window.togglePFILifecyclePanel = togglePFILifecyclePanel;
window.showSnapshotManager = showSnapshotManager;
window.closeSnapshotModal = closeSnapshotModal;
window.composeBAIVGraph = composeBAIVGraph;
window.freezeBAIVSnapshot = freezeBAIVSnapshot;
window.showBindingsTab = showBindingsTab;
window.doLifecycleLoadScopeRules = doLifecycleLoadScopeRules;
window.doLifecycleCompose = doLifecycleCompose;
window.doLifecycleResolveBindings = doLifecycleResolveBindings;
window.doFreezeSnapshot = doFreezeSnapshot;
window.doInheritSnapshot = doInheritSnapshot;
window.doDiffSelectedSnapshots = doDiffSelectedSnapshots;
window.filterBindings = filterBindings;
window.focusBindingNode = focusBindingNode;

/**
 * Maturity slider handler.
 * 9F.3 — Maturity Slider.
 */
function setMaturityLevel(level) {
  const val = parseInt(level, 10);
  state.activeMaturityLevel = val;
  const display = document.getElementById('maturity-value');
  if (display) display.textContent = val;
  const note = document.getElementById('maturity-exclusion-note');
  if (note) note.style.display = val < 3 ? 'block' : 'none';
  try { localStorage.setItem('oaa-viz-maturity-level', val); } catch { /* quota */ }
  if (state.activeCategories.length > 0) {
    applyCategorySelection();
  }
}

/**
 * Compliance scope toggle handler.
 * 9F.4 — Compliance Scope Toggle.
 */
function toggleComplianceScope(checked) {
  state.complianceScopeActive = !!checked;
  if (state.activeCategories.length > 0) {
    applyCategorySelection();
  }
}

/** Tiny HTML-attribute escaper for generated markup. */
function _escapeAttr(s) {
  if (!s) return '';
  return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// ========================================
// CONTEXT SWITCH UI (F8.8)
// ========================================

/**
 * Update the context identity bar to reflect the active PFI/PF-Core context.
 * S8.8.1 — F8.8
 */
function updateContextBar() {
  const bar = document.getElementById('context-identity-bar');

  // Old identity bar is hidden; update EMC nav summary instead
  if (bar) {
    const hasRegistry = state.pfiInstances.size > 0;
    bar.style.display = hasRegistry ? 'flex' : 'none';
  }

  // Sync the EMC cascade nav bar summary
  _updateEMCNavSummary();
}

/**
 * Apply or remove inset glow on #graph-container based on brand context.
 * S8.8.2 — F8.8
 */
function updateGraphBorderGlow() {
  const container = document.getElementById('graph-container');
  if (!container) return;

  if (state.brandContext?.accentColor) {
    container.style.setProperty('--viz-brand-glow-color', state.brandContext.accentColor);
    container.classList.add('brand-glow');
  } else {
    container.classList.remove('brand-glow');
    container.style.removeProperty('--viz-brand-glow-color');
  }
}

/**
 * Update the browser tab title and favicon to reflect the active context.
 * S8.8.5 — F8.8
 */
function updateContextTitle() {
  if (state.activePFI) {
    document.title = `${state.activePFI} — OAA Visualiser`;
  } else {
    document.title = 'OAA Ontology Visualiser';
  }

  // Dynamic favicon — 16x16 canvas with brand accent dot
  const accentColor = state.brandContext?.accentColor || '#9dfff5';
  try {
    const canvas = document.createElement('canvas');
    canvas.width = 16;
    canvas.height = 16;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#1a1d27';
    ctx.fillRect(0, 0, 16, 16);
    ctx.beginPath();
    ctx.arc(8, 8, 6, 0, Math.PI * 2);
    ctx.fillStyle = accentColor;
    ctx.fill();

    let link = document.querySelector("link[rel~='icon']");
    if (!link) {
      link = document.createElement('link');
      link.rel = 'icon';
      document.head.appendChild(link);
    }
    link.href = canvas.toDataURL('image/png');
  } catch (_) { /* canvas not available in test env */ }
}

/**
 * Toggle the quick-switch context drawer.
 * S8.8.6 — F8.8
 */
function toggleContextDrawer() {
  const drawer = document.getElementById('context-drawer');
  if (!drawer) return;
  const isOpen = drawer.classList.toggle('open');
  if (isOpen) renderContextDrawer();
}

/**
 * Render PFI instance cards in the context drawer.
 * S8.8.6 — F8.8
 */
function renderContextDrawer() {
  const content = document.getElementById('context-drawer-content');
  if (!content) return;

  const instances = listPFIInstances(state.registryIndex);
  if (instances.length === 0) {
    content.innerHTML = '<p style="color:#666; font-size:12px;">No PFI instances found. Load the registry first.</p>';
    return;
  }

  let html = '';

  // PF-Core card (always first)
  const isCore = !state.activePFI;
  html += `<div class="context-card${isCore ? ' active' : ''}" onclick="selectPFIInstance('')">
    <div class="context-card-accent" style="background:var(--viz-accent);"></div>
    <div class="context-card-header">
      <span class="context-card-name">PF-Core</span>
      ${isCore ? '<span class="context-card-badge">Active</span>' : ''}
    </div>
    <div class="context-card-desc">Default templates — no PFI instance applied</div>
    <div class="context-card-meta"><span>Core Templates</span><span>Default DS</span></div>
  </div>`;

  // PFI instance cards
  for (const inst of instances) {
    const isActive = state.activePFI === inst.id;
    const config = state.pfiInstances.get(inst.id);
    const resolution = resolveDSBrandForPFI(config);
    const accentColor = state.brandContext?.accentColor && isActive
      ? state.brandContext.accentColor
      : '#9dfff5';

    html += `<div class="context-card${isActive ? ' active' : ''}" onclick="selectPFIInstance('${escapeHtml(inst.id)}')">
      <div class="context-card-accent" style="background:${accentColor};"></div>
      <div class="context-card-header">
        <span class="context-card-name">${escapeHtml(inst.id)}</span>
        <span style="color:${accentColor}; font-size:11px;">${escapeHtml(inst.brands?.[0] || '')}</span>
        ${isActive ? '<span class="context-card-badge">Active</span>' : ''}
      </div>
      <div class="context-card-desc">${escapeHtml(inst.description || inst.name)}</div>
      <div class="context-card-meta">
        <span>DS: ${escapeHtml(resolution.brand || 'PF-Core defaults')}</span>
      </div>
    </div>`;
  }

  content.innerHTML = html;
}

function renderDSPanel(parsed) {
  const summary = getDSInstanceSummary(parsed);

  // Summary section
  const summaryEl = document.getElementById('ds-summary');
  if (summaryEl) {
    const syncColor = summary.syncStatus === 'populated' ? '#4CAF50'
      : summary.syncStatus === 'draft' ? '#FF9800' : '#666';
    summaryEl.innerHTML = `
      <div class="ds-summary-grid">
        <div class="ds-summary-card">
          <div class="ds-summary-value">${escapeHtml(summary.brand)}</div>
          <div class="ds-summary-label">Brand</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value">v${escapeHtml(summary.version)}</div>
          <div class="ds-summary-label">Version</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value">${summary.totalTokens}</div>
          <div class="ds-summary-label">Tokens</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value" style="color:${syncColor};">${escapeHtml(summary.syncStatus)}</div>
          <div class="ds-summary-label">Status</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value">${summary.primitiveCount}</div>
          <div class="ds-summary-label">Primitives</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value">${summary.semanticCount}</div>
          <div class="ds-summary-label">Semantics</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value">${summary.componentCount}</div>
          <div class="ds-summary-label">Components</div>
        </div>
        <div class="ds-summary-card">
          <div class="ds-summary-value">${summary.themeModeSupport ? 'Yes' : 'No'}</div>
          <div class="ds-summary-label">Dark Mode</div>
        </div>
      </div>`;
  }

  // Categories
  renderDSSection('ds-categories', 'Categories', parsed.categories, cat => {
    const tier = cat['ds:tier'] || '';
    return `<div class="ds-token-item">
      <span class="ds-tier-badge ds-tier-${tier.toLowerCase()}">${escapeHtml(tier)}</span>
      <span class="ds-token-name">${escapeHtml(cat['ds:categoryName'] || cat['@id'])}</span>
    </div>`;
  });

  // Primitives
  renderDSSection('ds-primitives', `Primitives (${parsed.primitives.length})`, parsed.primitives, tok => {
    const val = tok['ds:value'] || '';
    const isColor = tok['ds:valueType'] === 'Color';
    const swatch = isColor ? `<span class="ds-color-swatch" style="background:${escapeHtml(val)};"></span>` : '';
    return `<div class="ds-token-item">
      ${swatch}
      <span class="ds-token-name">${escapeHtml(tok['ds:tokenName'] || tok['@id'])}</span>
      <span class="ds-token-value">${escapeHtml(val)}</span>
    </div>`;
  });

  // Semantics
  renderDSSection('ds-semantics', `Semantics (${parsed.semantics.length})`, parsed.semantics, tok => {
    const val = tok['ds:lightModeValue'] || '';
    const isColor = val.startsWith('#');
    const swatch = isColor ? `<span class="ds-color-swatch" style="background:${escapeHtml(val)};"></span>` : '';
    return `<div class="ds-token-item">
      ${swatch}
      <span class="ds-token-name">${escapeHtml(tok['ds:tokenName'] || tok['@id'])}</span>
      <span class="ds-token-value">${escapeHtml(val)}</span>
    </div>`;
  });

  // Components
  renderDSSection('ds-components', `Components (${parsed.components.length})`, parsed.components, tok => {
    const comp = tok['ds:componentName'] || '';
    const ref = tok['ds:referencesSemanticToken'];
    const refId = typeof ref === 'string' ? ref : ref?.['@id'] || '';
    return `<div class="ds-token-item">
      <span class="ds-tier-badge ds-tier-component">${escapeHtml(comp)}</span>
      <span class="ds-token-name">${escapeHtml(tok['ds:tokenName'] || tok['@id'])}</span>
      <span class="ds-token-value" title="${escapeHtml(refId)}">&rarr; ${escapeHtml(refId.split(':').pop())}</span>
    </div>`;
  });

  // Bridges (S7.6.2) — show cross-ontology bridge info when in multi mode
  const bridgesEl = document.getElementById('ds-bridges');
  if (bridgesEl) {
    const dsBridges = (state.crossEdges || []).filter(e =>
      e.sourceNamespace === 'ds:' || (e.from && e.from.startsWith('ds::')) || (e.to && e.to.startsWith('ds::'))
    );
    if (dsBridges.length > 0 && state.viewMode === 'multi') {
      const bridgesByTarget = {};
      for (const e of dsBridges) {
        const target = e.targetNamespace || e.to?.split('::')[0] || 'unknown';
        if (!bridgesByTarget[target]) bridgesByTarget[target] = [];
        bridgesByTarget[target].push(e);
      }
      bridgesEl.style.display = 'block';
      bridgesEl.innerHTML = `
        <div class="ds-section-toggle" onclick="this.parentElement.classList.toggle('collapsed')">
          Cross-Ontology Bridges (${dsBridges.length}) <span class="toggle-arrow">&#9660;</span>
        </div>
        <div class="ds-token-list">
          ${Object.entries(bridgesByTarget).map(([ns, edges]) => `
            <div class="ds-bridge-card">
              <span class="bridge-arrow">DS &rarr; ${escapeHtml(ns.replace(':', '').toUpperCase())}</span>
              <span class="bridge-target">${edges.length} connection${edges.length > 1 ? 's' : ''}</span>
            </div>
          `).join('')}
        </div>`;
    } else {
      bridgesEl.style.display = 'none';
    }
  }

  // Pages (S7.6.5)
  renderDSSection('ds-pages', `Pages (${(parsed.pages || []).length})`, parsed.pages || [], p => {
    const name = p['ds:pageName'] || p['@id'];
    const ver = p['ds:version'] || '';
    return `<div class="ds-token-item">
      <span class="ds-tier-badge" style="background:#1e40af; color:#93c5fd;">PAGE</span>
      <span class="ds-token-name">${escapeHtml(name)}</span>
      ${ver ? `<span class="ds-version-badge">v${escapeHtml(ver)}</span>` : ''}
    </div>`;
  });

  // Templates (S7.6.5)
  renderDSSection('ds-templates', `Templates (${(parsed.templates || []).length})`, parsed.templates || [], t => {
    const name = t['ds:templateName'] || t['@id'];
    const ver = t['ds:version'] || '';
    return `<div class="ds-token-item">
      <span class="ds-tier-badge" style="background:#6A1B9A; color:#CE93D8;">TMPL</span>
      <span class="ds-token-name">${escapeHtml(name)}</span>
      ${ver ? `<span class="ds-version-badge">v${escapeHtml(ver)}</span>` : ''}
    </div>`;
  });

  // Show actions
  _show('ds-actions');
}

function renderDSSection(containerId, title, items, renderItem) {
  const el = document.getElementById(containerId);
  if (!el) return;

  if (!items || items.length === 0) {
    el.style.display = 'none';
    return;
  }

  el.style.display = 'block';
  el.innerHTML = `
    <div class="ds-section-toggle" onclick="this.parentElement.classList.toggle('collapsed')">
      ${escapeHtml(title)} <span class="toggle-arrow">&#9660;</span>
    </div>
    <div class="ds-token-list">
      ${items.map(renderItem).join('')}
    </div>`;
}

function applyDSToVisualiser() {
  const brand = state.activeDSBrand;
  if (!brand) { alert('Select a brand first'); return; }

  const parsed = state.dsInstances.get(brand);
  if (!parsed) return;

  // Reset previous if any
  if (state.dsAppliedCSSVars) {
    resetCSSVars(state.dsAppliedCSSVars);
  }

  const cssVars = generateCSSVars(parsed);
  applyCSSVars(cssVars);
  state.dsAppliedCSSVars = cssVars;

  // F40.8: Apply brand variant tokenOverrides (BR-DS-006 enforced inside)
  const brandOverrideVars = applyBrandOverrides(parsed);
  if (Object.keys(brandOverrideVars).length > 0) {
    Object.assign(state.dsAppliedCSSVars, brandOverrideVars);
    console.log(`[DS] Applied ${Object.keys(brandOverrideVars).length} brand override(s)`);
  }
  invalidateTokenCache();

  // DR-BRAND-001: set brand context for node shadow glow
  const accentColor = cssVars['--viz-accent'] || '#9dfff5';
  state.brandContext = { brand, tier: 'PF-Instance', accentColor };

  // Persist so the theme survives page reload
  localStorage.setItem('oaa-viz-ds-brand', brand);
  localStorage.setItem('oaa-viz-ds-vars', JSON.stringify(cssVars));

  console.log(`[DS] Applied ${Object.keys(cssVars).length} CSS vars from brand "${brand}"`);
  refreshAdminPanel();
}

function resetDSTheme() {
  if (state.dsAppliedCSSVars) {
    resetCSSVars(state.dsAppliedCSSVars);
    state.dsAppliedCSSVars = null;
    console.log('[DS] Theme reset to defaults');
  }
  // DR-BRAND-001: clear brand context
  state.brandContext = null;
  invalidateTokenCache();
  localStorage.removeItem('oaa-viz-ds-brand');
  localStorage.removeItem('oaa-viz-ds-vars');
  refreshAdminPanel();
}

// ========================================
// DS BRIDGE FOCUS (S7.6.2)
// ========================================

function focusDSBridges() {
  if (state.viewMode !== 'multi') {
    alert('Load multiple ontologies (including DS-ONT) in merged graph mode to see DS bridges.');
    return;
  }
  // Activate cross-edge filter to show only cross-ontology edges
  if (!state.crossEdgeFilterActive) {
    state.crossEdgeFilterActive = true;
  }
  // If bridge filter exists, activate it
  if (!state.bridgeFilterActive) {
    state.bridgeFilterActive = true;
  }
  // Re-render the merged graph with filters applied
  if (state.mergedGraph && state.crossEdges && state.seriesData) {
    renderMultiGraph(state.mergedGraph, state.crossEdges, state.seriesData);
  }
  console.log('[DS] Bridge focus activated — showing cross-ontology connections');
}

// ========================================
// DS WORKFLOW VIEW (S7.6.7)
// ========================================

async function showDSWorkflow() {
  try {
    const processPath = REGISTRY_BASE_PATH + 'PE-Series/DS-ONT/ds-token-extraction-process-v2.0.0.json';
    const resp = await fetch(processPath);
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const processJson = await resp.json();
    const mermaidText = generateWorkflowMermaid(processJson);
    if (!mermaidText) { alert('Failed to generate workflow diagram'); return; }
    await loadAndRenderMermaid(mermaidText, 'PE-DS-EXTRACT-001 — Token Extraction Pipeline');
    console.log('[DS] Workflow diagram rendered');
  } catch (err) {
    console.error('[DS Workflow]', err);
    alert('Failed to load DS workflow: ' + err.message);
  }
}

// ========================================
// DS FIGMA MAKE IMPORT (S7.6.5)
// ========================================

function importFigmaMake() {
  if (!state.activeDSBrand || !state.dsInstances.has(state.activeDSBrand)) {
    alert('Select a DS brand first.');
    return;
  }
  const input = document.getElementById('figma-make-file-input');
  if (!input) return;
  input.onchange = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const json = JSON.parse(ev.target.result);
        const page = importFigmaMakeAsPage(json, state.activeDSBrand);
        if (!page) { alert('Invalid Figma Make file'); return; }
        const result = saveDSArtefact(state.activeDSBrand, page);
        if (!result.success) { alert(result.error); return; }
        // Re-render DS panel
        const parsed = state.dsInstances.get(state.activeDSBrand);
        if (parsed) renderDSPanel(parsed);
        console.log(`[DS] Imported Figma Make page: ${page['ds:pageName']}`);
      } catch (err) {
        alert('Failed to parse file: ' + err.message);
      }
    };
    reader.readAsText(file);
    input.value = ''; // reset for re-import
  };
  input.click();
}

// ========================================
// DS EXPORT (S7.6.8)
// ========================================

function exportDSPages() {
  const brand = state.activeDSBrand;
  if (!brand) { alert('Select a brand first'); return; }
  const parsed = state.dsInstances.get(brand);
  if (!parsed) return;

  const json = exportDSForDesignDirector(parsed, brand, { includeTokens: true });
  const blob = new Blob([json], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `${brand}-pages-for-design-director.json`;
  a.click();
  URL.revokeObjectURL(url);
  console.log(`[DS Export] Downloaded ${brand} pages`);
}

function copyDSPagesToClipboard() {
  const brand = state.activeDSBrand;
  if (!brand) { alert('Select a brand first'); return; }
  const parsed = state.dsInstances.get(brand);
  if (!parsed) return;

  const json = exportDSForDesignDirector(parsed, brand, { includeTokens: true });
  navigator.clipboard.writeText(json).then(() => {
    console.log('[DS Export] Copied to clipboard');
  }).catch(err => {
    console.error('[DS Export] Clipboard failed:', err);
  });
}

