    {
      "@type": "DefinedTerm",
      "@id": "emc:OntologyComposition",
      "name": "OntologyComposition",
      "description": "A resolved set of ontologies to load for a given requirement category and scoping context. Contains required, recommended, and optional ontology lists with dependency chain resolution.",
      "termCode": "OC",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "compositionId": {
          "type": "string",
          "description": "Unique identifier for the composition"
        },
        "requiredOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Must-load ontologies"
        },
        "recommendedOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Recommended for completeness"
        },
        "optionalOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional depth ontologies"
        },
        "excludedByMaturity": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ontologies excluded due to maturity filter"
        },
        "activeSeries": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Which series are activated"
        }
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:CompositionRule",
      "name": "CompositionRule",
      "description": "A rule that governs how ontologies are selected and composed based on scoping dimensions. Rules are prioritised and executed in sequence to resolve the final ontology composition.",
      "termCode": "CR",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "ruleId": {
          "type": "string",
          "description": "Unique rule identifier",
          "example": "emc:rule:foundation-always"
        },
        "ruleName": {
          "type": "string",
          "description": "Human-readable rule name"
        },
        "condition": {
          "type": "string",
          "description": "When this rule applies"
        },
        "action": {
          "type": "string",
          "description": "What the rule does"
        },
        "priority": {
          "type": "integer",
          "description": "Execution priority (1 = highest)"
        }
      },
      "instances": [
        {
          "@id": "emc:CompositionRule-FoundationAlways",
          "ruleName": "Foundation Always Required",
          "priority": 1,
          "description": "Any enterprise model must include ORG-ONT as the base foundation layer"
        },
        {
          "@id": "emc:CompositionRule-DependencyChain",
          "ruleName": "Dependency Chain Resolution",
          "priority": 2,
          "description": "When ontology X is required, automatically include all ontologies in X.dependencies"
        },
        {
          "@id": "emc:CompositionRule-MaturityFilter",
          "ruleName": "Maturity-Based Filtering",
          "priority": 3,
          "description": "When organisation maturity is below threshold, exclude advanced ontologies (KPI, GA, BSC)"
        },
        {
          "@id": "emc:CompositionRule-PFIInstance",
          "ruleName": "PFI Instance Data Loading",
          "priority": 4,
          "description": "When context level is PFI and product specified, load product-specific instance data"
        },
        {
          "@id": "emc:CompositionRule-RCSGGovernance",
          "ruleName": "RCSG Governance Overlay",
          "priority": 5,
          "description": "When compliance requirement scope is active, include RCSG-Series (GRC-FW, MCSB, GDPR, PII) as governance overlay"
        },
        {
          "@id": "emc:CompositionRule-AgenticBuild",
          "ruleName": "Agentic Build Requirements",
          "priority": 6,
          "description": "When requirement scope is AGENTIC, include PE-Process-Engr-ONT with AI agent definitions"
        },
        {
          "@id": "emc:CompositionRule-AgentRoleBridge",
          "ruleName": "Agent-Role Bridge Resolution",
          "priority": 7,
          "description": "When AGENTIC scope active AND PFI context, resolve agent-to-role-to-RBAC chain. Load PE-ONT (pe:AIAgent) + RRR-ONT (roles, RBAC) + agent instance data. Enables graph-queryable process ownership."
        }
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:GraphPattern",
      "name": "GraphPattern",
      "description": "A reusable pattern for composing ontologies into unified graph models. Patterns define how entities from different ontologies connect and traverse across series boundaries.",
      "termCode": "GP",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "patternId": {
          "type": "string",
          "description": "Unique pattern identifier"
        },
        "patternName": {
          "type": "string",
          "description": "Human-readable pattern name"
        },
        "hub": {
          "type": "string",
          "description": "Central entity or ontology (if hub-spoke)"
        },
        "spokes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Connected series (if hub-spoke)"
        },
        "useCase": {
          "type": "string",
          "description": "When to apply this pattern"
        }
      },
      "instances": [
        {
          "@id": "emc:GraphPattern-HubSpoke",
          "patternName": "Hub-Spoke Pattern",
          "description": "ORG-CONTEXT as central hub connecting VE, PE, RCSG, and Orchestration series as spokes for full enterprise model"
        },
        {
          "@id": "emc:GraphPattern-LineageChain",
          "patternName": "Lineage Chain Pattern",
          "description": "Sequential dependency from strategy to execution: VSOM → OKR → VP → PMF → EFS with traceability"
        },
        {
          "@id": "emc:GraphPattern-BridgeJoin",
          "patternName": "Bridge Join Pattern",
          "description": "Cross-ontology relationships via join points enabling cross-domain queries (VP↔RRR, CRT↔VP, EFS↔PPM, VSOM↔OKR, EA↔RCSG)"
        },
        {
          "@id": "emc:GraphPattern-GovernanceOverlay",
          "patternName": "Governance Overlay Pattern",
          "description": "RCSG-Series overlays onto PE and VE series providing compliance and security governance cross-references via GRC-FW hub"
        },
        {
          "@id": "emc:GraphPattern-AgentBridge",
          "patternName": "Agent-Role Bridge Pattern",
          "description": "pe:AIAgent bridges to RRR roles (agentActsAs), PE processes (agentOwnsProcess), and RBAC policies (agentGovernedBy) — enables graph-queryable agent authorization and process ownership"
        }
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:InstanceConfiguration",
      "name": "InstanceConfiguration",
      "description": "A pre-defined PFI configuration for a specific product instance. Specifies which ontologies to load, what instance data files to use, and how to filter by organisation context.",
      "termCode": "IC",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "instanceId": {
          "type": "string",
          "description": "Unique instance identifier"
        },
        "productCode": {
          "type": "string",
          "description": "Product code (e.g. BAIV-AIV)"
        },
        "contextLevel": {
          "type": "string",
          "description": "Always PFI for instances"
        },
        "requirementScopes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Active requirement scopes"
        },
        "requiredOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ontologies to load"
        },
        "recommendedOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ontologies recommended for the instance"
        },
        "instanceDataFiles": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Product-specific data files"
        },
        "maturityLevel": {
          "type": "integer",
          "description": "Organisation maturity level (0-5) — affects composition rule filtering"
        },
        "designSystemConfig": {
          "type": "object",
          "description": "DS-ONT brand resolution — maps this PFI instance to a design system brand for automatic theme application",
          "properties": {
            "brand": {
              "type": [
                "string",
                "null"
              ],
              "description": "DS-ONT brand key (null = PF-Core defaults)"
            },
            "fallback": {
              "type": "string",
              "description": "Fallback brand if primary is null or missing"
            },
            "configVersion": {
              "type": "string",
              "description": "Version pin for DS config schema"
            }
          }
        },
        "appSkeletonConfig": {
          "type": "object",
          "description": "DS-ONT v2.0.0 application skeleton cascade — maps this PFI instance to a base app skeleton and optional overrides for zone layout, navigation layers, and component placements. Follows the 4-tier EMC cascade: PFC → PFI → Product → App.",
          "properties": {
            "baseApp": {
              "type": "string",
              "description": "PFC skeleton ID (e.g., 'pfc-visualiser')"
            },
            "pfiOverrides": {
