        "designSystemConfig": {
          "type": "object",
          "description": "DS-ONT brand resolution — maps this PFI instance to a design system brand for automatic theme application",
          "properties": {
            "brand": {
              "type": ["string", "null"],
              "description": "DS-ONT brand key (null = PF-Core defaults)"
            },
            "fallback": {
              "type": "string",
              "description": "Fallback brand if primary is null or missing"
            },
            "configVersion": {
              "type": "string",
              "description": "Version pin for DS config schema"
            }
          }
        },
        "appSkeletonConfig": {
          "type": "object",
          "description": "DS-ONT v2.0.0 application skeleton cascade — maps this PFI instance to a base app skeleton and optional overrides for zone layout, navigation layers, and component placements. Follows the 4-tier EMC cascade: PFC → PFI → Product → App.",
          "properties": {
            "baseApp": {
              "type": "string",
              "description": "PFC skeleton ID (e.g., 'pfc-visualiser')"
            },
            "pfiOverrides": {
              "type": ["string", "null"],
              "description": "Path to PFI-tier skeleton override JSONLD (adds zones, L4 nav, PFI components)"
            },
            "productOverrides": {
              "type": ["string", "null"],
