      "instances": [
        {
          "@id": "emc:InstanceConfiguration-BAIV",
          "productCode": "BAIV-AIV",
          "description": "BAIV AI Visibility platform — B2B marketing product with VP, RRR, EFS ontologies, BAIV-specific instance data, and 3 graph-scope rules for product/market/maturity data slicing",
          "contextLevel": "PFI",
          "requirementScopes": [
            "PRODUCT",
            "COMPETITIVE",
            "STRATEGIC"
          ],
          "maturityLevel": 1,
          "verticalMarket": "MarTech",
          "appSkeletonConfig": {
            "baseApp": "pfc-visualiser",
            "pfiOverrides": "PBS/ONTOLOGIES/ontology-library/PE-Series/DS-ONT/instance-data/baiv-app-skeleton-v1.0.0.jsonld",
            "productOverrides": null,
            "appOverrides": null
          },
          "scopeRules": [
            {
              "@id": "emc:GraphScopeRule-BAIV-AIV-Product-Scope",
              "ruleId": "BAIV-AIV-Product-Scope",
              "ruleName": "BAIV AIV Product Scope",
              "description": "Include VP, RRR, and EFS entities scoped to BAIV AIV product context",
              "scopeLevel": "entity",
              "priority": 1,
              "isActive": true,
              "condition": {
                "@type": "emc:ScopeCondition",
                "conditionType": "product-match",
                "conditionOperator": "equals",
                "conditionValue": "BAIV-AIV",
                "conditionTarget": "org-ctx:Product.productCode"
              },
              "action": {
                "@type": "emc:ScopeAction",
                "actionType": "include-data",
                "targetNamespaces": ["vp:", "rrr:", "efs:"],
                "targetEntityTypes": ["vp:ValueProposition", "vp:IdealCustomerProfile", "rrr:Role", "rrr:Responsibility", "efs:Epic", "efs:Feature", "efs:Story"],
                "targetEntityFilter": "productContext == 'BAIV-AIV'",
                "applyToRelationships": true
              }
            },
            {
              "@id": "emc:GraphScopeRule-BAIV-MarTech-Market-Scope",
              "ruleId": "BAIV-MarTech-Market-Scope",
              "ruleName": "BAIV MarTech Market Scope",
              "description": "Include competitive analysis entities for MarTech market segment",
              "scopeLevel": "entity",
              "priority": 2,
              "isActive": true,
              "condition": {
                "@type": "emc:ScopeCondition",
                "conditionType": "market-segment",
                "conditionOperator": "equals",
                "conditionValue": "MarTech",
                "conditionTarget": "org-ctx:Organisation.verticalMarket"
              },
              "action": {
                "@type": "emc:ScopeAction",
                "actionType": "include-data",
                "targetNamespaces": ["org-ctx:", "ind:"],
                "targetEntityTypes": ["org-ctx:CompetitiveLandscape", "org-ctx:Competitor", "ind:IndustryAnalysis"],
                "targetEntityFilter": "marketSegment == 'MarTech'",
                "applyToRelationships": true
              }
            },
            {
              "@id": "emc:GraphScopeRule-BAIV-Startup-Maturity-Scope",
              "ruleId": "BAIV-Startup-Maturity-Scope",
              "ruleName": "BAIV Startup Maturity Scope",
              "description": "Exclude advanced analysis entities for organisations below maturity level 3",
              "scopeLevel": "ontology",
              "priority": 3,
              "isActive": true,
              "condition": {
                "@type": "emc:ScopeCondition",
                "conditionType": "maturity-threshold",
                "conditionOperator": "less-than",
                "conditionValue": "3",
                "conditionTarget": "org-ctx:Organisation.maturityLevel"
              },
              "action": {
                "@type": "emc:ScopeAction",
                "actionType": "exclude-data",
                "targetNamespaces": ["kpi:", "ga:"],
                "targetEntityTypes": ["kpi:KPI", "kpi:MetricDefinition", "ga:GapAnalysis", "ga:Threat"],
                "targetEntityFilter": null,
                "applyToRelationships": true
              }
            }
          ],
          "composedGraphSpec": {
            "@id": "emc:ComposedGraphSpec-BAIV-AIV",
            "specId": "BAIV-AIV-Graph-Spec",
            "specName": "BAIV AIV Composed Graph Specification",
            "componentOntologies": ["VP-ONT", "RRR-ONT", "EFS-ONT", "ORG-CONTEXT-ONT"],
            "dataSliceRefs": [
              {"ontology": "VP-ONT", "slice": "BAIV-AIV value propositions and ICPs"},
              {"ontology": "RRR-ONT", "slice": "BAIV roles, RACI assignments, RBAC policies"},
              {"ontology": "EFS-ONT", "slice": "BAIV epics, features, stories"},
              {"ontology": "ORG-CONTEXT-ONT", "slice": "BAIV organisation profile and competitive landscape"}
            ],
            "joinPoints": [
              {"from": "vp:IdealCustomerProfile", "to": "rrr:Role", "relationship": "icpMapsToRole", "description": "VP ICP segments map to RRR organisational roles"},
              {"from": "rrr:Role", "to": "org:Organisation", "relationship": "roleWithinOrg", "description": "RRR roles exist within organisational context"},
              {"from": "vp:Problem", "to": "efs:Epic", "relationship": "problemAddressedByEpic", "description": "VP problems are addressed by EFS delivery epics"}
            ],
            "rootAnchorEntity": "emc:InstanceConfiguration-BAIV",
            "frozenVersion": "1.0.0"
          },
          "canonicalSnapshot": {
            "@id": "emc:CanonicalSnapshot-BAIV-AIV-v1",
            "snapshotId": "BAIV-AIV-Snapshot-v1.0.0",
            "snapshotVersion": "1.0.0",
            "sourceComposedGraphSpec": "emc:ComposedGraphSpec-BAIV-AIV",
            "frozenAt": "2026-02-21T00:00:00Z",
            "frozenBy": "PF-Core Admin",
            "changeControlStatus": "locked",
            "parentSnapshot": null
          }
        },
        {
          "@id": "emc:InstanceConfiguration-VHF",
          "productCode": "VHF-Nutrition",
          "description": "VHF Nutrition App — B2C HealthTech product. Simplest valid PFI composition: 6-ontology, 3-pattern, B2C-focused graph. Proving ground for EMC composition pipeline.",
          "contextLevel": "PFI",
          "requirementScopes": [
            "PRODUCT"
          ],
          "requiredOntologies": [
            "VP-ONT",
            "RRR-ONT",
            "PMF-ONT",
            "CRT-ONT",
            "ORG-ONT",
            "ORG-CONTEXT-ONT"
          ],
          "recommendedOntologies": [
            "VSOM-ONT",
            "OKR-ONT"
          ],
          "maturityLevel": 0,
          "verticalMarket": "HealthTech",
          "designSystemConfig": {
            "brand": null,
            "fallback": "pfc",
            "configVersion": "1.0.0"
          },
          "compositionWorkedExample": {
            "input": {
              "contextLevel": "PFI",
              "productContext": "VHF-Nutrition",
              "orgContext": {
                "industry": "HealthTech",
                "size": "PoC",
                "maturityLevel": 0
              },
              "requirementScopes": [
                "PRODUCT"
              ]
            },
            "seriesActivation": {
              "PRODUCT": [
                "VE-Series (VP, PMF, CRT)",
                "Foundation (ORG, ORG-CONTEXT)"
              ]
            },
            "rulesFired": [
              {
                "rule": "FoundationAlways",
                "result": "ORG-ONT added to required"
              },
              {
                "rule": "DependencyChain",
                "result": "VP needs RRR → RRR-ONT added; CRT needs VP → already present"
              },
              {
                "rule": "MaturityFilter",
                "result": "maturityLevel 0 → exclude KPI-ONT, GA-ONT, BSC-ONT"
              },
              {
                "rule": "PFIInstance",
                "result": "Load VHF instance data files (VP, RRR, CRT)"
              },
              {
                "rule": "RCSGGovernance",
                "result": "No COMPLIANCE scope → skipped"
              },
              {
                "rule": "AgenticBuild",
                "result": "No AGENTIC scope → skipped"
              },
              {
                "rule": "AgentRoleBridge",
                "result": "No AGENTIC scope → skipped"
              }
            ],
            "resolvedComposition": {
              "requiredOntologies": [
                "ORG-ONT",
                "ORG-CONTEXT-ONT",
                "VP-ONT",
                "RRR-ONT",
                "PMF-ONT",
                "CRT-ONT"
              ],
              "recommendedOntologies": [
                "VSOM-ONT",
                "OKR-ONT"
              ],
              "optionalOntologies": [
                "INDUSTRY-ONT"
              ],
              "excludedByMaturity": [
                "KPI-ONT",
                "GA-ONT",
                "BSC-ONT"
              ],
              "activeSeries": [
                "VE-Series",
                "Foundation",
                "Orchestration"
              ]
            },
            "graphPatterns": [
              "HubSpoke (ORG-CONTEXT hub → VP, PMF, CRT, RRR spokes)",
              "LineageChain (VP → PMF, simplified)",
              "BridgeJoin (VP↔RRR, CRT↔VP)"
            ]
          }
        },
