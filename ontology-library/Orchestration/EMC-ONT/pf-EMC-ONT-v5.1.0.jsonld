            "type": "string"
          },
          "description": "Ontologies recommended for the instance"
        },
        "instanceDataFiles": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Product-specific data files"
        },
        "maturityLevel": {
          "type": "integer",
          "description": "Organisation maturity level (0-5) — affects composition rule filtering"
