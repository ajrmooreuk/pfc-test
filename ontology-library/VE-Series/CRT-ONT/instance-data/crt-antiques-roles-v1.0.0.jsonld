        }
      ]
    },

    {
      "@id": "crt:ant-interior-designer",
      "@type": "crt:CustomerRole",
      "crt:roleId": "crt:ant-interior-designer",
      "crt:name": "Interior Designer",
      "crt:channel": "B2B2C",
      "crt:category": "B2B2C_Intermediary",
      "crt:description": "Professional interior designer or decorator who sources and specifies antique and vintage pieces for client residential or commercial projects. Acts as a B2B2C intermediary — purchasing on behalf of private or commercial clients, often with a design fee or trade discount margin. Relationship with auction houses and dealers is professional and transactional, built on speed of access, trade pricing, condition reliability, and the breadth of sourcing capability. Their specification decisions drive purchasing by wealthy clients who follow their creative direction.",
      "crt:motivations": "Sourcing distinctive statement pieces that differentiate their design projects, accessing trade pricing and priority viewing, reliable condition and sizing information to avoid costly mistakes, building trusted supplier relationships for repeat sourcing, expanding the range of antique categories they can confidently specify, professional credibility for curating period-appropriate pieces",
      "crt:vpStakeholderType": "vp:Stakeholder",
      "crt:vpStakeholderRole": "Influencer",
      "crt:typicalEngagement": "Moderate",
      "crt:decisionStyle": "AestheticCommercial",
      "crt:buyerJourneyType": "ProjectDriven",
      "crt:budgetAuthority": "Delegated",
      "crt:priceElasticity": "Medium",
      "crt:purchaseFrequency": "Frequent",
      "crt:qualifiers": [
        {
          "@type": "crt:RoleQualifier",
          "crt:criteriaType": "Professional",
          "crt:criteriaName": "Design Practice",
          "crt:operator": "equals",
          "crt:value": "Operates as a professional interior designer or decorator, member of BIID, RIBA, or similar, or trading as a design practice with client projects"
        },
        {
          "@type": "crt:RoleQualifier",
          "crt:criteriaType": "Behavioural",
          "crt:criteriaName": "Antique Sourcing Pattern",
          "crt:operator": "greaterThanOrEqual",
          "crt:value": "Specifies or sources antique or vintage pieces for client projects at least 4 times per year"
        },
        {
          "@type": "crt:RoleQualifier",
          "crt:criteriaType": "Financial",
          "crt:criteriaName": "Client Budget Managed",
          "crt:operator": "greaterThanOrEqual",
          "crt:value": "Manages furniture and antique sourcing budgets of at least GBP 20,000 per project"
        }
      ]
    },

    {
      "@id": "crt:ant-dealer-retail",
      "@type": "crt:CustomerRole",
      "crt:roleId": "crt:ant-dealer-retail",
      "crt:name": "Retail Dealer",
      "crt:channel": "B2B2C",
      "crt:category": "B2B2C_Intermediary",
      "crt:description": "Antiques dealer who operates a physical retail gallery, shop, or market stall selling primarily to the general public (end consumers), but who also participates in the trade market by buying from auction houses, trade fairs, and fellow dealers. Sits at the B2B2C interface — trade buyer on the acquisition side, consumer retailer on the sales side. Typically operates at accessible price points, relies on footfall, passing trade, and online marketplace presence. May also exhibit at general antique fairs or centres.",
      "crt:motivations": "Stock turn at sustainable margin, customer footfall and return business, online marketplace visibility (1stDibs, Etsy, Vinterior, Chairish), sourcing stock at trade prices from auction or peer dealers, building a retail brand and reputation within a specialist niche, geographic catchment of their gallery location",
      "crt:vpStakeholderType": "vp:Stakeholder",
      "crt:vpStakeholderRole": "PrimaryUser",
      "crt:typicalEngagement": "High",
      "crt:decisionStyle": "CommercialRetail",
      "crt:buyerJourneyType": "OpportunisticRepeat",
      "crt:budgetAuthority": "Full",
      "crt:priceElasticity": "Medium",
      "crt:purchaseFrequency": "Frequent",
      "crt:qualifiers": [
        {
          "@type": "crt:RoleQualifier",
          "crt:criteriaType": "Professional",
          "crt:criteriaName": "Retail Operation",
          "crt:operator": "equals",
          "crt:value": "Operates a physical retail antiques gallery, shop, antique centre stall, or active online retail presence selling antiques to the general public"
        },
        {
          "@type": "crt:RoleQualifier",
          "crt:criteriaType": "Behavioural",
          "crt:criteriaName": "Dual-Channel Trading",
          "crt:operator": "equals",
          "crt:value": "Buys stock from auction, trade sources, or fellow dealers (B2B) and sells to end consumers (B2C) in the same trading entity"
        },
        {
          "@type": "crt:RoleQualifier",
          "crt:criteriaType": "Spending",
          "crt:criteriaName": "Annual Stock Investment",
          "crt:operator": "between",
          "crt:value": "GBP 5,000 to GBP 100,000 annual stock acquisition spend"
        }
      ]
    },

    {
      "@id": "crt:antiques-section6-qualification-examples",
      "@type": "crt:QualificationExampleSet",
      "crt:exampleSetId": "crt:antiques-qualification-examples-s6",
      "crt:description": "Section 6 qualification examples — three worked examples demonstrating how RoleQualifier instances are applied to real individuals during customer role assignment. Each example shows a full qualifier evaluation stack.",

      "crt:examples": [
        {
          "@type": "crt:QualificationExample",
          "crt:exampleId": "crt:ex-s6-serious-collector",
          "crt:exampleTitle": "Section 6.1 — Serious Collector Qualification Example",
          "crt:candidateDescription": "Margaret, age 68, retired professor, has been collecting 18th-century English delftware for 35 years. Owns 47 pieces in a coherent collection, spends approximately GBP 12,000 per year at specialist auctions and dealers, contributes scholarly notes to the English Ceramic Circle journal, and was approached by a regional museum to loan 8 pieces for a recent exhibition.",
          "crt:targetRoleId": "crt:ant-serious-collector",
          "crt:qualifierEvaluations": [
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Collection Depth",
              "crt:criteriaType": "Behavioural",
              "crt:operator": "greaterThanOrEqual",
              "crt:value": "Owns a collection of at least 20 antique items with thematic or categorical coherence",
              "crt:candidateEvidence": "Owns 47 pieces of 18th-century English delftware — a highly coherent specialist collection accumulated over 35 years",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            },
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Annual Acquisition Spend",
              "crt:criteriaType": "Spending",
              "crt:operator": "greaterThanOrEqual",
              "crt:value": "GBP 5,000 annually on antique acquisitions",
              "crt:candidateEvidence": "Spends approximately GBP 12,000 per year through auction and dealer channels",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            },
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Specialist Knowledge",
              "crt:criteriaType": "Psychographic",
              "crt:operator": "equals",
              "crt:value": "Demonstrates specialist knowledge sufficient to evaluate attribution, condition, and rarity independently",
              "crt:candidateEvidence": "Contributes scholarly articles to the English Ceramic Circle journal; peer group recognition of expertise; capable of museum-standard object assessment",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            }
          ],
          "crt:overallOutcome": "QUALIFIED",
          "crt:assignedRole": "crt:ant-serious-collector",
          "crt:notes": "Margaret is an exemplary Serious Collector — 3/3 qualifiers pass with high confidence. Her scholarly engagement and museum loan activity place her at the upper end of this role category."
        },

        {
          "@type": "crt:QualificationExample",
          "crt:exampleId": "crt:ex-s6-insurance-underwriter",
          "crt:exampleTitle": "Section 6.2 — Insurance Underwriter Qualification Example",
          "crt:candidateDescription": "James, age 44, is a senior underwriter at a Lloyd's syndicate. Holds ACII qualification (Chartered Insurance Institute). Manages a book of fine art, jewellery, and private collection insurance risks with total insured value of approximately GBP 180 million. Instructs 15-20 formal RICS and CIVA valuations per year for items above GBP 10,000. Attends Masterpiece London and TEFAF Maastricht annually for market intelligence.",
          "crt:targetRoleId": "crt:ant-insurance-underwriter",
          "crt:qualifierEvaluations": [
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Insurance Qualification",
              "crt:criteriaType": "Professional",
              "crt:operator": "equals",
              "crt:value": "Qualified underwriter (CII ACII/FCII or Lloyd's approved) with specialism in fine art, jewellery, or high-value personal possessions lines",
              "crt:candidateEvidence": "Holds ACII, is an approved Lloyd's underwriter, specialism in fine art and private collection risks",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            },
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Portfolio Specialism",
              "crt:criteriaType": "Behavioural",
              "crt:operator": "equals",
              "crt:value": "Underwrites or brokers fine art, antiques, or jewellery insurance policies as primary or significant book component",
              "crt:candidateEvidence": "Fine art, jewellery, and private collection risks form the primary book — GBP 180M total insured value under management",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            },
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Valuation Dependency",
              "crt:criteriaType": "Professional",
              "crt:operator": "equals",
              "crt:value": "Requires third-party professional valuations for items over GBP 5,000",
              "crt:candidateEvidence": "Instructs 15-20 formal RICS and CIVA valuations per year for items above GBP 10,000 — standard underwriting practice for his book",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            }
          ],
          "crt:overallOutcome": "QUALIFIED",
          "crt:assignedRole": "crt:ant-insurance-underwriter",
          "crt:notes": "James qualifies on all three criteria with high confidence. His annual valuation instruction volume (15-20) is above average for this role, indicating a high-value customer relationship opportunity."
        },

        {
          "@type": "crt:QualificationExample",
          "crt:exampleId": "crt:ex-s6-inheritor",
          "crt:exampleTitle": "Section 6.3 — Inheritor Qualification Example",
          "crt:candidateDescription": "Sarah, age 52, has recently lost her mother. The estate includes approximately 200 items — furniture, silver, paintings, ceramics, and jewellery — accumulated by her parents over 60 years. Sarah has never bought or sold at auction. She is overwhelmed by the volume and variety of items, emotionally attached to many of them, and unsure which (if any) to keep versus sell. Her solicitor has suggested she seek a valuation before making decisions.",
          "crt:targetRoleId": "crt:ant-inheritor",
          "crt:qualifierEvaluations": [
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Inheritance Trigger",
              "crt:criteriaType": "Contextual",
              "crt:operator": "equals",
              "crt:value": "Has recently inherited or is in the process of administering an inheritance that includes antiques, art, jewellery, or household effects",
              "crt:candidateEvidence": "Recently bereaved — mother's estate contains approximately 200 items across furniture, silver, paintings, ceramics, and jewellery",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            },
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Market Inexperience",
              "crt:criteriaType": "Psychographic",
              "crt:operator": "equals",
              "crt:value": "Has limited or no prior experience buying or selling through auction houses or specialist dealers",
              "crt:candidateEvidence": "Has never bought or sold at auction; no experience of the specialist antiques or fine art market",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "High"
            },
            {
              "@type": "crt:QualifierEvaluation",
              "crt:criteriaName": "Disposal Consideration",
              "crt:criteriaType": "Behavioural",
              "crt:operator": "equals",
              "crt:value": "Actively considering selling at least some inherited items rather than retaining all",
              "crt:candidateEvidence": "Solicitor has recommended valuation as first step; Sarah is considering her options and is not planning to retain all 200 items",
              "crt:evaluationOutcome": "PASS",
              "crt:confidence": "Medium",
              "crt:confidenceNote": "Disposal intent is likely but not yet confirmed — medium confidence pending clearer expression of selling intent at initial consultation"
            }
          ],
          "crt:overallOutcome": "QUALIFIED",
          "crt:assignedRole": "crt:ant-inheritor",
          "crt:notes": "Sarah qualifies as an Inheritor. Note the medium confidence on Disposal Consideration — this is typical for early-stage Inheritor interactions where emotional processing is still ongoing. Recommended initial engagement: a sensitive, no-obligation free valuation consultation to build trust before any selling conversation."
        }
      ]
    }

