    { "@type": "pe:linkTo", "from": "pe:delta-link-d-to-e", "to": "pe:delta-step-evaluate" },
    { "@type": "pe:linkFrom", "from": "pe:delta-link-e-to-l", "to": "pe:delta-step-evaluate" },
    { "@type": "pe:linkTo", "from": "pe:delta-link-e-to-l", "to": "pe:delta-step-leverage" },
    { "@type": "pe:linkFrom", "from": "pe:delta-link-l-to-t", "to": "pe:delta-step-leverage" },
    { "@type": "pe:linkTo", "from": "pe:delta-link-l-to-t", "to": "pe:delta-step-transform" },
    { "@type": "pe:linkFrom", "from": "pe:delta-link-t-to-a", "to": "pe:delta-step-transform" },
    { "@type": "pe:linkTo", "from": "pe:delta-link-t-to-a", "to": "pe:delta-step-adapt" },
    { "@type": "pe:linkFrom", "from": "pe:delta-link-a-to-e-feedback", "to": "pe:delta-step-adapt" },
    { "@type": "pe:linkTo", "from": "pe:delta-link-a-to-e-feedback", "to": "pe:delta-step-evaluate" },

    { "@type": "pe:pathImplementsPattern", "from": "pe:delta-path-cycle-flow", "to": "pe:delta-pattern-delta-cycle" }
  ]
}
