{
  "@context": {
    "@vocab": "https://schema.org/",
    "ds": "https://platformcore.io/ontology/ds/",
    "emc": "https://platformcore.io/ontology/emc/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@id": "ds:pfc-app-skeleton-v1.0.0",
  "@type": "ds:AppSkeletonInstance",
  "name": "PFC Base Application Skeleton",
  "description": "PF-Core immutable base skeleton defining 21 AppZones, 4 NavLayers (L1–L4), ~40 NavItems, and ~25 ZoneComponent placements. This is the PFC tier of the 4-tier EMC cascade (PFC → PFI → Product → App). PFI instances inherit and extend this skeleton — they may add zones, nav items, and components but cannot modify PFC-tier entities.",
  "version": "2.0.0",
  "dateCreated": "2026-02-21",
  "dateModified": "2026-02-24",
  "ds:targetOntology": "ds-v3.0.0-oaa-v6.json",

  "@graph": [

    {
      "@id": "ds:app-pfc-visualiser",
      "@type": "ds:Application",
      "ds:appId": "pfc-visualiser",
      "ds:appName": "PF-Core Graph Workbench & Ontology Visualiser",
      "ds:version": "4.5.0",
      "ds:appType": "SPA",
      "ds:rootRoute": "/",
      "ds:cascadeTier": "PFC",
      "ds:appUsesDesignSystem": { "@id": "ds:pfc-design-system" }
    },

    {
      "@id": "ds:zone-Z1",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z1",
      "ds:zoneName": "Header",
      "ds:zoneType": "Fixed",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": true,
      "ds:visibilityCondition": null,
      "ds:zIndex": 100,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "header",
      "description": "Top-level header bar — app title, ontology stats, version badge"
    },
    {
      "@id": "ds:zone-Z2",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z2",
      "ds:zoneName": "Toolbar",
      "ds:zoneType": "Fixed",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": true,
      "ds:visibilityCondition": null,
      "ds:zIndex": 99,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#dynamic-nav-bar",
      "description": "Primary toolbar hosting L1–L4 navigation layers — capabilities, view controls, context, PFI custom"
    },
    {
      "@id": "ds:zone-Z2-dyn",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z2-dyn",
      "ds:zoneName": "Dynamic Navigation Bar",
      "ds:zoneType": "Fixed",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.dynamicNavEnabled === true",
      "ds:zIndex": 99,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#dynamic-nav-bar",
      "description": "Skeleton-driven dynamic toolbar (F40.17b). Renders NavItems from JSONLD via ontology-driven Action entities. Replaces Z2 as sole toolbar."
    },
    {
      "@id": "ds:zone-Z3",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z3",
      "ds:zoneName": "Context Identity Bar",
      "ds:zoneType": "Conditional",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.isPFIMode === true",
      "ds:zIndex": 98,
      "ds:cascadeTier": "PFI",
      "ds:domSelector": "#emc-nav-bar",
      "description": "PFI brand identity bar — logo, instance name, brand colours. Only visible in PFI mode."
    },
    {
      "@id": "ds:zone-Z4",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z4",
      "ds:zoneName": "Authoring Toolbar",
      "ds:zoneType": "Conditional",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.authoringMode === true",
      "ds:zIndex": 97,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#dynamic-authoring-bar",
      "description": "Entity/relationship authoring toolbar — add entity, add relationship, validation actions"
    },
    {
      "@id": "ds:zone-Z4b",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z4b",
      "ds:zoneName": "Selection Toolbar",
      "ds:zoneType": "Conditional",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.selectedNodes.length > 0",
      "ds:zIndex": 96,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#dynamic-selection-bar",
      "description": "Selection-context toolbar — appears when nodes are selected, shows selection actions"
    },
    {
      "@id": "ds:zone-Z5",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z5",
      "ds:zoneName": "Breadcrumb Bar",
      "ds:zoneType": "Conditional",
      "ds:position": "top",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.breadcrumbPath.length > 0",
      "ds:zIndex": 95,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#breadcrumb-bar",
      "description": "Navigation breadcrumb — ontology path, cascade tier gauge, series filter chips"
    },
    {
      "@id": "ds:zone-Z6",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z6",
      "ds:zoneName": "Graph Canvas",
      "ds:zoneType": "Fixed",
      "ds:position": "center",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": true,
      "ds:visibilityCondition": null,
      "ds:zIndex": 1,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#network",
      "description": "Main content area — vis-network graph, Mermaid diagram, or Mindmap view depending on active view mode"
    },
    {
      "@id": "ds:zone-Z7",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z7",
      "ds:zoneName": "Legend",
      "ds:zoneType": "Floating",
      "ds:position": "bottom-left",
      "ds:defaultWidth": "auto",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 50,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#legend",
      "description": "Graph legend panel — entity archetype colour key, edge type key"
    },
    {
      "@id": "ds:zone-Z8",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z8",
      "ds:zoneName": "Layer Panel",
      "ds:zoneType": "Floating",
      "ds:position": "bottom-right",
      "ds:defaultWidth": "auto",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 50,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#layer-panel",
      "description": "Semantic layer filter panel — toggle entity groups by layer/category"
    },
    {
      "@id": "ds:zone-Z9",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z9",
      "ds:zoneName": "Sidebar Details",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultWidth": "380px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#sidebar",
      "description": "Right sidebar — entity details, connections, schema inspector, raw data tabs"
    },
    {
      "@id": "ds:zone-Z10",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z10",
      "ds:zoneName": "Audit Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultWidth": "340px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#audit-panel",
      "description": "OAA compliance audit panel — gate results, validation findings, fix suggestions"
    },
    {
      "@id": "ds:zone-Z11",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z11",
      "ds:zoneName": "Library Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultWidth": "420px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#library-panel",
      "description": "Ontology library browser — registry, dependencies, saved configs, recent loads"
    },
    {
      "@id": "ds:zone-Z12",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z12",
      "ds:zoneName": "DS Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultWidth": "380px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#ds-panel",
      "description": "Design system token browser — cascade visualisation, token search, brand comparison"
    },
    {
      "@id": "ds:zone-Z13",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z13",
      "ds:zoneName": "Backlog Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultWidth": "480px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#backlog-panel",
      "description": "Backlog manager panel — epic/feature/story hierarchy, status tracking, requirement cards"
    },
    {
      "@id": "ds:zone-Z14",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z14",
      "ds:zoneName": "Mermaid Editor",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultWidth": "380px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.currentView === 'mermaid'",
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#mermaid-editor",
      "description": "Mermaid diagram editor — code editor, preview, export controls"
    },
    {
      "@id": "ds:zone-Z15",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z15",
      "ds:zoneName": "Mindmap Properties",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultWidth": "320px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.currentView === 'mindmap'",
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#mindmap-properties",
      "description": "Mindmap property editor — node properties, styling, hierarchy controls"
    },
    {
      "@id": "ds:zone-Z16",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z16",
      "ds:zoneName": "Context Drawer",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultWidth": "380px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.isPFIMode === true",
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFI",
      "ds:domSelector": "#dynamic-nav-bar",
      "description": "PFI context drawer — instance switcher, brand settings, PFI-specific config"
    },
    {
      "@id": "ds:zone-Z17",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z17",
      "ds:zoneName": "Category Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultWidth": "380px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#category-panel",
      "description": "Category filter panel — maturity levels, compliance status, entity categories"
    },
    {
      "@id": "ds:zone-Z18",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z18",
      "ds:zoneName": "Modal/Dialog",
      "ds:zoneType": "Overlay",
      "ds:position": "center",
      "ds:defaultWidth": "auto",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 200,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": ".modal-overlay",
      "description": "Modal dialog system — confirmations, forms, multi-step wizards, overlay content"
    },
    {
      "@id": "ds:zone-Z19",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z19",
      "ds:zoneName": "Tooltip/Hover",
      "ds:zoneType": "Overlay",
      "ds:position": "cursor",
      "ds:defaultWidth": "auto",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 300,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": ".tooltip",
      "description": "Tooltip and hover card system — entity previews, relationship summaries, quick info"
    },
    {
      "@id": "ds:zone-Z20",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z20",
      "ds:zoneName": "Drop Zone",
      "ds:zoneType": "Conditional",
      "ds:position": "center",
      "ds:defaultWidth": "100%",
      "ds:defaultVisible": true,
      "ds:visibilityCondition": "state.isDragOver === true || state.ontologyCount === 0",
      "ds:zIndex": 2,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#drop-zone",
      "description": "File drop landing zone — drag-and-drop JSON/JSONLD file loading area, initial empty state"
    },
    {
      "@id": "ds:zone-Z21",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z21",
      "ds:zoneName": "PFI Lifecycle Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultWidth": "420px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.isPFIMode === true",
      "ds:zIndex": 60,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#pfi-lifecycle-panel",
      "description": "PFI lifecycle control centre — 10-step pipeline status, scope rule evaluation, snapshot management, binding inspector"
    },

    {
      "@id": "ds:zone-Z22",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z22",
      "ds:zoneName": "Skeleton Inspector",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultWidth": "440px",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": null,
      "ds:zIndex": 13,
      "ds:cascadeTier": "PFC",
      "ds:domSelector": "#skeleton-panel",
      "description": "Application skeleton inspector panel — browse zones, zone-component mappings, and navigation layers with a spatial wireframe diagram"
    },


    {
      "@id": "ds:navlayer-L1",
      "@type": "ds:NavLayer",
      "ds:layerId": "L1",
      "ds:layerName": "Main Capabilities",
      "ds:layerLevel": 1,
      "ds:renderOrder": 1,
      "ds:cascadeTier": "PFC",
      "ds:navLayerInZone": { "@id": "ds:zone-Z2" },
      "description": "Primary capability actions — ontology loading, audit, library, categories, layers, export"
    },
    {
      "@id": "ds:navlayer-L2",
      "@type": "ds:NavLayer",
      "ds:layerId": "L2",
      "ds:layerName": "View Controls",
      "ds:layerLevel": 2,
      "ds:renderOrder": 2,
      "ds:cascadeTier": "PFC",
      "ds:navLayerInZone": { "@id": "ds:zone-Z2" },
      "description": "Graph view manipulation — physics toggle, fit/reset view, details panel"
    },
    {
      "@id": "ds:navlayer-L3-context",
      "@type": "ds:NavLayer",
      "ds:layerId": "L3-context",
      "ds:layerName": "Context/Mode",
      "ds:layerLevel": 3,
      "ds:renderOrder": 3,
      "ds:cascadeTier": "PFC",
      "ds:navLayerInZone": { "@id": "ds:zone-Z2" },
      "description": "View mode tabs and context-specific tools — graph/DS/mermaid/mindmap tabs, backlog, mermaid editor"
    },
    {
      "@id": "ds:navlayer-L3-admin",
      "@type": "ds:NavLayer",
      "ds:layerId": "L3-admin",
      "ds:layerName": "Admin/Config",
      "ds:layerLevel": 3,
      "ds:renderOrder": 4,
      "ds:cascadeTier": "PFC",
      "ds:navLayerInZone": { "@id": "ds:zone-Z2" },
      "description": "Administrative controls — DS tokens, token map, PFC/PFI toggle, instance picker, brand variant"
    },
    {
      "@id": "ds:navlayer-L4",
      "@type": "ds:NavLayer",
      "ds:layerId": "L4",
      "ds:layerName": "PFI Custom",
      "ds:layerLevel": 4,
      "ds:renderOrder": 5,
      "ds:cascadeTier": "PFI",
      "ds:navLayerInZone": { "@id": "ds:zone-Z2" },
      "description": "PFI instance custom navigation — empty at PFC level, PFI instances add their own items here"
    },
    {
      "@id": "ds:navlayer-L5-authoring",
      "@type": "ds:NavLayer",
      "ds:layerId": "L5-authoring",
      "ds:layerName": "Authoring Tools",
      "ds:layerLevel": 5,
      "ds:renderOrder": 6,
      "ds:cascadeTier": "PFC",
      "ds:navLayerInZone": { "@id": "ds:zone-Z4" },
      "description": "Entity/relationship authoring toolbar — visible when authoring mode active"
    },
    {
      "@id": "ds:navlayer-L6-selection",
      "@type": "ds:NavLayer",
      "ds:layerId": "L6-selection",
      "ds:layerName": "Selection Tools",
      "ds:layerLevel": 6,
      "ds:renderOrder": 7,
      "ds:cascadeTier": "PFC",
      "ds:navLayerInZone": { "@id": "ds:zone-Z4b" },
      "description": "Selection-context toolbar — visible when nodes are selected in authoring mode"
    },


    {
      "@id": "ds:nav-L1-ontology",
      "@type": "ds:NavItem",
      "ds:itemId": "nav-ontology",
      "ds:label": "Ontology",
      "ds:itemType": "Dropdown",
      "ds:action": "toggleOntologyMenu",
      "ds:icon": "database",
      "ds:shortcut": null,
      "ds:visibilityCondition": null,
      "ds:renderOrder": 1,
      "ds:cascadeTier": "PFC",
      "ds:belongsToLayer": { "@id": "ds:navlayer-L1" },
      "ds:executesAction": { "@id": "ds:action-toggleOntologyMenu" },
      "description": "Ontology loading dropdown — Load from registry, GitHub, URL, local file"
    },
    {
      "@id": "ds:nav-L1-audit",
      "@type": "ds:NavItem",
      "ds:itemId": "nav-audit",
      "ds:label": "OAA Audit",
      "ds:itemType": "Button",
      "ds:action": "toggleAuditPanel",
      "ds:icon": "clipboard-check",
      "ds:shortcut": "Ctrl+Shift+A",
      "ds:visibilityCondition": null,
      "ds:renderOrder": 2,
      "ds:cascadeTier": "PFC",
      "ds:belongsToLayer": { "@id": "ds:navlayer-L1" },
      "ds:executesAction": { "@id": "ds:action-toggleAuditPanel" },
      "description": "Toggle OAA compliance audit panel (Z10)"
    },
    {
      "@id": "ds:nav-L1-library",
      "@type": "ds:NavItem",
      "ds:itemId": "nav-library",
      "ds:label": "Library",
      "ds:itemType": "Button",
      "ds:action": "toggleLibraryPanel",
      "ds:icon": "book-open",
      "ds:shortcut": "Ctrl+Shift+L",
      "ds:visibilityCondition": null,
      "ds:renderOrder": 3,
      "ds:cascadeTier": "PFC",
      "ds:belongsToLayer": { "@id": "ds:navlayer-L1" },
      "ds:executesAction": { "@id": "ds:action-toggleLibraryPanel" },
      "description": "Toggle ontology library browser panel (Z11)"
    },
    {
      "@id": "ds:nav-L1-categories",
      "@type": "ds:NavItem",
      "ds:itemId": "nav-categories",
      "ds:label": "Categories",
      "ds:itemType": "Button",
      "ds:action": "toggleCategoryPanel",
      "ds:icon": "tag",
      "ds:shortcut": null,
      "ds:visibilityCondition": null,
      "ds:renderOrder": 4,
      "ds:cascadeTier": "PFC",
      "ds:belongsToLayer": { "@id": "ds:navlayer-L1" },
      "ds:executesAction": { "@id": "ds:action-toggleCategoryPanel" },
      "description": "Toggle category filter panel (Z17)"
    },
    {
      "@id": "ds:nav-L1-layers",
      "@type": "ds:NavItem",
      "ds:itemId": "nav-layers",
      "ds:label": "Layers",
      "ds:itemType": "Button",
      "ds:action": "toggleLayerPanel",
      "ds:icon": "layers",
      "ds:shortcut": null,
      "ds:visibilityCondition": null,
      "ds:renderOrder": 5,
      "ds:cascadeTier": "PFC",
      "ds:belongsToLayer": { "@id": "ds:navlayer-L1" },
      "ds:executesAction": { "@id": "ds:action-toggleLayerPanel" },
      "description": "Toggle semantic layer filter panel (Z8)"
    },
    {
      "@id": "ds:nav-L1-export",
      "@type": "ds:NavItem",
      "ds:itemId": "nav-export",
      "ds:label": "Export \u25BC",
      "ds:itemType": "Dropdown",
      "ds:action": "noop",
      "ds:icon": "download",
      "ds:shortcut": null,
      "ds:visibilityCondition": null,
      "ds:renderOrder": 6,
      "ds:cascadeTier": "PFC",
      "ds:belongsToLayer": { "@id": "ds:navlayer-L1" },
      "ds:children": [
        { "ds:label": "PNG Image",               "ds:action": "exportPNG",          "ds:executesAction": { "@id": "ds:action-exportPNG" },          "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "SVG Image",               "ds:action": "exportSVG",          "ds:executesAction": { "@id": "ds:action-exportSVG" },          "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "Mermaid Diagram",          "ds:action": "exportMermaid",      "ds:executesAction": { "@id": "ds:action-exportMermaid" },      "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "D3.js JSON",              "ds:action": "exportD3JSON",       "ds:executesAction": { "@id": "ds:action-exportD3JSON" },       "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "Neo4j Cypher",            "ds:action": "exportCypher",       "ds:executesAction": { "@id": "ds:action-exportCypher" },       "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "---" },
        { "ds:label": "Validation Report (MD)",  "ds:action": "exportGateReport",   "ds:executesAction": { "@id": "ds:action-exportGateReport" },   "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "Audit Report (JSON)",     "ds:action": "exportAuditFile",    "ds:executesAction": { "@id": "ds:action-exportAuditFile" },    "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "Full Report (PDF)",       "ds:action": "exportPDF",          "ds:executesAction": { "@id": "ds:action-exportPDF" },          "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "---" },
        { "ds:label": "Compare Versions...",     "ds:action": "showDiffModal",      "ds:executesAction": { "@id": "ds:action-showDiffModal" },      "ds:parentNavItem": { "@id": "ds:nav-L1-export" } },
        { "ds:label": "---" },
