    { "@type": "raci:forRole", "from": "pf:raci-vhf-progress-monitoring", "to": "pf:func-vhf-coach" },
    { "@type": "raci:forRole", "from": "pf:raci-vhf-progress-monitoring-c", "to": "pf:func-vhf-client" }
  ],

