    { "@type": "vp:offeredThrough", "from": "vp:vhf-vp-nutritional-quality", "to": "vp:vhf-sol-nutritional-quality" },

    { "@type": "vp:solutionAddressesProblem", "from": "vp:vhf-sol-weight-mgmt", "to": "vp:vhf-prob-weight-mgmt" },
