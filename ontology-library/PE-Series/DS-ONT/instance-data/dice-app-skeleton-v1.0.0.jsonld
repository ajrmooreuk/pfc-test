  "@graph": [

    {
      "@id": "ds:dice-app-skeleton-v1.0.0",
      "@type": "ds:Application",
      "ds:appId": "dice-app",
      "ds:appName": "FloodGraph AI — PFI-PC-DICE",
      "ds:version": "1.0.0",
      "ds:dateCreated": "2026-02-24",
      "ds:description": "Democratise expert-level flood risk assessment for UK construction by fusing regulatory knowledge graphs, real-time environmental data, and AI reasoning — reducing FRA turnaround from weeks to hours while eliminating compliance blind spots.",
      "ds:appType": "SPA",
      "ds:rootRoute": "/",
      "ds:cascadeTier": "PFI",
      "ds:extendsApp": { "@id": "ds:pfc-app-skeleton-v1.0.0" },
      "ds:configuredByApp": { "@id": "emc:InstanceConfiguration-PFI-PC-DICE" }
    },


    {
      "@id": "ds:zone-Z-DICE-100",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-100",
      "ds:zoneName": "FloodGraph AI Identity",
      "ds:zoneType": "Conditional",
      "ds:position": "top",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 97
    },

    {
      "@id": "ds:zone-Z-DICE-101",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-101",
      "ds:zoneName": "Agent Dashboard",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "Overview of all 11 agents — 7 inherited PE-RMF agents (Intake, Data-Gathering, Compliance, Report, Project-Manager, Regulatory-Watch, Archive) plus 4 domain agents (FRA-Assessment, SuDS-Mitigation, Climate-Projection, FRA-Narrative)"
    },

    {
      "@id": "ds:zone-Z-DICE-102",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-102",
      "ds:zoneName": "FRA Assessment Agent Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "FRA-Assessment-Agent — maps to PE-RMF Hazard-Assessment slot. Composes flood knowledge graph via EMC scope rules, identifies hazards (depth x velocity x return period), evaluates risk (hazard rating x vulnerability x consequence). Governed by grc:NPPF-Framework."
    },

    {
      "@id": "ds:zone-Z-DICE-103",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-103",
      "ds:zoneName": "SuDS Mitigation Agent Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "SuDS-Mitigation-Agent — maps to PE-RMF Mitigation slot. Designs SuDS treatment trains per CIRIA C753, calculates attenuation volumes, recommends resilience measures per BS 85500. Governed by grc:CIRIA-C753."
    },

    {
      "@id": "ds:zone-Z-DICE-104",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-104",
      "ds:zoneName": "Climate Projection Agent Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "Climate-Projection-Agent — maps to PE-RMF Scenario slot. Calculates epoch allowances for model runs using UKCP18 scenarios (RCP 2.6/4.5/8.5). Governed by grc:EA-ClimateGuidance."
    },

    {
      "@id": "ds:zone-Z-DICE-105",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-105",
      "ds:zoneName": "FRA Narrative Agent Panel",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "FRA-Narrative-Agent — maps to PE-RMF Narrative slot. Generates FRA sections with flood-specific terminology, attaches graph provenance and evidence citations. Governed by grc:FRA-ReportStandard."
    },

    {
      "@id": "ds:zone-Z-DICE-200",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-200",
      "ds:zoneName": "Developer View",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE' && state.activeStakeholderRole === 'Developer'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "Property developer portal — site selection, cost estimation, risk summary dashboard. Key actions: submit site, compare alternatives, view Sequential Test."
    },

    {
      "@id": "ds:zone-Z-DICE-201",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-201",
      "ds:zoneName": "Consultant View",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE' && state.activeStakeholderRole === 'Consultant'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "Planning consultant workspace — full FRA workspace, ontology browser, evidence attachment. Key actions: author assessment, commission surveys, generate report."
    },

    {
      "@id": "ds:zone-Z-DICE-202",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-202",
      "ds:zoneName": "LPA View",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE' && state.activeStakeholderRole === 'LPA'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "Local Planning Authority view — compliance checklist, test verification, cross-application comparison. Key actions: verify Sequential/Exception Test, approve/reject FRA."
    },

    {
      "@id": "ds:zone-Z-DICE-203",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-203",
      "ds:zoneName": "Insurer View",
      "ds:zoneType": "Sliding",
      "ds:position": "right",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE' && state.activeStakeholderRole === 'Insurer'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "Insurance underwriter view — risk scoring, portfolio aggregation, claims correlation. Key actions: score risk, aggregate portfolio, price premium."
    },

    {
      "@id": "ds:zone-Z-DICE-300",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-300",
      "ds:zoneName": "Compliance Dashboard",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "GRC-FW compliance dashboard — NPPF Sequential/Exception Test status, BS 85500 resilience checklist, CIRIA C753 SuDS compliance, EA Standing Advice decision tree verification, EA Climate Change Allowance currency."
    },

    {
      "@id": "ds:zone-Z-DICE-301",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-301",
      "ds:zoneName": "Analytics Dashboard",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE'",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "KPI metrics and BSC objective tracking — Financial (ARR, cost per assessment), Customer (turnaround, NPS, LPA acceptance), Process (AI concordance, graph latency, Sequential Test automation), Learning (training corpus, climate currency)."
    },

    {
      "@id": "ds:zone-Z-DICE-302",
      "@type": "ds:AppZone",
      "ds:zoneId": "Z-DICE-302",
      "ds:zoneName": "Project Management",
      "ds:zoneType": "Sliding",
      "ds:position": "left",
      "ds:defaultVisible": false,
      "ds:visibilityCondition": "state.activeInstanceId === 'PFI-PC-DICE' && state.ppmActive === true",
      "ds:cascadeTier": "PFI",
      "ds:zIndex": 60,
      "ds:zoneDescription": "PPM lifecycle for Level 2+ FRAs — survey commission → hydraulic modelling → assessment → SuDS design → report phases. Manages LSC supplier engagements (surveyors, modellers). Activates when fra:assessmentLevel >= Level2."
    },


