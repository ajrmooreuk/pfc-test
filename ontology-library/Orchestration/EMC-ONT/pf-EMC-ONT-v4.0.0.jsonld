{
  "@context": {
    "@vocab": "https://schema.org/",
    "pf": "https://platformcore.io/ontology/",
    "emc": "https://platformcore.io/ontology/emc/",
    "oaa": "https://platformcore.io/ontology/oaa/",
    "vsom": "https://platformcore.io/ontology/vsom/",
    "okr": "https://platformcore.io/ontology/okr/",
    "ppm": "https://platformcore.io/ontology/ppm/",
    "pe": "https://platformcore.io/ontology/pe/",
    "ea": "https://platformcore.io/ontology/ea/",
    "mcsb": "https://platformcore.io/ontology/mcsb/",
    "gdpr": "https://platformcore.io/ontology/gdpr/",
    "grc-fw": "https://platformcore.io/ontology/grc-fw/",
    "org": "https://platformcore.io/ontology/org/",
    "org-ctx": "https://platformcore.io/ontology/org-context/",
    "ind": "https://oaa-ontology.org/v6/industry/",
    "crt": "https://platformcore.io/ontology/crt/",
    "rbac": "https://platformcore.io/ontology/rbac/"
  },
  "@type": "pf:Ontology",
  "@id": "emc:emc-ontology",
  "name": "EMC Ontology (Enterprise Model Composition)",
  "description": "Orchestration ontology that defines how to compose enterprise models by selecting and connecting ontologies based on PFC/PFI context, product scope, organisation context, and requirement categories. Acts as the wiring diagram for building tech-agnostic data and information models across all 5 ontology series, with agent-role bridge pattern for agentic process ownership and two-path competition model (market-level + org-specific).",
  "version": "4.0.0",
  "oaaVersion": "6.1.0",
  "created": "2026-02-02",
  "lastModified": "2026-02-20",
  "author": "PF-Core Orchestration Module",
  "schemaOrgAlignment": 0.75,
  "pfCoreModule": "Orchestration",
  "pfCoreInstances": [
    "W4M-EMC",
    "BAIV-EMC",
    "VHF-EMC",
    "ANTQ-EMC",
    "AIRL-EMC"
  ],
  "changeLog": {
    "v4.0.0": {
      "date": "2026-02-20",
      "summary": "Fix stale series counts, remove deprecated Competitive series (CA/CL absorbed into ORG-CONTEXT since Epic 9C), add two-path competition model, agent-role bridge pattern, CRT-ONT to VE-Series, VHF InstanceConfiguration",
      "breaking": [
        "OntologySeries-Competitive removed",
        "RequirementCategory-Competitive removed",
        "orchestratesCompetitive relationship removed"
      ],
      "additions": [
        "Agent bridge relationships (agentActsAs, agentOwnsProcess, agentGovernedBy)",
        "orchestratesOrgContext, orchestratesMarketContext, orchestratesCustomerRoles relationships",
        "CompositionRule-AgentRoleBridge",
        "InstanceConfiguration-VHF",
        "CRT-ONT added to VE-Series"
      ],
      "fixes": [
        "VE series count 6→16",
        "PE series count 4→10",
        "RCSG series count 5→10",
        "Foundation series count 4→5",
        "Series total 6→5 (Competitive removed)"
      ]
    }
  },
  "metadata": {
    "domain": "Enterprise Model Orchestration",
    "purpose": "Enable high-level scoping of requirements to automatically determine which ontologies to connect for a given enterprise model configuration, bridging all 5 series (VE, PE, RCSG, Foundation, Orchestration) with two-path competition (market-level via VE INDUSTRY/PORTFOLIO, org-specific via Foundation ORG-CONTEXT) and agent-role bridge pattern for agentic process ownership",
    "scope": "Cross-series ontology composition covering PFC templates and PFI product instances",
    "targetAudience": [
      "Enterprise Architects",
      "Platform Engineers",
      "Solution Architects",
      "AI Agent Developers"
    ],
    "seriesBridges": [
      "VE-Series",
      "PE-Series",
      "RCSG-Series",
      "Foundation",
      "Orchestration"
    ]
  },
  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "@id": "emc:ScopingDimension",
      "name": "ScopingDimension",
      "description": "A dimension used to determine ontology composition. Four scoping dimensions control which ontologies are activated: Context Level (PFC vs PFI), Product Context, Organisation Context, and Requirement Scope.",
      "termCode": "SD",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "dimensionId": {
          "type": "string",
          "description": "Unique identifier for the dimension",
          "example": "emc:dim:context-level"
        },
        "dimensionName": {
          "type": "string",
          "description": "Human-readable dimension name"
        },
        "dimensionDescription": {
          "type": "string",
          "description": "What this dimension controls"
        },
        "determines": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "What aspects of composition this dimension determines"
        }
      },
      "instances": [
        {
          "@id": "emc:ScopingDimension-ContextLevel",
          "dimensionName": "Context Level",
          "description": "PFC (Platform Foundation Core) vs PFI (Platform Foundation Instance) — determines template vs instance data access"
        },
        {
          "@id": "emc:ScopingDimension-ProductContext",
          "dimensionName": "Product Context",
          "description": "Specific product or solution being modelled (e.g. BAIV-AIV, VHF-Nutrition, ANTQ-Valuations) — determines product-specific ontology instances"
        },
        {
          "@id": "emc:ScopingDimension-OrgContext",
          "dimensionName": "Organisation Context",
          "description": "Client organisational profile and maturity — determines role applicability, process complexity, and competitive landscape filtering"
        },
        {
          "@id": "emc:ScopingDimension-RequirementScope",
          "dimensionName": "Requirement Scope",
          "description": "Category of requirements being addressed — determines which ontology series to activate"
        }
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:ContextLevel",
      "name": "ContextLevel",
      "description": "Enumeration distinguishing PFC (core ontology schemas and templates) from PFI (product/client-specific implementations). This dimension determines whether to access reusable templates or deployed instances.",
      "termCode": "CL",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Enumeration",
      "properties": {
        "levelCode": {
          "type": "string",
          "description": "Short code for the context level"
        },
        "levelDescription": {
          "type": "string",
          "description": "What this level provides"
        }
      },
      "instances": [
        {
          "@id": "emc:ContextLevel-PFC",
          "levelCode": "PFC",
          "description": "Platform Foundation Core — core ontology schemas and templates for reuse"
        },
        {
          "@id": "emc:ContextLevel-PFI",
          "levelCode": "PFI",
          "description": "Platform Foundation Instance — product/client-specific implementations with instance data"
        }
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:RequirementCategory",
      "name": "RequirementCategory",
      "description": "High-level requirement categories that map to specific ontology compositions. Each category activates a defined set of required, recommended, and optional ontologies from across all series.",
      "termCode": "RC",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "categoryCode": {
          "type": "string",
          "description": "Short code for the category",
          "example": "STRATEGIC"
        },
        "categoryName": {
          "type": "string",
          "description": "Human-readable category name"
        },
        "useCases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Typical use cases for this category"
        },
        "requiredOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ontologies that must be loaded"
        },
        "recommendedOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ontologies recommended for completeness"
        },
        "optionalOntologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ontologies that may be added for depth"
        }
      },
      "instances": [
        {
          "@id": "emc:RequirementCategory-Strategic",
          "categoryCode": "STRATEGIC",
          "categoryName": "Strategic Planning & Alignment",
          "description": "Vision, strategy, objectives, organisational alignment, and market-level competitive analysis — activates VE-Series (VSOM, OKR, INDUSTRY, PORTFOLIO) plus Foundation"
        },
        {
          "@id": "emc:RequirementCategory-Product",
          "categoryCode": "PRODUCT",
          "categoryName": "Product Development & Go-to-Market",
          "description": "Value proposition, product-market fit, customer roles, feature development, and org-specific competitive landscape — activates VE-Series (VP, PMF, CRT) plus Foundation (ORG-CONTEXT competitive)"
        },
        {
          "@id": "emc:RequirementCategory-PPM",
          "categoryCode": "PPM",
          "categoryName": "Portfolio, Program & Project Management",
          "description": "Project execution, resource management, delivery tracking — activates PE-Series (PPM, EFS, PE)"
        },
        {
          "@id": "emc:RequirementCategory-OrgDesign",
          "categoryCode": "ORG-DESIGN",
          "categoryName": "Organisation Design & Governance",
          "description": "Roles, responsibilities, RACI, RBAC, organisational structure — activates Foundation (ORG, ORG-MAT) plus VE (RRR)"
        },
        {
          "@id": "emc:RequirementCategory-Process",
          "categoryCode": "PROCESS",
          "categoryName": "Process Engineering & Automation",
          "description": "Process design, AI augmentation, workflow orchestration — activates PE-Series with AI agent support"
        },
        {
          "@id": "emc:RequirementCategory-Enterprise",
          "categoryCode": "ENTERPRISE",
          "categoryName": "Full Enterprise Model",
          "description": "Complete enterprise architecture with all 5 ontology series activated — digital transformation, platform development"
        },
        {
          "@id": "emc:RequirementCategory-Compliance",
          "categoryCode": "COMPLIANCE",
          "categoryName": "Compliance, Security & Governance",
          "description": "Regulatory compliance, security controls, data protection — activates RCSG-Series (GRC-FW hub, MCSB, GDPR, PII) plus EA governance"
        },
        {
          "@id": "emc:RequirementCategory-Agentic",
          "categoryCode": "AGENTIC",
          "categoryName": "Agentic AI Solution Build",
          "description": "AI-augmented solutions using ontologies as tech-agnostic layer — activates PE-Series with AI agent definitions and agent-role bridge (RRR RBAC, process ownership)"
        }
      ]
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:OntologySeries",
      "name": "OntologySeries",
      "description": "A logical grouping of related ontologies into a series. The library comprises 5 series: VE (Value Engineering), PE (Process Engineering), RCSG (Governance, Risk & Compliance), Foundation, and Orchestration. The former Competitive series was deprecated in Epic 9C — its entities were absorbed into ORG-CONTEXT-ONT v3.0.0.",
      "termCode": "OS",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "seriesCode": {
          "type": "string",
          "description": "Short code for the series"
        },
        "seriesName": {
          "type": "string",
          "description": "Full series name"
        },
        "ontologyCount": {
          "type": "integer",
          "description": "Number of ontologies in this series"
        },
        "ontologyIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of ontology IDs in this series"
        }
      },
      "instances": [
        {
