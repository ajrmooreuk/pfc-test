window.switchToDSCascadeTab = function() {
  if (state.activeView === 'ds-cascade') return;
  if (!state.activeDSBrand || !state.dsInstances?.has(state.activeDSBrand)) {
    console.warn('[DS Cascade] No DS brand loaded — load a DS-ONT instance first');
    return;
  }
  setViewMode('ds-cascade');
};

/**
 * Render the DS token cascade graph into the #network container.
 * Uses buildDSTokenGraph() and sets up click-to-trace resolution. (S7.6.7)
 */
function _renderDSCascadeGraph() {
  const brand = state.activeDSBrand;
  const parsed = state.dsInstances?.get(brand);
  if (!parsed) {
    document.getElementById('stats').textContent = 'No DS brand loaded';
    return;
  }

  const graph = buildDSTokenGraph(parsed);
  const container = document.getElementById('network');
  if (!container) return;

  const visNodes = new vis.DataSet(graph.nodes);
  const visEdges = new vis.DataSet(graph.edges);

  // Destroy previous network if exists
  if (state.network) { state.network.destroy(); state.network = null; }

  state.network = new vis.Network(container, { nodes: visNodes, edges: visEdges }, {
    layout: {
      hierarchical: {
        enabled: true,
        direction: 'LR',
        sortMethod: 'directed',
        levelSeparation: 200,
        nodeSpacing: 80,
      }
    },
    physics: { enabled: false },
    interaction: { hover: true, tooltipDelay: 200 },
    edges: { smooth: { type: 'cubicBezier' } },
  });

  // Click-to-trace: highlight resolution path on node click
  state.network.on('click', function(params) {
    if (params.nodes.length > 0) {
      const nodeId = params.nodes[0];
      const trace = traceTokenResolution(nodeId, parsed);

      if (trace.path.length > 1) {
        // Highlight traced path nodes and dim others
        const highlightIds = new Set(trace.nodeIds);
        const updatedNodes = graph.nodes.map(n => ({
          id: n.id,
          opacity: highlightIds.has(n.id) ? 1.0 : 0.15,
          font: { ...n.font, color: highlightIds.has(n.id) ? '#e0e0e0' : '#555' },
        }));
        visNodes.update(updatedNodes);

        // Show trace path in stats bar
        const pathStr = trace.path.map(p => `${p.name}${p.value ? ' =' + p.value : ''}`).join(' → ');
        document.getElementById('stats').textContent =
          `Trace: ${pathStr} (${trace.path.length} tiers)`;
      } else {
        // Single node click — show node info
        const node = graph.nodes.find(n => n.id === nodeId);
        document.getElementById('stats').textContent =
          `${node?.label || nodeId} — ${node?._dsType || 'node'}`;
      }
    } else {
      // Click empty space — reset all node opacity
      const resetNodes = graph.nodes.map(n => ({
        id: n.id,
        opacity: 1.0,
        font: { ...n.font, color: n.font?.color || '#e0e0e0' },
      }));
      visNodes.update(resetNodes);
      document.getElementById('stats').textContent =
        `DS Cascade: ${brand} — ${graph.nodes.length} nodes | ${graph.edges.length} edges`;
    }
  });

  state.network.once('stabilizationIterationsDone', function() {
    state.network.fit({ animation: true });
  });

  document.getElementById('stats').textContent =
    `DS Cascade: ${brand} — ${graph.nodes.length} nodes | ${graph.edges.length} edges`;
}

// Legacy toggle functions (kept for backward compatibility)
window.toggleMermaidView = function() {
  if (state.activeView === 'mermaid') {
    setViewMode('graph');
  } else {
    if (state.lastParsed) {
      state.mermaidOrigin = 'export';
      setViewMode('mermaid');
      const mermaidText = exportMermaid();
      if (mermaidText) loadAndRenderMermaid(mermaidText, 'ontology-export.mmd');
