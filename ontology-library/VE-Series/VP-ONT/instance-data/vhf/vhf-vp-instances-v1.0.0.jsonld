  "oaa:brand": "vhf",
  "oaa:brandFullName": "VHF Nutrition App",
  "oaa:organizationContextRef": "org:ctx-vhf",
  "oaa:created": "2026-02-26",
  "oaa:lastModified": "2026-02-26",
  "oaa:imports": [
    { "ontology": "VP-ONT", "version": ">=1.2.3", "purpose": "Value Proposition schema" },
    { "ontology": "RRR-ONT", "version": ">=4.0.0", "purpose": "VP-RRR alignment convention" },
    { "ontology": "ORG-ONT", "version": ">=2.1.0", "purpose": "Organization context" }
  ],

  "entities": [

    {"_section": "=== VP CANVAS 1: WEIGHT MANAGEMENT ==="},

    {
      "@id": "vp:vhf-vp-weight-mgmt",
      "@type": "vp:ValueProposition",
      "vpId": "vp:vhf-weight-management",
      "name": "VHF Weight Management Value Proposition",
      "description": "AI-generated personalised meal plans with macro targeting that enable measurable weight progress while maintaining clinical safety for clients with medical conditions.",
      "primaryStatement": "VHF delivers AI-personalised meal plans that target your exact macro needs, track your weight progress, and keep you clinically safe -- so you lose weight consistently without guesswork or risk.",
      "alternativeStatement": "Your macros, your conditions, your plan -- generated by AI, supervised by Coach James.",
      "keyBenefits": [
        "Measurable weight progress with clinical safety guardrails",
        "Personalised macro targets adjusted to medical conditions",
        "30-day automated meal plans with weekly progress checkpoints",
        "Coach-supervised AI ensuring human oversight of clinical safety"
      ],
      "organizationContextRef": "org:ctx-vhf",
      "status": "Active",
      "validationDate": "2026-02-26"
    },

    {
      "@id": "vp:vhf-prob-weight-mgmt",
      "@type": "vp:Problem",
      "problemId": "prob:vhf-weight-medical-conditions",
      "problemStatement": "Clients with medical conditions (diabetes, PCOS, thyroid disorders, IBS) struggle to manage weight because generic diet plans ignore their clinical constraints -- leading to unsafe food choices, stalled progress, and abandonment of nutrition programmes within 4-6 weeks.",
      "problemType": "Functional",
      "severity": "Critical",
      "frequency": "Constant",
      "isGrowing": true,
      "marketSizeImpact": "UK weight management market GBP 2B pa; medically-constrained segment est. 35% of adults",
      "scopeLevel": "Strategic",
      "ownerRole": "pf:func-vhf-coach",
      "vpRrrAlignment": {
        "alignsTo": "rrr:risk-vhf-weight-medical-safety",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-sol-weight-mgmt",
      "@type": "vp:Solution",
      "solutionId": "sol:vhf-macro-targeting",
      "name": "AI-Generated Personalised Meal Plans with Macro Targeting",
      "coreFunctionality": "AI meal plan generator that takes client medical profile, dietary restrictions, and weight goals as inputs, then generates 30-day personalised meal plans with per-meal macro targets (protein, carbs, fat, fibre, calories) adjusted for medical conditions. Coach reviews and approves before client receives plan.",
      "deliveryMethod": "VHF Nutrition App (B2C mobile/web) with coach dashboard",
      "pricingModel": "Monthly subscription with tiered coaching (self-serve AI / coach-assisted / full coaching)",
      "timeToValue": "First personalised plan generated within 24 hours of onboarding",
      "vpRrrAlignment": {
        "alignsTo": "rrr:req-vhf-macro-targeting",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-ben-weight-mgmt",
      "@type": "vp:Benefit",
      "benefitId": "ben:vhf-weight-progress-safety",
      "benefitDescription": "Measurable weight progress with clinical safety -- clients achieve target weight trajectory (within 2% of plan) while zero clinical safety violations are recorded across all medical-condition plans.",
      "benefitType": "Quantifiable",
      "benefitCategory": "RiskReduction",
      "quantifiedValue": "Target weight trajectory within 2% of plan; zero clinical safety violations",
      "measurementMethod": "Weekly weigh-in variance vs plan trajectory; clinical safety audit log (zero violations)",
      "realizationTimeframe": "12 weeks per client cohort",
      "vpRrrAlignment": {
        "alignsTo": "rrr:result-vhf-weight-progress-safety",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },

    {"_section": "=== VP CANVAS 2: DIETARY COMPLIANCE ==="},

    {
      "@id": "vp:vhf-vp-dietary-compliance",
      "@type": "vp:ValueProposition",
      "vpId": "vp:vhf-dietary-compliance",
      "name": "VHF Dietary Compliance Value Proposition",
      "description": "Constraint-resolution engine that navigates the combinatorial complexity of 30 diet types crossed with 14 allergen categories, guaranteeing 100% allergen-safe meal plans with zero violations.",
      "primaryStatement": "VHF resolves the impossible puzzle of multiple dietary restrictions and allergens -- so every meal in your plan is 100% safe, 100% compliant, with zero manual checking.",
      "alternativeStatement": "30 diet types, 14 allergens, zero violations -- constraint resolution that a human cannot do at scale.",
      "keyBenefits": [
        "100% allergen-safe meal plans with zero violations",
        "Automatic constraint resolution across 30 diet types x 14 allergen categories",
        "Elimination of manual allergen checking by coaches",
        "Client confidence in every meal recommendation"
      ],
      "organizationContextRef": "org:ctx-vhf",
      "status": "Active",
      "validationDate": "2026-02-26"
    },

    {
      "@id": "vp:vhf-prob-dietary-compliance",
      "@type": "vp:Problem",
      "problemId": "prob:vhf-dietary-confusion",
      "problemStatement": "Clients with multiple dietary restrictions and allergens face overwhelming confusion -- combining vegan + nut-free + low-FODMAP requires expert knowledge that most nutrition coaches lack, leading to unsafe recommendations, client distrust, and liability risk for the coaching business.",
      "problemType": "Functional",
      "severity": "Critical",
      "frequency": "Constant",
      "isGrowing": true,
      "marketSizeImpact": "UK food allergy prevalence 2M adults; multiple restriction overlap est. 8% of adults",
      "scopeLevel": "Operational",
      "ownerRole": "pf:func-vhf-ai-agent",
      "vpRrrAlignment": {
        "alignsTo": "rrr:risk-vhf-allergen-violation",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-sol-dietary-compliance",
      "@type": "vp:Solution",
      "solutionId": "sol:vhf-constraint-resolution",
      "name": "Multi-Constraint Resolution Engine (30 Diet Types x 14 Allergens)",
      "coreFunctionality": "Constraint-resolution engine that models 30 diet types (keto, vegan, halal, low-FODMAP, Mediterranean, etc.) and 14 major allergen categories (peanut, tree nut, dairy, gluten, soy, shellfish, egg, fish, sesame, mustard, celery, lupin, mollusc, sulphites) as graph constraints. Every generated meal is validated against all active constraints before inclusion in any plan. Impossible constraint combinations are detected at onboarding and flagged to coach.",
      "deliveryMethod": "Built-in constraint engine within VHF Nutrition App AI pipeline",
      "pricingModel": "Included in all subscription tiers",
      "timeToValue": "Instant -- constraints applied at meal plan generation time",
      "vpRrrAlignment": {
        "alignsTo": "rrr:req-vhf-constraint-resolution",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-ben-dietary-compliance",
      "@type": "vp:Benefit",
      "benefitId": "ben:vhf-allergen-safety",
      "benefitDescription": "100% allergen-safe meal plans with zero violations -- every meal in every plan passes all active dietary and allergen constraints. No manual checking required by coach or client.",
      "benefitType": "Quantifiable",
      "benefitCategory": "ComplianceAssurance",
      "quantifiedValue": "100% allergen compliance rate; zero violations across all generated plans",
      "measurementMethod": "Automated constraint validation pass rate per plan; violation incident count (target: 0)",
      "realizationTimeframe": "Immediate on first plan generation",
      "vpRrrAlignment": {
        "alignsTo": "rrr:result-vhf-allergen-compliance",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },

    {"_section": "=== VP CANVAS 3: COACH EFFICIENCY ==="},

    {
      "@id": "vp:vhf-vp-coach-efficiency",
      "@type": "vp:ValueProposition",
      "vpId": "vp:vhf-coach-efficiency",
      "name": "VHF Coach Efficiency Value Proposition",
      "description": "Automated 30-day meal plan generation with coaching protocols that enable 10x coach throughput -- more clients per coach with higher quality plans and less manual effort.",
      "primaryStatement": "VHF automates the 4-6 hours a coach spends creating each meal plan down to minutes -- freeing Coach James to focus on client relationships, progress coaching, and growing the business to 10x current client capacity.",
      "alternativeStatement": "AI generates the plans, coaches add the human touch -- 10x more clients, same quality.",
      "keyBenefits": [
        "10x coach throughput (from 20 to 200+ active clients per coach)",
        "Plan generation reduced from 4-6 hours to under 10 minutes",
        "Consistent quality across all generated plans",
        "Coach time redirected from plan creation to client coaching and retention"
      ],
      "organizationContextRef": "org:ctx-vhf",
      "status": "Active",
      "validationDate": "2026-02-26"
    },

    {
      "@id": "vp:vhf-prob-coach-efficiency",
      "@type": "vp:Problem",
      "problemId": "prob:vhf-coach-bottleneck",
      "problemStatement": "Nutrition coaches spend 4-6 hours manually creating each personalised meal plan -- researching recipes, calculating macros, checking allergens, ensuring variety, and formatting for client delivery. This limits Coach James to approximately 20 active clients, creating a direct bottleneck on revenue growth and making the coaching model unsustainable at scale.",
      "problemType": "Economic",
      "severity": "Major",
      "frequency": "Constant",
      "isGrowing": true,
      "marketSizeImpact": "UK online nutrition coaching market GBP 180M pa; coach capacity is the binding constraint on growth",
      "scopeLevel": "Strategic",
      "ownerRole": "pf:func-vhf-coach",
      "vpRrrAlignment": {
        "alignsTo": "rrr:risk-vhf-coaching-bottleneck",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-sol-coach-efficiency",
      "@type": "vp:Solution",
      "solutionId": "sol:vhf-automated-generation",
      "name": "Automated 30-Day Meal Plan Generation with Coaching Protocols",
      "coreFunctionality": "AI pipeline that generates complete 30-day meal plans (90 meals + snacks) in under 10 minutes, incorporating all client constraints, macro targets, variety rules, and coaching protocols. Coach reviews AI output via dashboard, approves/adjusts, and plan is delivered to client. Coaching protocols encode Coach James Kerby's methodology as rules (e.g., progressive macro adjustment, cheat day placement, re-feed strategies).",
      "deliveryMethod": "VHF Coach Dashboard with one-click generation, review, and approval workflow",
      "pricingModel": "Coach subscription tier with per-client generation credits",
      "timeToValue": "First automated plan within 1 week of coach onboarding",
      "vpRrrAlignment": {
        "alignsTo": "rrr:req-vhf-automated-generation",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-ben-coach-efficiency",
      "@type": "vp:Benefit",
      "benefitId": "ben:vhf-coach-throughput",
      "benefitDescription": "10x coach throughput -- Coach James scales from 20 to 200+ active clients without additional coaching hires. Plan generation time drops from 4-6 hours to under 10 minutes. Coach time reallocated from plan creation (80% of time) to client coaching, retention, and business growth.",
      "benefitType": "Quantifiable",
      "benefitCategory": "RevenueGrowth",
      "quantifiedValue": "10x client capacity per coach; 4-6 hours reduced to <10 minutes per plan",
      "measurementMethod": "Active clients per coach; average plan generation time; coach time allocation (creation vs coaching)",
      "realizationTimeframe": "3-6 months post-launch",
      "vpRrrAlignment": {
        "alignsTo": "rrr:result-vhf-coach-throughput",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },

    {"_section": "=== VP CANVAS 4: NUTRITIONAL QUALITY ==="},

    {
      "@id": "vp:vhf-vp-nutritional-quality",
      "@type": "vp:ValueProposition",
      "vpId": "vp:vhf-nutritional-quality",
      "name": "VHF Nutritional Quality Value Proposition",
      "description": "Variety rules, portion scaling, and theme curation that ensure every generated meal plan delivers consistent nutritional quality -- high variety scores and tight macro adherence without monotony.",
      "primaryStatement": "VHF meal plans are never boring and never off-target -- variety rules prevent repetition, portion scaling hits your macros precisely, and theme curation makes every week feel fresh while keeping you on track.",
      "alternativeStatement": "60%+ variety, less than 5% macro variance -- AI-curated plans that are as enjoyable as they are effective.",
      "keyBenefits": [
        "Greater than 60% variety score across all generated plans",
        "Less than 5% macro variance from target across all meals",
        "Theme-curated weeks (Mediterranean, Asian, comfort food) for engagement",
        "Portion scaling that maintains macro accuracy across serving sizes"
      ],
      "organizationContextRef": "org:ctx-vhf",
      "status": "Active",
      "validationDate": "2026-02-26"
    },

    {
      "@id": "vp:vhf-prob-nutritional-quality",
      "@type": "vp:Problem",
      "problemId": "prob:vhf-recipe-pool-inadequacy",
      "problemStatement": "Manually curated meal plans suffer from recipe pool inadequacy -- coaches reuse the same 30-50 recipes, leading to monotonous plans that clients abandon within 3 weeks. Macro adherence varies wildly (15-25% variance) because portion calculations are done manually and recipes are not standardised for macro precision.",
      "problemType": "Functional",
      "severity": "Major",
      "frequency": "Frequent",
      "isGrowing": false,
      "marketSizeImpact": "Client dropout rate 60-70% within 8 weeks on manual plans; variety and monotony are cited as top 3 reasons",
      "scopeLevel": "Tactical",
      "ownerRole": "pf:func-vhf-ai-agent",
      "vpRrrAlignment": {
        "alignsTo": "rrr:risk-vhf-recipe-pool-inadequacy",
        "alignmentType": "Problem->Risk",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-sol-nutritional-quality",
      "@type": "vp:Solution",
      "solutionId": "sol:vhf-variety-enforcement",
      "name": "Variety Rules + Portion Scaling + Theme Curation",
      "coreFunctionality": "Three-layer quality enforcement: (1) Variety rules prevent recipe repetition within configurable windows (default: no repeat within 10 days), enforce cuisine diversity, and track ingredient variety scores per plan. (2) Portion scaling adjusts every recipe to hit per-meal macro targets (protein, carbs, fat, fibre, calories) with less than 5% variance. (3) Theme curation assigns weekly cuisine themes (Mediterranean, Asian, British comfort, etc.) to maintain engagement while respecting all constraints.",
      "deliveryMethod": "Built-in quality layer within VHF AI meal plan generation pipeline",
      "pricingModel": "Included in all subscription tiers",
      "timeToValue": "Applied automatically on every plan generation",
      "vpRrrAlignment": {
        "alignsTo": "rrr:req-vhf-variety-enforcement",
        "alignmentType": "Solution->Requirement",
        "convention": "JP-VP-RRR-001"
      }
    },

    {
      "@id": "vp:vhf-ben-nutritional-quality",
      "@type": "vp:Benefit",
      "benefitId": "ben:vhf-variety-macro-accuracy",
      "benefitDescription": "Greater than 60% variety score and less than 5% macro variance across all generated plans -- clients receive diverse, enjoyable meal plans that hit their nutritional targets precisely, reducing dropout from monotony and improving clinical outcomes.",
      "benefitType": "Quantifiable",
      "benefitCategory": "ExperienceImprovement",
      "quantifiedValue": ">60% variety score; <5% macro variance from target",
      "measurementMethod": "Variety score (unique recipes / total meals per plan); macro variance (actual vs target per meal, averaged across plan)",
      "realizationTimeframe": "Immediate on first plan generation",
      "vpRrrAlignment": {
        "alignsTo": "rrr:result-vhf-variety-macro-accuracy",
        "alignmentType": "Benefit->Result",
        "convention": "JP-VP-RRR-001"
      }
    },

    {"_section": "=== PAIN POINTS ==="},

    {
      "@id": "vp:vhf-pain-001",
      "@type": "vp:PainPoint",
      "painId": "pain:vhf-unsafe-diet-plans",
      "painDescription": "Clients with medical conditions receive generic meal plans that ignore their clinical constraints, leading to unsafe food choices (e.g., high-GI meals for diabetics, high-oxalate for kidney stone sufferers).",
      "painDimension": "Functional",
      "customerImpact": "Health risk, loss of trust in coaching programme, potential liability",
      "quantifiedImpact": "35% of UK adults have at least one medical condition affecting diet",
      "impactUnit": "percentage"
    },
    {
      "@id": "vp:vhf-pain-002",
      "@type": "vp:PainPoint",
      "painId": "pain:vhf-allergen-checking-burden",
      "painDescription": "Coaches spend 30-45 minutes per plan manually cross-checking recipes against client allergen profiles -- a tedious, error-prone process that scales linearly with client count.",
      "painDimension": "Process",
      "customerImpact": "Coach burnout, increased risk of missed allergen, limits client capacity",
      "quantifiedImpact": "30-45 minutes per plan for allergen verification alone",
      "impactUnit": "minutes"
    },
    {
      "@id": "vp:vhf-pain-003",
      "@type": "vp:PainPoint",
      "painId": "pain:vhf-plan-monotony",
      "painDescription": "Manually curated plans reuse the same 30-50 recipes, causing client boredom and abandonment within 3 weeks. Coaches lack time to research and validate new recipes.",
      "painDimension": "Functional",
      "customerImpact": "60-70% client dropout within 8 weeks; lost subscription revenue",
      "quantifiedImpact": "65% average dropout rate on monotonous plans",
      "impactUnit": "percentage"
    },
    {
      "@id": "vp:vhf-pain-004",
      "@type": "vp:PainPoint",
      "painId": "pain:vhf-macro-inaccuracy",
      "painDescription": "Manual portion calculations produce 15-25% macro variance from targets -- clients either under-eat (stalling progress) or over-eat (gaining weight), undermining trust in the coaching programme.",
      "painDimension": "Functional",
      "customerImpact": "Stalled weight progress, client frustration, programme abandonment",
      "quantifiedImpact": "15-25% average macro variance on manually calculated plans",
      "impactUnit": "percentage"
    },

    {"_section": "=== GAINS ==="},

    {
      "@id": "vp:vhf-gain-001",
      "@type": "vp:Gain",
      "gainId": "gain:vhf-clinical-safety",
      "gainDescription": "Every meal plan is validated against the client's full medical profile before delivery -- diabetic-safe, kidney-safe, thyroid-safe with zero clinical violations.",
      "gainType": "Required",
      "gainCategory": "RiskReduction",
      "priority": 1,
      "quantifiedValue": "Zero clinical safety violations across all plans"
    },
    {
      "@id": "vp:vhf-gain-002",
      "@type": "vp:Gain",
      "gainId": "gain:vhf-instant-constraint-check",
      "gainDescription": "Constraint resolution happens in seconds, not hours -- coach no longer needs to manually check allergens, and impossible constraint combinations are flagged immediately.",
      "gainType": "Expected",
      "gainCategory": "ExperienceImprovement",
      "priority": 2,
      "quantifiedValue": "Constraint resolution in under 5 seconds per plan"
    },
    {
      "@id": "vp:vhf-gain-003",
      "@type": "vp:Gain",
      "gainId": "gain:vhf-scalable-coaching",
      "gainDescription": "Coach James grows from 20 clients to 200+ without hiring additional coaches -- AI handles plan generation, coach focuses on relationships and progress.",
      "gainType": "Desired",
      "gainCategory": "StrategicAdvantage",
      "priority": 3,
      "quantifiedValue": "10x client capacity per coach"
    },

    {"_section": "=== SUCCESS METRICS ==="},

    {
      "@id": "vp:vhf-sm-001",
      "@type": "vp:SuccessMetric",
      "metricId": "sm:vhf-allergen-compliance",
      "description": "Allergen constraint compliance rate across all generated meal plans",
      "baseline": "Manual checking with estimated 2-5% miss rate",
      "target": "100% compliance, zero violations",
      "measurementMethod": "Automated constraint validation pass/fail per plan",
      "measurementFrequency": "Per plan generation"
    },
    {
      "@id": "vp:vhf-sm-002",
      "@type": "vp:SuccessMetric",
      "metricId": "sm:vhf-macro-variance",
      "description": "Average macro variance from target across all meals in all plans",
      "baseline": "15-25% variance (manual calculation)",
      "target": "<5% variance",
      "measurementMethod": "Per-meal macro actual vs target, averaged across plan",
      "measurementFrequency": "Per plan generation"
    },
    {
      "@id": "vp:vhf-sm-003",
      "@type": "vp:SuccessMetric",
      "metricId": "sm:vhf-variety-score",
      "description": "Recipe variety score across all generated meal plans",
      "baseline": "30-40% (same 30-50 recipes reused)",
      "target": ">60% variety score",
      "measurementMethod": "Unique recipes / total meals per 30-day plan",
      "measurementFrequency": "Per plan generation"
    },
    {
      "@id": "vp:vhf-sm-004",
      "@type": "vp:SuccessMetric",
      "metricId": "sm:vhf-coach-throughput",
      "description": "Number of active clients per coach",
      "baseline": "20 clients (manual plan creation bottleneck)",
      "target": "200+ clients per coach",
      "measurementMethod": "Active subscription count per coach",
      "measurementFrequency": "Monthly"
    },

    {"_section": "=== MESSAGING ==="},

    {
      "@id": "vp:vhf-msg-primary",
      "@type": "vp:MessagingFramework",
      "frameworkId": "msg:vhf-primary",
      "primaryMessage": "Your body, your rules, your perfect plan -- AI-powered nutrition that respects every restriction and hits every target.",
      "supportingMessages": [
        "30 diet types, 14 allergens, zero compromises -- every meal is safe",
        "Less than 5% macro variance -- your plan hits the numbers, every time",
        "Fresh variety every week -- never the same boring meals on repeat",
        "Coach James reviews every plan -- AI power with human expertise"
      ],
      "emotionalHooks": ["Confidence in every meal", "Progress you can measure", "A plan that actually fits your life"],
      "useCustomerLanguage": true
    }
  ],

