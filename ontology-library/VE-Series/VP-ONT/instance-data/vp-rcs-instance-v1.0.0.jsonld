    },
    {
      "@id": "vp:rcs-sm-compliance-score",
      "@type": "vp:SuccessMetric",
      "name": "Cross-Framework Compliance Coverage Score",
      "metricId": "sm:rcs-coverage-score",
      "description": "Weighted compliance coverage percentage across all applicable frameworks (MCSB, GDPR, PII, Azure Security Baseline)",
      "baseline": 62,
      "target": 88,
      "measurementMethod": "Automated compliance coverage calculation: (controls implemented and evidenced / total applicable controls) weighted by framework criticality.",
      "measurementFrequency": "P1M"
    },
    {
      "@id": "vp:rcs-sm-audit-findings",
      "@type": "vp:SuccessMetric",
      "name": "Audit Finding Count",
      "metricId": "sm:rcs-audit-findings",
      "description": "Number of material audit findings per external audit cycle, particularly cross-framework intersection gaps",
      "baseline": 12,
      "target": 3,
      "measurementMethod": "Count material and significant audit findings per external audit cycle. Track separately: per-framework findings vs. cross-framework intersection findings.",
      "measurementFrequency": "P6M"
    },
    {
      "@id": "vp:rcs-sm-remediation-velocity",
      "@type": "vp:SuccessMetric",
      "name": "Remediation Velocity (Gaps/Month)",
      "metricId": "sm:rcs-remediation",
      "description": "Number of compliance gaps remediated per month, weighted by cross-framework impact",
      "baseline": 8,
      "target": 20,
      "measurementMethod": "Count compliance gaps resolved per month. Weight each resolution by number of frameworks impacted (1x for single-framework, 2x for dual, 3x for tri-framework impact).",
      "measurementFrequency": "P1M"
    },

    {
      "@id": "vp:rcs-sh-ciso",
      "@type": "vp:Stakeholder",
      "name": "CISO",
      "stakeholderId": "sh:rcs-ciso",
      "stakeholderRole": "DecisionMaker",
      "influenceLevel": "High",
      "interests": "Board-level compliance confidence; regulatory penalty avoidance; unified risk view; audit efficiency; team productivity",
      "objections": "Already invested in GRC platform; integration complexity with existing tooling; concern about replacing established processes mid-audit-cycle"
    },
    {
      "@id": "vp:rcs-sh-compliance-dir",
      "@type": "vp:Stakeholder",
      "name": "Compliance Director",
      "stakeholderId": "sh:rcs-compliance-dir",
      "stakeholderRole": "Champion",
      "influenceLevel": "High",
      "interests": "Cross-framework visibility; audit preparation efficiency; team capacity for remediation vs. evidence collection; continuous monitoring",
      "objections": "Learning curve for ontology-based approach; migration from existing GRC workflows; accuracy of automated cross-referencing"
    },
    {
      "@id": "vp:rcs-sh-security-analyst",
      "@type": "vp:Stakeholder",
      "name": "Security/Compliance Analyst",
      "stakeholderId": "sh:rcs-analyst",
      "stakeholderRole": "PrimaryUser",
      "influenceLevel": "Medium",
      "interests": "Reduced manual mapping effort; automated evidence collection; clear remediation priorities; skill development in cross-framework compliance",
      "objections": "Yet another tool to learn; worried about accuracy of automated mappings; concern that automation reduces analyst value"
    },
    {
      "@id": "vp:rcs-sh-auditor",
      "@type": "vp:Stakeholder",
      "name": "External Auditor / Regulator",
      "stakeholderId": "sh:rcs-auditor",
      "stakeholderRole": "Influencer",
      "influenceLevel": "High",
      "interests": "Complete audit trail; evidence quality; cross-framework control mapping accuracy; continuous compliance evidence vs. point-in-time",
      "objections": "Unfamiliar with ontology-based compliance; requires validation of cross-framework mapping methodology"
    },

    {
      "@id": "vp:rcs-msg-csuite",
      "@type": "vp:MessagingFramework",
      "name": "CISO / C-Suite Compliance Messaging",
      "frameworkId": "msg:rcs-csuite",
      "primaryMessage": "Eliminate compliance fragmentation and regulatory penalty risk — see your entire compliance posture across MCSB, GDPR, PII, and Azure in a single, continuously updated dashboard that your auditors will trust.",
      "supportingMessages": "1. 60% reduction in audit preparation time through automated cross-framework mapping. 2. 85%+ compliance coverage within 90 days across all applicable frameworks. 3. Eliminate 40% duplicate compliance effort by unifying overlapping requirements. 4. Zero audit findings on cross-framework mapping gaps in pilot deployments.",
      "emotionalHooks": "Sleep-at-night confidence in compliance posture; board-level credibility through quantified compliance; protection from headline-making regulatory penalties; control over compliance programme rather than being controlled by it",
      "useCustomerLanguage": true
    },
    {
      "@id": "vp:rcs-msg-director",
      "@type": "vp:MessagingFramework",
      "name": "Compliance Director Operational Messaging",
      "frameworkId": "msg:rcs-director",
      "primaryMessage": "Free your compliance team from perpetual audit preparation — automated cross-framework mapping and continuous monitoring means your team spends time on remediation, not evidence collection.",
      "supportingMessages": "1. Automated cross-referencing across MCSB, GDPR, PII, and Azure with 95% accuracy. 2. Continuous compliance monitoring replaces point-in-time audit snapshots. 3. Single remediation action can close gaps across multiple frameworks simultaneously. 4. Audit-ready evidence packages generated automatically.",
      "emotionalHooks": "Team empowerment through automation; escape from audit-prep treadmill; professional recognition for proactive compliance programme; confidence in cross-framework coverage",
      "useCustomerLanguage": true
    },
    {
      "@id": "vp:rcs-msg-analyst",
      "@type": "vp:MessagingFramework",
      "name": "Security Analyst Practitioner Messaging",
      "frameworkId": "msg:rcs-analyst",
      "primaryMessage": "Stop spending 60+ hours per cycle manually mapping controls across frameworks — get automated cross-references with 95% accuracy and focus your expertise on remediation and risk reduction.",
      "supportingMessages": "1. Automated control mapping replaces manual spreadsheet cross-referencing. 2. Evidence collection integrated with Azure compliance APIs. 3. Clear remediation priorities ranked by cross-framework impact. 4. Continuous learning: system improves mapping accuracy from your feedback.",
      "emotionalHooks": "Freedom from tedious mapping work; valued for expertise not data entry; confidence in mapping accuracy; professional growth in cross-framework compliance",
      "useCustomerLanguage": true
    },

