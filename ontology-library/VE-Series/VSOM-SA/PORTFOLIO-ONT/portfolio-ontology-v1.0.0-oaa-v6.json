  "businessRules": [
    {
      "ruleId": "BR-PFL-001",
      "name": "BCG Entry Must Have Market Data",
      "condition": "IF a GrowthShareEntry is created",
      "action": "THEN relativeMarketShare and marketGrowthRate MUST be specified",
      "severity": "error"
    },
    {
      "ruleId": "BR-PFL-002",
      "name": "BCG Quadrant Must Match Data",
      "condition": "IF a GrowthShareEntry has quadrant specified",
      "action": "THEN quadrant MUST be consistent with relativeMarketShare and marketGrowthRate values (Star=high share/high growth, CashCow=high share/low growth, QuestionMark=low share/high growth, Dog=low share/low growth)",
      "severity": "error"
    },
    {
      "ruleId": "BR-PFL-003",
      "name": "Three Horizons Investment Must Sum to 100",
      "condition": "IF a ThreeHorizonsModel is created",
      "action": "THEN h1InvestmentPct + h2InvestmentPct + h3InvestmentPct MUST equal 100",
      "severity": "error"
    },
    {
      "ruleId": "BR-PFL-004",
      "name": "Horizon Risk Must Match Horizon",
      "condition": "IF a HorizonInitiative is created",
      "action": "THEN riskLevel SHOULD be consistent with horizon (H1=Low/Moderate, H2=Moderate/High, H3=High/VeryHigh)",
      "severity": "warning"
    },
    {
      "ruleId": "BR-PFL-005",
      "name": "Investment Map Must Reference VSOM",
      "condition": "IF a StrategicInvestmentMap is created",
      "action": "THEN vsomFrameworkRef MUST reference a valid vsom:VSOMFramework @id",
      "severity": "error"
    },
    {
      "ruleId": "BR-PFL-006",
      "name": "Portfolio Lens Must Have Direction",
      "condition": "IF a PortfolioStrategicLens is created",
      "action": "THEN strategicDirection MUST be specified",
      "severity": "error"
    },
    {
      "ruleId": "BR-PFL-007",
      "name": "Strategic Direction Summary Must Reference All Layers",
      "condition": "IF a StrategicDirectionSummary is created",
      "action": "THEN at least pestelRef OR porterRef OR swotRef SHOULD be populated to demonstrate analysis grounding",
      "severity": "warning"
    },
    {
      "ruleId": "BR-PFL-008",
      "name": "Investment Allocation Must Align to Strategy",
      "condition": "IF an InvestmentAllocation is created",
      "action": "THEN vsomStrategyRef MUST reference a valid vsom:StrategyComponent @id",
      "severity": "error"
    },
    {
      "ruleId": "BR-PFL-009",
      "name": "Star Entries Should Have Investment",
      "condition": "IF a GrowthShareEntry has quadrant 'Star'",
      "action": "THEN strategicDirection SHOULD be 'InvestGrow' and investmentAllocationPct SHOULD be among the highest",
      "severity": "warning"
    },
    {
      "ruleId": "BR-PFL-010",
      "name": "Dog Entries Should Be Reviewed",
      "condition": "IF a GrowthShareEntry has quadrant 'Dog'",
      "action": "THEN strategicDirection SHOULD be 'DivestEliminate' or 'Turnaround' with explicit rationale",
      "severity": "warning"
    }
  ],
