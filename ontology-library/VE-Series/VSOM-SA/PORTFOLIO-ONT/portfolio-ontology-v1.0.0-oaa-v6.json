        {
          "name": "modelId",
          "type": "xsd:string",
          "required": true,
          "schemaOrgMapping": "schema:identifier"
        },
        {
          "name": "name",
          "type": "xsd:string",
          "required": true,
          "schemaOrgMapping": "schema:name"
        },
        {
          "name": "contextRef",
          "type": "xsd:string",
          "required": true,
          "description": "Reference to orgctx:OrganizationContext @id"
        },
        {
          "name": "analysisDate",
          "type": "xsd:date",
          "required": true
        },
        {
          "name": "h1InvestmentPct",
          "type": "xsd:decimal",
          "required": true,
          "description": "Horizon 1 investment percentage (typically 70%)"
        },
        {
          "name": "h2InvestmentPct",
          "type": "xsd:decimal",
          "required": true,
          "description": "Horizon 2 investment percentage (typically 20%)"
        },
        {
          "name": "h3InvestmentPct",
          "type": "xsd:decimal",
          "required": true,
          "description": "Horizon 3 investment percentage (typically 10%)"
        },
        {
          "name": "totalInvestmentBudget",
          "type": "xsd:decimal",
          "required": false
        },
        {
          "name": "rebalancingNeeded",
          "type": "xsd:boolean",
          "required": false
        },
        {
          "name": "rebalancingActions",
          "type": "xsd:string",
          "required": false,
          "description": "Actions to rebalance investment split",
          "cardinality": "0..*"
        },
        {
          "name": "vsomFrameworkRef",
          "type": "xsd:string",
          "required": false,
          "description": "Reference to vsom:VSOMFramework @id"
        }
      ]
    },
    {
      "@id": "pfl:HorizonInitiative",
      "@type": "rdfs:Class",
      "name": "HorizonInitiative",
