      "problemId": "prob:rcs-control-mapping",
      "problemStatement": "Security Analysts struggle with manual control mapping when cross-referencing MCSB controls to GDPR articles to PII requirements, resulting in 60+ hours per mapping cycle, 15-20% error rate in cross-references, and inability to identify true coverage gaps across overlapping frameworks.",
      "problemType": "Functional",
      "severity": "Major",
      "frequency": "Frequent",
      "isGrowing": true,
