    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:GraphScopeRule",
      "name": "GraphScopeRule",
      "description": "A declarative IF-THEN rule that governs how PFI instance graphs are composed from component ontology data slices. Each rule has a ScopeCondition (IF clause) and a ScopeAction (THEN clause), evaluated in priority order within an InstanceConfiguration. Scope rules operate at a finer granularity than CompositionRules — they filter instance-level data rather than selecting series-level ontologies.",
      "termCode": "GSR",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "ruleId": {
          "type": "string",
          "required": true,
          "description": "Unique rule identifier within the EMC namespace",
          "example": "BAIV-AIV-Product-Scope"
        },
        "ruleName": {
          "type": "string",
          "required": true,
          "description": "Human-readable name for the scope rule"
        },
        "description": {
          "type": "string",
          "description": "What this scope rule does and why"
        },
        "scopeLevel": {
          "type": "string",
          "enum": ["series", "ontology", "entity", "property"],
          "description": "Granularity at which the rule operates: series (entire ontology series), ontology (specific ontology), entity (specific entity types), property (specific entity properties)"
        },
        "priority": {
          "type": "integer",
          "required": true,
          "description": "Evaluation order within the instance (lower = higher priority). Must be unique within an InstanceConfiguration."
        },
        "isActive": {
          "type": "boolean",
          "default": true,
          "description": "Whether this rule is currently active. Inactive rules are skipped during evaluation."
        }
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:ScopeCondition",
      "name": "ScopeCondition",
      "description": "The IF clause of a GraphScopeRule. Evaluates a condition against the PFI context to determine whether the rule's action should fire. Multiple conditions on a single rule are AND-combined.",
      "termCode": "SC",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "conditionType": {
          "type": "string",
          "enum": [
            "product-match",
            "brand-match",
            "market-segment",
            "maturity-threshold",
            "jurisdiction-match",
            "requirement-scope",
            "gap-severity",
            "icp-seniority",
            "persona-scope"
          ],
          "description": "What aspect of context this condition evaluates"
        },
        "conditionOperator": {
          "type": "string",
          "enum": ["equals", "contains", "not-equals", "greater-than", "less-than", "in-set"],
          "description": "Comparison operator for evaluating the condition"
        },
        "conditionValue": {
          "type": ["string", "array"],
          "description": "The value(s) to match against. String for single values, array for in-set operator."
        },
        "conditionTarget": {
          "type": "string",
          "description": "Property path reference being evaluated (e.g. 'org-ctx:Product.productCode', 'org-ctx:Organisation.maturityLevel')"
        }
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:ScopeAction",
      "name": "ScopeAction",
      "description": "The THEN clause of a GraphScopeRule. Defines what happens when the rule's condition(s) evaluate to true — which data to include, exclude, ghost, merge, or scope to a persona.",
      "termCode": "SA",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "actionType": {
          "type": "string",
          "enum": ["include-data", "exclude-data", "ghost", "merge-subgraph", "scope-to-persona"],
          "description": "What action to take: include-data (add to visible set), exclude-data (remove from visible set), ghost (render as faded/secondary), merge-subgraph (merge external subgraph into composed graph), scope-to-persona (filter to persona-specific workflow)"
        },
        "targetNamespaces": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Namespace prefixes to target (e.g. ['vp:', 'rrr:', 'efs:'])"
        },
        "targetEntityTypes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific entity @type values to target (e.g. ['vp:ValueProposition', 'rrr:Role'])"
        },
        "targetEntityFilter": {
          "type": ["string", "null"],
          "description": "Property predicate expression for fine-grained entity filtering (e.g. \"productContext == 'BAIV-AIV'\")"
        },
        "applyToRelationships": {
          "type": "boolean",
          "description": "Whether the action cascades to relationships connected to matched entities"
        }
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:ComposedGraphSpec",
      "name": "ComposedGraphSpec",
      "description": "A specification for a composed PFI dataset — like a view definition for the PFI graph. Defines which ontologies contribute data, how data slices are selected, and what cross-ontology join points connect the composed graph.",
      "termCode": "CGS",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "specId": {
          "type": "string",
          "required": true,
          "description": "Unique spec identifier",
          "example": "BAIV-AIV-Graph-Spec"
        },
        "specName": {
          "type": "string",
          "required": true,
          "description": "Human-readable name for the composed graph"
        },
        "componentOntologies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Which ontologies contribute data to this composed graph"
        },
        "dataSliceRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ontology": { "type": "string" },
              "slice": { "type": "string" }
            }
          },
          "description": "References to specific data slices within each contributing ontology"
        },
        "joinPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "relationship": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Cross-ontology join definitions connecting entities across ontology boundaries"
        },
        "rootAnchorEntity": {
          "type": "string",
          "description": "The anchor node @id for the graph — typically the InstanceConfiguration that owns this spec"
        },
        "frozenVersion": {
          "type": ["string", "null"],
          "description": "null = draft (still being composed), semver string = frozen (locked via CanonicalSnapshot)"
        }
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:CanonicalSnapshot",
      "name": "CanonicalSnapshot",
      "description": "A frozen, versioned graph template that PFI instances inherit. Once locked, a snapshot is immutable — changes require creating a new version. Snapshots form a version chain via parentSnapshot references.",
      "termCode": "CS",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "snapshotId": {
          "type": "string",
          "required": true,
          "description": "Unique snapshot identifier",
          "example": "BAIV-AIV-Snapshot-v1.0.0"
        },
        "snapshotVersion": {
          "type": "string",
          "required": true,
          "description": "Semantic version of this snapshot (e.g. '1.0.0')"
        },
        "sourceComposedGraphSpec": {
          "type": "string",
          "description": "Reference to the ComposedGraphSpec that this snapshot freezes"
        },
        "frozenAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the snapshot was frozen"
        },
        "frozenBy": {
          "type": "string",
          "description": "Admin or system reference that created the frozen snapshot"
        },
        "changeControlStatus": {
          "type": "string",
          "enum": ["locked", "pending-review", "superseded"],
          "description": "locked = immutable active snapshot, pending-review = proposed but not yet approved, superseded = replaced by a newer version"
        },
        "parentSnapshot": {
          "type": ["string", "null"],
          "description": "Reference to the previous snapshot version in the chain (null for first version)"
        }
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:ProductEntityBinding",
      "name": "ProductEntityBinding",
      "description": "Represents a binding between a product/service and a graph entity. Bindings are created explicitly from instance data or inferred by relationship proximity (BFS). Each binding carries a confidence score: 1.0 for explicit (instance-data or cross-reference), 0.5 for inferred at depth 1, 0.25 for inferred at depth 2.",
      "termCode": "PEB",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Intangible",
      "properties": {
        "bindingId": {
          "type": "string",
          "required": true,
          "description": "Unique binding identifier",
          "example": "PEB-BAIV-AIV-vp-prob-001"
        },
        "productRef": {
          "type": "string",
          "required": true,
          "description": "Reference to an org-ctx:Product @id",
          "example": "org-ctx:Product-BAIV-AIV"
        },
        "boundEntityRef": {
          "type": "string",
          "required": true,
          "description": "Reference to the bound entity @id (any entity in any ontology)",
          "example": "vp:airl-prob-strategic"
        },
        "boundOntology": {
          "type": "string",
          "required": true,
          "description": "Namespace prefix of the ontology containing the bound entity",
          "example": "vp:"
        },
        "bindingType": {
          "type": "string",
          "required": true,
          "enum": ["instance-data", "cross-reference", "inferred"],
          "description": "instance-data = entity present in PFI instance data files for this product, cross-reference = entity referenced via cross-ontology relationship, inferred = entity discovered via BFS proximity to an explicitly-bound entity"
        },
        "bindingConfidence": {
          "type": "number",
          "required": true,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Confidence score: 1.0 = explicit binding (instance-data or cross-reference), 0.5 = inferred at BFS depth 1, 0.25 = inferred at BFS depth 2"
        }
      },
      "addedIn": "v5.1.0"
    },
    {
      "@type": "DefinedTerm",
      "@id": "emc:BindingType",
      "name": "BindingType",
      "description": "Enumeration of product-entity binding types",
      "termCode": "BT",
      "inDefinedTermSet": "emc:emc-ontology",
      "schemaType": "schema:Enumeration",
      "enumValues": [
        {
          "@id": "emc:BindingType-InstanceData",
          "name": "instance-data",
          "description": "Entity is present in PFI instance data files for the product — direct, explicit binding"
        },
        {
          "@id": "emc:BindingType-CrossReference",
          "name": "cross-reference",
          "description": "Entity is bound via a cross-ontology relationship (e.g. join point, conditionReferencesProduct)"
        },
        {
          "@id": "emc:BindingType-Inferred",
          "name": "inferred",
          "description": "Entity inferred by BFS proximity to an explicitly-bound entity — confidence decreases with depth"
        }
      ],
      "addedIn": "v5.1.0"
    },
    {
      "@type": "DefinedTerm",
      "@id": "vsom:Vision",
      "name": "Vision",
      "description": "External VSOM entity representing the organisational vision that anchors VE-Series strategic planning compositions. EMC orchestrates vision-to-execution flows through this entry point.",
      "oaa:externalOntology": "vsom:VisionStrategyObjectivesMetricsOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "okr:Objective",
      "name": "Objective",
      "description": "External OKR entity representing a strategic objective. EMC maps requirement categories to OKR objectives for goal-driven ontology composition.",
      "oaa:externalOntology": "okr:OKROntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "ppm:Portfolio",
      "name": "Portfolio",
      "description": "External PPM entity representing a project portfolio. EMC orchestrates portfolio-to-delivery flows through PE-Series activation.",
      "oaa:externalOntology": "ppm:PortfolioProgramProjectManagementOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "ea:Initiative",
      "name": "Initiative",
      "description": "External EA entity representing an enterprise architecture initiative. EMC connects EA initiatives to compliance and governance through RCSG-Series.",
      "oaa:externalOntology": "ea:EnterpriseArchitectureOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "mcsb:SecurityControl",
      "name": "SecurityControl",
      "description": "External MCSB entity representing a cloud security benchmark control. EMC activates RCSG-Series governance overlay when compliance requirements are in scope.",
      "oaa:externalOntology": "mcsb:MCSBOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "gdpr:ComplianceObligation",
      "name": "ComplianceObligation",
      "description": "External GDPR entity representing a regulatory compliance obligation. EMC includes GDPR obligations in governance-aware compositions.",
      "oaa:externalOntology": "gdpr:GDPRRegulatoryFrameworkOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "org:Organisation",
      "name": "Organisation",
      "description": "External ORG entity representing the organisational context. EMC scopes all compositions to organisation context as the mandatory foundation layer.",
      "oaa:externalOntology": "org:OrganisationFoundationOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "org-ctx:CompetitiveLandscape",
      "name": "CompetitiveLandscape",
      "description": "External ORG-CONTEXT entity representing the org-specific competitive landscape — competitors, market position, differentiation. Replaces the deprecated CA-ONT/CL-ONT entities (absorbed in Epic 9C).",
      "oaa:externalOntology": "org-ctx:OrganisationContextOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "org-ctx:Product",
      "name": "Product",
      "description": "External ORG-CONTEXT entity representing a product or service within the organisation. Graph-scope rules use product-match conditions to filter instance data by product context.",
      "oaa:externalOntology": "org-ctx:OrganisationContextOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "vp:IdealCustomerProfile",
      "name": "IdealCustomerProfile",
      "description": "External VP-ONT entity representing an ideal customer profile (ICP). Graph-scope rules use icp-seniority conditions to filter data by customer segment and seniority level.",
      "oaa:externalOntology": "vp:ValuePropositionOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "ind:IndustryAnalysis",
      "name": "IndustryAnalysis",
      "description": "External INDUSTRY-ONT entity representing market-level competitive analysis — Porter's 5 Forces, SWOT/TOWS, Ansoff Growth Matrix. Provides industry/sector-level competition context distinct from org-specific competitive landscape.",
      "oaa:externalOntology": "ind:IndustryAnalysisOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "crt:CustomerRole",
      "name": "CustomerRole",
      "description": "External CRT-ONT hub entity representing a customer-side role archetype (B2B buyer, B2C consumer, B2B2C intermediary). Maps to VP-ONT stakeholder types and RRR-ONT roles. Enables role-specific value propositions and risk/requirement modelling.",
      "oaa:externalOntology": "crt:CustomerRoleTaxonomyOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "pe:AIAgent",
      "name": "AIAgent",
      "description": "External PE-ONT entity representing an AI agent (analysis, generation, optimization, orchestration, validation, monitoring). Bridges to RRR roles via agentActsAs and to PE processes via agentOwnsProcess.",
      "oaa:externalOntology": "pe:ProcessEngineeringOntology"
    },
    {
      "@type": "DefinedTerm",
      "@id": "rbac:AccessPolicy",
      "name": "AccessPolicy",
      "description": "External RBAC entity (defined in RRR-ONT) that binds roles to permission sets. Agents are governed by access policies via agentGovernedBy, enabling graph-queryable authorization.",
      "oaa:externalOntology": "rrr:RolesRACIRBACOntology"
    }
  ],
  "relationships": [
    {
      "@type": "rdf:Property",
      "@id": "emc:hasScopingDimension",
      "name": "hasScopingDimension",
      "description": "The EMC ontology defines scoping dimensions that control composition",
      "domainIncludes": "emc:emc-ontology",
      "rangeIncludes": "emc:ScopingDimension",
      "cardinality": "1:n"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:hasCategory",
      "name": "hasCategory",
      "description": "The EMC ontology defines requirement categories that map to compositions",
      "domainIncludes": "emc:emc-ontology",
      "rangeIncludes": "emc:RequirementCategory",
      "cardinality": "1:n"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:producesComposition",
      "name": "producesComposition",
      "description": "A requirement category produces a specific ontology composition when activated",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "emc:OntologyComposition",
      "cardinality": "1:1"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:scopedByDimension",
      "name": "scopedByDimension",
      "description": "A requirement category is further refined by scoping dimensions",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "emc:ScopingDimension",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:governedByRule",
      "name": "governedByRule",
      "description": "An ontology composition is governed by composition rules that determine final output",
      "domainIncludes": "emc:OntologyComposition",
      "rangeIncludes": "emc:CompositionRule",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:usesPattern",
      "name": "usesPattern",
      "description": "An ontology composition uses a graph pattern for cross-series assembly",
      "domainIncludes": "emc:OntologyComposition",
      "rangeIncludes": "emc:GraphPattern",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:activatesSeries",
      "name": "activatesSeries",
      "description": "A requirement category activates one or more ontology series in its composition",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "emc:OntologySeries",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:hasContextLevel",
      "name": "hasContextLevel",
      "description": "A scoping dimension distinguishes between PFC and PFI context levels",
      "domainIncludes": "emc:ScopingDimension",
      "rangeIncludes": "emc:ContextLevel",
      "cardinality": "1:n"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:hasInstanceConfig",
      "name": "hasInstanceConfig",
      "description": "A PFI context level has pre-defined instance configurations for specific products",
      "domainIncludes": "emc:ContextLevel",
      "rangeIncludes": "emc:InstanceConfiguration",
      "cardinality": "1:n"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesVESeries",
      "name": "orchestratesVESeries",
      "description": "EMC requirement categories orchestrate VE-Series by connecting to strategic vision and objectives for value engineering compositions",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "vsom:Vision",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesOKR",
      "name": "orchestratesOKR",
      "description": "EMC requirement categories connect to OKR objectives for goal-driven composition filtering",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "okr:Objective",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesPESeries",
      "name": "orchestratesPESeries",
      "description": "EMC requirement categories orchestrate PE-Series by connecting to portfolio management for execution-layer compositions",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "ppm:Portfolio",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesEAInitiatives",
      "name": "orchestratesEAInitiatives",
      "description": "EMC requirement categories connect to EA initiatives for enterprise architecture compositions with governance",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "ea:Initiative",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesRCSGSeries",
      "name": "orchestratesRCSGSeries",
      "description": "EMC requirement categories orchestrate RCSG-Series by activating GRC-FW governance hub, security controls and compliance obligations as governance overlay",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "mcsb:SecurityControl",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesCompliance",
      "name": "orchestratesCompliance",
      "description": "EMC requirement categories connect to GDPR compliance obligations for regulatory-aware compositions",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "gdpr:ComplianceObligation",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesFoundation",
      "name": "orchestratesFoundation",
      "description": "EMC requirement categories orchestrate Foundation by scoping all compositions to organisation context as the mandatory base layer",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "org:Organisation",
      "cardinality": "n:1"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesOrgContext",
      "name": "orchestratesOrgContext",
      "description": "EMC requirement categories connect to ORG-CONTEXT competitive landscape for org-specific competitor analysis, market position, and differentiation. Replaces the deprecated orchestratesCompetitive bridge (CA-ONT absorbed into ORG-CONTEXT since Epic 9C).",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "org-ctx:CompetitiveLandscape",
      "cardinality": "n:m",
      "competitionPath": "org-specific"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesMarketContext",
      "name": "orchestratesMarketContext",
      "description": "EMC requirement categories connect to INDUSTRY-ONT for market-level competitive analysis — Porter's 5 Forces, SWOT/TOWS, Ansoff Growth, sector dynamics. Distinct from org-specific competition in ORG-CONTEXT.",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "ind:IndustryAnalysis",
      "cardinality": "n:m",
      "competitionPath": "market-level"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:orchestratesCustomerRoles",
      "name": "orchestratesCustomerRoles",
      "description": "EMC requirement categories connect to CRT-ONT customer role taxonomy for B2B/B2C/B2B2C customer-side role modelling, enabling role-specific value propositions and risk/requirement mapping",
      "domainIncludes": "emc:RequirementCategory",
      "rangeIncludes": "crt:CustomerRole",
      "cardinality": "n:m"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:agentActsAs",
      "name": "agentActsAs",
      "description": "An AI agent acts on behalf of a specific organisational role — inherits the role's strategic focus, RACI responsibilities, and decision authority. Enables role-scoped agent behaviour.",
      "domainIncludes": "pe:AIAgent",
      "rangeIncludes": [
        "pf:ExecutiveRole",
        "pf:FunctionalRole"
      ],
      "cardinality": "n:1",
      "bridgeType": "agent-role"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:agentOwnsProcess",
      "name": "agentOwnsProcess",
      "description": "An AI agent is the designated owner/executor of a process or workflow. Replaces the string-typed pe:Process.owner with a graph-queryable entity reference.",
      "domainIncludes": "pe:AIAgent",
      "rangeIncludes": "pe:Process",
      "cardinality": "n:m",
      "bridgeType": "agent-process"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:agentGovernedBy",
      "name": "agentGovernedBy",
      "description": "An AI agent's permissions are determined by an RBAC access policy. The policy defines which actions the agent can execute, on which resources, with what effect (allow/deny).",
      "domainIncludes": "pe:AIAgent",
      "rangeIncludes": "rbac:AccessPolicy",
      "cardinality": "n:m",
      "bridgeType": "agent-rbac"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:instanceHasScopeRule",
      "name": "instanceHasScopeRule",
      "description": "An InstanceConfiguration owns one or more GraphScopeRules that govern PFI data slicing for that instance",
      "domainIncludes": "emc:InstanceConfiguration",
      "rangeIncludes": "emc:GraphScopeRule",
      "cardinality": "1:n",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:ruleHasCondition",
      "name": "ruleHasCondition",
      "description": "A GraphScopeRule has one or more ScopeConditions (AND-combined) that must evaluate to true for the rule to fire",
      "domainIncludes": "emc:GraphScopeRule",
      "rangeIncludes": "emc:ScopeCondition",
      "cardinality": "1:n",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:ruleHasAction",
      "name": "ruleHasAction",
      "description": "A GraphScopeRule has exactly one ScopeAction that executes when all conditions are met",
      "domainIncludes": "emc:GraphScopeRule",
      "rangeIncludes": "emc:ScopeAction",
      "cardinality": "1:1",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:specReferencesOntologyData",
      "name": "specReferencesOntologyData",
      "description": "A ComposedGraphSpec references data from one or more OntologySeries as component data sources",
      "domainIncludes": "emc:ComposedGraphSpec",
      "rangeIncludes": "emc:OntologySeries",
      "cardinality": "n:n",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:snapshotFreezesSpec",
      "name": "snapshotFreezesSpec",
      "description": "A CanonicalSnapshot freezes a specific ComposedGraphSpec, creating an immutable versioned template",
      "domainIncludes": "emc:CanonicalSnapshot",
      "rangeIncludes": "emc:ComposedGraphSpec",
      "cardinality": "1:1",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:instanceInheritsSnapshot",
      "name": "instanceInheritsSnapshot",
      "description": "An InstanceConfiguration inherits a frozen CanonicalSnapshot as the basis for its PFI graph",
      "domainIncludes": "emc:InstanceConfiguration",
      "rangeIncludes": "emc:CanonicalSnapshot",
      "cardinality": "0:1",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:conditionReferencesProduct",
      "name": "conditionReferencesProduct",
      "description": "A ScopeCondition with conditionType 'product-match' references a specific org-ctx:Product entity",
      "domainIncludes": "emc:ScopeCondition",
      "rangeIncludes": "org-ctx:Product",
      "cardinality": "0:n",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:conditionReferencesICP",
      "name": "conditionReferencesICP",
      "description": "A ScopeCondition with conditionType 'icp-seniority' or 'persona-scope' references a specific vp:IdealCustomerProfile entity",
      "domainIncludes": "emc:ScopeCondition",
      "rangeIncludes": "vp:IdealCustomerProfile",
      "cardinality": "0:n",
      "addedIn": "v5.0.0"
    },
    {
      "@type": "rdf:Property",
      "@id": "emc:entityHasProductBinding",
      "name": "entityHasProductBinding",
      "description": "Any graph entity may have zero or more product bindings, each recording which product/service the entity is associated with and the confidence of that association",
      "domainIncludes": "schema:Thing",
      "rangeIncludes": "emc:ProductEntityBinding",
      "cardinality": "0:n",
      "addedIn": "v5.1.0"
    }
  ],
  "businessRules": [
    {
      "@id": "emc:rule-foundation-always-required",
      "name": "FoundationAlwaysRequired",
      "description": "Every enterprise model composition must include Foundation ORG-ONT as the base layer",
      "condition": "IF emc:OntologyComposition is created",
      "action": "THEN emc:OntologyComposition.requiredOntologies MUST include org:Organisation",
      "priority": 1,
      "severity": "error",
      "enforcementLevel": "mandatory"
    },
    {
      "@id": "emc:rule-dependency-chain-resolution",
      "name": "DependencyChainResolution",
      "description": "When an ontology is included in a composition, all its dependencies must also be included",
      "condition": "IF ontology X is in emc:OntologyComposition.requiredOntologies",
      "action": "THEN all ontologies in X.dependencies MUST also be in requiredOntologies",
      "priority": 2,
      "severity": "error",
      "enforcementLevel": "mandatory"
    },
    {
      "@id": "emc:rule-category-minimum-ontologies",
      "name": "CategoryMinimumOntologies",
      "description": "Every requirement category must activate at least one required ontology",
      "condition": "IF emc:RequirementCategory is specified",
      "action": "THEN emc:RequirementCategory.requiredOntologies.length >= 1",
      "priority": 3,
      "severity": "error",
      "enforcementLevel": "mandatory"
    },
    {
      "@id": "emc:rule-pfi-requires-product",
      "name": "PFIRequiresProductContext",
      "description": "PFI context level requires a product context to be specified for instance data loading",
      "condition": "IF emc:ContextLevel = PFI",
      "action": "THEN emc:ScopingDimension-ProductContext MUST be specified",
      "priority": 4,
      "severity": "error",
      "enforcementLevel": "mandatory"
    },
    {
      "@id": "emc:rule-maturity-filter",
      "name": "MaturityBasedFiltering",
      "description": "Organisations with maturity below threshold should not include advanced ontologies",
      "condition": "IF emc:ScopingDimension-OrgContext.maturityLevel < 3",
      "action": "THEN exclude advanced ontologies (KPI-ONT, GA-ONT, BSC-ONT) from composition",
      "priority": 5,
      "severity": "warning",
      "enforcementLevel": "advisory"
    },
    {
      "@id": "emc:rule-rcsg-governance-overlay",
      "name": "RCSGGovernanceOverlay",
      "description": "When compliance or security requirements are in scope, RCSG-Series must be activated as governance overlay via GRC-FW hub",
      "condition": "IF emc:RequirementCategory.categoryCode = COMPLIANCE OR ea:Initiative references compliance",
      "action": "THEN activate emc:OntologySeries-RCSG with GRC-FW hub, MCSB and GDPR ontologies",
      "priority": 6,
      "severity": "warning",
      "enforcementLevel": "advisory"
    },
    {
      "@id": "emc:rule-enterprise-all-series",
      "name": "EnterpriseAllSeries",
      "description": "Full enterprise model composition must activate all 5 ontology series",
      "condition": "IF emc:RequirementCategory.categoryCode = ENTERPRISE",
      "action": "THEN emc:OntologyComposition.activeSeries MUST include VE, PE, RCSG, Foundation, Orchestration",
      "priority": 7,
      "severity": "error",
      "enforcementLevel": "mandatory"
    },
    {
      "@id": "emc:rule-agent-role-bridge",
      "name": "AgentRoleBridgeRequired",
      "description": "When AGENTIC scope is active in a PFI context, the agent-role-RBAC bridge chain must be resolvable",
      "condition": "IF emc:RequirementCategory.categoryCode = AGENTIC AND emc:ContextLevel = PFI",
      "action": "THEN pe:AIAgent instances MUST have agentActsAs → role reference AND agentGovernedBy → RBAC policy",
      "priority": 8,
      "severity": "error",
      "enforcementLevel": "mandatory"
    },
    {
      "@id": "emc:rule-scope-rule-requires-condition",
      "name": "ScopeRuleRequiresCondition",
      "description": "Every GraphScopeRule must have at least one ScopeCondition to evaluate",
      "condition": "IF emc:GraphScopeRule is created",
      "action": "THEN emc:GraphScopeRule MUST have >= 1 ScopeCondition via ruleHasCondition",
      "priority": 9,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-scope-rule-requires-action",
      "name": "ScopeRuleRequiresAction",
      "description": "Every GraphScopeRule must have exactly one ScopeAction to execute",
      "condition": "IF emc:GraphScopeRule is created",
      "action": "THEN emc:GraphScopeRule MUST have exactly 1 ScopeAction via ruleHasAction",
      "priority": 10,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-scope-priority-unique",
      "name": "ScopePriorityUnique",
      "description": "GraphScopeRule priorities must be unique within each InstanceConfiguration to ensure deterministic evaluation order",
      "condition": "IF emc:GraphScopeRule is assigned to an InstanceConfiguration",
      "action": "THEN emc:GraphScopeRule.priority MUST be unique within that InstanceConfiguration",
      "priority": 11,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-include-before-exclude",
      "name": "IncludeBeforeExclude",
      "description": "When scope rules at the same effective priority conflict, include-data actions should evaluate before exclude-data actions",
      "condition": "IF two GraphScopeRules have the same effective priority within an instance",
      "action": "THEN include-data actions SHOULD evaluate before exclude-data actions",
      "priority": 12,
      "severity": "warning",
      "enforcementLevel": "advisory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-product-match-valid",
      "name": "ProductMatchValid",
      "description": "Product-match conditions must reference a valid product entity in ORG-CONTEXT",
      "condition": "IF emc:ScopeCondition.conditionType = 'product-match'",
      "action": "THEN emc:ScopeCondition.conditionValue MUST reference a valid org-ctx:Product",
      "priority": 13,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-composed-graph-not-empty",
      "name": "ComposedGraphNotEmpty",
      "description": "A composed graph specification must produce at least one visible entity after all scope rules are evaluated",
      "condition": "IF emc:ComposedGraphSpec is evaluated with scope rules",
      "action": "THEN the resolved entity set MUST NOT be empty (at least 1 visible entity)",
      "priority": 14,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-snapshot-immutable",
      "name": "SnapshotImmutable",
      "description": "A locked CanonicalSnapshot is immutable — any modifications require creating a new version with an incremented snapshotVersion and a parentSnapshot reference to the locked version",
      "condition": "IF emc:CanonicalSnapshot.changeControlStatus = 'locked'",
      "action": "THEN the snapshot MUST NOT be modified; changes require a new CanonicalSnapshot with incremented version",
      "priority": 15,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.0.0"
    },
    {
      "@id": "emc:rule-binding-confidence-valid",
      "name": "BindingConfidenceValid",
      "description": "ProductEntityBinding confidence must be 1.0 for instance-data and cross-reference binding types, and auto-calculated for inferred bindings (0.5 at BFS depth 1, 0.25 at depth 2)",
      "condition": "IF emc:ProductEntityBinding is created",
      "action": "THEN bindingConfidence MUST be 1.0 when bindingType is 'instance-data' or 'cross-reference', and MUST be 0.5 (depth 1) or 0.25 (depth 2) when bindingType is 'inferred'",
      "priority": 16,
      "severity": "error",
      "enforcementLevel": "mandatory",
      "addedIn": "v5.1.0"
    }
  ],
  "crossOntologyReferences": {
    "description": "EMC serves as the orchestration hub connecting all 5 ontology series with two-path competition, agent-role bridges, and graph-scope rule references",
    "keyBridges": [
      {
        "from": "emc:RequirementCategory",
        "to": "vsom:Vision",
        "relationship": "orchestratesVESeries",
        "series": "VE-Series"
      },
      {
        "from": "emc:RequirementCategory",
        "to": "okr:Objective",
        "relationship": "orchestratesOKR",
        "series": "VE-Series"
      },
      {
        "from": "emc:RequirementCategory",
        "to": "crt:CustomerRole",
        "relationship": "orchestratesCustomerRoles",
        "series": "VE-Series"
      },
      {
        "from": "emc:RequirementCategory",
        "to": "ppm:Portfolio",
        "relationship": "orchestratesPESeries",
        "series": "PE-Series"
      },
      {
        "from": "emc:RequirementCategory",
        "to": "ea:Initiative",
        "relationship": "orchestratesEAInitiatives",
        "series": "PE-Series"
      },
      {
        "from": "emc:RequirementCategory",
        "to": "mcsb:SecurityControl",
