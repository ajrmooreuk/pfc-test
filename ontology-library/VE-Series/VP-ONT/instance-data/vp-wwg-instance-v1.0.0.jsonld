    },

    {
      "@id": "vp:wwg-msg-primary",
      "@type": "vp:MessagingFramework",
      "frameworkId": "msg:wwg-primary",
      "primaryMessage": "World-class products, world-class visibility — your international supply chain, managed.",
      "supportingMessages": [
        "4 corridors, 1 graph — see your entire supply chain in real time",
        "We tell you about disruptions before they reach your customers",
        "Margin-protected fulfilment: you know the true cost of every order, every day",
        "When AU is disrupted, NZ is ready — cross-corridor substitution in hours, not weeks"
      ],
      "emotionalHooks": ["Confidence in supply", "No more month-end margin surprises", "Your customers never see the disruption"],
      "useCustomerLanguage": true
    }
  ],

  "relationships": [
    { "@type": "vp:belongsToOrgContext", "from": "vp:wwg-vp-001", "to": "org:ctx-wwg" },

    { "@type": "vp:targetsICP", "from": "vp:wwg-vp-001", "to": "vp:wwg-icp-restaurant" },
    { "@type": "vp:targetsICP", "from": "vp:wwg-vp-001", "to": "vp:wwg-icp-wholesaler" },
    { "@type": "vp:targetsICP", "from": "vp:wwg-vp-001", "to": "vp:wwg-icp-foodservice" },
