  "vsom:metrics": [
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-f1-1",
      "vsom:metricName": "Margin Realisation Ratio",
      "vsom:metricType": "Lagging",
      "vsom:formula": "Realised margin / Booked margin × 100%",
      "vsom:unit": "%",
      "vsom:baselineValue": 72,
      "vsom:targetValue": 88,
      "vsom:dataSource": "ERP margin reports + graph MarginImpact entities",
      "vsom:frequency": "Monthly",
      "vsom:objectiveRef": "vsom:obj-wwg-f1"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-f2-1",
      "vsom:metricName": "Annualised Disruption Cost",
      "vsom:metricType": "Lagging",
      "vsom:formula": "Σ(supply disruption cost + demand disruption cost) over trailing 12 months",
      "vsom:unit": "GBP",
      "vsom:baselineValue": 480000,
      "vsom:targetValue": 180000,
      "vsom:dataSource": "ImpactAssessment + MarginImpact entities",
      "vsom:frequency": "Monthly",
      "vsom:objectiveRef": "vsom:obj-wwg-f2"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-f2-2",
      "vsom:metricName": "Margin-at-Risk (MaR)",
      "vsom:metricType": "Leading",
      "vsom:formula": "Σ(active_erosion) + Σ(P(risk_i) × impact_i) + max(scenario_exposure)",
      "vsom:unit": "GBP",
      "vsom:baselineValue": null,
      "vsom:targetValue": null,
      "vsom:dataSource": "MarginImpact + FulfilmentRisk + Scenario entities",
      "vsom:frequency": "Weekly",
      "vsom:objectiveRef": "vsom:obj-wwg-f2"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-c1-1",
      "vsom:metricName": "OTIF Rate",
      "vsom:metricType": "Lagging",
      "vsom:formula": "On-Time In-Full deliveries / Total deliveries × 100%",
      "vsom:unit": "%",
      "vsom:baselineValue": 88,
      "vsom:targetValue": 97,
      "vsom:dataSource": "DeliveryWindow + DispatchLeg entities",
      "vsom:frequency": "Monthly",
      "vsom:objectiveRef": "vsom:obj-wwg-c1"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-c2-1",
      "vsom:metricName": "Proactive Notification Rate",
      "vsom:metricType": "Leading",
      "vsom:formula": "Disruptions notified proactively / Total disruptions × 100%",
      "vsom:unit": "%",
      "vsom:baselineValue": 20,
      "vsom:targetValue": 90,
      "vsom:dataSource": "FulfilmentRisk + notification log",
      "vsom:frequency": "Monthly",
      "vsom:objectiveRef": "vsom:obj-wwg-c2"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-p1-1",
      "vsom:metricName": "Mean Time to Detect (MTTD)",
      "vsom:metricType": "Leading",
      "vsom:formula": "Average(time from incident occurrence to detection) across all corridors",
      "vsom:unit": "hours",
      "vsom:baselineValue": 18,
      "vsom:targetValue": 2,
      "vsom:dataSource": "Incident + PredictivePattern entities",
      "vsom:frequency": "Monthly",
      "vsom:objectiveRef": "vsom:obj-wwg-p1"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-p2-1",
      "vsom:metricName": "Mean Time to Resolve (MTTR)",
      "vsom:metricType": "Lagging",
      "vsom:formula": "Average(time from detection to resolution) across all corridors",
      "vsom:unit": "hours",
      "vsom:baselineValue": 72,
      "vsom:targetValue": 12,
      "vsom:dataSource": "Incident + Escalation entities",
      "vsom:frequency": "Monthly",
      "vsom:objectiveRef": "vsom:obj-wwg-p2"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-l1-1",
      "vsom:metricName": "Validated Pattern Count",
      "vsom:metricType": "Leading",
      "vsom:formula": "Count of PredictivePattern entities with reliability > 0.6",
      "vsom:unit": "count",
      "vsom:baselineValue": 0,
      "vsom:targetValue": 50,
      "vsom:dataSource": "PredictivePattern entity library",
      "vsom:frequency": "Quarterly",
      "vsom:objectiveRef": "vsom:obj-wwg-l1"
    },
    {
      "@type": "vsom:Metric",
      "@id": "vsom:metric-wwg-cross-1",
      "vsom:metricName": "Supply Disruption → Customer Impact Ratio",
      "vsom:metricType": "Lagging",
      "vsom:formula": "Customers affected / Supply-side incidents",
      "vsom:unit": "ratio",
      "vsom:baselineValue": null,
      "vsom:targetValue": 3.0,
      "vsom:dataSource": "Cross-graph traversal: Incident → CascadeEffect → MarginImpact → SalesOrder",
      "vsom:frequency": "Monthly",
