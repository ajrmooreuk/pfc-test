  "@type": "vsom:VSOMFramework",
  "@id": "vsom:framework-airl",
  "vsom:organizationContextRef": "org:ctx-airl",

  "vsom:vision": {
    "@type": "vsom:Vision",
    "@id": "vsom:vision-airl",
    "vsom:visionStatement": "Become the UK's trusted platform for NCSC CAF compliance — replacing manual audit spreadsheets with an agentic assessment engine that delivers 70% cost savings, 5x faster assessments, and continuous compliance visibility from board level to IGP level.",
    "vsom:visionScope": "organizational",
    "vsom:visionHorizon": 5,
    "vsom:visionOwner": "rrr:role-airl-pfi-owner",
    "vsom:status": "draft",
    "vsom:keyInsight": "NIS Regulations require ~700 UK operators of essential services to demonstrate CAF compliance. Current approach: Big 4 consulting at £200K-£1M per engagement, 3-6 month cycles. Opportunity: platform-based compliance at 70% cost reduction with continuous monitoring."
  },

  "vsom:strategies": [
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-airl-1",
      "vsom:strategyName": "Agentic CAF Assessment Engine",
      "vsom:strategyDescription": "Build an agentic audit engine that automates gap analysis across the full CAF hierarchy (4 Objectives → 14 Principles → 41 Outcomes → ~559 IGPs), with evidence collection, scoring, and remediation sequencing.",
      "vsom:strategyType": "innovation",
      "vsom:strategicFocus": "Product differentiation through AI-driven automation",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-airl-pfi-owner",
      "vsom:informedBy": ["vsom:vision-airl"],
      "vsom:status": "draft"
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-airl-2",
      "vsom:strategyName": "Cross-Framework Compliance Bridge",
      "vsom:strategyDescription": "Map CAF compliance to parallel frameworks (ISO 27001, GDPR, Azure MCSB, DSPT) so that a single assessment covers multiple regulatory requirements, reducing total compliance burden for customers.",
      "vsom:strategyType": "operational_excellence",
      "vsom:strategicFocus": "Customer value through compliance efficiency",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-airl-pfi-owner",
      "vsom:informedBy": ["vsom:vision-airl"],
      "vsom:status": "draft",
      "vsom:frameworkMappings": [
        { "from": "NCSC-CAF", "to": "ISO 27001:2022", "ontology": "NCSC-CAF-ONT ↔ RMF-IS27005-ONT" },
        { "from": "NCSC-CAF", "to": "GDPR/UK DPA", "ontology": "NCSC-CAF-ONT ↔ PII-ONT" },
        { "from": "NCSC-CAF", "to": "Azure MCSB", "ontology": "NCSC-CAF-ONT ↔ MCSB-ONT" },
        { "from": "NCSC-CAF", "to": "DSPT", "ontology": "NCSC-CAF-ONT ↔ DSPT-ONT" }
      ]
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-airl-3",
      "vsom:strategyName": "Cyber Insurance Readiness Scoring",
      "vsom:strategyDescription": "Provide a quantified cyber insurance readiness score (0-100) based on CAF compliance evidence, enabling customers to negotiate better premiums and demonstrate due diligence to underwriters.",
      "vsom:strategyType": "customer_centricity",
      "vsom:strategicFocus": "Financial value creation for customers",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-airl-pfi-owner",
      "vsom:informedBy": ["vsom:vision-airl", "vsom:strategy-airl-1"],
      "vsom:status": "draft"
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-airl-4",
      "vsom:strategyName": "UK Public Sector Market Penetration",
      "vsom:strategyDescription": "Establish AIRL as the default CAF compliance platform for UK public sector and CNI operators, leveraging GovAssure preparation as the entry point.",
      "vsom:strategyType": "growth",
      "vsom:strategicFocus": "Market development and customer acquisition",
      "vsom:timeHorizon": 3,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-airl-pfi-owner",
      "vsom:informedBy": ["vsom:vision-airl"],
      "vsom:status": "draft"
    }
  ],

