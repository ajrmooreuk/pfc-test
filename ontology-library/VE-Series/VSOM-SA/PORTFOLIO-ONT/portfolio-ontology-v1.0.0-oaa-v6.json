  "oaa:joinPatterns": [
    {
      "patternId": "JP-PFL-001",
      "name": "Portfolio-to-Strategy-to-Execution Chain",
      "description": "BCG classification drives strategy which drives portfolio investment which drives agile execution.",
      "joinPath": "pfl:GrowthShareEntry → pfl:entryDrivesStrategy → vsom:StrategyComponent → ppm:Portfolio → ppm:Initiative → efs:Epic",
      "useCase": "From portfolio analysis through strategic investment to delivery"
    },
    {
      "patternId": "JP-PFL-002",
      "name": "Three Horizons Investment Flow",
      "description": "Innovation horizon investments flow through PPM to measurable outcomes via OKR/KPI.",
      "joinPath": "pfl:ThreeHorizonsModel → pfl:hasHorizonInitiative → pfl:HorizonInitiative → pfl:initiativeFundedBy → ppm:Initiative → kpi:KPI ← okr:Objective ← vsom:ObjectivesComponent",
      "useCase": "Innovation investments connect to strategic measurement"
    },
    {
      "patternId": "JP-PFL-003",
      "name": "Strategic Lens Full Traversal",
      "description": "From a single product/brand lens, traverse ALL connected strategic analyses — the focused graph view for AI agents.",
      "joinPath": "pfl:PortfolioStrategicLens → pfl:lensViewsEntity → orgctx:Product → [pfl:GrowthShareEntry, ind:AnsoffGrowthMatrix, vp:ValueProposition, pmf:ProductMarketFit, kpi:KPI, okr:Objective, ppm:Initiative]",
      "useCase": "Comprehensive strategic picture for a single portfolio element"
    },
    {
      "patternId": "JP-PFL-004",
      "name": "E2E Strategic Analysis Graph",
      "description": "THE COMPLETE END-TO-END GRAPH across all VSOM-SA layers: macro → industry → org → reasoning → portfolio → execution.",
      "joinPath": "mac:PESTELAnalysis → vsom:VisionComponent → vsom:StrategyComponent ← [ind:SWOTAnalysis, ind:PortersFiveForcesAnalysis] → bsc:BalancedScorecard → kpi:KPI; vsom:StrategyComponent → pfl:StrategicInvestmentMap → ppm:Portfolio → efs:Epic",
      "useCase": "Complete outside-in strategic analysis from macro environment to agile delivery"
    }
  ],
