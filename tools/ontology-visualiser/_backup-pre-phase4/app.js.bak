};

let _mermaidEditorDebounce = null;
window.toggleMermaidEditor = function() {
  const panel = document.getElementById('mermaid-editor-panel');
  if (!panel) return;
  const isOpen = panel.classList.contains('open');
  if (isOpen) {
    panel.classList.remove('open');
    state.mermaidEditorOpen = false;
  } else {
    panel.classList.add('open');
    state.mermaidEditorOpen = true;
    // Populate editor with current diagram source
    const textarea = document.getElementById('mermaid-source-editor');
    if (textarea && state.mermaidDiagrams.length) {
      textarea.value = state.mermaidDiagrams[state.mermaidActiveDiagram]?.source || '';
    }
  }
};

window.fitMermaid = function() {
  fitMermaidDiagram('mermaid-render');
};

window.onMermaidSourceChange = function() {
  clearTimeout(_mermaidEditorDebounce);
  _mermaidEditorDebounce = setTimeout(async () => {
    const textarea = document.getElementById('mermaid-source-editor');
    if (!textarea) return;
    const source = textarea.value.trim();
    if (!source) return;

    const errorEl = document.getElementById('mermaid-editor-error');
    const result = await renderMermaidDiagram(source, 'mermaid-render');
    if (result.error && errorEl) {
      errorEl.textContent = result.error;
      errorEl.style.display = 'block';
    } else if (errorEl) {
      errorEl.style.display = 'none';
    }

    // Update state
    if (state.mermaidDiagrams[state.mermaidActiveDiagram]) {
      state.mermaidDiagrams[state.mermaidActiveDiagram].source = source;
    }
  }, 300);
};

window.insertMermaidTemplate = function(type) {
  const templates = {
    flowchart: 'flowchart LR\n    A["Start"] --> B["Process"]\n    B --> C{"Decision"}\n    C -->|"Yes"| D["End"]\n    C -->|"No"| B',
    sequence: 'sequenceDiagram\n    participant A as Client\n    participant B as Server\n    A->>B: Request\n    B-->>A: Response',
    state: 'stateDiagram-v2\n    [*] --> Idle\n    Idle --> Processing: start\n    Processing --> Done: complete\n    Done --> [*]',
    gantt: 'gantt\n    title Project Plan\n    dateFormat YYYY-MM-DD\n    section Phase 1\n    Task A :a1, 2025-01-01, 30d\n    Task B :after a1, 20d',
    classDiagram: 'classDiagram\n    class Entity {\n        +String name\n        +String description\n    }\n    class Relationship {\n        +String type\n    }\n    Entity --> Relationship'
  };
  const textarea = document.getElementById('mermaid-source-editor');
  if (textarea && templates[type]) {
    textarea.value = templates[type];
    window.onMermaidSourceChange();
  }
  // Reset the select
  const sel = document.getElementById('mermaid-type-select');
  if (sel) sel.selectedIndex = 0;
};

window.downloadMermaidSource = function() {
  const textarea = document.getElementById('mermaid-source-editor');
  const source = textarea?.value || state.mermaidSource || '';
  if (!source.trim()) { alert('No Mermaid source to download'); return; }
  const baseName = (state.mermaidFileName || 'diagram').replace(/\.(mmd|mermaid)$/i, '');
  const blob = new Blob([source], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `${baseName}.mmd`;
  a.click();
  URL.revokeObjectURL(url);
};

