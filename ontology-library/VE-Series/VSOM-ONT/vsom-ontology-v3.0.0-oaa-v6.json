            "Minor-Adjustment",
            "Major-Pivot",
            "Full-Revision"
          ]
        },
        {
          "name": "recommendedActions",
          "type": "xsd:string",
          "required": false,
          "description": "Recommended strategic adjustments"
        },
        {
          "name": "decisionOutcome",
