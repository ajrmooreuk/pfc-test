flowchart TB
    subgraph F["Financial Perspective"]
        direction LR
        F1["£500K ARR from<br/>Ontology Risk Services"]
        F2["70% Gross Margin<br/>via Ontology Reuse"]
    end

    subgraph C["Customer Perspective"]
        direction LR
        C1["25 Continuous Risk<br/>Graph Clients"]
        C2["90%+ Annual<br/>Retention Rate"]
        C3["100 Qualified Prospects<br/>via Benchmarking"]
    end

    subgraph P["Internal Process Perspective"]
        direction LR
        P1["Production Ontology<br/>500+ Classes"]
        P2["Automated Graph Deploy<br/>Under 2 Hours"]
        P3["Auto Compliance Gap<br/>Detection (5 Frameworks)"]
    end

    subgraph L["Learning & Growth Perspective"]
        direction LR
        L1["6 Certified Ontology<br/>& Graph Consultants"]
        L2["4 Sector Ontology<br/>Templates"]
    end

    L1 -->|"enables"| P1
    L2 -->|"accelerates"| P2
    L1 -->|"enables"| P3
    P1 -->|"powers"| C3
    P2 -->|"drives"| C1
    P3 -->|"drives"| C2
    P1 -->|"improves"| F2
    C1 -->|"increases"| F1
    C2 -->|"stabilises"| F1
    C3 -->|"converts to"| C1

    style F fill:#c8e6c9
    style C fill:#bbdefb
    style P fill:#fff9c4
    style L fill:#ffccbc
