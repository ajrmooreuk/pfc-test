      "oaa:properties": [
        {
          "name": "frameworkId",
          "type": "xsd:string",
          "required": true,
          "schemaOrgMapping": "schema:identifier"
        },
        {
          "name": "name",
          "type": "xsd:string",
          "required": true,
          "schemaOrgMapping": "schema:name"
        },
        {
          "name": "description",
          "type": "xsd:string",
          "required": false,
          "schemaOrgMapping": "schema:description"
        },
        {
          "name": "organizationRef",
          "type": "xsd:string",
          "required": true,
          "description": "Reference to org:Organization @id"
        },
        {
          "name": "driver",
          "type": "xsd:string",
          "required": true,
          "default": "BusinessImpact"
        },
        {
          "name": "goal",
          "type": "xsd:string",
          "required": true,
          "default": "Outcomes"
        },
        {
          "name": "measure",
          "type": "xsd:string",
          "required": true,
          "default": "Value"
        }
      ]
    },
