/**
 * Toggle the layer panel open/closed.
 */
function toggleLayerPanel() {
  const panel = document.getElementById('layer-panel');
  if (!panel) return;
  const isOpen = panel.style.display !== 'none';
  panel.style.display = isOpen ? 'none' : 'block';
  state.layerPanelOpen = !isOpen;
  if (!isOpen) _populateLayerChips();
}

/**
 * Populate the layer chips with current counts.
 */
function _populateLayerChips() {
  const container = document.getElementById('layer-chips');
  if (!container) return;
  const nodes = _getLayerFilterNodes();
  const crossRefIds = buildCrossRefNodeSet(state.crossEdges);
  const counts = computeLayerCounts(nodes, crossRefIds);

  let html = '';
  for (const [key, layer] of Object.entries(SEMANTIC_LAYERS)) {
    const count = counts[key] || 0;
    const isActive = state.activeLayers.has(key);
    const isEmpty = count === 0;
    const cls = `layer-chip${isActive ? ' active' : ''}${isEmpty ? ' empty' : ''}`;
    html += `<div class="${cls}" data-layer="${key}" onclick="toggleLayerUI('${key}')">` +
      `<div class="layer-chip-dot" style="background:${layer.color}; color:${layer.color}"></div>` +
      `<span class="layer-chip-name">${layer.name}</span>` +
      `<span class="layer-chip-count">${count}</span></div>`;
  }
  container.innerHTML = html;
}

/**
 * Get the nodes for layer filtering.
 * Uses mergedGraph nodes (multi-mode) or lastParsed (single-mode).
 */
function _getLayerFilterNodes() {
  if (state.mergedGraph && state.viewMode === 'multi') return state.mergedGraph.nodes || [];
  if (state.lastParsed) return state.lastParsed.nodes || [];
  return [];
}

/**
 * Toggle a specific layer on/off.
 */
function toggleLayerUI(layerKey) {
  if (!SEMANTIC_LAYERS[layerKey]) return;
  if (state.activeLayers.has(layerKey)) {
    state.activeLayers.delete(layerKey);
  } else {
    state.activeLayers.add(layerKey);
  }
  state.layerPreset = null; // clear preset when manually toggling
  const presetSelect = document.getElementById('layer-preset-select');
  if (presetSelect) presetSelect.value = '';
  _applyAndUpdateLayerUI();
}

/**
 * Set OR/AND filter mode.
 */
function setLayerModeUI(mode) {
  if (mode !== 'or' && mode !== 'and') return;
  state.layerMode = mode;
  // Update button states
  const btns = document.querySelectorAll('.layer-mode-btn');
  btns.forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
  if (state.layerFilterActive) applyLayerFilterToGraph();
  _updateLayerHash();
}

/**
 * Apply a preset layer view.
 */
function applyLayerPresetUI(presetKey) {
  if (!presetKey) {
    clearLayerFilterUI();
    return;
  }
  const preset = LAYER_PRESETS[presetKey];
  if (!preset) return;
  state.activeLayers = new Set(preset.layers);
  state.layerMode = preset.mode || 'or';
  state.layerPreset = presetKey;
  // Update mode buttons
  const btns = document.querySelectorAll('.layer-mode-btn');
  btns.forEach(b => b.classList.toggle('active', b.dataset.mode === state.layerMode));
  _applyAndUpdateLayerUI();
}

/**
 * Clear all layer filtering — show all nodes.
 */
function clearLayerFilterUI() {
  state.activeLayers = new Set();
  state.layerFilterActive = false;
  state.layerPreset = null;
  state.layerSearchQuery = '';
  const presetSelect = document.getElementById('layer-preset-select');
  if (presetSelect) presetSelect.value = '';
  const searchInput = document.getElementById('layer-search-input');
  if (searchInput) searchInput.value = '';
  _populateLayerChips();
  _restoreAllNodeOpacity();
  _updateLayerHash();
}

/**
 * Apply layer filter and update UI.
 */
function _applyAndUpdateLayerUI() {
  state.layerFilterActive = state.activeLayers.size > 0;
  _populateLayerChips();
  if (state.layerFilterActive) {
    applyLayerFilterToGraph();
  } else {
    _restoreAllNodeOpacity();
  }
  _updateLayerHash();
}

/**
 * Core function: compute layer filter and batch-update node opacities.
 */
function applyLayerFilterToGraph() {
  if (!state.network) return;
  const nodes = _getLayerFilterNodes();
  if (nodes.length === 0) return;

  const crossRefIds = buildCrossRefNodeSet(state.crossEdges);
  const { visible, dimmed } = computeLayerFilter(nodes, state.activeLayers, state.layerMode, crossRefIds);

  const allVisNodes = state.network.body.data.nodes.get();
  const updates = allVisNodes.map(n => {
    const isLayerVisible = visible.has(n.id);
    // Check if node is a ghost from composition filter — preserve ghost styling
    const isGhost = n._data && n._data.isGhost;
    const baseOpacity = isGhost ? 0.55 : 1.0;
    const baseFontColor = isGhost ? '#666' : '#e0e0e0';

    return {
      id: n.id,
      opacity: isLayerVisible ? baseOpacity : 0.15,
      font: { color: isLayerVisible ? baseFontColor : '#333', size: n.font?.size || 13 },
    };
  });
  state.network.body.data.nodes.update(updates);

  // Also dim edges where both endpoints are dimmed
  const allEdges = state.network.body.data.edges.get();
  const edgeUpdates = allEdges.map(e => {
    const fromVisible = visible.has(e.from);
    const toVisible = visible.has(e.to);
    const edgeVisible = fromVisible || toVisible;
    return {
      id: e.id,
      hidden: false,
      color: {
        ...e.color,
        opacity: edgeVisible ? 1.0 : 0.1,
      },
    };
  });
  state.network.body.data.edges.update(edgeUpdates);
}

/**
 * Restore all node opacities to defaults (respecting ghost nodes).
 */
function _restoreAllNodeOpacity() {
  if (!state.network) return;
  const allNodes = state.network.body.data.nodes.get();
  const updates = allNodes.map(n => {
    const isGhost = n._data && n._data.isGhost;
    return {
      id: n.id,
      opacity: isGhost ? 0.55 : 1.0,
      font: { color: isGhost ? '#666' : '#e0e0e0', size: n.font?.size || 13 },
    };
  });
  state.network.body.data.nodes.update(updates);

  // Restore edge opacity
  const allEdges = state.network.body.data.edges.get();
  const edgeUpdates = allEdges.map(e => ({
    id: e.id,
    color: { ...e.color, opacity: 1.0 },
  }));
  state.network.body.data.edges.update(edgeUpdates);
}

/**
 * Layer-aware search (S8.7.6).
 */
function layerSearchUI(query) {
  state.layerSearchQuery = query || '';
  const searchAll = document.getElementById('layer-search-all-cb')?.checked || false;
  state.layerSearchAll = searchAll;

  if (!state.network || !query || query.trim().length < 2) {
    // Clear search — restore to layer filter state
    if (state.layerFilterActive) {
      applyLayerFilterToGraph();
    } else {
      _restoreAllNodeOpacity();
    }
    return;
  }

  const lowerQuery = query.trim().toLowerCase();
  const nodes = _getLayerFilterNodes();
  const crossRefIds = buildCrossRefNodeSet(state.crossEdges);
  let layerVisible = null;
  if (state.layerFilterActive) {
    const result = computeLayerFilter(nodes, state.activeLayers, state.layerMode, crossRefIds);
    layerVisible = result.visible;
  }

  const allVisNodes = state.network.body.data.nodes.get();
  const updates = allVisNodes.map(n => {
    const rawNode = n._data || {};
    const label = (n.label || '').toLowerCase();
    const entityType = (rawNode.entityType || '').toLowerCase();
    const desc = (rawNode.description || '').toLowerCase();
    const matchesSearch = label.includes(lowerQuery) || entityType.includes(lowerQuery) || desc.includes(lowerQuery);

    const inActiveLayer = !layerVisible || layerVisible.has(n.id);
    const isGhost = rawNode.isGhost;
    const baseFontColor = isGhost ? '#666' : '#e0e0e0';

    let opacity, fontColor;
    if (matchesSearch && (inActiveLayer || searchAll)) {
      // Match found — full visibility (or 0.5 if in hidden layer with searchAll)
      opacity = inActiveLayer ? (isGhost ? 0.55 : 1.0) : 0.5;
      fontColor = baseFontColor;
    } else if (inActiveLayer && !state.layerFilterActive) {
      opacity = isGhost ? 0.55 : 0.3;
      fontColor = '#333';
    } else if (inActiveLayer) {
      opacity = isGhost ? 0.35 : 0.3;
      fontColor = '#333';
    } else {
      opacity = 0.1;
      fontColor = '#333';
    }

    return { id: n.id, opacity, font: { color: fontColor, size: n.font?.size || 13 } };
  });
  state.network.body.data.nodes.update(updates);
}

/**
 * Update URL hash with current layer state (DR-LAYER-003).
 */
function _updateLayerHash() {
  const hash = serializeLayerState(state.activeLayers, state.layerMode, state.layerPreset);
  if (hash) {
    history.replaceState(null, '', '#' + hash);
  } else {
    history.replaceState(null, '', window.location.pathname + window.location.search);
  }
}

/**
 * Restore layer state from URL hash on page load.
 */
function _restoreLayerFromHash() {
  const hash = window.location.hash;
  if (!hash || hash === '#') return;
  const restored = deserializeLayerState(hash);
  if (restored.activeLayers.size > 0) {
    state.activeLayers = restored.activeLayers;
    state.layerMode = restored.mode;
    state.layerPreset = restored.preset;
    state.layerFilterActive = true;
    // Update mode buttons
    const btns = document.querySelectorAll('.layer-mode-btn');
    btns.forEach(b => b.classList.toggle('active', b.dataset.mode === state.layerMode));
    // Update preset select
    const presetSelect = document.getElementById('layer-preset-select');
    if (presetSelect && restored.preset) presetSelect.value = restored.preset;
  }
}

// Restore layer state on load
window.addEventListener('DOMContentLoaded', _restoreLayerFromHash);
window.addEventListener('DOMContentLoaded', initEMCNavBar);

// F40.17b + F40.20: Dynamic nav bar is the sole toolbar — load skeleton at boot.
// Auto-load registry so the app opens ready-to-use with all ontologies loaded.
window.addEventListener('DOMContentLoaded', async () => {
  state.dynamicNavEnabled = true;
  // Load skeleton immediately so the nav bar renders on page open.
  // Skip localStorage cache — always fetch fresh JSONLD for nav bar.
  try {
    await loadAppSkeletonFresh();
  } catch (err) {
    console.warn('[DynNav] Boot skeleton load failed:', err.message);
  }
  // Auto-load the unified registry so the user lands on a ready graph.
  loadRegistry().catch(err =>
    console.warn('[Boot] Auto-load registry failed:', err.message)
  );
});

// F40.22 S40.22.6: Restore ghost toggle state from localStorage
window.addEventListener('DOMContentLoaded', () => {
  try {
    const saved = localStorage.getItem('oaa-viz-ghost-visible');
    if (saved === '0') state.ghostNodesVisible = false;
  } catch (_) { /* ignore */ }
});
window.addEventListener('hashchange', () => {
  const restored = deserializeLayerState(window.location.hash);
  if (restored.activeLayers.size > 0 || state.layerFilterActive) {
    state.activeLayers = restored.activeLayers;
    state.layerMode = restored.mode;
    state.layerPreset = restored.preset;
    state.layerFilterActive = restored.activeLayers.size > 0;
    _populateLayerChips();
    if (state.layerFilterActive) {
      applyLayerFilterToGraph();
    } else {
      _restoreAllNodeOpacity();
    }
  }
});

// Window exports for HTML onclick handlers
window.toggleLayerPanel = toggleLayerPanel;
window.toggleLayerUI = toggleLayerUI;
window.setLayerModeUI = setLayerModeUI;
window.applyLayerPresetUI = applyLayerPresetUI;
window.clearLayerFilterUI = clearLayerFilterUI;
window.layerSearchUI = layerSearchUI;
window.applyLayerFilterToGraph = applyLayerFilterToGraph;

// Keyboard shortcuts (Epic 7 — Authoring)
document.addEventListener('keydown', (e) => {
  if (!state.authoringMode) return;
  const isInput = e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT';
  if (isInput) return;
  if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
    e.preventDefault();
    doUndo(renderGraph);
  } else if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.shiftKey && e.key === 'z'))) {
    e.preventDefault();
    doRedo(renderGraph);
  } else if ((e.ctrlKey || e.metaKey) && e.key === 's') {
    e.preventDefault();
    showSaveWithValidation();
  }
});

// Diff / Changelog (Epic 4)
let _diffFileData = null;

window.showDiffModal = function() {
  if (!state.currentData) {
    alert('Load an ontology first');
    return;
  }
  const modal = document.getElementById('diff-modal');
  const nameEl = document.getElementById('diff-current-name');
  const fileName = document.getElementById('file-name')?.textContent || 'Ontology';
  if (nameEl) nameEl.textContent = fileName;
  _hide('diff-results');
  const dr = document.getElementById('diff-results');
  if (dr) dr.innerHTML = '';
  _hide('btn-export-changelog');
  const runBtn = document.getElementById('btn-run-diff');
  if (runBtn) runBtn.disabled = true;
  const dfn = document.getElementById('diff-file-name');
  if (dfn) dfn.textContent = '';
  _diffFileData = null;
  if (modal) modal.style.display = 'flex';
};

window.closeDiffModal = function() {
  _hide('diff-modal');
};

// File input handler for diff
document.getElementById('diff-file-input')?.addEventListener('change', (e) => {
  const file = e.target.files[0];
  if (!file) return;
  document.getElementById('diff-file-name').textContent = file.name;
  const reader = new FileReader();
  reader.onload = (evt) => {
    try {
      _diffFileData = JSON.parse(evt.target.result);
      document.getElementById('btn-run-diff').disabled = false;
    } catch (err) {
      alert('Invalid JSON file');
      _diffFileData = null;
      document.getElementById('btn-run-diff').disabled = true;
    }
  };
  reader.readAsText(file);
});

window.runDiff = function() {
  if (!_diffFileData || !state.currentData) return;
  const diff = diffOntologies(_diffFileData, state.currentData);

  // Attach old parsed data for ghost node rendering in diff graph
  try {
    diff._oldParsed = parseOntology(_diffFileData, 'previous-version');
  } catch (_) {
    diff._oldParsed = null;
  }

  state.lastDiff = diff;
  state.diffBaseData = _diffFileData;
  renderDiffView(diff);
  applyDiffHighlighting(diff);
};

window.exportChangelog = function() {
  if (!state.lastDiff) return;
  const md = generateChangelog(state.lastDiff);
  const blob = new Blob([md], { type: 'text/markdown' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `changelog-${state.lastDiff.oldVersion}-to-${state.lastDiff.newVersion}.md`;
  a.click();
  URL.revokeObjectURL(url);
};

window.exitDiffMode = exitDiffMode;

// Re-render helper for component toggle/filter (avoids circular import)
window.rerenderSingleGraph = function() {
  if (state.lastParsed && state.viewMode === 'single') {
    renderGraph(state.lastParsed);
  } else if (state.currentTier === 2 && state.currentOntology) {
    const record = state.loadedOntologies?.get(state.currentOntology);
    if (record?.parsed) {
      state.viewMode = 'single';
      renderGraph(record.parsed);
      state.viewMode = 'multi';
    }
  }
};

// ========================================
// INITIALISATION
// ========================================

initLibraryDB().catch(err => console.error('Failed to init library DB:', err));
setupLibraryDragDrop();
restoreRevisionState();
restoreCompositionState();
restoreDomainState();

// Early restore of DS brand theme from localStorage (prevents flash of dark defaults)
try {
  const savedVars = localStorage.getItem('oaa-viz-ds-vars');
  if (savedVars) {
    const cssVars = JSON.parse(savedVars);
    applyCSSVars(cssVars);
    state.dsAppliedCSSVars = cssVars;
    state.activeDSBrand = localStorage.getItem('oaa-viz-ds-brand');
    // DR-BRAND-001: restore brand context for node shadow glow
    if (state.activeDSBrand) {
      const accentColor = cssVars['--viz-accent'] || '#9dfff5';
      state.brandContext = { brand: state.activeDSBrand, tier: 'PF-Instance', accentColor };
    }
    console.log(`[DS] Early restore: ${Object.keys(cssVars).length} CSS vars from "${state.activeDSBrand}"`);
  }
} catch (e) { /* ignore corrupt localStorage */ }

// Enter key triggers URL load
document.getElementById('url-input')?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') loadFromURL();
});

// Enter key triggers GitHub connect
document.getElementById('gh-repo-input')?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') ghConnect();
});
