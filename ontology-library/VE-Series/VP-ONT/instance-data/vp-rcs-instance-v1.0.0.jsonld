    {
      "@id": "vp:rcs-prob-fragmented",
      "@type": "vp:Problem",
      "name": "Fragmented Multi-Framework Compliance",
      "description": "Enterprises subject to multiple regulatory frameworks manage compliance in silos, with separate teams, tools, and evidence repositories for each framework",
      "problemId": "prob:rcs-fragmented",
      "problemStatement": "CISOs in regulated industries struggle with fragmented compliance across multiple frameworks (MCSB, GDPR, PII, Azure Security Baseline) when demonstrating regulatory adherence, resulting in 40% duplicated effort across frameworks, $500K-$2M annual wasted spend on overlapping assessments, and critical gaps at framework intersection points that auditors consistently flag.",
      "problemType": "Functional",
      "severity": "Critical",
      "frequency": "Constant",
      "isGrowing": true,
      "marketSizeImpact": 8000000000,
      "scopeLevel": "Strategic",
      "ownerRole": "pf:exec-ciso"
    },
    {
      "@id": "vp:rcs-prob-audit-prep",
      "@type": "vp:Problem",
      "name": "Costly and Time-Consuming Audit Preparation",
      "description": "Compliance directors spend 3-6 months preparing for each audit cycle, manually mapping controls to framework requirements and collecting evidence from disparate systems",
