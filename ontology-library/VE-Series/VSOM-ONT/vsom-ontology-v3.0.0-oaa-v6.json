          "required": true,
          "description": "Date of strategic review"
        },
        {
          "name": "triggerType",
          "type": "xsd:string",
          "required": true,
          "enum": [
            "Scheduled",
            "MetricBreach",
            "MarketEvent",
            "CompetitorAction",
            "OpportunityIdentified",
            "RiskMaterialized"
          ]
        },
        {
          "name": "triggerDescription",
          "type": "xsd:string",
          "required": false,
