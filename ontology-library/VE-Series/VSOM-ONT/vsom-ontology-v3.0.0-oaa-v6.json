            "Approved",
            "Deferred",
            "Rejected",
            "RequiresMoreData"
          ]
        },
        {
          "name": "nextReviewDate",
          "type": "xsd:date",
          "required": false,
          "description": "Scheduled next review"
        }
      ]
    },
