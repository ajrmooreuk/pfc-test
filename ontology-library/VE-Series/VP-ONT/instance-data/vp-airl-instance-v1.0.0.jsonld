  "entities": [
    {
      "@id": "vp:airl-vp-001",
      "@type": "vp:ValueProposition",
      "name": "AIRL Enterprise AI Readiness Value Proposition",
      "description": "AI Readiness assessment and maturity modelling platform for enterprise organisations pursuing structured AI transformation",
      "vpId": "vp:airl-vp-001",
      "primaryStatement": "For CTOs, CIOs, and AI Programme Leads in mid-to-large enterprises who need structured AI adoption without costly false starts, AIRL provides an ontology-driven AI Readiness assessment and maturity modelling platform that delivers quantified readiness scores, gap analysis, and prioritised transformation roadmaps — unlike spreadsheet-based assessments or generic consulting frameworks — because our approach is built on the AIR-ONT maturity framework with cross-domain visibility across strategy, people, process, technology, and governance dimensions.",
      "alternativeStatement": "AIRL transforms AI adoption from guesswork to science by providing a structured, ontology-backed readiness assessment that quantifies your organisation's AI maturity across every dimension and generates actionable transformation roadmaps.",
      "keyBenefits": "Reduced AI project failure rate by 40-60%; 3x faster time-to-readiness; Quantified maturity scores across 5 dimensions; Automated gap analysis with prioritised remediation; Cross-domain visibility from C-suite to delivery teams",
      "uniqueDifferentiators": "Ontology-driven assessment (vs. spreadsheet); Cross-domain AI maturity model (AIR-ONT); Visualiser-powered interactive exploration; Integration with enterprise architecture frameworks; Automated lineage from strategy to execution",
      "organizationContextRef": "org:ctx-airl",
      "status": "Active",
      "validationDate": "2026-01-15"
    },

    {
      "@id": "vp:airl-icp-enterprise",
      "@type": "vp:IdealCustomerProfile",
      "name": "Enterprise AI Transformation Buyer",
      "description": "Mid-to-large enterprise organisations (500+ employees) actively pursuing or planning AI transformation, with existing technology estate and governance structures requiring structured readiness assessment",
      "icpId": "icp:airl-enterprise",
      "customerType": "B2B",
      "segmentDescription": "Mid-to-large enterprises (500-50,000 employees) in regulated or complex industries pursuing AI transformation. Typically have existing EA practices, compliance requirements, and multi-year technology strategies. Annual IT budgets >$5M with dedicated AI/digital transformation budget lines.",
      "demographics": "Industry: Financial Services, Healthcare, Manufacturing, Government, Telecoms. Size: 500-50,000 employees. Geography: UK, EU, Middle East, APAC. Revenue: $100M-$50B",
      "firmographics": "Established technology estate with cloud adoption in progress. Hybrid infrastructure (on-prem + cloud). Existing governance frameworks. Matrix organisational structure with centralised IT and distributed business units.",
      "psychographics": "Risk-aware but innovation-driven. Value structured approaches over ad-hoc initiatives. Prefer data-driven decision making. Concerned about AI ethics and governance. Seek competitive advantage through technology transformation.",
      "willingnessToPayIndicator": "High",
      "marketSize": 45000000000,
      "acquisitionCost": 85000,
      "lifetimeValue": 750000
    },

