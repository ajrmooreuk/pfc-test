{
  "@context": {
    "@vocab": "https://schema.org/",
    "pf": "https://platformcore.io/ontology/",
    "dt": "https://platformcore.io/ontology/dt/",
    "oaa": "https://platformcore.io/ontology/oaa/",
    "emc": "https://platformcore.io/ontology/emc/",
    "pe": "https://platformcore.io/ontology/pe/"
  },
  "@type": "pf:Ontology",
  "@id": "dt:dt-ontology",
  "name": "DT Ontology (Decision Tree — Extensibility Pattern Evaluation)",
  "description": "Hypothesis-testing decision tree for evaluating when to create an Agent, Skill, Plugin, or Cowork Plugin within the Anthropic Claude ecosystem and PF-Core platform architecture. 7 hypothesis gates across 3 evaluation layers (Capability, Composition, Distribution) route to 12 terminal recommendations via weighted scoring.",
  "version": "1.0.0",
  "oaaVersion": "7.0.0",
  "created": "2026-02-24",
  "lastModified": "2026-02-24",
  "author": "PF-Core Orchestration Module",
  "schemaOrgAlignment": 0.85,
  "pfCoreModule": "Orchestration",
  "pfCoreInstances": ["BAIV-DT", "W4M-DT", "AIRL-DT"],
  "changeLog": {
    "v1.0.0": {
      "date": "2026-02-24",
      "summary": "Initial release — 7 hypothesis gates, 12 terminal recommendations, 3 evaluation layers, 8 test scenarios. Implements F40.1 Extensibility Decision Tree Engine for the PF-Core Visualiser.",
      "breaking": [],
      "additions": [
        "EvaluationLayer entity type (3 layers: Capability, Composition, Distribution)",
        "HypothesisGate entity type (7 gates with weighted evaluation criteria)",
        "EvaluationCriterion entity type (28 criteria with weights 2-3 and pass/fail examples)",
        "GateThreshold entity type (routing rules with minScore and next targets)",
        "Recommendation entity type (12 terminal recommendations with effort/complexity)",
        "AutomationDecisionRecord entity type (evaluation session record with path traversal)",
        "TestScenario entity type (8 scenarios at 60/20/10/10 distribution)",
        "20 relationships including gate routing, layer membership, and cross-ontology bridges",
        "15 business rules for evaluation sequencing, scoring, and routing",
        "8 enums for outcomes, layers, recommendation types, complexity levels"
      ]
    }
  },

  "entities": {
    "dt:EvaluationLayer": {
      "@type": "pf:EntityDefinition",
      "name": "EvaluationLayer",
      "description": "One of three evaluation layers that group hypothesis gates by concern: L1 Capability (autonomous vs scripted), L2 Composition (standalone vs bundled), L3 Distribution (target users and packaging)",
      "schemaOrgBase": "schema:CategoryCodeSet",
      "properties": {
        "layerId": { "type": "Text", "required": true, "example": "L1_Capability" },
        "name": { "type": "Text", "required": true, "example": "Capability" },
        "color": { "type": "Text", "required": true, "description": "Hex colour for visual encoding", "example": "#ef4444" },
        "purpose": { "type": "Text", "required": true },
        "gates": { "type": "ItemList", "required": true, "itemType": "Text", "description": "Ordered list of gate IDs in this layer" }
      }
    },

    "dt:HypothesisGate": {
      "@type": "pf:EntityDefinition",
      "name": "HypothesisGate",
      "description": "A weighted decision point where a hypothesis is tested against 4 evaluation criteria to produce a normalised score (0-10) that routes to the next gate or terminal recommendation",
      "schemaOrgBase": "schema:ChooseAction",
      "properties": {
        "gateId": { "type": "Text", "required": true, "example": "HG-01" },
        "layer": { "type": "Text", "required": true, "constraints": { "enum": ["L1_Capability", "L2_Composition", "L3_Distribution"] } },
        "name": { "type": "Text", "required": true, "example": "Autonomy Assessment" },
        "hypothesis": { "type": "Text", "required": true },
        "testMethod": { "type": "Text", "required": true },
        "evaluationCriteria": { "type": "ItemList", "required": true, "itemType": "dt:EvaluationCriterion", "constraints": { "minItems": 4, "maxItems": 4 } },
        "thresholds": { "type": "Object", "required": true, "description": "Map of outcome keys to GateThreshold objects" }
      }
    },

    "dt:EvaluationCriterion": {
      "@type": "pf:EntityDefinition",
      "name": "EvaluationCriterion",
      "description": "A single weighted criterion within a hypothesis gate. Score 0-10 multiplied by weight contributes to the gate's normalised score.",
      "schemaOrgBase": "schema:PropertyValue",
      "properties": {
        "criterion": { "type": "Text", "required": true },
        "weight": { "type": "Number", "required": true, "constraints": { "minimum": 1, "maximum": 5 } },
        "examples": {
          "type": "Object", "required": true,
          "properties": {
            "pass": { "type": "Text", "required": true },
            "fail": { "type": "Text", "required": true }
          }
        }
      }
    },

    "dt:GateThreshold": {
      "@type": "pf:EntityDefinition",
      "name": "GateThreshold",
      "description": "A routing rule within a gate that maps a minimum normalised score to a next target (gate or recommendation). Thresholds are evaluated in descending minScore order.",
      "schemaOrgBase": "schema:QuantitativeValue",
      "properties": {
        "outcomeKey": { "type": "Text", "required": true, "example": "pass" },
        "minScore": { "type": "Number", "required": true, "constraints": { "minimum": 0, "maximum": 10 } },
        "nextGate": { "type": "Text", "required": false, "description": "Gate ID to advance to" },
        "recommendation": { "type": "Text", "required": false, "description": "Terminal recommendation key" }
      }
    },

    "dt:Recommendation": {
      "@type": "pf:EntityDefinition",
      "name": "Recommendation",
      "description": "A terminal extensibility pattern recommendation with implementation guidance. One of 12 possible outcomes from the decision tree evaluation.",
      "schemaOrgBase": "schema:Recommendation",
      "properties": {
        "key": { "type": "Text", "required": true, "example": "AGENT_ORCHESTRATOR" },
        "label": { "type": "Text", "required": true, "example": "Full Agent (Orchestrator Tier)" },
        "description": { "type": "Text", "required": true },
        "typicalComplexity": { "type": "Text", "required": true, "constraints": { "enum": ["None", "Low", "Low-Medium", "Medium", "Medium-High", "High"] } },
        "estimatedEffort": { "type": "Text", "required": true },
        "templateSection": { "type": "Text", "required": false },
        "oaaRequirement": { "type": "Text", "required": false },
        "examples": { "type": "ItemList", "required": false, "itemType": "Text" }
      }
    },

    "dt:AutomationDecisionRecord": {
      "@type": "pf:EntityDefinition",
      "name": "AutomationDecisionRecord",
      "description": "A complete evaluation session record capturing the problem statement, evaluator, traversed path through hypothesis gates, scores at each gate, and final recommendation. Exportable as JSON-LD.",
      "schemaOrgBase": "schema:AssessAction",
      "properties": {
        "evaluationId": { "type": "Text", "required": true, "example": "EVAL-EXT-2026-001" },
        "problemStatement": { "type": "Text", "required": true },
        "evaluator": { "type": "Text", "required": true },
        "evaluationDate": { "type": "Date", "required": true },
        "gateResults": { "type": "ItemList", "required": true, "itemType": "Object" },
        "traversedPath": { "type": "ItemList", "required": true, "itemType": "Text", "description": "Ordered gate IDs visited" },
        "finalRecommendation": { "type": "Text", "required": true },
        "confidence": { "type": "Number", "required": false, "constraints": { "minimum": 0, "maximum": 100 } }
      }
    },

    "dt:TestScenario": {
      "@type": "pf:EntityDefinition",
      "name": "TestScenario",
      "description": "A validation scenario that exercises a specific path through the decision tree with expected outcomes",
      "schemaOrgBase": "schema:HowTo",
      "properties": {
        "scenarioId": { "type": "Text", "required": true, "example": "TS-01" },
        "category": { "type": "Text", "required": true, "constraints": { "enum": ["typical", "edge", "boundary", "invalid"] } },
        "description": { "type": "Text", "required": true },
        "expectedPath": { "type": "Text", "required": true },
        "expectedRecommendation": { "type": "Text", "required": true }
      }
    }
  },

  "relationships": [
    { "@id": "dt:layerContainsGate", "from": "dt:EvaluationLayer", "to": "dt:HypothesisGate", "type": "containment", "cardinality": "1:N", "description": "A layer groups 2-3 hypothesis gates" },
    { "@id": "dt:gateHasCriteria", "from": "dt:HypothesisGate", "to": "dt:EvaluationCriterion", "type": "composition", "cardinality": "1:4", "description": "Each gate has exactly 4 weighted evaluation criteria" },
    { "@id": "dt:gateHasThresholds", "from": "dt:HypothesisGate", "to": "dt:GateThreshold", "type": "composition", "cardinality": "1:N", "description": "Each gate has 2-3 threshold routing rules" },
    { "@id": "dt:thresholdRoutesToGate", "from": "dt:GateThreshold", "to": "dt:HypothesisGate", "type": "routing", "cardinality": "N:1", "description": "A threshold routes to another gate for continued evaluation" },
    { "@id": "dt:thresholdRoutesToRecommendation", "from": "dt:GateThreshold", "to": "dt:Recommendation", "type": "routing", "cardinality": "N:1", "description": "A threshold routes to a terminal recommendation" },
    { "@id": "dt:recordTraversesGate", "from": "dt:AutomationDecisionRecord", "to": "dt:HypothesisGate", "type": "traversal", "cardinality": "1:N", "description": "A decision record captures results for each traversed gate" },
    { "@id": "dt:recordResultsInRecommendation", "from": "dt:AutomationDecisionRecord", "to": "dt:Recommendation", "type": "outcome", "cardinality": "1:1", "description": "A decision record produces exactly one final recommendation" },
    { "@id": "dt:scenarioValidatesPath", "from": "dt:TestScenario", "to": "dt:HypothesisGate", "type": "validation", "cardinality": "1:N", "description": "A test scenario validates a specific gate traversal path" },

    { "@id": "dt:gateAdvancesTo_HG01_HG02", "from": "dt:HypothesisGate", "fromInstance": "HG-01", "to": "dt:HypothesisGate", "toInstance": "HG-02", "type": "pass-routing", "condition": "score >= 7" },
    { "@id": "dt:gateAdvancesTo_HG01_HG03", "from": "dt:HypothesisGate", "fromInstance": "HG-01", "to": "dt:HypothesisGate", "toInstance": "HG-03", "type": "partial-routing", "condition": "score >= 4 && score < 7" },
    { "@id": "dt:gateAdvancesTo_HG01_HG04", "from": "dt:HypothesisGate", "fromInstance": "HG-01", "to": "dt:HypothesisGate", "toInstance": "HG-04", "type": "fail-routing", "condition": "score < 4" },
    { "@id": "dt:gateAdvancesTo_HG02_HG05", "from": "dt:HypothesisGate", "fromInstance": "HG-02", "to": "dt:HypothesisGate", "toInstance": "HG-05", "type": "all-routing", "condition": "all outcomes route to HG-05" },
    { "@id": "dt:gateAdvancesTo_HG03_HG06", "from": "dt:HypothesisGate", "fromInstance": "HG-03", "to": "dt:HypothesisGate", "toInstance": "HG-06", "type": "pass-routing", "condition": "score >= 7" },
    { "@id": "dt:gateAdvancesTo_HG03_HG07", "from": "dt:HypothesisGate", "fromInstance": "HG-03", "to": "dt:HypothesisGate", "toInstance": "HG-07", "type": "partial-routing", "condition": "score >= 4 && score < 7" },
    { "@id": "dt:gateTerminal_HG03_SKILL", "from": "dt:HypothesisGate", "fromInstance": "HG-03", "to": "dt:Recommendation", "toInstance": "SKILL_STANDALONE", "type": "fail-routing", "condition": "score < 4" },
    { "@id": "dt:gateTerminal_HG04_SKILL", "from": "dt:HypothesisGate", "fromInstance": "HG-04", "to": "dt:Recommendation", "toInstance": "SKILL_STANDALONE", "type": "pass-routing", "condition": "score >= 7" },
    { "@id": "dt:gateTerminal_HG04_SIMPLE", "from": "dt:HypothesisGate", "fromInstance": "HG-04", "to": "dt:Recommendation", "toInstance": "SKILL_SIMPLE", "type": "partial-routing", "condition": "score >= 4 && score < 7" },
    { "@id": "dt:gateTerminal_HG04_NOACTION", "from": "dt:HypothesisGate", "fromInstance": "HG-04", "to": "dt:Recommendation", "toInstance": "NO_ACTION_INLINE_PROMPTING", "type": "fail-routing", "condition": "score < 4" },
    { "@id": "dt:gateTerminal_HG05_COWORK_AGENT", "from": "dt:HypothesisGate", "fromInstance": "HG-05", "to": "dt:Recommendation", "toInstance": "PLUGIN_COWORK_WITH_AGENT", "type": "pass_with_gui-routing", "condition": "score >= 8" },
    { "@id": "dt:gateTerminal_HG05_CC_AGENT", "from": "dt:HypothesisGate", "fromInstance": "HG-05", "to": "dt:Recommendation", "toInstance": "PLUGIN_CLAUDECODE_WITH_AGENT", "type": "pass_dev_only-routing", "condition": "score >= 6 && score < 8" },
    { "@id": "dt:gateTerminal_HG05_STANDALONE", "from": "dt:HypothesisGate", "fromInstance": "HG-05", "to": "dt:Recommendation", "toInstance": "AGENT_STANDALONE", "type": "fail-routing", "condition": "score < 6" }
  ],

  "businessRules": [
    {
      "ruleId": "BR-DT-001",
      "name": "Entry Point Rule",
      "description": "All evaluations must begin at HG-01 (Autonomy Assessment)",
      "severity": "mandatory",
      "rule": "IF evaluation.startGate != 'HG-01' THEN reject('Evaluation must begin at HG-01')"
    },
    {
      "ruleId": "BR-DT-002",
      "name": "Scoring Formula",
      "description": "Gate normalised score = sum(weight * score) / sum(weight * 10) * 10, clamped to [0, 10]",
      "severity": "mandatory",
      "rule": "IF gate.evaluationComplete THEN normalizedScore = clamp(sum(criteria[i].weight * scores[i]) / sum(criteria[i].weight * 10) * 10, 0, 10)"
    },
    {
      "ruleId": "BR-DT-003",
      "name": "Standard Three-Tier Threshold",
      "description": "Gates HG-01, HG-02, HG-03, HG-04 use standard 3-tier thresholds: pass >= 7, partial >= 4, fail < 4",
      "severity": "mandatory",
      "rule": "IF gate.id IN ('HG-01','HG-02','HG-03','HG-04') THEN thresholds = {pass: 7, partial: 4, fail: 0}"
    },
    {
      "ruleId": "BR-DT-004",
      "name": "HG-05 Three-Tier Special",
      "description": "HG-05 uses unique 3-tier thresholds: pass_with_gui >= 8, pass_dev_only >= 6, fail < 6",
      "severity": "mandatory",
      "rule": "IF gate.id == 'HG-05' THEN thresholds = {pass_with_gui: 8, pass_dev_only: 6, fail: 0}"
    },
    {
      "ruleId": "BR-DT-005",
      "name": "HG-06/HG-07 Two-Tier Threshold",
      "description": "Gates HG-06 and HG-07 use 2-tier thresholds: pass >= 7, fail < 7",
      "severity": "mandatory",
      "rule": "IF gate.id IN ('HG-06','HG-07') THEN thresholds = {pass: 7, fail: 0}"
    },
    {
      "ruleId": "BR-DT-006",
      "name": "Sequential Evaluation",
      "description": "Gates must be evaluated in tree order — cannot skip gates or evaluate out of sequence",
      "severity": "mandatory",
      "rule": "IF gate[n].notEvaluated AND gate[n-1].notEvaluated THEN reject('Must evaluate gates in order')"
    },
    {
      "ruleId": "BR-DT-007",
      "name": "Four Criteria Per Gate",
      "description": "Every hypothesis gate must have exactly 4 evaluation criteria with integer weights summing to 10",
      "severity": "mandatory",
      "rule": "IF gate.criteria.length != 4 OR sum(gate.criteria.weights) != 10 THEN reject('Invalid gate structure')"
    },
    {
      "ruleId": "BR-DT-008",
      "name": "Score Range Validation",
      "description": "Individual criterion scores must be integers in range [0, 10]",
      "severity": "mandatory",
      "rule": "IF score < 0 OR score > 10 OR !isInteger(score) THEN reject('Score must be integer 0-10')"
    },
    {
      "ruleId": "BR-DT-009",
      "name": "Terminal Path Completeness",
      "description": "All 12 recommendations must be reachable through at least one gate traversal path",
      "severity": "mandatory",
      "rule": "IF recommendation.reachablePaths.length == 0 THEN reject('Unreachable recommendation')"
    },
    {
      "ruleId": "BR-DT-010",
      "name": "Decision Record Immutability",
      "description": "Once exported, an AutomationDecisionRecord cannot be modified",
      "severity": "mandatory",
      "rule": "IF record.exported AND record.modified THEN reject('Exported records are immutable')"
    },
    {
      "ruleId": "BR-DT-011",
      "name": "HG-02 Agent Tier Annotation",
      "description": "HG-02 thresholds include informational agent tier annotations (ORCHESTRATOR/SPECIALIST/UTILITY) that flow through to HG-05",
      "severity": "advisory",
      "rule": "IF gate.id == 'HG-02' THEN threshold.recommendation is informational agent tier, not terminal"
    },
    {
      "ruleId": "BR-DT-012",
      "name": "Reset Cascade",
      "description": "Resetting a gate clears it and all subsequent gates in the traversed path",
      "severity": "mandatory",
      "rule": "IF resetFromGate(gateId) THEN clear(gate) AND clear(allSubsequentGates)"
    },
    {
      "ruleId": "BR-DT-013",
      "name": "Single Active Gate",
      "description": "At most one gate may be in 'active' state at any time during evaluation",
      "severity": "mandatory",
      "rule": "IF count(gates.where(state == 'active')) > 1 THEN reject('Only one active gate allowed')"
    },
    {
      "ruleId": "BR-DT-014",
      "name": "VSOM Alignment Required",
      "description": "Decision records should reference the strategic objective being served",
      "severity": "advisory",
      "rule": "IF record.vsomAlignment == null THEN warn('Consider linking to a strategic objective')"
    },
    {
      "ruleId": "BR-DT-015",
      "name": "Cross-Ontology Agent Bridge",
      "description": "Agent-tier recommendations (AGENT_ORCHESTRATOR, AGENT_SPECIALIST, AGENT_UTILITY) bridge to pe:AIAgent entity type",
      "severity": "advisory",
      "rule": "IF recommendation.type.startsWith('AGENT_') THEN recommendation.bridgesTo = 'pe:AIAgent'"
    }
  ],

  "enums": {
    "dt:GateOutcome": {
      "values": ["PASS", "PARTIAL", "FAIL"],
      "description": "Standard 3-tier gate outcome"
    },
    "dt:HG05Outcome": {
      "values": ["pass_with_gui", "pass_dev_only", "fail"],
      "description": "HG-05 special 3-tier outcome for agent distribution"
    },
    "dt:TwoTierOutcome": {
      "values": ["pass", "fail"],
      "description": "2-tier outcome used by HG-06 and HG-07"
    },
    "dt:EvaluationLayerId": {
      "values": ["L1_Capability", "L2_Composition", "L3_Distribution"],
      "description": "The three evaluation layers"
    },
    "dt:RecommendationType": {
      "values": [
        "AGENT_ORCHESTRATOR", "AGENT_SPECIALIST", "AGENT_UTILITY", "AGENT_STANDALONE",
        "SKILL_STANDALONE", "SKILL_SIMPLE", "SKILL_WITH_MCP",
        "PLUGIN_CLAUDECODE", "PLUGIN_COWORK", "PLUGIN_CLAUDECODE_WITH_AGENT", "PLUGIN_COWORK_WITH_AGENT",
        "PLUGIN_LIGHTWEIGHT", "NO_ACTION_INLINE_PROMPTING"
      ],
      "description": "All 13 possible recommendation keys (12 terminal + AGENT_STANDALONE from HG-05 fail)"
    },
    "dt:ComplexityLevel": {
      "values": ["None", "Low", "Low-Medium", "Medium", "Medium-High", "High"],
      "description": "Implementation complexity rating for recommendations"
    },
    "dt:ScenarioCategory": {
      "values": ["typical", "edge", "boundary", "invalid"],
      "description": "Test scenario categories per OAA distribution: 60/20/10/10"
    },
    "dt:BSCPerspective": {
      "values": ["Financial", "Customer", "InternalProcess", "LearningGrowth"],
      "description": "Balanced Scorecard perspective for VSOM alignment"
    }
  },

  "instanceData": {
    "layers": [
      {
        "@type": "dt:EvaluationLayer",
        "@id": "dt:L1_Capability",
        "layerId": "L1_Capability",
        "name": "Capability",
        "color": "#ef4444",
        "purpose": "Determine if the need requires autonomous reasoning (Agent) or scripted execution (Skill/Plugin)",
        "gates": ["HG-01", "HG-02"]
      },
      {
        "@type": "dt:EvaluationLayer",
        "@id": "dt:L2_Composition",
        "layerId": "L2_Composition",
        "name": "Composition",
        "color": "#3b82f6",
        "purpose": "Determine bundling requirements — standalone vs packaged",
        "gates": ["HG-03", "HG-04", "HG-07"]
      },
      {
        "@type": "dt:EvaluationLayer",
        "@id": "dt:L3_Distribution",
        "layerId": "L3_Distribution",
        "name": "Distribution",
        "color": "#8b5cf6",
        "purpose": "Determine target users and distribution mechanism",
        "gates": ["HG-05", "HG-06"]
      }
    ],

    "gates": [
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-01",
        "gateId": "HG-01",
        "layer": "L1_Capability",
        "name": "Autonomy Assessment",
        "hypothesis": "This capability requires autonomous reasoning, judgment, or decision-making that goes beyond executing predefined instructions",
        "testMethod": "Evaluate whether the capability needs to: (a) interpret ambiguous inputs, (b) make contextual decisions, (c) adapt behavior based on state, (d) coordinate with other capabilities",
        "evaluationCriteria": [
          { "criterion": "Requires interpretation of ambiguous or novel inputs", "weight": 3, "examples": { "pass": "Analyzing a client's competitive landscape and recommending AI visibility strategy", "fail": "Converting a CSV file into a formatted Excel spreadsheet" } },
          { "criterion": "Must make decisions with incomplete information", "weight": 3, "examples": { "pass": "Prioritizing gap analysis findings when multiple issues exist", "fail": "Applying brand colors to a presentation template" } },
          { "criterion": "Needs to maintain and reason over state across interactions", "weight": 2, "examples": { "pass": "Tracking a client's AI visibility improvement over a 30-day engagement", "fail": "Generating a single PDF report from provided data" } },
          { "criterion": "Coordinates or delegates to other capabilities", "weight": 2, "examples": { "pass": "Orchestrating discovery agents to feed analysis agents to produce strategy", "fail": "Running a Python script to extract text from documents" } }
        ],
        "thresholds": {
          "pass": { "minScore": 7, "nextGate": "HG-02" },
          "partial": { "minScore": 4, "nextGate": "HG-03" },
          "fail": { "minScore": 0, "nextGate": "HG-04" }
        }
      },
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-02",
        "gateId": "HG-02",
        "layer": "L1_Capability",
        "name": "Orchestration Scope",
        "hypothesis": "This autonomous capability needs to orchestrate sub-agents, tools, or multi-step workflows beyond a single agent's scope",
        "testMethod": "Evaluate whether the capability: (a) spans multiple domains, (b) requires parallel execution, (c) needs workflow state management, (d) involves human-in-the-loop checkpoints",
        "evaluationCriteria": [
          { "criterion": "Spans multiple domain ontologies or agent scopes", "weight": 3, "examples": { "pass": "BAIV Discovery > Analysis > Generation > Optimization pipeline", "fail": "Single-domain content quality analysis" } },
          { "criterion": "Requires parallel or sequential sub-agent coordination", "weight": 3, "examples": { "pass": "Running SEO audit, content analysis, and competitor research simultaneously", "fail": "Sequential steps within a single analysis task" } },
          { "criterion": "Needs persistent workflow state management", "weight": 2, "examples": { "pass": "30-day AI visibility engagement with checkpoints and deliverables", "fail": "Stateless request-response analysis" } },
          { "criterion": "Involves human-in-the-loop decision points", "weight": 2, "examples": { "pass": "Strategy recommendations requiring executive approval before execution", "fail": "Fully automated data transformation" } }
        ],
        "thresholds": {
          "pass": { "minScore": 7, "recommendation": "AGENT_ORCHESTRATOR", "nextGate": "HG-05" },
          "partial": { "minScore": 4, "recommendation": "AGENT_SPECIALIST", "nextGate": "HG-05" },
          "fail": { "minScore": 0, "recommendation": "AGENT_UTILITY", "nextGate": "HG-05" }
        }
      },
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-03",
        "gateId": "HG-03",
        "layer": "L2_Composition",
        "name": "Bundling Requirement",
        "hypothesis": "This capability needs to bundle multiple extension types (skills + MCP + commands + agents) into a distributable package",
        "testMethod": "Evaluate whether: (a) multiple skills need coordinated loading, (b) external tool integrations are required, (c) custom commands streamline workflow, (d) the package serves a specific role or team",
        "evaluationCriteria": [
          { "criterion": "Requires coordinated loading of multiple skills", "weight": 2, "examples": { "pass": "Brand guidelines skill + document creation skill + design system skill needed together", "fail": "Single skill for PDF generation is sufficient" } },
          { "criterion": "Needs MCP integrations to external services", "weight": 3, "examples": { "pass": "Must connect to Figma, Notion, and Supabase to complete workflow", "fail": "Works entirely with local files and Claude's built-in capabilities" } },
          { "criterion": "Custom slash commands would streamline repeated workflows", "weight": 2, "examples": { "pass": "/audit-client, /generate-report, /run-gap-analysis as team shortcuts", "fail": "One-off task with no repeated pattern" } },
          { "criterion": "Serves a specific team role or department function", "weight": 3, "examples": { "pass": "Marketing team needs consistent AI visibility audit workflow", "fail": "General-purpose utility used across all contexts" } }
        ],
        "thresholds": {
          "pass": { "minScore": 7, "nextGate": "HG-06" },
          "partial": { "minScore": 4, "nextGate": "HG-07" },
          "fail": { "minScore": 0, "recommendation": "SKILL_STANDALONE" }
        }
      },
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-04",
        "gateId": "HG-04",
        "layer": "L2_Composition",
        "name": "Task Complexity Assessment",
        "hypothesis": "This scripted capability is complex enough to warrant a formal Skill rather than inline instructions or simple prompting",
        "testMethod": "Evaluate whether: (a) instructions exceed simple prompt scope, (b) executable scripts are needed, (c) the task is repeatable across contexts, (d) quality requires standardized approach",
        "evaluationCriteria": [
          { "criterion": "Instructions exceed 500 words or require multi-step procedures", "weight": 2, "examples": { "pass": "Detailed brand-compliant document generation with 15 formatting rules", "fail": "Simple instruction: Summarize this document in 3 bullet points" } },
          { "criterion": "Requires executable scripts (Python, Node.js, Bash) for reliable output", "weight": 3, "examples": { "pass": "PPTX generation requiring python-pptx with specific template layouts", "fail": "Text transformation that Claude handles natively" } },
          { "criterion": "Task is repeatable and benefits from standardized approach", "weight": 3, "examples": { "pass": "Client onboarding data collection follows same 12-step process every time", "fail": "One-time creative brainstorming session" } },
          { "criterion": "Quality/consistency requires formalized instructions over ad-hoc prompting", "weight": 2, "examples": { "pass": "Ontology generation must follow OAA Registry v3.0 compliance standards", "fail": "Casual note-taking with no format requirements" } }
        ],
        "thresholds": {
          "pass": { "minScore": 7, "recommendation": "SKILL_STANDALONE" },
          "partial": { "minScore": 4, "recommendation": "SKILL_SIMPLE" },
          "fail": { "minScore": 0, "recommendation": "NO_ACTION_INLINE_PROMPTING" }
        }
      },
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-05",
        "gateId": "HG-05",
        "layer": "L3_Distribution",
        "name": "Agent Distribution Strategy",
        "hypothesis": "This agent capability needs to be packaged for distribution beyond its original development context",
        "testMethod": "Evaluate whether: (a) other teams/projects need this agent, (b) the agent needs to ship with its tools and skills, (c) version management is needed, (d) marketplace distribution adds value",
        "evaluationCriteria": [
          { "criterion": "Multiple PF-Core instances or teams need this agent capability", "weight": 3, "examples": { "pass": "OAA agent needed by BAIV, W4M, and AIR instances", "fail": "BAIV-specific discovery agent only used in one context" } },
          { "criterion": "Agent needs to ship bundled with its tools, skills, and MCP configs", "weight": 3, "examples": { "pass": "Agent + ontology validation skill + Supabase MCP + /validate command", "fail": "Agent operates with only built-in Claude capabilities" } },
          { "criterion": "Formal version management and update distribution required", "weight": 2, "examples": { "pass": "Breaking changes to agent behavior need controlled rollout across teams", "fail": "Informal updates shared via documentation" } },
          { "criterion": "Non-technical users need GUI-based access to this agent's capabilities", "weight": 2, "examples": { "pass": "Client account managers need to run AI visibility audits without terminal", "fail": "Only developers use this agent via Claude Code" } }
        ],
        "thresholds": {
          "pass_with_gui": { "minScore": 8, "recommendation": "PLUGIN_COWORK_WITH_AGENT" },
          "pass_dev_only": { "minScore": 6, "recommendation": "PLUGIN_CLAUDECODE_WITH_AGENT" },
          "fail": { "minScore": 0, "recommendation": "AGENT_STANDALONE" }
        }
      },
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-06",
        "gateId": "HG-06",
        "layer": "L3_Distribution",
        "name": "User Persona Assessment",
        "hypothesis": "The primary users of this bundled capability are non-technical knowledge workers who need GUI-based access",
        "testMethod": "Evaluate the target user persona: (a) technical proficiency, (b) workflow context, (c) customization needs, (d) team distribution requirements",
        "evaluationCriteria": [
          { "criterion": "Primary users are non-developers (marketing, sales, operations, legal)", "weight": 3, "examples": { "pass": "Marketing team running weekly content campaigns", "fail": "Development team managing CI/CD pipelines" } },
          { "criterion": "Users need desktop GUI installation, not terminal commands", "weight": 3, "examples": { "pass": "Account manager clicks Install in Cowork sidebar", "fail": "Developer runs /plugin install in Claude Code" } },
          { "criterion": "Conversational customization adds value over file editing", "weight": 2, "examples": { "pass": "User says customize this for my sales process and Claude adapts", "fail": "Configuration requires editing YAML files and MCP configs" } },
          { "criterion": "Organization-wide deployment to non-technical teams is needed", "weight": 2, "examples": { "pass": "Roll out standardized audit workflow to 50-person consulting team", "fail": "Individual developer tool used in personal workflow" } }
        ],
        "thresholds": {
          "pass": { "minScore": 7, "recommendation": "PLUGIN_COWORK" },
          "fail": { "minScore": 0, "recommendation": "PLUGIN_CLAUDECODE" }
        }
      },
      {
        "@type": "dt:HypothesisGate",
        "@id": "dt:HG-07",
        "gateId": "HG-07",
        "layer": "L2_Composition",
        "name": "Skill Enhancement Assessment",
        "hypothesis": "This capability should be a standalone Skill enhanced with additional components rather than a full Plugin",
        "testMethod": "Evaluate whether minimal additions to a Skill would satisfy the need without full Plugin overhead",
        "evaluationCriteria": [
          { "criterion": "One or two additional components (MCP or command) complete the solution", "weight": 3, "examples": { "pass": "Skill + one MCP connection to Supabase is sufficient", "fail": "Needs 5+ MCP integrations, 3 sub-agents, and custom commands" } },
          { "criterion": "The Skill is the primary value; extras are convenience", "weight": 3, "examples": { "pass": "Ontology generation skill works alone; Supabase storage is optional enhancement", "fail": "Without the MCP integrations, the skill is useless" } },
          { "criterion": "Maintenance burden of full Plugin is unjustified", "weight": 2, "examples": { "pass": "Simple skill that rarely changes; plugin.json overhead is waste", "fail": "Frequently updated workflow requiring coordinated component versioning" } },
          { "criterion": "Cross-platform portability (Claude.ai + Code + API) is important", "weight": 2, "examples": { "pass": "Skill needs to work identically in Claude.ai chat and API calls", "fail": "Only used in Claude Code terminal context" } }
        ],
        "thresholds": {
          "pass": { "minScore": 7, "recommendation": "SKILL_WITH_MCP" },
          "fail": { "minScore": 0, "recommendation": "PLUGIN_LIGHTWEIGHT" }
        }
      }
    ],

