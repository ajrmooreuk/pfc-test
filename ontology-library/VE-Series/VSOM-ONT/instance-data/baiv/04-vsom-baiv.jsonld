  "vsom:vision": {
    "@type": "vsom:Vision",
    "@id": "vsom:vision-baiv",
    "vsom:visionStatement": "When businesses think 'how do I get recommended by AI', they think Be AI Visible. We own the AI Visibility category the way SEO owned Google rankings.",
    "vsom:visionScope": "organizational",
    "vsom:visionHorizon": 5,
    "vsom:visionOwner": "rrr:role-baiv-pfi-owner",
    "vsom:status": "draft",
    "vsom:keyInsight": "40% of B2B purchase decisions now include AI conversation research. There is a 12-18 month window before incumbent SEO tools add AI tracking. Category creation is the strategic imperative."
  },

  "vsom:strategies": [
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-baiv-1",
      "vsom:strategyName": "AI Visibility Category Creation",
      "vsom:strategyDescription": "Establish BAIV as the category-defining platform for AI Visibility — the way SEMrush defined SEO tooling. First-mover advantage with 12-18 month window before incumbents respond.",
      "vsom:strategyType": "growth",
      "vsom:strategicFocus": "Market creation and brand positioning",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-baiv-pfi-owner",
      "vsom:informedBy": ["vsom:vision-baiv"],
      "vsom:status": "draft"
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-baiv-2",
      "vsom:strategyName": "Ontology-Driven Platform Architecture",
      "vsom:strategyDescription": "Use the 52-ontology PFC knowledge graph to deliver 10x faster feature development via semantic understanding, enabling AI Visibility scoring, cross-LLM tracking, and content optimization at a depth competitors cannot match.",
      "vsom:strategyType": "innovation",
      "vsom:strategicFocus": "Technology differentiation and development velocity",
      "vsom:timeHorizon": 3,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-baiv-admin",
      "vsom:informedBy": ["vsom:vision-baiv"],
      "vsom:status": "draft",
      "vsom:agentArchitecture": {
        "totalAgents": 16,
        "clusters": [
          { "name": "Discovery", "description": "Discover brand mentions and citations across LLMs" },
          { "name": "Analysis", "description": "Score AI Visibility across 5 dimensions" },
          { "name": "Generation", "description": "Generate LLM-optimized content recommendations" },
          { "name": "Optimisation", "description": "Continuously optimize AI Visibility based on results" }
        ]
      }
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-baiv-3",
      "vsom:strategyName": "Discovery Audit as Growth Engine",
      "vsom:strategyDescription": "Use a 2.5-minute AI Visibility audit as the primary customer acquisition engine — a low-friction, high-value entry point that demonstrates the AI Visibility gap and drives platform subscriptions.",
      "vsom:strategyType": "customer_centricity",
      "vsom:strategicFocus": "Customer acquisition and conversion",
      "vsom:timeHorizon": 1,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:role-baiv-pfi-owner",
      "vsom:informedBy": ["vsom:vision-baiv", "vsom:strategy-baiv-1"],
      "vsom:status": "draft"
    }
  ],

