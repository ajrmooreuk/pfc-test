    {"@type": "nut:MealTheme", "@id": "nut:theme-LowFODMAP", "name": "Low FODMAP", "nut:targetsGoal": [{"@id": "nut:goal-medical-management"}]},
    {"@type": "nut:MealTheme", "@id": "nut:theme-FamilyMeals", "name": "Family Meals", "nut:targetsGoal": []},
    {"@type": "nut:MealTheme", "@id": "nut:theme-GutHealth", "name": "Gut Health", "nut:targetsGoal": [{"@id": "nut:goal-medical-management"}]},
