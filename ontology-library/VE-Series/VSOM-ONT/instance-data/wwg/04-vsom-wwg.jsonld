{
  "@context": {
    "vsom": "https://platformcore.io/ontology/vsom/",
    "bsc": "https://platformcore.io/ontology/bsc/",
    "orgctx": "https://platformcore.io/ontology/org-context/",
    "rrr": "https://platformcore.io/ontology/rrr/",
    "pfc": "https://platformcore.io/ontology/"
  },
  "@type": "vsom:VSOMFramework",
  "@id": "vsom:framework-wwg",
  "vsom:organizationContextRef": "org:ctx-wwg",

  "vsom:vision": {
    "@type": "vsom:Vision",
    "@id": "vsom:vision-wwg",
    "vsom:visionStatement": "Transform World Wide Gourmet from a reactive food importer into a margin-intelligent, graph-driven business that sees every pound of exposure from container stuffing to customer delivery — and acts on that visibility to protect, price, and grow margin across every corridor and every order.",
    "vsom:visionScope": "organizational",
    "vsom:visionHorizon": 5,
    "vsom:visionOwner": "rrr:exec-wwg-managing-director",
    "vsom:status": "draft",
    "vsom:keyInsight": "Today WWG operates two disconnected worlds: procurement watches inbound corridors, sales watches outbound fulfilment. Nobody owns the warehouse in between, where margin bleeds invisibly. The E2E graph eliminates this blind spot."
  },

  "vsom:strategies": [
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-wwg-1",
      "vsom:strategyName": "Three-Layer Composed Graph — Supply, Bridge, Demand",
      "vsom:strategyDescription": "Build a unified three-layer graph connecting 4 inbound corridors (LSC-ONT) through the UK warehouse margin pool to 5+ customer segments (OFM-ONT), with bidirectional traversal and 9 cross-layer join points.",
      "vsom:strategyType": "transformation",
      "vsom:strategicFocus": "Data infrastructure and operational visibility",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:exec-wwg-managing-director",
      "vsom:informedBy": ["vsom:vision-wwg"],
      "vsom:status": "draft",
      "vsom:keyDesignDecisions": [
        "One graph, not two — LSC-ONT and OFM-ONT joined through 9 explicit join points",
        "StockAllocation is the critical bridge entity connecting lsc:Shipment to ofm:OrderLine",
        "Bidirectional cascades: supply disruption → customer impact AND demand change → supply exposure",
        "4 EMC scope rules: product match, corridor scope, fulfilment scope, maturity threshold"
      ]
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-wwg-2",
      "vsom:strategyName": "Margin-at-Risk (MaR) — The Unifying Metric",
      "vsom:strategyDescription": "Develop a single, real-time Margin-at-Risk metric aggregating active erosion, probabilistic erosion, and scenario exposure across every order, corridor, and time horizon.",
      "vsom:strategyType": "operational_excellence",
      "vsom:strategicFocus": "Financial visibility and risk quantification",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:func-wwg-finance-analyst",
      "vsom:informedBy": ["vsom:vision-wwg"],
      "vsom:status": "draft",
      "vsom:formula": "MaR = Σ(active_erosion_per_order) + Σ(P(risk_i) × impact_i) + max(scenario_exposure)"
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-wwg-3",
      "vsom:strategyName": "Cross-Corridor Substitution Engine",
      "vsom:strategyDescription": "Use the unified graph to automatically identify commodity-equivalent substitutions across corridors when a primary source is disrupted, with margin impact pre-calculated before the substitution is offered.",
      "vsom:strategyType": "innovation",
      "vsom:strategicFocus": "Supply chain resilience and customer retention",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:func-wwg-procurement-mgr",
      "vsom:informedBy": ["vsom:vision-wwg", "vsom:strategy-wwg-1"],
      "vsom:status": "draft"
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-wwg-4",
      "vsom:strategyName": "Proactive Customer Lifecycle Management",
      "vsom:strategyDescription": "Use demand-side patterns and fulfilment risk scores to segment customers by behaviour, predict changes before they happen, and protect relationships through pre-emptive action.",
      "vsom:strategyType": "customer_centricity",
      "vsom:strategicFocus": "Customer experience and retention",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:func-wwg-sales-account-mgr",
      "vsom:informedBy": ["vsom:vision-wwg", "vsom:strategy-wwg-1"],
      "vsom:status": "draft",
      "vsom:riskBands": {
        "green": "0-3: on track, stock allocated, dispatch scheduled",
        "amber": "4-6: at risk — notify customer with revised ETA and alternatives",
        "red": "7-10: fulfilment failure likely — escalate, activate substitution engine"
      }
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-wwg-5",
      "vsom:strategyName": "Warehouse Capacity Intelligence",
      "vsom:strategyDescription": "Model the UK cold warehouse as a capacity-constrained bridge node, forecasting inbound arrivals against outbound dispatches to prevent storage overflow, minimise dwell time, and optimise dispatch consolidation.",
      "vsom:strategyType": "operational_excellence",
      "vsom:strategicFocus": "Warehouse cost control and capacity planning",
      "vsom:timeHorizon": 1,
      "vsom:strategyScope": "functional",
      "vsom:setByRole": "rrr:func-wwg-warehouse-mgr",
      "vsom:informedBy": ["vsom:vision-wwg"],
      "vsom:status": "draft",
      "vsom:warehouseProfile": {
        "location": "Daventry, UK",
        "frozenCapacity": "1,600 pallet positions @ -25°C",
        "chilledCapacity": "800 pallet positions @ +2°C",
        "frozenDailyCost": "GBP 1.80/pallet/day",
        "chilledDailyCost": "GBP 2.40/pallet/day",
        "breakEvenDwell": "5 days"
      }
    },
    {
      "@type": "vsom:Strategy",
      "@id": "vsom:strategy-wwg-6",
      "vsom:strategyName": "Unified Risk & Performance Reporting",
      "vsom:strategyDescription": "Deliver a single BSC-structured performance view across all 4 corridors and all customer segments, with causal links from operational actions to financial outcomes.",
      "vsom:strategyType": "operational_excellence",
      "vsom:strategicFocus": "Performance measurement and strategic alignment",
      "vsom:timeHorizon": 2,
      "vsom:strategyScope": "organizational",
      "vsom:setByRole": "rrr:func-wwg-finance-analyst",
      "vsom:informedBy": ["vsom:vision-wwg"],
      "vsom:status": "draft"
    }
  ],

  "vsom:objectives": [
    {
      "@type": "vsom:StrategicObjective",
      "@id": "vsom:obj-wwg-f1",
      "vsom:objectiveName": "Maximise margin realisation",
      "vsom:objectiveDescription": "Close the gap between booked margin and realised margin across all corridors and customer segments",
      "vsom:bscPerspective": "Financial",
      "vsom:priority": "P1-Critical",
      "vsom:ownerRole": "rrr:func-wwg-finance-analyst",
      "vsom:parentStrategy": "vsom:strategy-wwg-2",
      "vsom:timeframe": "Multi-year",
      "vsom:baseline": "72%",
      "vsom:target": "88%",
      "vsom:timeline": "18 months"
    },
    {
