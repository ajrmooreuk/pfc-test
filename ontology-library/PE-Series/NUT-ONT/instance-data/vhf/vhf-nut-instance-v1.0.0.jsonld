{
  "@context": {
    "@vocab": "https://schema.org/",
    "nut": "https://oaa-ontology.org/v7/nutrition/",
    "vp": "https://oaa-ontology.org/v6/vp/",
    "rrr": "https://oaa-ontology.org/v5/rrr/",
    "kpi": "https://oaa-ontology.org/v6/kpi/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@type": "nut:InstanceDataSet",
  "@id": "nut:vhf-instance-v1.0.0",
  "metadata": {
    "title": "VHF Nutrition App — NUT-ONT Instance Data",
    "version": "1.0.0",
    "created": "2026-03-05",
    "author": "PF-Core Platform Team",
    "owningInstance": "PFI-VHF",
    "sourceOntology": "NUT-ONT v1.0.0",
    "oaaVersion": "7.0.0",
    "description": "NUT-ONT instance data for VHF Nutrition App. 1 coach, 12 client profiles (9 good, 3 poor-data for validation), 5 goals, 16 meal themes, 14 allergens, 30 diet types, 30 recipes. Migrated from VHF-RMP-ONT v1.0.0 legacy format to NUT-ONT nut: namespace. Seed data for PFC Ontology Visualiser graph rendering.",
    "migrationSource": "pfi-vhf-nutrition-app-dev/instance-data/ontologies/VHF-RECIPE-MEALPLAN-ONT/test-data/",
    "visualiserConfig": {
      "graphRenderTarget": "PFC Ontology Visualiser",
      "emcCompositionRef": "emc:InstanceConfiguration-VHF",
      "joinPatterns": ["JP-NUT-001", "JP-NUT-002", "JP-NUT-003", "JP-NUT-004", "JP-NUT-005", "JP-NUT-006", "JP-NUT-007"]
    }
  },
  "examples": [

    {"_section": "=== COACH ==="},

    {
      "@type": "nut:Coach",
      "@id": "nut:coach-james-kerby",
      "name": "James Kerby",
      "givenName": "James",
      "familyName": "Kerby",
      "jobTitle": "Personal Trainer Coach & Clinical Weight-Loss Practitioner",
      "nut:qualifications": [
        "Level 5 Clinical Weight Loss Practitioner",
        "Diploma in Sports Science",
        "Nutrition and Weight Management Qualified"
      ],
      "nut:specialisms": ["weight-loss", "strength-training", "injury-rehabilitation", "seniors", "sports-performance"],
      "nut:manages": [
        {"@id": "nut:client-tp-001"}, {"@id": "nut:client-tp-002"}, {"@id": "nut:client-tp-003"},
        {"@id": "nut:client-tp-004"}, {"@id": "nut:client-tp-005"}, {"@id": "nut:client-tp-006"},
        {"@id": "nut:client-tp-007"}, {"@id": "nut:client-tp-008"}, {"@id": "nut:client-tp-009"},
        {"@id": "nut:client-tp-010"}, {"@id": "nut:client-tp-011"}, {"@id": "nut:client-tp-012"}
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Viridian Health & Fitness",
        "address": {"@type": "PostalAddress", "streetAddress": "Woodhams Farm, Kings Worthy", "addressLocality": "Winchester", "addressRegion": "Hampshire", "addressCountry": "GB"}
      }
    },

    {"_section": "=== GOALS (5) ==="},

    {"@type": "nut:Goal", "@id": "nut:goal-weight-loss", "name": "Weight Loss", "description": "Reduce body weight through caloric deficit while preserving lean mass", "nut:goalMapsToBenefit": {"@id": "vp:benefit-weight-management"}},
    {"@type": "nut:Goal", "@id": "nut:goal-muscle-gain", "name": "Muscle Gain", "description": "Increase lean muscle mass through caloric surplus and high protein intake", "nut:goalMapsToBenefit": {"@id": "vp:benefit-nutritional-quality"}},
    {"@type": "nut:Goal", "@id": "nut:goal-maintenance", "name": "Maintenance", "description": "Maintain current weight and body composition", "nut:goalMapsToBenefit": {"@id": "vp:benefit-dietary-compliance"}},
    {"@type": "nut:Goal", "@id": "nut:goal-sports-performance", "name": "Sports Performance", "description": "Optimise nutrition for athletic training and competition", "nut:goalMapsToBenefit": {"@id": "vp:benefit-nutritional-quality"}},
    {"@type": "nut:Goal", "@id": "nut:goal-medical-management", "name": "Medical Management", "description": "Nutrition therapy aligned with medical conditions and clinical protocols", "nut:goalMapsToBenefit": {"@id": "vp:benefit-dietary-compliance"}},

    {"_section": "=== MEAL THEMES (16) ==="},

    {"@type": "nut:MealTheme", "@id": "nut:theme-HighProtein", "name": "High Protein", "nut:targetsGoal": [{"@id": "nut:goal-muscle-gain"}, {"@id": "nut:goal-weight-loss"}]},
    {"@type": "nut:MealTheme", "@id": "nut:theme-Mediterranean", "name": "Mediterranean", "nut:targetsGoal": [{"@id": "nut:goal-maintenance"}]},
    {"@type": "nut:MealTheme", "@id": "nut:theme-QuickWeeknight", "name": "Quick Weeknight", "nut:targetsGoal": []},
    {"@type": "nut:MealTheme", "@id": "nut:theme-DiabeticFriendly", "name": "Diabetic Friendly", "nut:targetsGoal": [{"@id": "nut:goal-medical-management"}]},
    {"@type": "nut:MealTheme", "@id": "nut:theme-AsianFusion", "name": "Asian Fusion", "nut:targetsGoal": []},
