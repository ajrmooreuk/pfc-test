{
  "@context": {
    "@vocab": "https://schema.org/",
    "oaa": "https://oaa-ontology.org/v6/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "vsom": "https://oaa-ontology.org/v6/vsom/",
    "org": "https://oaa-ontology.org/v6/organization/",
    "cl": "https://oaa-ontology.org/v6/competitive-landscape/"
  },
  "@id": "https://oaa-ontology.org/v6/vsom/schema",
  "@type": "owl:Ontology",
  "name": "VSOM Core Capability Ontology",
  "alternateName": "Vision-Strategy-Objectives-Metrics Framework",
  "description": "Comprehensive ontology for Vision, Strategy, Objectives, and Metrics framework. Includes StrategicReviewCycle for iterative feedback from competitive landscape. Business Impact is the Driver, Outcomes the Goal, and Value the Measure.",
  "oaa:schemaVersion": "7.0.0",
  "oaa:moduleVersion": "3.0.0",
  "oaa:previousVersion": "2.1.0",
  "oaa:domain": "Strategic Management, Business Performance",
  "oaa:status": "Production",
  "dateCreated": "2025-11-14",
  "dateModified": "2026-02-08",
  "creator": {
    "@type": "Organization",
    "name": "W4M Core Capability Framework"
  },
  "oaa:imports": [
    {
      "@id": "org:schema",
      "name": "ORG-ONT",
      "version": "2.1.0",
      "importedEntities": [
        "org:Organization",
        "org:OrganizationContext"
      ],
      "importedRelationships": [
        "org:hasContext"
      ]
    },
    {
      "@id": "cl:schema",
      "name": "CL-ONT",
      "version": "1.0.0",
      "importedEntities": [
        "cl:CompetitiveLandscape"
      ],
      "importedRelationships": []
    }
  ],
  "oaa:joinPatterns": [
    {
      "patternId": "JP-VSOM-001",
      "name": "Org-Context-VSOM Join",
      "description": "Join ORG-ONT Organization to VSOM Framework via OrganizationContext bridge",
      "joinPath": "org:Organization → org:hasContext → org:OrganizationContext → vsom:hasStrategicContext → vsom:VSOMFramework",
      "useCase": "Full organizational strategic context"
    },
    {
      "patternId": "JP-VSOM-002",
      "name": "Strategy-Landscape Iteration",
      "description": "StrategicReviewCycle connects competitive landscape feedback to strategy updates",
      "joinPath": "vsom:StrategicReviewCycle → vsom:reviewsLandscape → cl:CompetitiveLandscape",
      "useCase": "Competitive feedback informs strategic adjustment"
    },
    {
      "patternId": "JP-VSOM-003",
      "name": "Metric-Triggered Review",
      "description": "Metric threshold breach triggers strategic review cycle",
      "joinPath": "vsom:MetricsComponent → vsom:triggersReview → vsom:StrategicReviewCycle",
      "useCase": "Performance-driven strategy iteration"
    }
  ],
  "entities": [
    {
      "@id": "vsom:VSOMFramework",
