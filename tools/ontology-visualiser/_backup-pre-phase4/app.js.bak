// Drag-drop handlers for skeleton editor (called from inline HTML in panel)
window._handleNavDrop = function(event, targetItemId, targetLayerId) {
  const data = event.dataTransfer.getData('text/plain');
  if (!data.startsWith('nav:')) return;
  const draggedItemId = data.slice(4);
  if (draggedItemId === targetItemId) return;
  // Move dragged item to the same layer as the target, then reorder to match position
  moveNavItemToLayer(draggedItemId, targetLayerId);
};
window._handleCmpDrop = function(event, targetPlacementId, targetZoneId) {
  const data = event.dataTransfer.getData('text/plain');
  if (!data.startsWith('cmp:')) return;
  const draggedPlacementId = data.slice(4);
  if (draggedPlacementId === targetPlacementId) return;
  moveZoneComponentToZone(draggedPlacementId, targetZoneId);
};

// ========================================
// DS CODE GENERATION (S8.3.1, S8.3.2, S8.3.3, S8.3.4)
// ========================================

function _downloadBlob(content, filename, mimeType) {
  const blob = new Blob([content], { type: mimeType });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
}

window.generateComponentCode = function() {
  const brand = state.activeDSBrand;
  const parsed = state.dsInstances?.get(brand);
  if (!parsed || !brand) { alert('Select a DS brand first'); return; }
  const code = generateReactComponentCode(parsed, brand);
  _downloadBlob(code, `${brand}-components.tsx`, 'text/typescript');
  console.log(`[DS Codegen] Generated ${brand}-components.tsx`);
};

window.downloadCSSTokens = function() {
  const brand = state.activeDSBrand;
  const parsed = state.dsInstances?.get(brand);
  if (!parsed || !brand) { alert('Select a DS brand first'); return; }
  const css = generateCSSCustomProperties(parsed, brand);
  _downloadBlob(css, `${brand}-tokens.css`, 'text/css');
  console.log(`[DS Codegen] Generated ${brand}-tokens.css`);
};

window.exportFigmaMake = function() {
  const brand = state.activeDSBrand;
  const parsed = state.dsInstances?.get(brand);
  if (!parsed || !brand) { alert('Select a DS brand first'); return; }
  const json = generateFigmaMakeJSON(parsed, brand);
  _downloadBlob(json, `${brand}-figma-make.json`, 'application/json');
  console.log(`[DS Codegen] Generated ${brand}-figma-make.json`);
};

window.previewComponents = function() {
  const brand = state.activeDSBrand;
  const parsed = state.dsInstances?.get(brand);
  if (!parsed || !brand) { alert('Select a DS brand first'); return; }
  const html = generateSandboxHTML(parsed, brand);
  const modal = document.getElementById('ds-preview-modal');
  const iframe = document.getElementById('ds-preview-iframe');
  const brandLabel = document.getElementById('ds-preview-brand');
  if (brandLabel) brandLabel.textContent = brand.toUpperCase();
  if (iframe) iframe.srcdoc = html;
  if (modal) modal.style.display = 'flex';
};

window.closePreviewModal = function() {
  const modal = document.getElementById('ds-preview-modal');
  const iframe = document.getElementById('ds-preview-iframe');
  if (modal) modal.style.display = 'none';
  if (iframe) iframe.srcdoc = '';
};

window.downloadComponentCSS = function() {
  const css = generateComponentCSSBundle();
  _downloadBlob(css, 'pfc-component-tokens.css', 'text/css');
  console.log('[DS Codegen] Generated pfc-component-tokens.css');
};

window.showLLMPrompt = function() {
  const modal = document.getElementById('oaa-modal');
  const body = document.getElementById('oaa-modal-body');
  if (!modal || !body) return;

  // Use a representative component for the prompt
  const componentName = 'pfc.viz.toolbar.btn-active';
  const chain = resolveInheritanceChain(componentName);
  const tokens = resolveInheritedTokens(componentName, []);
  const rules = getRulesForComponent(componentName);

  const cssPrompt = generateLLMPrompt(componentName, tokens, chain, rules, 'css');
  const reactPrompt = generateLLMPrompt(componentName, tokens, chain, rules, 'react');
  const tailwindPrompt = generateLLMPrompt(componentName, tokens, chain, rules, 'tailwind');

  body.innerHTML = `
    <p style="color:#888; margin-bottom:16px;">LLM prompt templates for component transcription. Copy a prompt and use it with Claude Code.</p>
    <div style="margin-bottom:12px;">
      <label style="font-size:12px; color:#888;">Target format:</label>
      <select id="llm-prompt-format" style="margin-left:8px; padding:4px 8px; background:#1a1d27; color:#e0e0e0; border:1px solid #333; border-radius:4px;"
        onchange="document.getElementById('llm-prompt-text').value =
          this.value === 'css' ? document.getElementById('llm-prompt-css').value :
          this.value === 'react' ? document.getElementById('llm-prompt-react').value :
          document.getElementById('llm-prompt-tailwind').value;">
        <option value="css">CSS Custom Properties</option>
        <option value="react">React / TypeScript</option>
        <option value="tailwind">Tailwind CSS</option>
      </select>
    </div>
    <textarea id="llm-prompt-text" readonly style="width:100%; height:300px; font-family:monospace; font-size:12px; background:#0f1117; color:#e0e0e0; border:1px solid #333; border-radius:8px; padding:12px; resize:vertical;">${cssPrompt.replace(/</g, '&lt;')}</textarea>
    <input type="hidden" id="llm-prompt-css" value="${cssPrompt.replace(/"/g, '&quot;')}" />
    <input type="hidden" id="llm-prompt-react" value="${reactPrompt.replace(/"/g, '&quot;')}" />
    <input type="hidden" id="llm-prompt-tailwind" value="${tailwindPrompt.replace(/"/g, '&quot;')}" />
    <div style="margin-top:12px;">
      <button class="oaa-btn" onclick="navigator.clipboard.writeText(document.getElementById('llm-prompt-text').value).then(() => { this.textContent='Copied!'; setTimeout(() => this.textContent='Copy Prompt', 2000); })">Copy Prompt</button>
      <button class="oaa-btn oaa-btn-secondary" onclick="document.getElementById('oaa-modal').style.display='none';">Close</button>
    </div>`;
  modal.style.display = 'flex';
};

// ========================================
// CENTRALISED VIEW SWITCHER
// ========================================

function setViewMode(mode) {
  const prev = state.activeView;
  if (mode === prev) return;

  // 1. Close all overlays
  _closeAllOverlays();

  // 2. Update state
  state.activeView = mode;
  state.mermaidMode = (mode === 'mermaid');
  state.mindmapMode = (mode === 'mindmap');

  // 3. Switch containers
  if (mode === 'graph') {
    switchToOntologyMode();
    // Restore drop-zone if no ontology loaded
    const dropZone = document.getElementById('drop-zone');
    if (dropZone && !state.lastParsed) {
      dropZone.style.display = '';
      dropZone.classList.remove('hidden');
    }
    if (state.lastParsed && state.viewMode === 'single') renderGraph(state.lastParsed);
  } else if (mode === 'ds-cascade') {
    switchToOntologyMode(); // reuse same #network container
    _renderDSCascadeGraph();
  } else if (mode === 'mermaid') {
    switchToMermaidMode();
  } else if (mode === 'mindmap') {
    switchToMindmapMode();
  }

  // 4. Update toolbar buttons and view tabs
  _setToolbarButtonsForView(mode);
  _updateViewTabs(mode);

  // 4b. Sync dynamic nav bar state (F40.17b Phase 2)
  _syncDynNav();

  // 5. Update breadcrumb for the active view (S9C.1.1: persist across all views)
  if (mode === 'mermaid') {
    updateMermaidBreadcrumb();
  } else if (state.navigationStack && state.navigationStack.length > 0) {
    updateBreadcrumb();
  } else {
    _hide('breadcrumb');
  }
}

function _closeAllOverlays() {
  const sidebar = document.getElementById('sidebar');
  if (sidebar) sidebar.classList.remove('open');
  const auditPanel = document.getElementById('audit-panel');
  if (auditPanel) auditPanel.classList.remove('open');
  const mermaidEditor = document.getElementById('mermaid-editor-panel');
  if (mermaidEditor) mermaidEditor.classList.remove('open');
  state.mermaidEditorOpen = false;
  const mmProps = document.getElementById('mindmap-properties-panel');
  if (mmProps) mmProps.classList.remove('open');
  state.mindmapPropertiesPanelOpen = false;
}

function _setToolbarButtonsForView(mode) {
  // Tri-state config per view mode: 'active' | 'disabled' | 'hidden'
  // Only buttons with non-default states need listing; unlisted buttons stay active
  const mermaidState = {
    'btn-physics':       'disabled',
    'layout-select':     'disabled',
    'btn-fit-view':      'disabled',
    'btn-reset':         'disabled',
    'btn-sidebar':       'disabled',
    'btn-audit':         'disabled',
    'btn-glossary':      'disabled',
    'btn-load-registry': 'disabled',
    'btn-test-data':     'hidden',
    'btn-new-ontology':  'hidden',
    'btn-fork':          'hidden',
    'btn-ds-panel':      'hidden',
    'ds-brand-select':   'hidden',
    'exp-png':           'disabled',
    'exp-svg':           'disabled',
    'exp-d3':            'disabled',
    'exp-audit':         'disabled',
    'exp-pdf':           'disabled',
    'exp-diff':          'disabled',
    'exp-ds-bundle':     'hidden',
  };
  const mermaidActive = ['btn-mermaid-editor', 'btn-mermaid-fit'];
  const mindmapState = {
    'btn-physics':       'disabled',
    'layout-select':     'disabled',
    'btn-fit-view':      'disabled',
    'btn-reset':         'disabled',
    'btn-sidebar':       'disabled',
    'btn-audit':         'disabled',
    'btn-glossary':      'disabled',
    'btn-mermaid-editor':'hidden',
    'btn-mermaid-fit':   'hidden',
    'btn-load-registry': 'disabled',
    'btn-test-data':     'hidden',
    'btn-new-ontology':  'hidden',
    'btn-fork':          'hidden',
    'btn-ds-panel':      'hidden',
    'ds-brand-select':   'hidden',
    'exp-png':           'disabled',
    'exp-svg':           'disabled',
    'exp-mermaid':       'disabled',
    'exp-d3':            'disabled',
    'exp-cypher':        'disabled',
    'exp-gate-report':   'disabled',
    'exp-audit':         'disabled',
    'exp-pdf':           'disabled',
    'exp-diff':          'disabled',
    'exp-ds-bundle':     'hidden',
  };

  const dsCascadeState = {
    'btn-physics':       'disabled',
    'layout-select':     'disabled',
    'btn-audit':         'disabled',
    'btn-glossary':      'disabled',
    'btn-mermaid-editor':'hidden',
    'btn-mermaid-fit':   'hidden',
    'btn-test-data':     'hidden',
    'btn-new-ontology':  'hidden',
    'btn-fork':          'hidden',
    'exp-mermaid':       'disabled',
    'exp-d3':            'disabled',
    'exp-cypher':        'disabled',
    'exp-gate-report':   'disabled',
    'exp-audit':         'disabled',
    'exp-diff':          'disabled',
  };

  const stateMap = mode === 'mermaid' ? mermaidState
                 : mode === 'mindmap' ? mindmapState
                 : mode === 'ds-cascade' ? dsCascadeState
                 : {};  // graph: all active

  // Collect all IDs we manage
  const allIds = new Set([
    ...Object.keys(mermaidState), ...mermaidActive, ...Object.keys(mindmapState),
    ...Object.keys(dsCascadeState)
  ]);

  for (const id of allIds) {
    const el = document.getElementById(id);
    if (!el) continue;
    const s = stateMap[id] || 'active';
    if (s === 'active') {
      el.style.display = '';
      el.classList.remove('tb-disabled');
      // Restore original title if previously overridden
      if (el.dataset.originalTitle) {
        el.title = el.dataset.originalTitle;
        delete el.dataset.originalTitle;
      }
    } else if (s === 'disabled') {
      el.style.display = '';
      el.classList.add('tb-disabled');
      if (!el.dataset.originalTitle && el.title) el.dataset.originalTitle = el.title;
      el.title = 'Not available in ' + mode + ' view';
    } else {
      el.style.display = 'none';
      el.classList.remove('tb-disabled');
    }
  }

  // Mermaid-specific buttons: show only in mermaid mode
  for (const id of mermaidActive) {
    const el = document.getElementById(id);
    if (el) el.style.display = (mode === 'mermaid') ? '' : 'none';
  }
}

function _updateViewTabs(mode) {
  const container = document.getElementById('view-tabs');
  if (!container) return;
  const tabs = container.querySelectorAll('.view-tab');
  tabs.forEach(tab => {
    if (tab.dataset.view === mode) {
      tab.classList.add('active');
    } else {
      tab.classList.remove('active');
    }
  });
}

// --- Mermaid Breadcrumb ---

function updateMermaidBreadcrumb() {
  const bar = document.getElementById('breadcrumb');
  if (!bar) return;

  // Hide graph-specific breadcrumb controls
  _hide('tier-depth-gauge');
  _hide('tier0-toggle');
  _hide('series-toggle');
  _hide('cross-edge-filter');
  _hide('bridge-filter');

  const bp = document.getElementById('breadcrumb-path');
  if (!bp) return;

  const homeBtn = bar.querySelector('.breadcrumb-home');
  const origin = state.mermaidOrigin;

  if (origin === 'export' && state.lastParsed) {
    // Export: Graph › OntologyName › Mermaid Export
    const name = escapeHtml(state.lastParsed.name || 'Ontology');
    bp.innerHTML = `<span class="breadcrumb-link" onclick="setViewMode('graph')">Graph</span>`
      + `<span class="breadcrumb-sep">\u203A</span>`
      + `<span class="breadcrumb-link" onclick="setViewMode('graph')">${name}</span>`
      + `<span class="breadcrumb-sep">\u203A</span>`
      + `<span class="breadcrumb-current">Mermaid Export</span>`;
    if (homeBtn) { homeBtn.style.display = ''; homeBtn.onclick = () => setViewMode('graph'); }
    bar.style.display = 'flex';
  } else if (origin === 'file' && state.mermaidFileName) {
    // File: Mermaid › filename.mmd
    const fname = escapeHtml(state.mermaidFileName);
    const diagrams = state.mermaidDiagrams || [];
    let trail = `<span class="breadcrumb-current">Mermaid</span>`
      + `<span class="breadcrumb-sep">\u203A</span>`
      + `<span class="breadcrumb-current">${fname}</span>`;
    if (diagrams.length > 1 && diagrams[state.mermaidActiveDiagram]) {
      const dname = escapeHtml(diagrams[state.mermaidActiveDiagram].title);
      trail += `<span class="breadcrumb-sep">\u203A</span>`
        + `<span class="breadcrumb-current">${dname}</span>`;
    }
    bp.innerHTML = trail;
    if (homeBtn) homeBtn.style.display = 'none';
    bar.style.display = 'flex';
  } else {
    // No diagram loaded — show minimal label
    bp.innerHTML = `<span class="breadcrumb-current">Mermaid</span>`;
    if (homeBtn) homeBtn.style.display = 'none';
    bar.style.display = 'flex';
  }
}

window.updateMermaidBreadcrumb = updateMermaidBreadcrumb;

// --- Mermaid Drop-Zone Wiring ---

function _initMermaidDropZone() {
  const dropArea = document.getElementById('mermaid-drop-area');
  const fileInput = document.getElementById('mermaid-file-input');
  if (!dropArea || !fileInput) return;

  // Click the drop area to open file picker
  dropArea.addEventListener('click', (e) => {
    if (e.target.tagName === 'BUTTON' || e.target.tagName === 'INPUT') return;
    fileInput.click();
  });

  // Drag events
  ['dragenter', 'dragover'].forEach(evt => {
    dropArea.addEventListener(evt, e => { e.preventDefault(); dropArea.classList.add('dragover'); });
  });
  ['dragleave', 'drop'].forEach(evt => {
    dropArea.addEventListener(evt, e => { e.preventDefault(); dropArea.classList.remove('dragover'); });
  });

  dropArea.addEventListener('drop', e => {
    const file = e.dataTransfer?.files[0];
    if (file) _loadMermaidFile(file);
  });

  // File input change
  fileInput.addEventListener('change', e => {
    const file = e.target.files[0];
    if (file) _loadMermaidFile(file);
    fileInput.value = '';
  });
}

async function _loadMermaidFile(file) {
  const text = await file.text();
  state.mermaidOrigin = 'file';
  const result = await loadAndRenderMermaid(text, file.name);
  if (result.error) {
    const errorEl = document.getElementById('mermaid-editor-error');
    if (errorEl) { errorEl.textContent = result.error; errorEl.style.display = 'block'; }
  }
  document.getElementById('file-name').textContent = file.name;
  addRecentFile({ name: file.name, source: 'file', path: file.name, format: 'mermaid' });
}

window.openMermaidFilePicker = function() {
  const input = document.getElementById('mermaid-file-input');
  if (input) input.click();
};

window.startMermaidFromTemplate = function() {
  const template = `flowchart LR\n    A[Start] --> B{Decision}\n    B -->|Yes| C[Action]\n    B -->|No| D[End]`;
  state.mermaidOrigin = 'file';
  loadAndRenderMermaid(template, 'new-diagram.mmd').then(() => {
    // Open editor so user can modify the template
    if (typeof window.toggleMermaidEditor === 'function') window.toggleMermaidEditor();
  });
  document.getElementById('file-name').textContent = 'new-diagram.mmd';
};

