  "oaa:designDirectorPipeline": {
    "description": "AIRL VP feeds into the Design Director pipeline: VP -> PMF -> EFS -> DS-ONT -> Component Code",
    "upstreamDependencies": [
      { "ontology": "VSOM-ONT", "entities": ["vsom:obj-ai-transformation", "vsom:obj-digital-maturity"], "role": "Strategic alignment" },
      { "ontology": "ORG-ONT", "entities": ["org:ctx-airl"], "role": "Organisation context scoping" },
      { "ontology": "RRR-ONT", "entities": ["pf:exec-cto", "pf:func-ai-programme-director", "pf:func-ai-manager"], "role": "Role-based ICP mapping" }
    ],
    "downstreamConsumers": [
      { "ontology": "EFS-ONT", "bridgeType": "manifestsAsPersona + mapsToEpic + gainMapsToFeature + realizesInStory", "role": "ICP→Persona, Problem→Epic, Gain→Feature, Benefit→UserStory" },
      { "ontology": "PMF-ONT", "bridgeType": "VP validation feeds PMF product-market fit assessment", "role": "VP evidence strengthens PMF confidence scoring" },
      { "ontology": "DS-ONT", "bridgeType": "Via EFS: Features → DS component requirements", "role": "VP-driven features eventually manifest as design system components" }
    ],
    "emcComposition": {
      "category": "PRODUCT",
      "ontologiesComposed": ["VP-ONT", "PMF-ONT", "PE-ONT", "CA-ONT"],
      "instanceBrand": "airl"
    }
  }
}
