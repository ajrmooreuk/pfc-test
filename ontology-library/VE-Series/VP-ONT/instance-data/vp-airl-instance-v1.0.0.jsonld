      "baseline": 2.1,
      "target": 3.5,
      "measurementMethod": "Compare aggregate AIR-ONT maturity scores at T0 (initial assessment) and T+12 months across Strategy, People, Process, Technology, Governance dimensions (scale 1-5).",
      "measurementFrequency": "P3M"
    },

    {
      "@id": "vp:airl-sh-cto",
      "@type": "vp:Stakeholder",
      "name": "CTO / CIO",
      "stakeholderId": "sh:airl-cto",
      "stakeholderRole": "DecisionMaker",
      "influenceLevel": "High",
      "interests": "Board-level AI strategy confidence; quantified maturity metrics for investment justification; competitive positioning; risk reduction on AI initiatives",
      "objections": "Already invested in Big 4 advisory relationships; concerns about platform lock-in; questioning ROI vs. existing assessment approaches"
    },
    {
      "@id": "vp:airl-sh-director",
      "@type": "vp:Stakeholder",
      "name": "AI Programme Director",
      "stakeholderId": "sh:airl-director",
      "stakeholderRole": "Champion",
      "influenceLevel": "High",
      "interests": "Cross-domain visibility for programme planning; continuous monitoring capability; vendor-neutral assessment; integration with existing EA tools",
      "objections": "Learning curve for ontology-based approach; integration complexity with existing toolchain; team adoption resistance"
    },
    {
      "@id": "vp:airl-sh-manager",
      "@type": "vp:Stakeholder",
      "name": "AI/Data Manager",
      "stakeholderId": "sh:airl-manager",
      "stakeholderRole": "PrimaryUser",
      "influenceLevel": "Medium",
      "interests": "Reduced manual assessment burden; repeatable processes; clear team-level improvement targets; skill gap identification",
      "objections": "Yet another tool to learn; worried about job displacement; concerns about scoring objectivity"
    },
    {
      "@id": "vp:airl-sh-cfo",
      "@type": "vp:Stakeholder",
      "name": "CFO / Finance Director",
      "stakeholderId": "sh:airl-cfo",
      "stakeholderRole": "EconomicBuyer",
      "influenceLevel": "High",
      "interests": "Quantified ROI on AI investments; cost reduction vs. consultant dependency; budget predictability; risk mitigation for AI portfolio",
      "objections": "Platform subscription cost vs. ad-hoc consultant engagement; unclear payback period; preference for OpEx vs. CapEx models"
    },

    {
      "@id": "vp:airl-msg-csuite",
      "@type": "vp:MessagingFramework",
      "name": "C-Suite AI Readiness Messaging",
      "frameworkId": "msg:airl-csuite",
      "primaryMessage": "Transform AI investment from guesswork to science — quantify your organisation's AI readiness across every dimension and make board-confident investment decisions backed by data, not opinion.",
      "supportingMessages": "1. Reduce AI project failure rate by 40-60% through structured readiness assessment. 2. 3x faster time-to-readiness vs. manual assessment approaches. 3. 70% cost reduction vs. Big 4 consulting engagements. 4. Cross-domain visibility across Strategy, People, Process, Technology, and Governance.",
      "emotionalHooks": "Confidence in AI investment decisions; board credibility through data-driven reporting; competitive advantage through structured transformation; peace of mind that readiness gaps are identified before costly deployment",
      "useCustomerLanguage": true
    },
    {
      "@id": "vp:airl-msg-director",
      "@type": "vp:MessagingFramework",
      "name": "Director-Level Programme Messaging",
      "frameworkId": "msg:airl-director",
      "primaryMessage": "Get complete cross-domain visibility into your AI programme's readiness state — identify dependency gaps between technology, people, and governance dimensions before they become programme blockers.",
      "supportingMessages": "1. Unified maturity view across all business units and dimensions. 2. Automated gap analysis with prioritised remediation roadmaps. 3. Continuous monitoring replaces point-in-time snapshots. 4. Integration with existing EA frameworks and governance structures.",
      "emotionalHooks": "Control over complex programme landscape; early warning on hidden blockers; credibility with C-suite through quantified reporting; reduction in firefighting",
      "useCustomerLanguage": true
    },
    {
      "@id": "vp:airl-msg-manager",
      "@type": "vp:MessagingFramework",
      "name": "Manager-Level Practitioner Messaging",
      "frameworkId": "msg:airl-manager",
      "primaryMessage": "Replace 40+ hours of spreadsheet assessment with a platform that delivers consistent, repeatable maturity scores for your team — and tracks improvement over time automatically.",
      "supportingMessages": "1. Self-service assessment replaces manual data collection. 2. Consistent scoring eliminates assessor bias. 3. Historical tracking shows team improvement over time. 4. Clear skill gap identification for team development planning.",
      "emotionalHooks": "Freedom from tedious manual assessment; objective evidence of team improvement; professional development clarity; reduced assessment anxiety",
      "useCustomerLanguage": true
    },

