window.showWorkspaceManagerUI = async function() {
  const workspaces = await listWorkspaces();
  const listEl = document.getElementById('mm-workspace-list');
  if (listEl) {
    listEl.innerHTML = workspaces.map(ws => `
      <div class="mm-workspace-item${ws.id === state.mindmapActiveWorkspaceId ? ' active' : ''}"
           onclick="loadWorkspaceUI(${ws.id})">
        <span class="mm-workspace-item-name">${escapeHtml(ws.name)}</span>
        <span class="mm-workspace-item-meta">${ws.nodeCount} nodes | ${ws.updated ? new Date(ws.updated).toLocaleDateString() : ''}</span>
        <span class="mm-workspace-item-actions">
          <button onclick="event.stopPropagation(); deleteWorkspaceUI(${ws.id})" title="Delete" style="color:#fca5a5;">&times;</button>
        </span>
      </div>
    `).join('') || '<p style="color:#666; font-size:13px;">No saved workspaces yet</p>';
  }
  document.getElementById('mm-workspace-modal').style.display = 'flex';
};

window.closeWorkspaceManagerUI = function() {
  document.getElementById('mm-workspace-modal').style.display = 'none';
};

window.createNewWorkspaceUI = async function() {
  const nameInput = document.getElementById('mm-new-workspace-name');
  const name = nameInput?.value?.trim() || 'Untitled Workspace';
  clearCanvas();
  state.mindmapWorkspaceName = name;
  state.mindmapActiveWorkspaceId = null;
  await saveWorkspace(name);
  if (nameInput) nameInput.value = '';
  document.getElementById('mm-workspace-name').textContent = name;
  window.closeWorkspaceManagerUI();
};

window.loadWorkspaceUI = async function(id) {
  if (state.mindmapDirty && !confirm('You have unsaved changes. Load anyway?')) return;
  await loadWorkspace(id);
  document.getElementById('mm-workspace-name').textContent = state.mindmapWorkspaceName;
  window.closeWorkspaceManagerUI();
};

window.deleteWorkspaceUI = async function(id) {
  if (!confirm('Delete this workspace?')) return;
  await deleteWorkspace(id);
  window.showWorkspaceManagerUI();
};

