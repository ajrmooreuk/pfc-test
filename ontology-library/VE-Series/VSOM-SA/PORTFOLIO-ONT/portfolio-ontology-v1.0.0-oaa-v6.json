  "@id": "https://oaa-ontology.org/v6/portfolio/schema",
  "@type": "owl:Ontology",
  "name": "Portfolio Strategy & Execution Ontology",
  "alternateName": "PORTFOLIO-ONT — BCG Growth-Share, Three Horizons, Investment Maps, Strategic Lens & Direction",
  "description": "The innermost execution layer. Formalizes portfolio-level strategic analysis and resource allocation: BCG Growth-Share Matrix (portfolio classification), Three Horizons Model (innovation investment across time), Strategic Investment Maps (budget-to-strategy alignment), Portfolio Strategic Lens (focused graph views by product/brand/BU), and Strategic Direction Summary (executive one-pager). Bridges VSOM strategy to PPM portfolio execution across brands, products, services, and business units. Part of VE-Series VSOM-SA (Strategy Analysis).",
  "oaa:schemaVersion": "7.0.0",
  "oaa:moduleVersion": "1.0.0",
  "oaa:domain": "Portfolio Management, Innovation Strategy, Resource Allocation, Strategic Execution",
  "oaa:status": "Draft",
  "dateCreated": "2026-02-12",
  "dateModified": "2026-02-12",
  "creator": {
    "@type": "Organization",
    "name": "W4M Strategic Patterns Framework"
  },
