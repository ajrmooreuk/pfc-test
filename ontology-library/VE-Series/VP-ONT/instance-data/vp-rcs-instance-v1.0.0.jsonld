  "oaa:designDirectorPipeline": {
    "description": "RCS VP feeds into the Design Director pipeline with strong RCSG-Series integration for compliance dashboard components",
    "upstreamDependencies": [
      { "ontology": "VSOM-ONT", "entities": ["vsom:obj-regulatory-compliance", "vsom:obj-security-posture"], "role": "Strategic alignment" },
      { "ontology": "ORG-ONT", "entities": ["org:ctx-rcs"], "role": "Organisation context scoping" },
      { "ontology": "RRR-ONT", "entities": ["pf:exec-ciso", "pf:func-compliance-director", "pf:func-security-analyst"], "role": "Role-based ICP mapping" },
      { "ontology": "MCSB-ONT", "entities": ["rcsg:mcsb-control", "rcsg:mcsb-benchmark"], "role": "Microsoft Cloud Security Benchmark controls" },
      { "ontology": "GDPR-ONT", "entities": ["rcsg:gdpr-article", "rcsg:gdpr-obligation"], "role": "GDPR compliance requirements" },
      { "ontology": "PII-ONT", "entities": ["rcsg:pii-category", "rcsg:pii-safeguard"], "role": "PII protection framework" },
      { "ontology": "AZALZ-ONT", "entities": ["rcsg:azure-policy", "rcsg:azure-baseline"], "role": "Azure security baseline" }
    ],
    "downstreamConsumers": [
      { "ontology": "EFS-ONT", "bridgeType": "manifestsAsPersona + mapsToEpic + gainMapsToFeature", "role": "ICP->Persona, Problem->Epic, Gain->Feature" },
