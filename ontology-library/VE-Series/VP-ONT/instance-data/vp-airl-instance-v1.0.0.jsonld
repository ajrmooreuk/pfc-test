    {
      "@id": "vp:airl-prob-strategic",
      "@type": "vp:Problem",
      "name": "Unstructured AI Adoption at Enterprise Scale",
      "description": "Enterprise AI adoption without structured readiness assessment leading to high failure rates and wasted investment",
      "problemId": "prob:airl-strategic",
      "problemStatement": "CTOs and CIOs in mid-to-large enterprises struggle with AI adoption without structured readiness assessment when scaling from pilots to enterprise-wide deployment, resulting in 70-85% AI project failure rates, $5M-$50M wasted investment per failed initiative, and loss of competitive advantage to AI-native competitors.",
      "problemType": "Functional",
      "severity": "Critical",
      "frequency": "Constant",
      "isGrowing": true,
      "marketSizeImpact": 15000000000,
      "scopeLevel": "Strategic",
      "ownerRole": "pf:exec-cto"
    },
    {
      "@id": "vp:airl-prob-tactical",
      "@type": "vp:Problem",
      "name": "Cross-Domain AI Maturity Blindspots",
      "description": "AI programme directors lack cross-domain visibility across strategy, people, process, technology, and governance dimensions",
      "problemId": "prob:airl-tactical",
      "problemStatement": "AI Programme Directors struggle with cross-domain maturity blindspots when coordinating AI readiness across business units, resulting in siloed assessments, inconsistent maturity scoring, and inability to identify critical dependency gaps between technology readiness and organisational capability.",
      "problemType": "Functional",
      "severity": "Major",
      "frequency": "Frequent",
      "isGrowing": true,
      "scopeLevel": "Tactical",
      "ownerRole": "pf:func-ai-programme-director"
    },
    {
      "@id": "vp:airl-prob-operational",
