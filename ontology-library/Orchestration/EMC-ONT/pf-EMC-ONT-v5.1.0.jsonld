            },
            "appOverrides": {
              "type": ["string", "null"],
              "description": "Path to App-tier skeleton override JSONLD (optional)"
            }
          }
        },
        "scopeRules": {
          "type": "array",
          "items": {
            "$ref": "emc:GraphScopeRule"
          },
          "description": "Graph-scope rules governing PFI data slicing for this instance (F19.1)"
        },
        "composedGraphSpec": {
          "$ref": "emc:ComposedGraphSpec",
          "description": "View definition for the composed PFI dataset (F19.1)"
        },
        "canonicalSnapshot": {
          "$ref": "emc:CanonicalSnapshot",
          "description": "Frozen versioned graph template inherited by this instance (F19.1)"
        }
