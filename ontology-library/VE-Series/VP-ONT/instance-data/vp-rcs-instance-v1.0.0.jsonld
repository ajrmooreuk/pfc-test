      "name": "Regulated Industry Enterprise",
      "description": "Enterprises in regulated industries subject to multiple compliance frameworks simultaneously, requiring unified compliance management across GDPR, cloud security baselines, and data protection regulations",
      "icpId": "icp:rcs-regulated",
      "customerType": "B2B",
      "segmentDescription": "Mid-to-large enterprises (500-20,000 employees) in regulated industries — Financial Services, Healthcare, Insurance, Government, Legal — subject to 3+ compliance frameworks simultaneously. Typically have dedicated compliance teams, annual audit cycles, and regulatory reporting obligations. Annual compliance budgets >$2M.",
      "demographics": "Industry: Financial Services, Healthcare, Insurance, Government, Legal, Pharmaceuticals. Size: 500-20,000 employees. Geography: UK, EU, Middle East. Revenue: $100M-$20B",
      "firmographics": "Azure-first or Azure-heavy cloud estate. Multi-cloud in transition. Existing compliance tooling (fragmented). Dedicated CISO office. Internal audit function. External auditor relationships.",
      "psychographics": "Risk-averse, compliance-first culture. Fear of regulatory penalties and reputational damage. Value audit-readiness over innovation. Seek predictability in compliance posture. Board-level visibility on compliance status.",
      "willingnessToPayIndicator": "High",
      "marketSize": 28000000000,
      "acquisitionCost": 65000,
      "lifetimeValue": 520000
    },

